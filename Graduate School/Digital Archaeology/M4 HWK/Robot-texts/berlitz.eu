<script src="https://www.google.com/recaptcha/enterprise.js?render=6LcdeBQrAAAAAC2595BJvxPkuEsL7J0GyzNoinFB"></script>
<script async type="text/javascript">
document.addEventListener('DOMContentLoaded', function() {
    //Set for 
    let currentPageUrl = window.location.href;
    let Form_URL__c = document.getElementById('Form_URL__c');
    if (Form_URL__c) {
        Form_URL__c.value = currentPageUrl;
    }
    let field_url = document.getElementById('url');
    if (field_url) {
        field_url.value = currentPageUrl;
    }
    const forms = document.querySelectorAll('form'); // Use your appropriate form selector if needed
    forms.forEach(formElement => {
      formElement.addEventListener('submit', function(event) {
        // --- 1. Prevent Submission
        event.preventDefault();
  
        // --- 2. If we have other validation
        let proceedWithSubmit = true;
        // ... validation checks
  
        // --- 3. Check if we should proceed
        if (!proceedWithSubmit) {
          return;
        }

        // --- 4. Disable Submit Button
        const submitButton = formElement.querySelector('input[type="submit"], button[type="submit"]');
        if (submitButton) {
            console.log('Disabling submit button');
            submitButton.disabled = true;
        }
  
        // --- 5. DATALAYER LOGIC
        console.log('Executing dataLayer push logic for form:', formElement);
        // Define findFieldValue function directly
        function findFieldValue(baseName) {
            for (let i = 0; i <= 9; i++) {
                let queryName = i === 0 ? baseName : `${baseName}-${i}`;
                let inputElement = formElement.querySelector(`input[name="${queryName}"]`);
                if (!inputElement) {
                    inputElement = formElement.querySelector(`select[name="${queryName}"]`);
                }
                if (inputElement && typeof inputElement.value !== 'undefined') {
                    return inputElement.value;
                }
            }
            return '';
        }
        // Initialize variables
        let contactFormName = findFieldValue("first_name");
        let contactFormLastname = findFieldValue("last_name");
        let contactFormEmail = findFieldValue("email") || findFieldValue("Email");
        let contactFormPhone = findFieldValue("phone");
        let contactFormProgram = findFieldValue("Class_Type__c");
        let contactFormLanguage = findFieldValue("00NJ6000000ZS1H");
        // Construct and push dataLayer object
        const dataLayerObject = {
            'contactFormName': contactFormName, 'contactFormLastname': contactFormLastname,
            'contactFormEmail': contactFormEmail, 'contactFormPhone': contactFormPhone,
            'event': 'leadEnquiryContactForm'
        };
        if (contactFormProgram) { dataLayerObject.contactFormProgram = contactFormProgram; }
        if (contactFormLanguage) { dataLayerObject.contactFormLanguage = contactFormLanguage; }
        window.dataLayer = window.dataLayer || []; window.dataLayer.push(dataLayerObject);
        sessionStorage.setItem("email", contactFormEmail); sessionStorage.setItem("phone", contactFormPhone);
        console.log('DataLayer push successful:', dataLayerObject);
        // --- End of DataLayer Logic ---
  
        // --- 6. Execute reCAPTCHA Enterprise ---
        const recaptchaResponseInput = formElement.querySelector('.g-recaptcha-response-field');
        if (!recaptchaResponseInput) {
           console.error("reCAPTCHA hidden input field '.g-recaptcha-response-field' not found in form:", formElement);
           alert('Form configuration error. Cannot submit.');
           return;
        }
  
        // Use grecaptcha.enterprise.ready to ensure API is loaded
        grecaptcha.enterprise.ready(async () => {
            try {
                // Use await to get the token
                const token = await grecaptcha.enterprise.execute('6LcdeBQrAAAAAC2595BJvxPkuEsL7J0GyzNoinFB', { action: 'form_submit' });
  
                // Add the token to the hidden input field
                recaptchaResponseInput.value = token;
                console.log('reCAPTCHA Enterprise token obtained:', token);
  
                // --- 6. Submit the Form Data via Fetch AS JSON ---
                console.log('Submitting form data asynchronously (JSON):', formElement);
  
                const url = formElement.action;
                const method = formElement.method.toUpperCase() || 'POST';
                const formData = new FormData(formElement);
                const plainFormData = Object.fromEntries(formData.entries());
  
                const response = await fetch(url, {
                    method: method,
                    headers: {
                      'Content-Type': 'application/json', // Sending as JSON
                      'Accept': 'application/json'
                    },
                    body: JSON.stringify(plainFormData) // Body is JSON string
                });
  
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP error! Status: ${response.status}, Body: ${errorText}`);
                }
  
                const responseData = await response.json();
                console.log('Form submission successful (JSON):', responseData);
  
                // --- Handle Success: CLIENT-SIDE REDIRECT LOGIC ---
                const retURLInput = formElement.querySelector('input[name="retURL"]');
                if (retURLInput && retURLInput.value) {
                    const redirectUrl = retURLInput.value;
                    console.log('AJAX submission successful. Redirecting to:', redirectUrl);
                    window.location.href = redirectUrl; // Perform the client-side redirect
                } else {
                    //Redirect to default /de/thankyou
                    const defaultRedirectUrl = '/de/thankyou';
                }
                if (submitButton) {
                    console.log('Disabling submit button');
                    submitButton.disabled = false;
                }
                // --- End of Success Handling ---
  
            } catch (error) {
                // Handle errors during reCAPTCHA execution OR Fetch call
                console.error('Form submission failed:', error);
                alert(`Submission failed: ${error.message}. Please check your details and try again.`);
                if (submitButton) {
                    console.log('Disabling submit button');
                    submitButton.disabled = false;
                }
            }
        }); // End of grecaptcha.enterprise.ready
      }); // End of form submit listener
    }); // End of forms.forEach
}); // End of DOMContentLoaded listener

// --- 7. Handle Page Refresh ---
window.onpageshow = function(event) {
    if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
        window.location.reload(true);
    }
};
</script></head><body><div class="page-wrapper"><div class="html-embed-gtm w-embed w-iframe"><!-- Google Tag Manager (noscript) -->
