tent":{"blockClass":"footer","src":"https:\u002F\u002Fmotorolaimgrepo.vteximg.com.br\u002Farquivos\u002Fprotection.png","maxHeight":30,"maxWidth":30,"link":"","alt":"","title":"","loading":"eager","fetchpriority":"auto","analyticsProperties":"none"},"contentIds":[""]},"store.home\u002F$after_footer\u002Ffooter-layout.desktop\u002Fflex-layout.row#footer-4-desktop\u002Fflex-layout.col#footer-col2-desktop\u002Fcopy-right":{"before":[],"around":[],"after":[],"blockId":"motorolain.motorola-store-theme@1.x:copy-right","blocks":[],"component":"motorolain.motorola-store-theme@1.1.87\u002FCopyRight","composition":"blocks","contentMapId":"wD1Gu4KPr3uQ6Sk1o9V6Pt","hasContentSchema":false,"hydration":"on-view","implements":["motorolain.motorola-store-theme@1.x:copy-right"],"preview":null,"props":{"copyRightText":"\u003Cp\u003E© 2019 Motorola Mobility LLC. All Rights Reserved\u003C\u002Fp\u003E\u003Cp\u003EMOTOROLA, the Stylized M Logo, MOTO and the MOTO family of marks are trademarks of Motorola Trademark Holdings, LLC. LENOVO is a trademark of Lenovo. All other trademarks are the property of their respective owners. © 2017 Motorola Mobility LLC.\u003C\u002Fp\u003E\u003Cp\u003EAll mobile phones are designed and manufactured by Motorola Mobility LLC, a wholly owned subsidiary of Lenovo.\u003C\u002Fp\u003E","copyRightViews":"\u003Cp\u003E† All battery life claims are approximate and based on a mixed use profile (which includes both usage and standby time) under optimal network conditions. Actual battery performance will vary and depends on many factors including signal strength, network configuration, age of battery, operating temperature, features selected, device settings, and voice, data, and other application usage patterns.\u003C\u002Fp\u003E\u003Cp\u003E§ The display and embedded lens are warranted against shattering and cracking for four (4) years from the original date of purchase. This phone is not shockproof or designed to withstand all damage from dropping. All other warranty exclusions, including scratches and other cosmetic damage, intentional damage or abuse, normal wear and tear and other limitations apply; visit Motorola.com for details and warranty coverage.\u003C\u002Fp\u003E\u003Cp\u003E‡ Liquid damage not covered under warranty. Water, splash and dust resistance were tested to IP68 standards under controlled laboratory conditions. Resistance will decrease as a result of normal wear. Not designed to work while submerged underwater. Do not expose to pressurized water, or liquids other than fresh water. Do not attempt to charge a wet phone.\u003C\u002Fp\u003E\u003Cp\u003E** $30 off moto g6 play. Up to $160 off moto g5s plus: $140 off 32 GB, $160 off 64 GB. Up to $120 off moto g6: $70 off 32 GB, $120 off 64 GB. Promos good May 19, 2019 12:00 a.m. CDT through May 25, 2019 11:59 p.m. CDT or while supplies last.\u003C\u002Fp\u003E"},"render":"server","track":[],"content":{"copyRightText":"\u003Cp\u003E© {year} Motorola Mobility LLC. All Rights Reserved\u003C\u002Fp\u003E\u003Cp\u003EMOTOROLA, the Stylized M Logo, MOTO and the MOTO family of marks are trademarks of Motorola Trademark Holdings, LLC. LENOVO is a trademark of Lenovo. All other trademarks are the property of their respective owners. © 2017 Motorola Mobility LLC.\u003C\u002Fp\u003E\u003Cp\u003EAll mobile phones are designed and manufactured by Motorola Mobility LLC, a wholly owned subsidiary of Lenovo.\u003C\u002Fp\u003E\n","text":"","copyRightViews":"\u003Cp\u003E† All battery life claims are approximate and based on a mixed use profile (which includes both usage and standby time) under optimal network conditions. Actual battery performance will vary and depends on many factors including signal strength, network configuration, age of battery, operating temperature, features selected, device settings, and voice, data, and other application usage patterns.\u003C\u002Fp\u003E\u003Cp\u003E§ The display and embedded lens are warranted against shattering and cracking for four (4) years from the original date of purchase. This phone is not shockproof or designed to withstand all damage from dropping. All other warranty exclusions, including scratches and other cosmetic damage, intentional damage or abuse, normal wear and tear and other limitations apply; visit Motorola.com for details and warranty coverage.\u003C\u002Fp\u003E\u003Cp\u003E‡ Liquid damage not covered under warranty. Water, splash and dust resistance were tested to IP68 standards under controlled laboratory conditions. Resistance will decrease as a result of normal wear. Not designed to work while submerged underwater. Do not expose to pressurized water, or liquids other than fresh water. Do not attempt to charge a wet phone.\u003C\u002Fp\u003E\u003Cp\u003E** $30 off moto g6 play. Up to $160 off moto g5s plus: $140 off 32 GB, $160 off 64 GB. Up to $120 off moto g6: $70 off 32 GB, $120 off 64 GB. Promos good May 19, 2019 12:00 a.m. CDT through May 25, 2019 11:59 p.m. CDT or while supplies last.\u003C\u002Fp\u003E"},"contentIds":["wD1Gu4KPr3uQ6Sk1o9V6Pt~wxnzaDoHqwgdVskb3bbEjS"]},"store.home\u002F$after_footer\u002Ffooter-layout.desktop\u002Fflex-layout.row#footer-5-desktop\u002Fflex-layout.col#poweredBy\u002Frich-text#poweredBy":{"before":[],"around":[],"after":[],"blockId":"motorolain.motorola-store-theme@1.x:rich-text#poweredBy","blocks":[],"component":"vtex.rich-text@0.16.0\u002Findex","composition":"blocks","hasContentSchema":true,"hydration":"on-view","implements":["vtex.rich-text@0.x:rich-text"],"preview":null,"props":{"blockClass":["createdby"],"text":"Powered by:"},"render":"server","track":[],"content":{"blockClass":["createdby"],"text":"Powered by:"},"contentIds":[""]},"store.home\u002F$after_footer\u002Ffooter-layout.desktop\u002Fflex-layout.row#footer-5-desktop\u002Fflex-layout.col#poweredBy\u002Fimage#vtex":{"before":[],"around":[],"after":[],"blockId":"motorolain.motorola-store-theme@1.x:image#vtex","blocks":[],"component":"vtex.store-components@3.178.5\u002