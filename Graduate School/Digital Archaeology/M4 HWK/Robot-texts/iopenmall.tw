        <script>
            class EventEmitter {
                constructor() {
                    this.events = {};
                }

                on(event, callback) {
                    if (!this.events[event]) {
                        this.events[event] = [];
                    }
                    this.events[event].push(callback);
                }

                emit(event, ...args) {
                    if (this.events[event]) {
                        this.events[event].forEach(callback => callback(...args));
                    }
                }
            }

            const eventEmitterForViewItemList = new EventEmitter();
            const observerForViewItemList = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const num = $(entry.target).data('num');
                        const max = $(entry.target).data('max');
                        const wpitem = $(entry.target).parents('.iopen-mall-item-container').data('wpitem');
                        eventEmitterForViewItemList.emit(`wpitem-${wpitem}`, num, max);
                        observerForViewItemList.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.18 });
            
            const wait = (duration, ...args) => new Promise(resolve => {
                setTimeout(resolve, duration, ...args);
            });

            $.ajaxSetup({
                complete: function(xhr, textStatus) {
                    if (this.type.toUpperCase() == 'POST') {
                        const searchParams = new URLSearchParams(this.data);
                        if (this.url.indexOf('index.php?action=shopping_cart&web_cart_myAct=SHOPPING_CART') > -1) {
                            if (searchParams.get('myAct') == 'ajaxadd' && searchParams.get('prod_no[]')){
                                var [no, item] = Object.entries(xhr?.responseJSON.prodContents || {})[0];
                                // 觸發加入購物車事件
                                window.dispatchEvent(new CustomEvent('add_to_cart', { 
                                    detail: {
                                        items: [{
                                            quantity: searchParams.get('scar_count[]'),
                                            ...item
                                        }], 
                                    } 
                                }));
                            }
                        } else if (this.url.indexOf('api/api.product_trace_list.php') > -1) {
                            if (searchParams.get('myAct') == 'add' && searchParams.get('prod_no')) {
                                if (xhr?.responseJSON && 
                                    xhr.responseJSON?.error == 'C00' && 
                                    xhr.responseJSON?.status == 1
                                ) {
                                    if (typeof this.prod == undefined) {
                                        console.error('Product track not set');
                                        return
                                    }
                                    // 觸發商品追蹤事件
                                    window.dispatchEvent(new CustomEvent('add_to_favorite', { 
                                        detail: {
                                            items: [{
                                                'prod_no': this?.prod.id, 
                                                'attribution_id': this?.prod.attribution_id,
                                                'canonical_url': this?.prod.canonical_url,
                                                'content_name': this?.prod.name,
                                                'category_no': this?.prod.category_no,
                                                'category_name': this?.prod.category_name,
                                                'category_layers': this?.prod.category_layers,
                                                'keywords': this?.prod.name,
                                                'price': this?.prod.price,
                                                'quantity': this?.prod.quantity || 1,
                                                'variant': this?.prod.variant,
                                                'affiliation': this?.prod.affiliation,
                                            }]
                                        }
                                    }));
                                }
                            }
                        }
                    }
                }
            });
        </script>
