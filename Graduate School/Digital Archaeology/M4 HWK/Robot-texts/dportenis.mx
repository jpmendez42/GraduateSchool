    #h-calzado:checked ~ .card-container .img-calzado,
    #h-ropa:checked ~ .card-container .img-ropa,
    #h-accesorios:checked ~ .card-container .img-accesorios {
        display: block;
    }
    .texto-descriptivo {
      margin: 10px 0;
      font-weight: 800;

