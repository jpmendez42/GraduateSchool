;\u0026eta;\u0026theta;ό \u0026tau;\u0026eta;\u0026sigmaf; \u0026omega;\u0026sigmaf; ά\u0026nu;\u0026omega; \u0026mu;\u0026eta;\u0026tau;\u0026rho;\u0026omicron;\u0026pi;ό\u0026lambda;\u0026epsilon;\u0026omega;\u0026sigmaf; \u0026epsilon;\u0026pi;ί\u0026sigma;\u0026kappa;\u0026omicron;\u0026pi;\u0026omicron; \u0026Beta;έ\u0026lambda;\u0026iota;\u0026tau;\u0026sigmaf; \u0026Nu;\u0026iota;\u0026kappa;ό\u0026lambda;\u0026alpha;\u0026omicron; \u0026kappa;\u0026alpha;\u0026iota; \u0026tau;\u0026omicron;\u0026nu; \u0026pi;\u0026rho;\u0026omicron;ϊ\u0026sigma;\u0026tau;ά\u0026mu;\u0026epsilon;\u0026nu;\u0026omicron; \u0026tau;\u0026omega;\u0026nu; \u0026epsilon;\u0026kappa;\u0026delta;ό\u0026sigma;\u0026epsilon;\u0026omega;\u0026nu; \u0026tau;\u0026eta;\u0026sigmaf; \u0026epsilon;\u0026kappa;\u0026kappa;\u0026lambda;\u0026eta;\u0026sigma;\u0026iota;\u0026alpha;\u0026sigma;\u0026tau;\u0026iota;\u0026kappa;ή\u0026sigmaf; \u0026epsilon;\u0026pi;\u0026alpha;\u0026rho;\u0026chi;ί\u0026alpha;\u0026sigmaf; \u0026Sigma;\u0026kappa;\u0026omicron;\u0026pi;ί\u0026omega;\u0026nu; \u0026iota;\u0026epsilon;\u0026rho;\u0026omicron;\u0026mu;ό\u0026nu;\u0026alpha;\u0026chi;\u0026omicron; \u0026Alpha;\u0026theta;\u0026alpha;\u0026nu;ά\u0026sigma;\u0026iota;\u0026omicron; \u0026Alpha;\u0026rho;\u0026sigma;ό\u0026sigma;\u0026kappa;\u0026iota;.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"6:[\"$\",\"$L13\",null,{\"params\":{\"locale\":\"robots.txt\"},\"topArticles\":[{\"category_id\":null,\"id\":117723,\"old_id\":null,\"title\":\"Святейший Патриарх Кирилл освятил Троицкий храм в селе Саввино муниципального округа Егорьевск Московской области\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003e12 октября, в Неделю 18-ю по Пятидесятнице, Святейший Патриарх Московский и всея Руси Кирилл совершил чин великого освящения храма Святой Троицы в с. Саввино муниципального округа Егорьевск Московской области и возглавил служение Божественной литургии в новоосвященном храме.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/Xrf5bTAgOaCTh03HUVowDh2AUICEf90AZnR9kSyH.jpeg\",\"published_at\":\"2025-10-12 15:08:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":\"966070ff1c9ba3396970f24d3d11bc3e\",\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":\"$14\",\"category_id_main\":26,\"category_id_letopis\":1213,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":\"https://foto.patriarchia.ru/news/patriarshee-sluzhenie-v-troitskom-khrame-v-s-savvino-moskovskoy-oblasti-2025-10-12/\"},{\"category_id\":null,\"id\":117674,\"old_id\":null,\"title\":\"В день памяти преподобного Сергия Радонежского Предстоятель Русской Церкви совершил Литургию в Успенском соборе Троице-Сергиевой лавры\",\"title_gr\":\"Ο Προκαθήμενος της Ρωσικής Ορθοδόξου Εκκλησίας τέλεσε τη Θεία Λειτουργία την ημέρα μνήμης του Αγίου Σεργίου του Ράντονεζ\",\"title_en\":null,\"title_ua\":\"У день пам'яті преподобного Сергія Радонезького Предстоятель Руської Церкви звершив Літургію в Успенському соборі Троїце-Сергієвої лаври\",\"excerpt\":\"\u003cp\u003e8 октября, в день преставления преподобного Сергия, игумена Радонежского, чудотворца, Святейший Патриарх Московский и всея Руси Кирилл совершил Божественную литургию в Успенском соборе Свято-Троицкой Сергиевой лавры.\u003c/p\u003e\",\"excerpt_gr\":\"$15\",\"excerpt_en\":null,\"excerpt_ua\":\"\u003cp class=\\\"MsoNormal\\\"\u003e\u003cspan lang=\\\"UK\\\" style=\\\"mso-ansi-language: UK;\\\"\u003e8 жовтня, в день преставлення преподобного Сергія, ігумена Радонезького, чудотворця, Святіший Патріарх Московський і всієї Русі Кирил звершив Божественну літургію в Успенському соборі Свято-Троїцької Сергієвої лаври.\u003c/span\u003e\u003c/p\u003e\",\"photo_preview\":\"photos/wCkxORhYEYcWBF9uvOWn5Y67cFPB5eWUO18KgKjM.jpeg\",\"published_at\":\"2025-10-08 14:12:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":\"8faaaaaeec4dbb157ee7e06543855b1a,fee5dc828de9b58e60218336ded2476e\",\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":\"$16\",\"category_id_main\":26,\"category_id_letopis\":1213,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":\"https://foto.patriarchia.ru/news/patriarshee-sluzhenie-v-troitse-sergievoy-lavre-v-den-pamyati-prepodobnogo-sergiya-radonezhskogo-2025-10-08/\"},{\"category_id\":null,\"id\":117504,\"old_id\":null,\"title\":\"В праздник Воздвижения Креста Господня Предстоятель Русской Церкви освятил храм преподобного Сергия Радонежского в Гольянове г. Москвы\",\"title_gr\":null,\"title_en\":null,\"title_ua\":\"У день свята Воздвиження Хреста Господнього Предстоятель Руської Церкви освятив храм преподобного Сергія Радонезького у Гольянові м. Москви\",\"excerpt\":\"\u003cp\u003e27 сентября, в праздник Всемирного Воздвижения Честного и Животворящего Креста Господня, Святейший Патриарх Кирилл совершил чин великого освящения храма преподобного Сергия Радонежского, Патриаршего подворья в Гольянове г. Москвы и Божественную литургию в новоосвященном храме.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":\"\u003cp\u003e27 вересня, у день свята Всесвітнього Воздвиження Чесного та Животворчого Хреста Господнього, Святіший Патріарх Кирил звершив чин великого освячення храму преподобного Сергія Радонезького, Патріаршого подвір'я у Гольянові м. Москви та Божественну літургію в новоосвяченому храмі.\u003c/p\u003e\",\"photo_preview\":\"photos/bNekRV9v8QreJQmlsdoG3eoD5iZgmIW3Qn7PT6HB.jpeg\",\"published_at\":\"2025-09-27 14:57:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":\"e9a6798659c4c2ae6b0ae5be4ca8a404\",\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":\"$17\",\"category_id_main\":26,\"category_id_letopis\":1213,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":\"https://foto.patriarchia.ru/news/patriarshee-sluzhenie-v-prazdnik-vozdvizheniya-kresta-gospodnya-velikoe-osvyashchenie-khrama-prepodobnogo-sergiya-radonezhskogo-v-golyanove-g-moskvy-2025-09-27/\"}],\"latestNews\":[{\"category_id\":null,\"id\":117744,\"old_id\":null,\"title\":\"Председатель Синодального отдела по благотворительности посетил Шахтинскую епархию\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eПредседатель Синодального отдела по церковной благотворительности и социальному служению протоиерей Михаил Потокин посетил Шахтинскую епархию. В ходе поездки он встретился с епископом Шахтинским и Миллеровским Симоном и посетил реабилитационный центр \u0026laquo;Берега\u0026raquo;.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/gvioAEsp63rrWY1EQ9habwJ40BKsshvhOyOqWhme.jpeg\",\"published_at\":\"2025-10-13 17:44:11\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":29,\"category_id_letopis\":1220,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117737,\"old_id\":null,\"title\":\"В федеральных округах России прошли первые онлайн-совещания центров апологетической миссии\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eЦентральными темами встреч стали выстраивание системы взаимодействия между центрами, сбор и анализ информации о деструктивных религиозных движениях и сектах, а также разработка методических материалов для дальнейшей апологетической и просветительской деятельности.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/h5lRnl88X6MBtMPz1ePmCtQpTlAsIhmCaRyqFdKs.jpeg\",\"published_at\":\"2025-10-13 16:28:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":29,\"category_id_letopis\":1220,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117736,\"old_id\":null,\"title\":\"Состоялась встреча главы Казахстанского митрополичьего округа с акимом Костанайской области\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003e13 октября в областном акимате в Костанае состоялась встреча митрополита Астанайского и Казахстанского Александра с акимом Костанайской области К.И. Аксакаловым.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/OLCci8VvRaUZyaunoeGfwadeIs0A8HzdABwZZBYR.jpeg\",\"published_at\":\"2025-10-13 14:44:46\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":31,\"category_id_letopis\":1267,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117731,\"old_id\":null,\"title\":\"Патриарший экзарх всея Беларуси освятил восстановленный собор Рождества Пресвятой Богородицы в Юровичском мужском монастыре\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003e12 октября Патриарший экзарх всея Беларуси\u0026nbsp;митрополит Минский и Заславский Вениамин совершил чин великого освящения восстановленного собора Рождества Пресвятой Богородицы (XVIII в.) в Юровичском мужском монастыре (аг. Юровичи Калинковичского района Гомельской области)\u0026nbsp;и Божественную литургию в новоосвященном храме.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/TN9XMdwzqd70aDZ06fnnyKAtXuXLpD8PaosoUrcT.jpeg\",\"published_at\":\"2025-10-13 12:35:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":31,\"category_id_letopis\":1222,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117730,\"old_id\":null,\"title\":\"В Москве откроется фотовыставка о социальном служении Церкви на Донбассе\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eНа фотографиях представлена деятельность добровольцев-ремонтников, сестер милосердия, добровольцев по уходу, а также социальных волонтеров в церковных центрах помощи в Донецке, Мариуполе, Волновахе, Авдеевке.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/WDCUo9aMTAI10KeDv9zqn8L3Xnz2bOTekFYtyA4E.jpeg\",\"published_at\":\"2025-10-13 10:21:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":31,\"category_id_letopis\":1219,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117724,\"old_id\":null,\"title\":\"Митрополит Астанайский и Казахстанский Александр возглавил торжества по случаю 15-летия учреждения Костанайской епархии\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003e12 октября в г. Костанае Республики Казахстан состоялись духовные торжества по случаю 15-летия учреждения Костанайской епархии.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/tT1jz5nvkpcAh8a2c8SIIuANY3l6OqUl0bnpPgnE.jpeg\",\"published_at\":\"2025-10-12 17:34:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":31,\"category_id_letopis\":1267,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117725,\"old_id\":null,\"title\":\"Началась паломническая поездка македонской церковной делегации к святыням Русской Православной Церкви\",\"title_gr\":\"Άρχισε προσκυνηματική εκδρομή της αντιπροσωπείας της Ορθοδόξου Αρχιεπισκοπής Αχρίδος στα ιερά προσκυνήματα της Ρωσικής Ορθοδόξου Εκκλησίας\",\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003e7 октября по приглашению Святейшего Патриарха Московского и всея Руси Кирилла в Москву с паломнической поездкой прибыла делегация Македонской Православной Церкви \u0026mdash; Охридской Архиепископии.\u003c/p\u003e\",\"excerpt_gr\":\"$18\",\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/0rESs79dTrGEvW6jdW068rmEEzCuoI736mKKXOUx.jpeg\",\"published_at\":\"2025-10-12 16:54:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":30,\"category_id_letopis\":null,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null}],\"latestPublications\":[{\"category_id\":null,\"id\":117670,\"old_id\":null,\"title\":\"Великое освящение Покровского храма Московской духовной академии в 1955 году (к 70-летию со дня освящения)\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eВ 2025 году исполнилось 70 лет со дня освящения академического Покровского храма Московской духовной академии. В статье, опубликованной на портале Богослов.\u003cspan lang=\\\"EN-US\\\"\u003eru,\u003c/span\u003e описаны мероприятия, предшествующие этому событию, и само великое освящение храма, совершенное 21 мая 1955 года Святейшим Патриархом Алексием I.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/9wc3oWb8R9551tvHjaT8kLIhfd0pPLpzR7HJiIFL.jpeg\",\"published_at\":\"2025-10-13 19:52:01\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":39,\"category_id_letopis\":null,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117734,\"old_id\":null,\"title\":\"Циркулярное письмо Управления делами Московской Патриархии о принятии Федерального закона № 319-Ф3 «О внесении изменения в статью 3 Федерального закона \\\"О свободе совести и о религиозных объединениях\\\"»\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eЦиркулярное письмо Управления делами Московской Патриархии о принятии Федерального закона от 31.07.2025 № 319-Ф3 \u0026laquo;О внесении изменения в статью 3 Федерального закона \\\"О свободе совести и о религиозных объединениях\\\"\u0026raquo; и о практических аспектах его применения в деятельности православных организаций.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":null,\"published_at\":\"2025-10-13 15:00:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":null,\"category_id_letopis\":null,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117565,\"old_id\":null,\"title\":\"Патриаршее поздравление настоятельнице Борисоглебского Аносина ставропигиального монастыря игумении Марии (Солодовниковой) с 20-летием трудов в должности настоятельницы обители\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp class=\\\"MsoNormal\\\"\u003eСвятейший Патриарх Московский и всея Руси Кирилл поздравил настоятельницу Борисоглебского Аносина ставропигиального женского монастыря игумению Марию (Солодовникову) с 20-летием трудов в должности настоятельницы обители.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/Jw1aQWJy0nZNCxCpcxPWNJiWl4je8TkXVnNADNM9.jpeg\",\"published_at\":\"2025-10-13 10:30:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":1079,\"category_id_letopis\":1213,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117553,\"old_id\":null,\"title\":\"Патриаршее поздравление епископу Шахтинскому Симону с 50-летием со дня рождения\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eСвятейший Патриарх Московский и всея Руси Кирилл поздравил епископа Шахтинского и Миллеровского Симона с 50-летием со дня рождения.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/y2nlD1owgUYCLAZ19kvBPDle1tFIrrQO3OmWzA0M.jpeg\",\"published_at\":\"2025-10-13 10:00:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":1079,\"category_id_letopis\":1213,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117727,\"old_id\":null,\"title\":\"Патриаршая проповедь после Литургии в Троицком храме с. Саввино Московской области\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003e12 октября, в Неделю 18-ю по Пятидесятнице, Святейший Патриарх Московский и всея Руси Кирилл совершил Божественную литургию в храме Святой Троицы с. Саввино муниципального округа Егорьевск Московской области. По окончании Литургии Предстоятель Русской Православной Церкви произнес проповедь.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/2pVLX8exVrPZWeTwAGUgOgb2JXWfckM7VNOVMrAT.jpeg\",\"published_at\":\"2025-10-12 17:47:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":16,\"category_id_letopis\":null,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117557,\"old_id\":null,\"title\":\"Поздравление Святейшего Патриарха Кирилла председателю Совета при Президенте РФ по развитию гражданского общества и правам человека В.А. Фадееву с 65-летием со дня рождения\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eСвятейший Патриарх Московский и всея Руси Кирилл поздравил председателя Совета при Президенте Российской Федерации по развитию гражданского общества и правам человека В.А. Фадеева с 65-летием со дня рождения.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/p4bh9GceIOBpyHdFXeqccPzHUKhUnyBBidbIvhNy.jpeg\",\"published_at\":\"2025-10-10 10:00:00\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":1079,\"category_id_letopis\":null,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null},{\"category_id\":null,\"id\":117686,\"old_id\":null,\"title\":\"Блаженнейший Тихон, Митрополит всей Америки и Канады: «Святитель Тихон укрепляет веру и помогает держаться пути спасения»\",\"title_gr\":null,\"title_en\":null,\"title_ua\":null,\"excerpt\":\"\u003cp\u003eИнтервью опубликовано в октябрьском номере \u0026laquo;Журнала Московской Патриархии\u0026raquo;.\u003c/p\u003e\",\"excerpt_gr\":null,\"excerpt_en\":null,\"excerpt_ua\":null,\"photo_preview\":\"photos/xjox7OuXCgA9Eypq2k4rxHjE9l8icJxjuxXo28tX.jpeg\",\"published_at\":\"2025-10-09 15:56:18\",\"youtube_id\":null,\"vk_id\":null,\"rutube_id\":null,\"video_duration\":null,\"photos_uploaded\":\"[]\",\"photos\":null,\"category_id_main\":40,\"category_id_letopis\":null,\"category_id_sobor\":null,\"category_id_edinstvo\":null,\"author\":null,\"author_gr\":null,\"author_en\":null,\"author_ua\":null,\"photo_album_id\":null}]}]\n"])</script><script>self.__next_f.push([1,""])</script></body></html>