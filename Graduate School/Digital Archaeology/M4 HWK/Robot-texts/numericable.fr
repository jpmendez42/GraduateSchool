<style>
    .reseau {
        background-color: #f2f2f2;
        padding-top: 50px;
        padding-bottom: 50px;
        text-align: center;
    }
    
    @media (min-width: 992px) {
        .reseau {
            padding-top: 100px;
            padding-bottom: 100px;
        }
    }
    
    .reseau:after {
        content: "";
        display: block;
        height: 100%;
        width: 1px;
        background-color: #222222;
    }
    
    .reseau__container {
        padding-bottom: 20px;
    }
    
    .reseau__separator {
        position: absolute;
        right: 0;
        left: 0;
        background-color: #d2d2d2;
        top: auto;
        height: 1px;
        bottom: -15px;
        width: 90%;
        margin: 0 auto;
    }
    
    @media (min-width: 768px) {
        .reseau__separator {
            left: auto;
            right: 0;
            top: 0;
            height: 100%;
            width: 1px;
        }
    }
    
    .reseau__image {
        display: -webkit-box;
        display: -ms-flexbox;
        display: flex;
        -webkit-box-pack: center;
        -ms-flex-pack: center;
        justify-content: center;
        -webkit-box-align: center;
        -ms-flex-align: center;
        align-items: center;
        min-height: 150px;
        opacity: 0;
    }
    
    .reseau__image img {
        max-width: 100%;
    }
    
    @media (min-width: 992px) {
        .reseau__image {
            margin-bottom: 40px;
        }
    }
    
    .reseau__title {
        margin-bottom: 10px;
        color: #222222;
    }
    
    .reseau__text {
        margin-bottom: 10px;
        color: #222222;
    }
    
    @charset "UTF-8";
</style>
