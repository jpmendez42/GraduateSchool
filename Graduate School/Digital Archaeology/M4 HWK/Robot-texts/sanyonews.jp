							<h3 class="post_title"><a href="/article/1809092?rct=">岡山で民家２棟全焼　けが人なし</a></h3>
							<div class="post_meta">
								<div class="post_date">
10月13日
								</div>
							</div>
						</div>

							</div>							
								</div>
						
					</div>
					<div class="flex_col_item top_sub">
						<div class="post_list post_list-type_thm_bg-s">
		
					
        
        
										<div class="post_item">
								
						<div class="post_thm">
							<a href="/article/1809093"><div class="post_thm_bg  post_thm_movie">
								<img src="//static.sanyonews.jp/image/article/size3/a/e/0/8/ae08a2ac17ef1a35f642c14e9ac26596_1.jpg" alt="キリシタン流刑地 備前市・鶴島で野外ミサ　信者ら約２００人 苦難の歴史に思いはせ">
							</div></a>
