<style>#DP--design_pack_marquee_8qQqjB {  position: relative;  overflow: hidden;  background: linear-gradient(320deg, rgba(65, 65, 67, 1), rgba(17, 174, 95, 1) 52%, rgba(65, 65, 67, 1) 100%);  font-size: 18px;  margin-top: 0px;  margin-bottom: 0px;}#DP--design_pack_marquee_8qQqjB .dsgn-pck__marquee__inner {  display:flex;  flex-wrap: nowrap;  white-space: nowrap;  min-width: 100%;  padding-top: 10px;  padding-bottom: 10px;  padding-top: 10px;  padding-bottom: 10px;  height: 100%;}#DP--design_pack_marquee_8qQqjB .dsgn-pck__marquee__block {  display: flex;  flex-shrink: 0;  color: #ffffff;  align-items: center;  animation:  slide-left  20s linear infinite;}#DP--design_pack_marquee_8qQqjB .dsgn-pck__marquee-pause-true:hover .dsgn-pck__marquee__block {  animation-play-state: paused;}#DP--design_pack_marquee_8qQqjB .dsgn-pck__text {  padding-left: 20px;  margin: 0;  font-size: calc(var(--dp-g-heading-size, var(--dp-heading-size, 35px)) * 0.6);}#DP--design_pack_marquee_8qQqjB .dsgn-pck__marquee__block img {  width: auto;  display: inline-block;  padding-left: 20px;  height: calc(var(--dp-g-heading-size, var(--dp-heading-size, 35px)) * 0.6);}@keyframes slide-left {  from {    -webkit-transform: translateX(0);            transform: translateX(0);  }  to {    -webkit-transform: translateX(-100%);            transform: translateX(-100%);  }}@keyframes slide-right {  from {    -webkit-transform: translateX(-100%);            transform: translateX(-100%);  }  to {    -webkit-transform: translateX(0);            transform: translateX(0);  }}@media (prefers-reduced-motion: reduce) {  .dsgn-pck__marquee span {    animation: none;    width: auto;    display: block;    line-height: 1.5;    text-align: center;    white-space: normal;  }}/* Landscape phone to portrait tablet */@media (max-width: 767px) {  #DP--design_pack_marquee_8qQqjB {    font-size: 14px;  }}/* Landscape phones and down */@media (max-width: 480px) {  #DP--design_pack_marquee_8qQqjB {    margin-top: 0px;    margin-b