.modal_title{position:relative;z-index:1;width:100%;height:50px;margin:0 0 8px 0;padding:10px 0;font-size:15px;line-height:30px;text-indent:10px;letter-spacing:0.8px;font-weight:normal;border-bottom:1px solid #e6e6e6;background:#fff;}
.modal_content{padding:25px;height: calc(100% - 175px);max-height:350px;overflow-y:auto;font-size:14px;}
.modal_membership, .modal_dialog{height: 100%;}

.membership_box+.membership_box{margin-top:1rem;}
.msg_box{margin-bottom:.5rem;}
.modal_content .alert{padding:4px 6px;font-size:16px;border-radius:4px;border:1px solid #eee;font-size:16px;}
.modal_content .alert.alert_danger{color:#ed2525;background-color:#fde9e9;border-color:#f8a8a8;}
.modal .membership_head{font-weight:bold;margin-bottom:.5rem;}

.modal .btn-block{padding:10px;}
.modal .btn-block input[type="button"]{cursor:pointer;}
.modal .btn-block li+li{margin-left:16px;}
.modal .btn-block input{padding:8px 16px;}
.modal_footer{padding:0 25px;}
.modal_footer .it66_agree_to_terms{margin-bottom:10px;}
.modal_footer label.it45_pd_item_label{width: auto;height:auto;padding:0 0 0 26px;}
.modal_footer label.it45_pd_item_label input[type="checkbox"]:disabled{cursor:default;}
.modal_footer label.it45_pd_item_label input[type="checkbox"]:disabled+div.label_name{opacity:0.6;}
.modal_membership, .modal_dialog{height: 100%;}

/* list 通用樣式 */
.list_box>li .list_box,.list_box>li .list_alpha,.list_box>li p{margin-left:1.5rem;}
.list_box.list_decimal>li .list_box.list_decimal_paren{margin-left:2.5rem;}
.list_box li+li,.list_box li p+p,.list_box+p,p+.list_box{margin-top:4px;}
.list_box.list_disc{list-style:disc;}
.list_box.list_circle{list-style:circle;}
.list_box.list_square{list-style:square;}
.list_box.list_decimal{list-style-type:none;counter-reset:list-counter;}
.list_box.list_decimal>li{counter-increment:list-counter;position:relative;}
.list_box.list_decimal>li:before {content:counter(list-counter) ".";margin-right:.25rem;}
.list_box.list_decimal_paren>li:before{ content:"(" counter(list-counter) ")";margin-left:-1.25rem;}
.list_box .list_box.list_alpha li{list-style:lower-alpha;}
</style>
