TA__" type="application/json">{"props":{"pageProps":{"page":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"dtcyb9axb0au"}},"id":"4XvF5uv3HZ26P0yWbIfQw9","type":"Entry","createdAt":"2022-12-07T08:41:56.378Z","updatedAt":"2025-05-13T08:47:27.071Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":9,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"page"}},"locale":"en-US"},"fields":{"name":"Mail - Basic Page ASMTP","title":"Fejlmeddelelser i ASMTP (udgående post)","slug":"fejlmeddelelser-i-asmtp-udgaende-post","content":{"metadata":null,"sys":{"id":"2ae5uM5YPU2jjsqoEKLzlV","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"pageBasicPageLayout"}}},"fields":{"internalName":"Mail - Basic Page ASMTP","body":[{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"dtcyb9axb0au"}},"id":"2671xNhxc9eiN5wGijWza4","type":"Entry","createdAt":"2022-12-07T08:40:53.530Z","updatedAt":"2024-10-01T10:09:33.257Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":69,"revision":4,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentText"}},"locale":"en-US"},"fields":{"internalName":"Mail - Basic Page - Text","text":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Klik på den fejlmeddelelse, du har modtaget, og se hvad den betyder.","marks":[],"data":{}}]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"5cSCVRvv4FSSeOre4WGBet","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 421 4.5.1","title":"421 4.5.1 No more messages on this connection","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du kan ikke sende flere mails via denne forbindelse. Vi har afbrudt forbindelsen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Opret en ny forbindelse for at sende flere mails.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Opstår denne fejl, når du forsøger at sende større mails (evt. med vedhæftede filer), bedes du kontrolle om din opsætning. Typisk er \"Opdeling af mails større end x kB\" aktiveret, hvilket gør at en større mail opdeles i mange små mails, når den forsøges sendt. Slå denne indstilling fra og problemet burde være løst.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"2GHZTwumwZMJUEjAXRGEa6","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion Ukendt afsender","title":"Ukendt afsender","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"451 4.2.1 sender unknown, try again later","marks":[{"type":"bold"}],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du forsøger at afsende post med en mailadresse som ikke findes i den pågældende postkasses opsætning (mailadressen er måske flyttet til et andet abonnement).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"I webmail bedes du vælge \"Indstillinger\" og her \"Vælg afsenderadresse\".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"webmail","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"66AA3uQtoev28t9vgiBwre","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 451 4.4.0 ","title":"451 4.4.0 local processing error, try again later","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"451 4.4.0 local processing error, try again later","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Tjenesten er ikke tilgængelig i øjeblikket.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Vente nogle timer og prøv igen.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[],"value":"Hvis fejlen fortsætter, så kontroller:\n- logon oplysninger (brugernavn indeholder sandsynligvis mellemrum eller andre ugyldige tegn).","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSpørgsmål vedr. denne fejlmeddelelse kan rettes til postmaster@mail.dk","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-blo