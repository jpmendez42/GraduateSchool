anche – auf dem Messegelände und mitten in der Münchner Innenstadt.\",\n  \"alternateName\": [\n    \"Automesse München\",\n    \"IAA Automesse\"\n  ],\n  \"startDate\": \"2027-09-07\",\n  \"endDate\": \"2027-09-12\",\n  \"eventStatus\": \"https://schema.org/EventScheduled\",\n  \"eventAttendanceMode\": \"https://schema.org/MixedEventAttendanceMode\",\n  \"location\": {\n    \"@type\": \"Place\",\n    \"name\": \"München\",\n    \"address\": {\n      \"@type\": \"PostalAddress\",\n      \"addressLocality\": \"München\",\n      \"addressCountry\": \"DE\"\n    }\n  },\n  \"image\": \"https://www.iaa-mobility.com/.imaging/mte/vda-theme/1400w/dam/iaa-mobility/2025/allgemein/grafikassets/keyvisual-2025/header/iaa-mobility-2025-keyvisual-social.jpg/jcr:content/iaa-mobility-2025-keyvisual-social.jpg\",\n  \"url\": \"https://www.iaa-mobility.com/\",\n  \"organizer\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Verband der Automobilindustrie e. V. (VDA)\",\n    \"url\": \"https://vda.de\"\n  },\n  \"audience\": [\n    {\n      \"@type\": \"Audience\",\n      \"audienceType\": \"Fachbesucher\"\n    },\n    {\n      \"@type\": \"Audience\",\n      \"audienceType\": \"Privatbesucher\"\n    }\n  ],\n  \"subEvent\": [\n    {\n      \"@type\": \"Event\",\n      \"name\": \"IAA Summit – Pressetag\",\n      \"startDate\": \"2027-09-06T08:00\",\n      \"endDate\": \"2027-09-06T18:00\",\n      \"audience\": {\n        \"@type\": \"Audience\",\n        \"audienceType\": \"Fachpresse und Medienvertreter\"\n      },\n      \"eventAttendanceMode\": \"https://schema.org/OfflineEventAttendanceMode\",\n      \"eventStatus\": \"https://schema.org/EventScheduled\",\n      \"location\": {\n        \"@type\": \"Place\",\n        \"name\": \"Messegelände Messe München\",\n        \"address\": {\n          \"@type\": \"PostalAddress\",\n          \"addressLocality\": \"München\",\n          \"addressCountry\": \"DE\"\n        }\n      }\n    },\n    {\n      \"@type\": \"Event\",\n      \