<script>
  (function () {
    function isRealTextNode(node) {
      return node?.nodeType === Node.TEXT_NODE &&
        node.textContent.trim().length > 0;
    }

    function closeLanguage(item){
      if (!item.target.closest('.header-menu__language-options'))
        document.querySelector('.header-menu__language-options').setAttribute("hidden", '');
        document.removeEventListener('click', closeLanguage);
    }

	if(document.querySelector('.header-menu__selected-language')){
		document.querySelector('.header-menu__selected-language').addEventListener('click', ()=>{
		  const languages = document.querySelector('.header-menu__language-options');
		  if (languages.hasAttribute("hidden")){
			languages.removeAttribute('hidden');
			setTimeout(()=>document.addEventListener('click', closeLanguage), 0)
		  } else {
			languages.setAttribute("hidden", '');
			document.removeEventListener('click', closeLanguage);
		  }
		})
	}

    function hasRealSibling(node, direction) {
      let sib = node;
      while (sib = sib[direction]) {
        if (sib.nodeType === Node.TEXT_NODE && sib.textContent.trim().length === 0) continue;
        if (sib.nodeType === Node.ELEMENT_NODE && sib.tagName === "BR") continue;
        return isRealTextNode(sib);
      }
      return false;
    }

    function cleanWrapper() {
      const wrapper = document.querySelector('.wrapper');
      if (!wrapper) return;

      // Вспомогательная функция: проверяет, находится ли узел внутри элемента с классом text_editor
      function isInsideTextEditor(node) {
        let el = (node.nodeType === Node.TEXT_NODE) ? node.parentElement : node;
        while (el) {
          if (el.classList && el.classList.contains('text_editor')) {
            return true;
          }
          el = el.parentElement;
        }
        return false;
      }

      // Удаляем лишние <br> и  &nbsp;
      const walker = document.createTreeWalker(wrapper, NodeFilter.SHOW_ALL, null, false);
      let node, nodesToRemove = [];
      while (node = walker.nextNode()) {
        // Пропускаем любые узлы, которые внутри .text_editor
        if (isInsideTextEditor(node)) {
          continue;
        }

        // <br>
        if (node.nodeType === Node.ELEMENT_NODE && node.tagName === 'BR') {
          if (!(hasRealSibling(node, 'previousSibling') && hasRealSibling(node, 'nextSibling'))) {
            nodesToRemove.push(node);
          }
        }
        // &nbsp;
        if (node.nodeType === Node.TEXT_NODE) {
          const txt = node.textContent;
          if (txt.includes('\u00A0') && txt.trim().length === 0) {
            if (!(hasRealSibling(node, 'previousSibling') && hasRealSibling(node, 'nextSibling'))) {
              nodesToRemove.push(node);
            }
          }
        }
      }
      nodesToRemove.forEach(n => n.remove());

      // Удаляем пустые элементы, но только из списка deleteTags
      const deleteTags = new Set([
        'P', 'span', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'b', 'i', 'u', 'del'
      ]);
      const svgNS = 'http://www.w3.org/2000/svg';

      const allElems = Array.from(wrapper.querySelectorAll('*')).reverse();
      allElems.forEach(el => {
        if (el === wrapper) return;
        if (!deleteTags.has(el.tagName.toLowerCase())) return;
        if (el.namespaceURI === svgNS) return;

        let hasContent = false;
        for (const child of el.childNodes) {
          if (child.nodeType === Node.TEXT_NODE && child.textContent.trim().length > 0) {
            hasContent = true;
            break;
          }
          if (child.nodeType === Node.ELEMENT_NODE) {
            hasContent = true;
            break;
          }
        }
        if (!hasContent) {
          el.remove();
        }
      });
    }


    cleanWrapper();
  })();


  // Ограничение input(компонент Кнопка, Таймер)
  const observer = new MutationObserver((mutations, obs) => {
    const input = document.querySelector('input[name="TITLE25"]');
    if (!input) return;

    input.setAttribute('maxlength', '25');

    let alerted = false;
    input.addEventListener('input', function onInput() {
      if (this.value.length >= this.maxLength && !alerted) {
        alert('Максимум — 25 символов');
        alerted = true;
      } else if (this.value.length < this.maxLength) {
        alerted = false;
      }
    });

    obs.disconnect();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
  });


  // Перенос классов у битриксовых блоков в режим правки страницы
  function handleBitrixWrappers(target) {
    const parent = target.parentElement;
    const parentClasses = Array.from(parent.classList);

    if (parentClasses.length) {
      parent.classList.remove(...parentClasses);
      target.classList.add(...parentClasses);
    }

    const children = document.querySelectorAll('[id^="bx_incl_area_2_"]');

    children.forEach(child => {
      const firstChild = child.firstElementChild;
      if (firstChild) {
        const childClasses = Array.from(firstChild.classList);
        if (childClasses.length) {
          firstChild.classList.remove(...childClasses);
          child.classList.add(...childClasses);
        }
      }
    });
  }

  // Проверяем включен ли режим правки страницы
  const target = document.getElementById('bx_incl_area_2');

  if (target) {
    handleBitrixWrappers(target);
  }

  /* A11Y (ОВЗ) */

	const accessibilityBtn = document.querySelector(".accessibility-btn");
	const accessibilityPanel = document.querySelector(".accessibility-panel");
	const highContrastBlockList = Array.from(document.querySelectorAll(".accessibility-settings__highcontrast"));
	const fontsBlockList = Array.from(document.querySelectorAll(".accessibility-settings__font"));
	const imagesBlockList = Array.from(document.querySelectorAll(".accessibility-settings__img"));
	const fontTypeBlockList = Array.from(document.querySelectorAll(".accessibility-settings__fontType"));
	const kerningBlockList = Array.from(document.querySelectorAll(".accessibility-settings__kerning"));
	const imageTypeBlockList = Array.from(document.querySelectorAll(".accessibility-settings__imgType"));
	
	function removeAccessibity(arr) {
	  arr.forEach((e) => {
		document.body.classList.remove(e.getAttribute("data-type"));
	  })
	}
	
	function onSwitchAccessibility(arr, selectElement) {
	  const type = selectElement.getAttribute("data-type");
	  const settingType = arr[0].getAttribute("data-type").split("-")[0];
	
	  arr.forEach(e => {
		const currentType = e.getAttribute("data-type");
		document.body.classList.remove(currentType);
		e.classList.remove('accessibility-settings__block--active');
	  });
	
	  document.body.classList.add(type);
	  selectElement.classList.add('accessibility-settings__block--active');
	
	  // Сохраняем в localStorage
	  const saved = JSON.parse(localStorage.getItem("accessibilitySettings")) || {};
	  saved[settingType] = type;
	  localStorage.setItem("accessibilitySettings", JSON.stringify(saved));
	}
	
	function switchAccessibility(on) {
	  if (on) {
		localStorage.setItem("accessibilityPanelVisible", true);
		onSwitchAccessibility(highContrastBlockList, highContrastBlockList[0]);
		onSwitchAccessibility(fontsBlockList, fontsBlockList[2]);
		onSwitchAccessibility(imagesBlockList, imagesBlockList[1]);
		onSwitchAccessibility(fontTypeBlockList, fontTypeBlockList[0]);
		onSwitchAccessibility(kerningBlockList, kerningBlockList[0]);
		onSwitchAccessibility(imageTypeBlockList, imageTypeBlockList[0]);
    document.documentElement.style.setProperty('--slider-controls-bottom', '1rem');
	  } else {
		localStorage.setItem("accessibilityPanelVisible", false);
		  localStorage.removeItem("accessibilitySettings");
		removeAccessibity(highContrastBlockList);
		removeAccessibity(fontsBlockList);
		removeAccessibity(imagesBlockList);
		removeAccessibity(fontTypeBlockList);
		removeAccessibity(kerningBlockList);
		removeAccessibity(imageTypeBlockList);
    document.documentElement.style.setProperty('--slider-controls-bottom', '2rem');
	  }
	}
	
	// Загрузка сохранённых значений при инициализации
	function loadSavedSettings() {
	  const isVisible = localStorage.getItem("accessibilityPanelVisible") === "true";
	  const savedSettings = JSON.parse(localStorage.getItem("accessibilitySettings")) || {};
	
	  if (isVisible) {
		accessibilityPanel.removeAttribute("hidden");
	
		applySavedSetting(highContrastBlockList, savedSettings, "high");
		applySavedSetting(fontsBlockList, savedSettings, "font");
		applySavedSetting(imagesBlockList, savedSettings, "hide");
		applySavedSetting(fontTypeBlockList, savedSettings, "fontKind");
		applySavedSetting(kerningBlockList, savedSettings, "kerning");
		applySavedSetting(imageTypeBlockList, savedSettings, "image");
	  } else {
		accessibilityPanel.setAttribute("hidden", true);
	  }
    document.documentElement.style.setProperty(
      '--slider-controls-bottom',
      isVisible ? '1rem' : '2rem'
    );
	}
	
	function applySavedSetting(blockList, savedSettings, settingKey) {
	  const savedType = savedSettings[settingKey];
	  if (!savedType) return;
	
	  const targetElement = blockList.find(el => el.getAttribute("data-type") === savedType);
	  if (targetElement) {
		blockList.forEach(el => {
		  const currentType = el.getAttribute("data-type");
		  document.body.classList.remove(currentType);
		  el.classList.remove('accessibility-settings__block--active');
		});
	
		document.body.classList.add(savedType);
		targetElement.classList.add('accessibility-settings__block--active');
	  }
	}
	
	highContrastBlockList.forEach((item) => {
	  item.addEventListener("click", (e) => (onSwitchAccessibility(highContrastBlockList, item)));
	});
	
	fontsBlockList.forEach((item) => {
	  item.addEventListener("click", (e) => (onSwitchAccessibility(fontsBlockList, item)));
	});
	
	imagesBlockList.forEach((item) => {
	  item.addEventListener("click", (e) => (onSwitchAccessibility(imagesBlockList, item)));
	});
	
	fontTypeBlockList.forEach((item) => {
	  item.addEventListener("click", (e) => (onSwitchAccessibility(fontTypeBlockList, item)));
	});
	
	kerningBlockList.forEach((item) => {
	  item.addEventListener("click", (e) => (onSwitchAccessibility(kerningBlockList, item)));
	});
	
	imageTypeBlockList.forEach((item) => {
	  item.addEventListener("click", (e) => (onSwitchAccessibility(imageTypeBlockList, item)));
	});
	
	accessibilityBtn.addEventListener("click", (e) => {
	  switchAccessibility(accessibilityPanel.getAttributeNames().includes("hidden"));
	  if (accessibilityPanel.getAttributeNames().includes("hidden")) {
		accessibilityPanel.removeAttribute("hidden");
	  } else {
		accessibilityPanel.setAttribute("hidden", true);
	  }
	});
	
	loadSavedSettings();
</script>
