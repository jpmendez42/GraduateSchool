<script type="text/javascript">
document.addEventListener('DOMContentLoaded', function () {
  class PbSlider {
    constructor(selector) {
      this.slider = document.querySelector(selector);
      if (!this.slider) return;

      this.wrapper = this.slider.querySelector('.pb-slides-wrapper');
      this.slides = Array.from(this.wrapper.querySelectorAll('.pb-slide-item'));
      this.prevBtn = this.slider.querySelector('.pb-prev-visible');
      this.nextBtn = this.slider.querySelector('.pb-next-visible');
      this.caption = this.slider.querySelector('.pb-caption-visible');
      this.dotsContainer = this.slider.querySelector('.pb-dots-visible');

      this.slideIndex = 1; // začínáme na prvním reálném slidu
      this.totalSlidesOriginal = this.slides.length;

      this.cloneSlides();
      this.totalSlides = this.slides.length;

      // drag proměnné
      this.isDragging = false;
      this.isClick = true;
      this.startX = 0;
      this.startY = 0;
      this.currentTranslate = 0;
      this.prevTranslate = 0;
      this.movedDistance = 0;
      this.isTouch = false;

      this.init();
    }

    cloneSlides() {
      const firstClone = this.slides[0].cloneNode(true);
      const lastClone = this.slides[this.slides.length - 1].cloneNode(true);
      firstClone.classList.add('pb-first-clone');
      lastClone.classList.add('pb-last-clone');

      this.wrapper.appendChild(firstClone);
      this.wrapper.insertBefore(lastClone, this.slides[0]);

      this.slides = Array.from(this.wrapper.querySelectorAll('.pb-slide-item'));
    }

    init() {
      this.createDots();
      this.setPositionByIndex(false);
      this.startAutoPlay();
      this.attachEvents();
    }

    createDots() {
      if (!this.dotsContainer) return;
      this.dotsContainer.innerHTML = '';
      for (let i = 0; i < this.totalSlidesOriginal; i++) {
        const dot = document.createElement('span');
        dot.addEventListener('click', () => {
          this.slideIndex = i + 1; // +1 kvůli klonu na začátku
          this.setPositionByIndex();
          this.restartAutoPlay();
        });
        this.dotsContainer.appendChild(dot);
      }
    }

    next() {
      if (this.slideIndex >= this.slides.length - 1) return;
      this.slideIndex++;
      this.setPositionByIndex();
    }

    prev() {
      if (this.slideIndex <= 0) return;
      this.slideIndex--;
      this.setPositionByIndex();
    }

    setPositionByIndex(withTransition = true) {
      const slideWidth = this.slider.offsetWidth;
      const offset = slideWidth * this.slideIndex;
      this.currentTranslate = -offset;
      this.prevTranslate = this.currentTranslate;

      this.wrapper.style.transition = withTransition ? 'transform 0.6s ease-out' : 'none';
      this.wrapper.style.transform = `translateX(${this.currentTranslate}px)`;

      // caption
      if (this.caption) {
        this.caption.textContent = `${((this.slideIndex - 1 + this.totalSlidesOriginal) % this.totalSlidesOriginal) + 1} / ${this.totalSlidesOriginal}`;
      }

      // dots
      if (this.dotsContainer) {
        Array.from(this.dotsContainer.children).forEach((dot, index) => {
          dot.classList.toggle('active', index === (this.slideIndex - 1 + this.totalSlidesOriginal) % this.totalSlidesOriginal);
        });
      }

      // active_slide
      this.slides.forEach((slide, index) => {
        slide.classList.toggle('active_slide', index === this.slideIndex);
      });
    }

    attachEvents() {
      // šipky
      if (this.nextBtn) this.nextBtn.addEventListener('click', () => { this.next(); this.restartAutoPlay(); });
      if (this.prevBtn) this.prevBtn.addEventListener('click', () => { this.prev(); this.restartAutoPlay(); });

      // resize
      window.addEventListener('resize', () => this.setPositionByIndex(false));

      // transitionend pro reset při clone
      this.wrapper.addEventListener('transitionend', () => {
        if (this.slides[this.slideIndex].classList.contains('pb-first-clone')) {
          this.wrapper.style.transition = 'none';
          this.slideIndex = 1;
          this.setPositionByIndex(false);
        }
        if (this.slides[this.slideIndex].classList.contains('pb-last-clone')) {
          this.wrapper.style.transition = 'none';
          this.slideIndex = this.slides.length - 2;
          this.setPositionByIndex(false);
        }
      });

      // drag/swipe
      this.wrapper.addEventListener('mousedown', e => { this.isTouch = false; this.touchStart(e); });
      this.wrapper.addEventListener('mousemove', e => { if (!this.isTouch) this.touchMove(e); });
      this.wrapper.addEventListener('mouseup', e => { if (!this.isTouch) this.touchEnd(e); });
      this.wrapper.addEventListener('mouseleave', e => { if (!this.isTouch) this.touchEnd(e); });

      this.wrapper.addEventListener('touchstart', e => { this.isTouch = true; this.touchStart(e); });
      this.wrapper.addEventListener('touchmove', e => { if (this.isTouch) this.touchMove(e); });
      this.wrapper.addEventListener('touchend', e => { if (this.isTouch) this.touchEnd(e); });
    }

    getPositionX(e) {
      return e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
    }

    touchStart(e) {
      this.isDragging = true;
      this.isClick = true;
      this.startX = this.getPositionX(e);
      this.startY = e.type.includes('mouse') ? e.pageY : e.touches[0].clientY;
      this.movedDistance = 0;
      this.wrapper.style.transition = 'none';
    }

    touchMove(e) {
      if (!this.isDragging) return;
      const currentX = this.getPositionX(e);
      const currentY = e.type.includes('mouse') ? e.pageY : e.touches[0].clientY;
      const diffX = currentX - this.startX;
      const diffY = currentY - this.startY;

      if (Math.abs(diffX) > Math.abs(diffY)) {
        e.preventDefault();
        if (Math.abs(diffX) > 5) this.isClick = false;
        this.currentTranslate = this.prevTranslate + diffX;
        this.wrapper.style.transform = `translateX(${this.currentTranslate}px)`;
        this.movedDistance = diffX;
      }
    }

    touchEnd() {
      if (!this.isDragging) return;
      this.isDragging = false;

      const movedBy = this.currentTranslate - this.prevTranslate;
      if (movedBy < -50) this.next();
      else if (movedBy > 50) this.prev();
      else this.setPositionByIndex(true);
    }

    startAutoPlay() {
      this.stopAutoPlay();
      this.autoPlayInterval = setInterval(() => this.next(), 13000);
    }

    stopAutoPlay() {
      if (this.autoPlayInterval) clearInterval(this.autoPlayInterval);
    }

    restartAutoPlay() {
      this.startAutoPlay();
    }
  }

  new PbSlider('.pb-slider-777');
  new PbSlider('.pb-slider-778');
});
</script><script type="text/javascript">
document.addEventListener('DOMContentLoaded', function() {
  // --- tlačítka ---
  const registerButton = document.querySelector('.register-domain-btn');
  const transferButton = document.querySelector('.transfer-domain-btn');

  if (registerButton) {
    registerButton.addEventListener('click', () => {
      const domainInput = document.querySelector('#domainInput');
      let domain = domainInput ? domainInput.value : '';
      if (!domain) return;
      if (!domain.includes('.')) {
      domain += '.cz';
    }
      const [baseDomain, ...rest] = domain.split('.');
      const tld = rest.join('.');
      const url = `https://objednavka.forpsi.com/domain/cart-order.php?dom=${baseDomain}&tld%5B0%5D=${tld}&progress=1&lang=cz`;
      window.open(url, '_blank');
    });
  }

  if (transferButton) {
    transferButton.addEventListener('click', () => {
      const domainTransferInput = document.querySelector('#domainTransferInput');
      let domain = domainTransferInput ? domainTransferInput.value : '';
      if (!domain) return;
       if (!domain.includes('.')) {
      domain += '.cz';
    }
      const [baseDomain, ...rest] = domain.split('.');
      const tld = rest.join('.');
      const url = `https://objednavka.forpsi.com/domain/transfer.php?new=1&dom=${baseDomain}&tld%5B%5D=${tld}&lang=cz`;
      window.open(url, '_blank');
    });
  }

 
  
  function setupAutocomplete(inputId, suggestionsId, suffixList) {
    const input = document.getElementById(inputId);
    const container = document.getElementById(suggestionsId);
    let activeIndex = -1;

    container.style.display = 'none';

    function renderSuggestions() {
      const value = input.value.trim();
      container.innerHTML = '';
      activeIndex = -1;

      if (!value) {
        container.style.display = 'none';
        return;
      }

      const match = value.match(/^([^.]+)(\.[a-z]*)?$/i);
      if (!match) return container.style.display = 'none';

      const base = match[1];
      const partialSuffix = match[2] || '';
      const filtered = suffixList.filter(s => s.toLowerCase().startsWith(partialSuffix.toLowerCase()));
      if (!filtered.length) return container.style.display = 'none';

      filtered.forEach(suffix => {
        const full = base + suffix;
        const div = document.createElement('div');
        div.className = 'suggestion-item';
        div.tabIndex = 0;
        div.textContent = full;

        div.addEventListener('click', () => {
          input.value = full;
          container.innerHTML = '';
          container.style.display = 'none';
        });

        div.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            div.click();
          }
        });

        container.appendChild(div);
      });

      container.style.position = 'absolute';
      container.style.left = input.offsetLeft + 'px';
      container.style.top = input.offsetTop + input.offsetHeight + 'px';
      container.style.width = input.offsetWidth + 'px';
      container.style.display = 'block';
    }

    input.addEventListener('input', renderSuggestions);
input.addEventListener('keydown', (e) => {
  const items = container.querySelectorAll('.suggestion-item');

  if (e.key === 'ArrowDown') {
    if (!items.length) return;
    e.preventDefault();
    activeIndex = (activeIndex + 1) % items.length;
    items.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
    items[activeIndex].scrollIntoView({ block: 'nearest' });
  }

  if (e.key === 'ArrowUp') {
    if (!items.length) return;
    e.preventDefault();
    activeIndex = (activeIndex - 1 + items.length) % items.length;
    items.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
    items[activeIndex].scrollIntoView({ block: 'nearest' });
  }

if (e.key === 'Enter') {
  e.preventDefault();

  if (activeIndex >= 0 && items.length) {
    items[activeIndex].click();
  } else {
   
    if (!input.value.includes('.')) {
      input.value = input.value.trim() + '.cz';
    }

    if (inputId === 'domainInput') registerButton?.click();
    if (inputId === 'domainTransferInput') transferButton?.click();
  }
}

});

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target) && e.target !== input) {
        container.innerHTML = '';
        container.style.display = 'none';
        activeIndex = -1;
      }
    });
  }

  setupAutocomplete('domainInput', 'domainInputSuggestions', registerSuffixes);
  setupAutocomplete('domainTransferInput', 'domainTransferInputSuggestions', registerSuffixes);
});
$(document).ready(function () {
  $('.searchFormTabs a.nav-link').on('click', function (e) {
    if ($(this).is($('.searchFormTabs a.nav-link').first())) {
      $('.reg-show').css('display', 'block');
    } else {
      $('.reg-show').css('display', 'none');
    }
  });
});
