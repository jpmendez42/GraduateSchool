<style>
    .quixoticFluxFrame {
      max-width: 1300px;
      margin: 0 auto;
      overflow: hidden;
      position: relative;
      user-select: none;
    }

    a {
        text-decoration: none;
    }
    a:hover{
        text-decoration: none;
    }

    .zestfulTrack {
      display: flex;
      gap: 20px;
      margin-bottom:15px;
      transition: transform 0.5s ease;
      will-change: transform;
    }

    .whimsicalCard {
      flex: 0 0 calc(25% - 15px);
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
      cursor: grab;
    }
    .whimsicalCard:hover{
        background-color:#daedf0;
    }

    .whimsicalCard:active {
      cursor: grabbing;
    }

    .vividImagery {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .luminousCaption {
      padding: 15px;
    }

    .radiantTitle {
      font-size: 25px;
      margin: 0 0 10px;
      color: #333;
      font-weight:600;
      text-align: center;
    }

    .etherealDesc {
      font-size: 15px;
      color: #666;
      margin: 0;
      text-align:center;
      line-height: 1.4;
    }

    .lucidArrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0, 0, 0, 0.5);
      color: white;
      border: none;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1.5rem;
      z-index: 10;
      transition: background 0.3s;
    }

    .lucidArrow:hover {
      background: rgba(0, 0, 0, 0.7);
    }

    .lucidArrow--left {
      left: 3px;
    }

    .lucidArrow--right {
      right: 3px;
    }

    .lucidArrow:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    @media (max-width: 768px) {
      .whimsicalCard {
        flex: 0 0 calc(50% - 10px);
      }

      .lucidArrow {
        width: 35px;
        height: 35px;
        font-size: 1.2rem;
      }
    }
    @media only screen and (max-width: 767px) {
    .highlight-left .wrap:first-child, .highlight-right .wrap:last-child {
        background: #f6f6f7 !important;
    }
}

@media only screen and (max-width: 767px) {
    .highlight-left .section_wrapper .wrap, .highlight-right .section_wrapper .wrap {
        padding: 0 10px;
    }
}
