s\",\"606\",\"static/chunks/606-2657163138b7576d.js\",\"374\",\"static/chunks/374-51ff5d7d30355c11.js\",\"549\",\"static/chunks/549-eeb05a6c89e3d181.js\",\"495\",\"static/chunks/app/%5Blang%5D/page-42b7697544637f8d.js\"],\"default\"]\n11:{\"home_introduction\":\"GIỚI THIỆU\",\"home_general_introduction\":\"Giới thiệu chung\",\"home_vision_mission\":\"Tầm nhìn sứ mệnh\",\"home_orientation\":\"Định hướng\",\"home_core_values\":\"Giá trị cốt lõi\",\"home_outstanding_achievements\":\"Thành tích nổi bật\",\"home_development_history\":\"Lịch sử phát triển\",\"home_product_services\":\"SẢN PHẨM DỊCH VỤ\",\"home_television_media\":\"Truyền hình \u0026 Truyền thông\",\"home_online_entertainment\":\"Giải trí trực tuyến\",\"home_payments\":\"Thanh toán \u0026 Thương mại điện tử\",\"home_telecommunications_information\":\"Viễn thông - CNTT - Chuyển đổi số\",\"home_education_training\":\"Giáo dục - Đào tạo\",\"home_news\":\"TIN TỨC\",\"home_news_activities\":\"Tin tức hoạt động\",\"home_news_recruitment\":\"Tin tức tuyển dụng\",\"home_social_security\":\"AN SINH - XÃ HỘI\",\"home_information\":\"CÔNG BỐ THÔNG TIN\",\"home_other\":\"KHÁC\",\"home_corporate_culture\":\"VĂN HÓA DOANH NGHIỆP\",\"home_image_materials\":\"TƯ LIỆU HÌNH ẢNH\",\"home_faq\":\"FAQ\",\"home_member\":\"Đơn vị thành viên\"}\n12:{\"button_see_more\":\"Xem thêm\",\"button_no_data\":\"Không có dữ liệu\"}\n13:{\"news_des\":\"Cập nhật các tin tức mới nhất của Tổng Công Ty VTC, theo dõi tất cả các tin tức hoạt động.\"}\n14:{\"product_title\":\"Sản phẩm"])</script><script>self.__next_f.push([1," - Dịch vụ\",\"product_des\":\"Tổng công ty truyền thông đa phương tiện VTC là doanh nghiệp hàng đầu trong lĩnh vực Nội dung số, được biết đến với vai trò tiên phong trong việc khai thác và ứng dụng sức mạnh hội tụ của các ngành Phát thanh - Truyền hình, Viễn thông, Công nghệ thông tin và Giải trí trực tuyến.\"}\n15:{\"introduction_title\":\"Giới thiệu\",\"introduction_history\":\"Lịch sử phát triển\",\"introduction_history_vtc\":\"Lịch sử phát triển hình thành của VTC \"}\n16:{\"header_title\":\"Trang chủ\",\"header_image\":\"Tư liệu hình ảnh\",\"header_download\":\"Tải xuống\",\"header_news\":\"Tin tức\",\"header_des\":\"Cập nhật các tin tức mới nhất của Tổng Công Ty VTC, theo dõi tất cả các tin tức hoạt động.\",\"header_recruitment\":\"Tuyển dụng\",\"header_job\":\"Vị Trí Tuyển Dụng\",\"header_date\":\"Ngày đăng\",\"header_position\":\"Vị trí\",\"header_company\":\"Công ty\",\"header_AllCompany\":\"Tất cả công ty\",\"header_workplace\":\"Nơi làm việc\",\"header_action\":\"Thao tác\",\"header_apply\":\"Ứng tuyển\",\"header_information\":\"Công bố thông tin\",\"header_title2\":\"Tiêu đề\",\"header_year\":\"Năm\",\"header_search\":\"Tìm kiếm\",\"header_all\":\"Tất cả\",\"header_new_hot\":\"Bài đăng mới nhất\",\"header_other_product\":\"Các sản phẩm dịch vụ khác\",\"header_scroll\":\"Kéo xuống\",\"header_view\":\"Xem file\"}\n"])</script><script>self.__next_f.push([1,"17:{\"faq_title1\":\"VTC là công ty gì?\",\"faq_title2\":\"VTC (Tổng công ty Truyền thông Đa phương tiện Việt Nam) là một công ty đa phương tiện hàng đầu tại Việt Nam, chuyên cung cấp các dịch vụ truyền hình, truyền thông, và viễn thông.\",\"faq_title3\":\"Trụ sở chính của VTC nằm tại số 67b Hàm Long, Hoàn Kiếm, Hà Nội.\",\"faq_title4\":\"Lĩnh vực kinh doanh chính của VTC là gì?\",\"faq_title5\":\"VTC là doanh nghiệp hàng đầu trong lĩnh vực Nội dung số tại Việt Nam, hoạt động trong các lĩnh vực bao gồm:\",\"faq_title6\":\"- Truyền hình – Truyền thông\",\"faq_title7\":\"- Giải trí trực tuyến\",\"faq_title8\":\"- Thanh toán \u0026 Thương mại điện tử\",\"faq_title9\":\"- Viễn thông – CNTT – Chuyển đổi số\",\"faq_title10\":\"- Giáo dục – Đào tạo\",\"faq_title11\":\"VTC có bao nhiêu đơn vị thành viên trực thuộc?\",\"faq_title12\":\"Tổng công ty VTC có 7 đơn vị thành viên bao gồm:\",\"faq_title13\":\"- VTC Intecom: chuyên cung cấp dịch vụ trò chơi trực tuyến, giải pháp nội dung số và các dịch vụ giá trị gia tăng trên nền tảng internet\",\"faq_title14\":\"- VTC Digital: chuyên cung cấp dịch vụ truyền hình HD, phát thanh đa dạng và giải pháp truyền thông số sáng tạo\",\"faq_title15\":\"- VTC Digicom: chuyên cung cấp các dịch vụ viễn thông và giải pháp công nghệ thông tin tiên tiến\",\"faq_title16\":\"- VTC Comtech: kinh doanh và lắp đặt PTTH, thiết bị trình chiếu, cung cấp giải pháp kỹ thuật tối ưu và hiệu quả\",\"faq_title17\":\"- VTC Mobile: chuyên cung cấp dịch vụ giá trị gia tăng, giải trí và tiện ích di động\",\"faq_title18\":\"- VTC Netviet: hoạt động trong lĩnh vực truyền hình, báo chí điện tử, truyền thông và tổ chức sự kiện, tư vấn chiến lược chuyển đổi số và đào tạo kỹ năng số.\",\"faq_title19\":\"- VTC Online: hoạt động trong các lĩnh vực như phát hành và sản xuất game, mạng xã hội, thanh toán điện tử, đào tạo công nghệ và nội dung số, giáo dục trực tuyến...\",\"faq_title20\":\"VTC cung cấp những “dịch vụ truyền hình – truyền thông” nào?\",\"faq_title21\":\"- Truyền hình vệ tinh\",\"faq_title22\":\"- Truyền hình Internet\",\"faq_title23\":\"- Giải pháp khóa mã ViCas\",\"faq_title24\":\"- Truyền dẫn phát sóng\",\"faq_title25\":\"- Truyền thông trực tuyến\",\"faq_title26\":\"- Sản xuất nội dung truyền hình\",\"faq_title27\":\"- Sự kiện \u0026 Tài trợ\",\"faq_title28\":\"- Cổng Thông tin điện tử nhân đạo quốc gia (1400)\",\"faq_title29\":\"- Chi tiết truy cập mục “Sản phẩm – Dịch vụ” --\u003e Chọn “Truyền hình - truyền thông” -- \u003e Chọn “xem thêm”\",\"faq_title30\":\" VTC có những trò chơi điện tử nào?\",\"faq_title31\":\"VTC là nhà phát hành và phát triển đa dạng các thể loại với nhiều tựa game huyền thoại nổi tiếng và hấp dẫn, thu hút đông đảo người chơi tại Việt Nam như: Audition, Đột Kích (Crossfire), Truy kích, Silkroad, Phục kích, Đại chiến Tam quốc, Be A Pro: Football,…\",\"faq_title32\":\"VTC có những sản phẩm và dịch vụ “thanh toán \u0026 Thương mại điện tử” nào?\",\"faq_title33\":\"- Ví điện tử VTC Pay\",\"faq_title34\":\"- Cổng thanh toán VTC Pay\",\"faq_title35\":\"- Dịch vụ ngân hàng số\",\"faq_title36\":\"- Sàn thương mại điện tử Mudi.vn\",\"faq_title37\":\"- Chi tiết truy cập mục “Sản phẩm – Dịch vụ” --\u003e Chọn “Thanh toán \u0026 Thương mại điện tử” -- \u003e Chọn “xem thêm”\",\"faq_title38\":\"VTC có những sản phẩm và dịch vụ “viễn thông – CNTT – chuyển đổi số” nào?\",\"faq_title39\":\"- Dịch vụ viễn thông\",\"faq_title40\":\"- Trung tâm dữ liệu\",\"faq_title41\":\"- Điện toán đám mây\",\"faq_title42\":\"- Các giải pháp chuyển đổi số: Hệ thống thông tin nguồn Trung ương, Tòa soạn hội tụ; Trợ lý ảo; Lưu chiểu báo điện tử\",\"faq_title43\":\"- An toàn thông tin\",\"faq_title44\":\"Chi tiết truy cập mục “Sản phẩm – Dịch vụ” -- \u003e Chọn “viễn thông – CNTT – chuyển đổi số” -- \u003e Chọn “xem thêm”\",\"faq_title45\":\"VTC có những sản phẩm và dịch vụ “Giáo dục – Đào tạo” nào?\",\"faq_title46\":\"- Nền tảng Giáo dục và đào tạo số - VTC Edu\",\"faq_title47\":\"- Nền tảng học trực tuyến mở đại trà - OneTouch\",\"faq_title48\":\"- Nền tảng Sát hạch kỹ năng số\",\"faq_title49\":\"- Nền tảng Olympic Tiếng Anh trên Internet (IOE) và Olympic Tiếng Hàn trên Internet (IOK)\",\"faq_title50\":\"- Nền tảng An toàn giao thông số\",\"faq_title51\":\"- Đào tạo nhân lực ngành game\",\"faq_title52\":\"- Sản xuất học liệu số\",\"faq_title53\":\"Chi tiết truy cập mục “Sản phẩm – Dịch vụ” -- \u003e Chọn “Giáo dục – Đào tạo” -- \u003e Chọn “xem thêm”\",\"faq_title54\":\"Làm thế nào để liên hệ với bộ phận hỗ trợ khách hàng của VTC?\",\"faq_title55\":\"Với mỗi dịch vụ, VTC đều có đơn vị chủ quản riêng, bạn vui lòng liên hệ với bộ phận hỗ trợ khách hàng của các đơn vị VTC thông qua website hỗ trợ, email, hoặc qua các kênh truyền thông xã hội.\",\"faq_title56\":\"Làm thế nào để hợp tác kinh doanh với VTC?\",\"faq_title57\":\"Bạn có thể gửi yêu cầu hợp tác qua email chính thức của VTC:\",\"faq_title58\":\"- Email: family@vtc.vn\",\"faq_title59\":\"- Số điện thoại: 024.44501113 - Fax: 024.44501100\",\"faq_title60\":\"- Hoặc tới thẳng trực tiếp tại trụ sở chính: 67b Hàm Long, Hoàn Kiếm, Hà Nội.\",\"faq_title61\":\"Địa chỉ trụ sở chính của VTC ở đâu?\",\"faq_title62\":\"Câu hỏi thường gặp\",\"faq_title63\":\"Dịch vụ của VTC\",\"faq_title64\":\"Hỗ trợ khách hàng\",\"faq_about\":\"Thông tin chung về VTC\"}\n"])</script><script>self.__next_f.push([1,"18:{\"footer_title\":\"TỔNG CÔNG TY TRUYỀN THÔNG ĐA PHƯƠNG TIỆN (VTC)\",\"footer_address\":\"Địa chỉ\",\"footer_address_2\":\"Số 67B phố Hàm Long, Phường Cửa Nam, Thành phố Hà Nội, Việt Nam\",\"footer_contact\":\"THÔNG TIN LIÊN HỆ\",\"footer_member\":\"ĐƠN VỊ THÀNH VIÊN\",\"footer_email\":\"Email\",\"footer_hotline\":\"Hotline\",\"footer_contact_2\":\"Liên hệ\",\"footer_send\":\"Gửi\",\"footer_name\":\"Họ và tên\",\"footer_content\":\"Nội dung\",\"footer_phone\":\"Email/số điện thoại\"}\n10:{\"header\":\"$11\",\"otherButton\":\"$12\",\"news\":\"$13\",\"productService\":\"$14\",\"introductionHome\":\"$15\",\"headerChild\":\"$16\",\"faq\":\"$17\",\"footer\":\"$18\"}\n"])</script><script>self.__next_f.push([1,"7:[\"$\",\"main\",null,{\"id\":\"fullpage\",\"children\":[[\"$\",\"$Le\",null,{\"translate\":{\"header\":{\"home_introduction\":\"GIỚI THIỆU\",\"home_general_introduction\":\"Giới thiệu chung\",\"home_vision_mission\":\"Tầm nhìn sứ mệnh\",\"home_orientation\":\"Định hướng\",\"home_core_values\":\"Giá trị cốt lõi\",\"home_outstanding_achievements\":\"Thành tích nổi bật\",\"home_development_history\":\"Lịch sử phát triển\",\"home_product_services\":\"SẢN PHẨM DỊCH VỤ\",\"home_television_media\":\"Truyền hình \u0026 Truyền thông\",\"home_online_entertainment\":\"Giải trí trực tuyến\",\"home_payments\":\"Thanh toán \u0026 Thương mại điện tử\",\"home_telecommunications_information\":\"Viễn thông - CNTT - Chuyển đổi số\",\"home_education_training\":\"Giáo dục - Đào tạo\",\"home_news\":\"TIN TỨC\",\"home_news_activities\":\"Tin tức hoạt động\",\"home_news_recruitment\":\"Tin tức tuyển dụng\",\"home_social_security\":\"AN SINH - XÃ HỘI\",\"home_information\":\"CÔNG BỐ THÔNG TIN\",\"home_other\":\"KHÁC\",\"home_corporate_culture\":\"VĂN HÓA DOANH NGHIỆP\",\"home_image_materials\":\"TƯ LIỆU HÌNH ẢNH\",\"home_faq\":\"FAQ\",\"home_member\":\"Đơn vị thành viên\"},\"otherButton\":{\"button_see_more\":\"Xem thêm\",\"button_no_data\":\"Không có dữ liệu\"},\"news\":{\"news_des\":\"Cập nhật các tin tức mới nhất của Tổng Công Ty VTC, theo dõi tất cả các tin tức hoạt động.\"},\"productService\":{\"product_title\":\"Sản phẩm - Dịch vụ\",\"product_des\":\"Tổng công ty truyền thông đa phương tiện VTC là doanh nghiệp hàng đầu trong lĩnh vực Nội dung số, được biết đến với vai trò tiên phong trong việc khai thác và ứng dụng sức mạnh hội tụ của các ngành Phát thanh - Truyền hình, Viễn thông, Công nghệ thông tin và Giải trí trực tuyến.\"},\"introductionHome\":{\"introduction_title\":\"Giới thiệu\",\"introduction_history\":\"Lịch sử phát triển\",\"introduction_history_vtc\":\"Lịch sử phát triển hình thành của VTC \"},\"headerChild\":{\"header_title\":\"Trang chủ\",\"header_image\":\"Tư liệu hình ảnh\",\"header_download\":\"Tải xuống\",\"header_news\":\"Tin tức\",\"header_des\":\"Cập nhật các tin tức mới nhất của Tổng Công Ty VTC, theo dõi tất cả các tin tức hoạt động.\",\"header_recruitment\":\"Tuyển dụng\",\"header_job\":\"Vị Trí Tuyển Dụng\",\"header_date\":\"Ngày đăng\",\"header_position\":\"Vị trí\",\"header_company\":\"Công ty\",\"header_AllCompany\":\"Tất cả công ty\",\"header_workplace\":\"Nơi làm việc\",\"header_action\":\"Thao tác\",\"header_apply\":\"Ứng tuyển\",\"header_information\":\"Công bố thông tin\",\"header_title2\":\"Tiêu đề\",\"header_year\":\"Năm\",\"header_search\":\"Tìm kiếm\",\"header_all\":\"Tất cả\",\"header_new_hot\":\"Bài đăng mới nhất\",\"header_other_product\":\"Các sản phẩm dịch vụ khác\",\"header_scroll\":\"Kéo xuống\",\"header_view\":\"Xem file\"},\"faq\":{\"faq_title1\":\"VTC là công ty gì?\",\"faq_title2\":\"VTC (Tổng công ty Truyền thông Đa phương tiện Việt Nam) là một công ty đa phương tiện hàng đầu tại Việt Nam, chuyên cung cấp các dịch vụ truyền hình, truyền thông, và viễn thông.\",\"faq_title3\":\"Trụ sở chính của VTC nằm tại số 67b Hàm Long, Hoàn Kiếm, Hà Nội.\",\"faq_title4\":\"Lĩnh vực kinh doanh chính của VTC là gì?\",\"faq_title5\":\"VTC là doanh nghiệp hàng đầu trong lĩnh vực Nội dung số tại Việt Nam, hoạt động trong các lĩnh vực bao gồm:\",\"faq_title6\":\"- Truyền hình – Truyền thông\",\"faq_title7\":\"- Giải trí trực tuyến\",\"faq_title8\":\"- Thanh toán \u0026 Thương mại điện tử\",\"faq_title9\":\"- Viễn thông – CNTT – Chuyển đổi số\",\"faq_title10\":\"- Giáo dục – Đào tạo\",\"faq_title11\":\"VTC có bao nhiêu đơn vị thành viên trực thuộc?\",\"faq_title12\":\"Tổng công ty VTC có 7 đơn vị thành viên bao gồm:\",\"faq_title13\":\"- VTC Intecom: chuyên cung cấp dịch vụ trò chơi trực tuyến, giải pháp nội dung số và các dịch vụ giá trị gia tăng trên nền tảng internet\",\"faq_title14\":\"- VTC Digital: chuyên cung cấp dịch vụ truyền hình HD, phát thanh đa dạng và giải pháp truyền thông số sáng tạo\",\"faq_title15\":\"- VTC Digicom: chuyên cung cấp các dịch vụ viễn thông và giải pháp công nghệ thông tin tiên tiến\",\"faq_title16\":\"- VTC Comtech: kinh doanh và lắp đặt PTTH, thiết bị trình chiếu, cung cấp giải pháp kỹ thuật tối ưu và hiệu quả\",\"faq_title17\":\"- VTC Mobile: chuyên cung cấp dịch vụ giá trị gia tăng, giải trí và tiện ích di động\",\"faq_title18\":\"- VTC Netviet: hoạt động trong lĩnh vực truyền hình, báo chí điện tử, truyền thông và tổ chức sự kiện, tư vấn chiến lược chuyển đổi số và đào tạo kỹ năng số.\",\"faq_title19\":\"- VTC Online: hoạt động trong các lĩnh vực như phát hành và sản xuất game, mạng xã hội, thanh toán điện tử, đào tạo công nghệ và nội dung số, giáo dục trực tuyến...\",\"faq_title20\":\"VTC cung cấp những “dịch vụ truyền hình – truyền thông” nào?\",\"faq_title21\":\"- Truyền hình vệ tinh\",\"faq_title22\":\"- Truyền hình Internet\",\"faq_title23\":\"- Giải pháp khóa mã ViCas\",\"faq_title24\":\"- Truyền dẫn phát sóng\",\"faq_title25\":\"- Truyền thông trực tuyến\",\"faq_title26\":\"- Sản xuất nội dung truyền hình\",\"faq_title27\":\"- Sự kiện \u0026 Tài trợ\",\"faq_title28\":\"- Cổng Thông tin điện tử nhân đạo quốc gia (1400)\",\"faq_title29\":\"- Chi tiết truy cập mục “Sản phẩm – Dịch vụ” --\u003e Chọn “Truyền hình - truyền thông” -- \u003e Chọn “xem thêm”\",\"faq_title30\":\" VTC có những trò chơi điện tử nào?\",\"faq_title31\":\"VTC là nhà phát hành và phát triển đa dạng các thể loại với nhiều tựa game huyền thoại nổi tiếng và hấp dẫn, thu hút đông đảo người chơi tại Việt Nam như: Audition, Đột Kích (Crossfire), Truy kích, Silkroad, Phục kích, Đại chiến Tam quốc, Be A Pro: Football,…\",\"faq_title32\":\"VTC có những sản phẩm và dịch vụ “thanh toán \u0026 Thương mại điện tử” nào?\",\"faq_title33\":\"- Ví điện tử VTC Pay\",\"faq_title34\":\"- Cổng thanh toán VTC Pay\",\"faq_title35\":\"- Dịch vụ ngân hàng số\",\"faq_title36\":\"- Sàn thương mại điện tử Mudi.vn\",\"faq_title37\":\"- Chi tiết truy cập mục “Sản phẩm – Dịch vụ” --\u003e Chọn “Thanh toán \u0026 Thương mại điện tử” -- \u003e Chọn “xem thêm”\",\"faq_title38\":\"VTC có những sản phẩm và dịch vụ “viễn thông – CNTT – chuyển đổi số” nào?\",\"faq_title39\":\"- Dịch vụ viễn thông\",\"faq_title40\":\"- Trung tâm dữ liệu\",\"faq_title41\":\"- Điện toán đám mây\",\"faq_title42\":\"- Các giải pháp chuyển đổi số: Hệ thống thông tin nguồn Trung ương, Tòa soạn hội tụ; Trợ lý ảo; Lưu chiểu báo điện tử\",\"faq_title43\":\"- An toàn thông tin\",\"faq_title44\":\"Chi tiết truy cập mục “Sản phẩm – Dịch vụ” -- \u003e Chọn “viễn thông – CNTT – chuyển đổi số” -- \u003e Chọn “xem thêm”\",\"faq_title45\":\"VTC có những sản phẩm và dịch vụ “Giáo dục – Đào tạo” nào?\",\"faq_title46\":\"- Nền tảng Giáo dục và đào tạo số - VTC Edu\",\"faq_title47\":\"- Nền tảng học trực tuyến mở đại trà - OneTouch\",\"faq_title48\":\"- Nền tảng Sát hạch kỹ năng số\",\"faq_title49\":\"- Nền tảng Olympic Tiếng Anh trên Internet (IOE) và Olympic Tiếng Hàn trên Internet (IOK)\",\"faq_title50\":\"- Nền tảng An toàn giao thông số\",\"faq_title51\":\"- Đào tạo nhân lực ngành game\",\"faq_title52\":\"- Sản xuất học liệu số\",\"faq_title53\":\"Chi tiết truy cập mục “Sản phẩm – Dịch vụ” -- \u003e Chọn “Giáo dục – Đào tạo” -- \u003e Chọn “xem thêm”\",\"faq_title54\":\"Làm thế nào để liên hệ với bộ phận hỗ trợ khách hàng của VTC?\",\"faq_title55\":\"Với mỗi dịch vụ, VTC đều có đơn vị chủ quản riêng, bạn vui lòng liên hệ với bộ phận hỗ trợ khách hàng của các đơn vị VTC thông qua website hỗ trợ, email, hoặc qua các kênh truyền thông xã hội.\",\"faq_title56\":\"Làm thế nào để hợp tác kinh doanh với VTC?\",\"faq_title57\":\"Bạn có thể gửi yêu cầu hợp tác qua email chính thức của VTC:\",\"faq_title58\":\"- Email: family@vtc.vn\",\"faq_title59\":\"- Số điện thoại: 024.44501113 - Fax: 024.44501100\",\"faq_title60\":\"- Hoặc tới thẳng trực tiếp tại trụ sở chính: 67b Hàm Long, Hoàn Kiếm, Hà Nội.\",\"faq_title61\":\"Địa chỉ trụ sở chính của VTC ở đâu?\",\"faq_title62\":\"Câu hỏi thường gặp\",\"faq_title63\":\"Dịch vụ của VTC\",\"faq_title64\":\"Hỗ trợ khách hàng\",\"faq_about\":\"Thông tin chung về VTC\"},\"footer\":{\"footer_title\":\"TỔNG CÔNG TY TRUYỀN THÔNG ĐA PHƯƠNG TIỆN (VTC)\",\"footer_address\":\"Địa chỉ\",\"footer_address_2\":\"Số 67B phố Hàm Long, Phường Cửa Nam, Thành phố Hà Nội, Việt Nam\",\"footer_contact\":\"THÔNG TIN LIÊN HỆ\",\"footer_member\":\"ĐƠN VỊ THÀNH VIÊN\",\"footer_email\":\"Email\",\"footer_hotline\":\"Hotline\",\"footer_contact_2\":\"Liên hệ\",\"footer_send\":\"Gửi\",\"footer_name\":\"Họ và tên\",\"footer_content\":\"Nội dung\",\"footer_phone\":\"Email/số điện thoại\"}},\"params\":\"vi\"}],[\"$\",\"$Lf\",null,{\"translate\":\"$10\",\"params\":\"vi\"}],[\"$\",\"$L19\",null,{\"translate\":\"$10\",\"params\":\"vi\"}],[\"$\",\"section\",null,{\"id\":\"bx-tintuc\",\"className\":\"section\",\"children\":[\"$\",\"div\",null,{\"className\":\"relative bg-[#FBFCFE] w-full pb-20\",\"children\":[[\"$\",\"$L1a\",null,{\"className\":\"absolute right-0 botto