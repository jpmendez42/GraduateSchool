<script type="text/javascript">

var selected_free_banner = 0;
var slider_interval_ms = 6000;
var slider_pause = 0;

var main_element = document.getElementById('free_banner_list');

var slider_interval_ms = main_element.getAttribute('data-loopdelay');
if ( ! slider_interval_ms || slider_interval_ms < 1 ) {
	slider_interval_ms = 8000;
}

var dot_links = document.getElementsByName('dot_link');
for (var n=0; n < dot_links.length; n++ ) {
	dot_links[n].addEventListener('click', parse_dot_click);
	if ( dot_links[n].classList.contains('selected') ) {
		selected_free_banner = n;
		//console.log('external_free_banner.js - Active banner '+selected_free_banner);
	}
}
//console.log('external_free_banner.js - Loaded '+n+' banners');


if ( main_element.getAttribute('data-animate') == 1 ) {
	document.getElementById('free_banner_main_link').addEventListener('mouseover', pause_slide);
	document.getElementById('free_banner_main_link').addEventListener('mouseout', resume_slide);
	animate_slider();
}

function parse_dot_click(event) {
	event.preventDefault();
	if ( event.target.tagName != 'A') {
		if ( event.target.parentElement.tagName == 'A' ) {
			var ele = event.target.parentElement;
		}
		else {
			var ele = event.target.parentElement.parentElement;
		}
	}
	else {
		var ele = event.target;
	}
	var main_link = document.getElementById('free_banner_main_link');
	main_link.href = ele.getAttribute('data-link_trgt');
	main_link.setAttribute('title', ele.getAttribute('data-link_title'));
	var main_img = document.getElementById('free_banner_main_img');
	main_img.src = ele.getAttribute('data-img_url');
	main_img.setAttribute('alt', ele.getAttribute('data-img_alt'));
	
	var dot_links = document.getElementsByName('dot_link');
	for (var n=0; n < dot_links.length; n++ ) {
		if ( ele.id == dot_links[n].id ) {
			dot_links[n].classList.add('selected');
			dot_links[n].children[0].children[1].src = 'https://www.camera.it/images/dot-selected.png';
			dot_links[n].children[0].children[1].setAttribute('alt', 'Dot-selected');
			selected_free_banner = n;
		}
		else {
			dot_links[n].classList.remove('selected');
			dot_links[n].children[0].children[1].src = 'https://www.camera.it/images/dot.png';
			dot_links[n].children[0].children[1].setAttribute('alt', 'Dot');
		}
	}
}

function pause_slide(e) {
	slider_pause = 1;
}
function resume_slide(e) {
	slider_pause = 0;
}

function animate_slider() {
	var dot_links = document.getElementsByName('dot_link');
	setTimeout( function() {
		if ( slider_pause == 0 ) {
			if ( selected_free_banner < (dot_links.length-1) ) {
				var next_banner = selected_free_banner+1;
			}
			else {
				var next_banner = 0;
			}
			dot_links[next_banner].click();
		}
		animate_slider();
	}, slider_interval_ms);
}


</script>

