                <span class="storeheader">
                    Επίλεξε κατάστημα παραλαβής
                </span>
                <button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button>
                <div id="storesSearch" class="callout nomargin" style="margin-top: 25px">
                    <div class="main-searharea">
                        <div class="input-group nomargin">
                            <input id="address" type="text" placeholder="Συμπλήρωσε τον ΤΚ" />
                            <div class="input-group-button">
                                <a class="button" onclick="CollectGeocodeAddress();"><i class="fa fa-search"></i></a>
                            </div>
                        </div>
                        <a id="btnUseCurrentLocation" class="button warning" onclick="CollectUseLocation();">
                            <img src="https://s3.praktiker.gr/images/current-location.png" /></a>
                    </div>
                    <span class="headline">ή επίλεξε ένα κατάστημα εξυπηρέτησης:</span>

                    <div class="droplocationlist">

                        <ul id="ddlCollectStores" class="custom-select-list" size="6" style="height: 180px; overflow-y: auto">
                        </ul>
                        <input type="hidden" id="hdnStoreId" />
                    </div>

                    <div class="text-center margin-top-1">
                        <a id="setCollectStore" class="button button-light expanded ">Συνέχεια</a>
                    </div>

                </div>
            </div>
        </form>
    </div>
    <div class="off-canvas position-right" id="offCanvasBasket" data-off-canvas>
    </div>
    <div class="reveal" id="custom-modal" data-reveal>
        <!-- Content will be loaded here from somwhere else, crazy! -->
    </div>
    
     <script src='/bundles/App?v=4aggCaQYkulY72TOSlU-h_7shUGkGyxlheOOXErh-081' async></script>

     <script src='/Scripts/navigation.js' async></script>

 
    <noscript id="deferred-styles">
    </noscript>
    <script>
        jQuery(document).ready(function () {
            jQuery('#storesSearch').insertBefore('div.resultsLeft');
        });
        var geocoder = undefined;
        function initMap() {
            geocoder = new google.maps.Geocoder;
        }
        function CollectGeocodeAddress(resultsMap) {
            var address = document.getElementById('address').value;
            geocoder.geocode({
                'address': address, componentRestrictions: { country: 'GR' }
            }, function (results, status) {

                if (status === google.maps.GeocoderStatus.OK) {
                    CollectGetDistances(results[0].geometry.location);
                } else {
                    alert('Geocode was not successful for the following reason: ' + status);
                }
            });
        }

    </script>
    <script async defer
        src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAjkwHbgjLpViO4mR38DmDOtX16VafFChI&callback=initMap">
    </script>
    <!-- Start Scripts Region -->
    <script type="text/javascript">
        jQuery(document).ready(function () {
            jQuery('ul#mainmenu').appendTo(jQuery('#navMenu'));
            jQuery('ul#servicesmenu').appendTo(jQuery('#navMenuServices'));
            if (jQuery('input[id$=txtNewsletter]').length > 0) {
                jQuery('input[id$=txtNewsletter]').focus(function () {
                    if (this.value == 'Εισάγετε το email σας') {
                        this.value = '';
                        this.style.color = '#000000';
                    }
                });
                jQuery('input[id$=txtNewsletter]').blur(function () {
                    if (this.value == '') {
                        this.value = 'Εισάγετε το email σας';
                        this.style.color = '#CCCCCC';
                    }
                });
            }
            jQuery('#aNewsletter').click(function () {
                var re = /^(([^<>()[\]\\.,;:\s@\"]+(\.[^<>()[\]\\.,;:\s@\"]+)*)|(\".+\"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
                if (re.test(jQuery('#txtNewsletter').val())) {
                    try { fbq('track', 'CompleteRegistration'); } catch (err) { }
                    jQuery.ajax({
                        type: "POST",
                        url: 'https://www.praktiker.gr/Ajax.aspx?action=InsertNewsletterUser&email=' + escape(jQuery('#txtNewsletter').val()),
                        contentType: "application/json; charset=utf-8",
                        dataType: "json",
                        success: function (msg) {
                            if (msg == "0") {
                                jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button><div class="appmessage appmessage__success"><h5> Επιτυχής εγγραφή </h5><p>Ευχαριστούμε για την εγγραφή σας</p></div></div>').foundation('open');
                                jQuery('#txtNewsletter').val('');
                            }
                            else if (msg == "-1") {
                                jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button><div class="appmessage"><h5> Προσοχή  </h5><p>Είστε ήδη εγγεγραμμένος.</p></div></div>').foundation('open');
                            }
                            else if (msg == "-2") {
                                jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button><div class="appmessage"><h5> Προσοχή  </h5><p>Το e-mail δεν μπορεί να είναι κενό.</p></div></div>').foundation('open');
                            }
                            else if (msg == "-10") {
                                jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button><div class="appmessage"><h5> Προσοχή  </h5><p>Το E-mail δεν είναι έγκυρo. (π.χ. username@domain.gr)</p></div></div>').foundation('open');
                            }
                            else {
                                jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button><div class="appmessage"><h5> Προσοχή  </h5><p>Η εγγραφή σας απέτυχε. Παρακαλώ προσπαθήστε αργότερα.</p></div></div>').foundation('open');
                            }
                        }
                    });
                }
                else {
                    jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close-modal"></span></button><div class="appmessage"><h5> Προσοχή  </h5><p>Το E-mail δεν είναι έγκυρo. (π.χ. username@domain.gr)</p></div></div>').foundation('open');
                }
            });
        });
    </script>
    <script type="text/javascript">     
        /*Add a script element as a child of the body function*/
        //Defer load css
        function loadCSS(e, t, n) { "use strict"; var i = window.document.createElement("link"); var o = t || window.document.getElementsByTagName("script")[0]; i.rel = "stylesheet"; i.href = e; i.media = "only x"; o.parentNode.insertBefore(i, o); setTimeout(function () { i.media = n || "all" }) }
        //Defer load js
        /* Check for browser support of event handling capability*/
        if (window.addEventListener)
            window.addEventListener("load", downloadJSAtOnload, false);
        else if (window.attachEvent)
            window.attachEvent("onload", downloadJSAtOnload);
        else window.onload = downloadJSAtOnload;
        //load js inherinance
        var js, fjs = document.getElementsByTagName('script')[0];
        function addscript(url, id, async) {
            if (document.getElementById(id)) { return; }
            js = document.createElement('script');
            js.type = 'text/javascript';
            js.src = url;
            js.async = async;
            id && (js.id = id);
            fjs.parentNode.insertBefore(js, fjs);
        };
        function getScript(url, success) {
            var script = document.createElement('script');
            script.src = url;
            var head = document.getElementsByTagName('head')[0],
                done = false;
            script.onload = script.onreadystatechange = function () {
                if (!done && (!this.readyState || this.readyState == 'loaded' || this.readyState == 'complete')) {
                    done = true;
                    success();
                    script.onload = script.onreadystatechange = null;
                    head.removeChild(script);
                }
            };
            head.appendChild(script);
        }
        //Defer load Fonts
        WebFontConfig = {
            google: { families: ['Ubuntu:400,300,500,700:greek,latin', 'Roboto+Slab:100,300,400,700:greek'] }
        };
        (function () {
            var wf = document.createElement('script');
            wf.src = 'https://ajax.googleapis.com/ajax/libs/webfont/1/webfont.js';
            wf.type = 'text/javascript';
            wf.async = 'true';
            var s = document.getElementsByTagName('script')[0];
            s.parentNode.insertBefore(wf, s);
        })();
        //Load Css
        //start loadinng JS
        function downloadJSAtOnload() {
            jQuery(document).foundation();
            // new TypeWriter('#txtProductQuickSearch', ['Ψάχνω για ...'], { writeDelay: 200 });

            if (jQuery("#hdnCanRelate").val() == '1') {
                confirmModal(
                    'myPraktiker',
                    'Θέλεις να συσχετίσεις τον myPraktiker λογαριασμό σου με αυτόν του e-shop;',
                    'Ναι',
                    'Όχι',
                    function () {
                        
                        jQuery.ajax({
                            type: "POST",
                            url: '/Ajax.aspx?action=RelateUserLoyalty',
                            contentType: "application/json; charset=utf-8",
                            dataType: "json",
                            success: function (msg) {
                                if (msg.Error == '0') {
                                    location.href = location.href;
                                }
                                else {
                                    jQuery('#modal').removeClass("loading");
                                    jQueryModal.html('<div class=\"padding-2\"><button class="close-button" data-close="" aria-label="Close reveal" type="button"><span class="icon fa-close"></span></button><div class="basketMessage"><h5> Προσοχή  </h5><p>' + msg.Error + '</p></div></div>').foundation('open');
                                }
                            }
                        });
                    });
            }

            jQuery(".btnCloseModal").on('click', function (e) {
                e.preventDefault();
                jQuery.ajax({
                    type: "POST",
                    url: '/Ajax.aspx?action=RejectRelation',
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (msg) {
                        
                    }
                });
            });

            if (typeof downloadJS == 'function') { downloadJS(); }
        }
        loadCSS("https://cdn.myfontastic.com/MeZQNJN2RFAG3b4rbYd9RS/icons.css");
        loadCSS('/style/cfonts.css');

        if (EU.Cookie.canUseTargeting()) {
            var s = document.createElement('script');
            s.src = 'https://static.adman.gr/adman.js';
            document.head.appendChild(s);
            var AdmanQueue = AdmanQueue || [];
            AdmanQueue.push(function () {
				

                Adman.ws({
                    ws: 308,
                    s: '100x100',
                    h: 'greca.adman.gr',
                    elementId: 'grecaholder' // div id where the banner will be injected
                });
                Adman.ws({
                    ws: 23263,
                    s: '100x100',
                    h: 'greca.adman.gr',
                    elementId: 'grecaholder' // div id where the banner will be injected
                });
				

            });
        }
    </script>
    
