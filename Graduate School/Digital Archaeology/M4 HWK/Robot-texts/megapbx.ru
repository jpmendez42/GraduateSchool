n-box gtm-title-description-box"><div class="mfui-grid"><div data-testid="TitleDescriptionBox-grid" class="mfui-grid__container mfui-grid__container_multi-row"><div class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><h2 class="mfui-header mfui-header_color_inherit mfui-header_level_h2 mfui-header_h-align_inherit mfui-title-description-box__item mfui-title-description-box__item_header">Полезные материалы</h2></div></div></div></div><div class="mfui-blog-box"><div class="mfui-blog-box__list"><div class="mfui-blog-box__item mfui-blog-box__item_view_full"><a class="mfui-blog-box-tile mfui-blog-box-tile_view_full" href="https://tech.megafon.ru/information/5-poleznyx-funkcii-virtualnyx-ats" target="_blank" rel="noreferrer noopener"><picture class="mfui-blog-box-tile__picture"><source media="(min-width: 1024px)" srcSet="/corporate/upload/media/default/0001/07/vats/poleznyx1420x1116.jpg"/><img class="mfui-blog-box-tile__image" src="/corporate/upload/media/default/0001/07/vats/poleznyx1854x716.jpg" alt="image"/></picture><div class="mfui-blog-box-tile__content"><div class="mfui-blog-box-tile__date"> </div><div class="mfui-blog-box-tile__title">5 полезных функций виртуальных АТС</div></div></a></div><div class="mfui-blog-box__item mfui-blog-box__item_view_thumbnail"><a class="mfui-blog-box-tile mfui-blog-box-tile_view_thumbnail" href="https://tech.megafon.ru/information/vas-zvonok-ocen-vazen-dlia-nas-kak-ne-teriat-budushhix-klientov" target="_blank" rel="noreferrer noopener"><picture class="mfui-blog-box-tile__picture"><img class="mfui-blog-box-tile__image" src="/corporate/upload/media/default/0001/07/vats/vaszvonok446x340.jpg" alt="image"/></picture><div class="mfui-blog-box-tile__content"><div class="mfui-blog-box-tile__date"> </div><div class="mfui-blog-box-tile__title">«Ваш звонок очень важен для нас». Как не терять будущих клиентов</div></div></a></div><div class="mfui-blog-box__item mfui-blog-box__item_view_thumbnail"><a class="mfui-blog-box-tile mfui-blog-box-tile_view_thumbnail" href="https://tech.megafon.ru/information/kak-biznesu-prinimat-zvonki" target="_blank" rel="noreferrer noopener"><picture class="mfui-blog-box-tile__picture"><img class="mfui-blog-box-tile__image" src="/corporate/upload/media/default/0001/09/vats/vats_news7.png" alt="image"/></picture><div class="mfui-blog-box-tile__content"><div class="mfui-blog-box-tile__date"> </div><div class="mfui-blog-box-tile__title">Как бизнесу принимать звонки</div></div></a></div><div class="mfui-blog-box__item mfui-blog-box__item_view_thumbnail"><a class="mfui-blog-box-tile mfui-blog-box-tile_view_thumbnail" href="https://tech.megafon.ru/information/kak-biznesu-uvelicit-prodazi" target="_blank" rel="noreferrer noopener"><picture class="mfui-blog-box-tile__picture"><img class="mfui-blog-box-tile__image" src="/corporate/upload/media/default/0001/07/vats/prodazhi446x340.jpg" alt="image"/></picture><div class="mfui-blog-box-tile__content"><div class="mfui-blog-box-tile__date"> </div><div class="mfui-blog-box-tile__title">Онлайн: как бизнесу увеличить продажи</div></div></a></div></div><div class="mfui-blog-box__button-wrapper"><a class="mfui-button mfui-button_type_primary mfui-button_theme_green mfui-button_size-all_medium mfui-button_no-touch mfui-button_content-type_text mfui-blog-box__button" href="https://tech.megafon.ru/information/all/technology" target="_blank" rel="noreferrer noopener"><div class="mfui-button__inner"><div class="mfui-button__content"><span class="mfui-button__text">Перейти в блог</span></div></div></a></div></div></div></div></div></div><div class="mfui-container mfui-container_bg-color_default gtm-constructor-container" id="faq"><div class="mfui-container__inner mfui-container__inner_prevent gtm-constructor-container"><div class="mfui-content-area mfui-content-area_background-color_transparent"><div class="mfui-content-area__inner mfui-content-area__inner_background-color_transparent"><div data-gtm-title="Вопросы и ответы" class="mfui-title-description-box gtm-title-description-box"><div class="mfui-grid"><div data-testid="TitleDescriptionBox-grid" class="mfui-grid__container mfui-grid__container_multi-row"><div class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><h2 class="mfui-header mfui-header_color_inherit mfui-header_level_h2 mfui-header_h-align_inherit mfui-title-description-box__item mfui-title-description-box__item_header">Вопросы и ответы</h2></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Изменения в законе с 1 сентября" class="mfui-accordion mfui-accordion_opened gtm-accordion-box gtm-accordion-box-open"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Изменения в законе с 1 сентября</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Исходящие вызовы по этой услуге относятся к массовым и (или) автоматическим и согласно закону № 41-ФЗ от 1 апреля 2025 года должны выполняться по договору об оказании услуги по осуществлению массовых и (или) автоматических вызовов.</p>

<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Ознакомьтесь с <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://moscow.megafon.ru/corporate/massovye_vyzovy">условия␀ми</a> услуги.</p></div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Сколько стоят звонки?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Сколько стоят звонки?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Исходящие звонки облачной АТС оплачиваются по условиям тарифа подключённой сим‑карты.</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin"><b>Тарифы на звонки с SIP‑устройств</b></p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Тарифы при звонках с <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://help.megapbx.ru/sip_phones" target="_blank">SIP‑телефонов</a> или <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://help.megapbx.ru/softphone" target="_blank">софтфонов</a>:</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Исходящие звонки с SIP‑устройств на:</p>
<div class="mfui-list mfui-list_color_default mfui-list_weight_regular"><ul class="mfui-list__inner mfui-list__inner_type_ul">
<li class="mfui-list-item"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">мобильные номера России</p><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin"></p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">1,9 ₽ за минуту</p></li>
<li class="mfui-list-item"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">городские номера Москвы, Санкт‑Петербурга и Центрального федерального округа</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">1 ₽ за минуту</p></li>
<li class="mfui-list-item"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">на городские номера Северо‑Западного, Южного, Северо‑Кавказского, Приволжского и Уральских федеральных округов</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">1,6 ₽ за мину␀ту</p></li>
<li class="mfui-list-item"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">на городские номера Сибирского и Дальневосточного федеральных округов</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">1,9 ₽ за минуту</p></li>
</ul></div>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Плата по IP‑телефонии списывается с номера, который подставляется при исходящем звонке. Настроить подстановку номера можно в разделе <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://help.megapbx.ru/aone" target="_blank">«Исходящие номера»</a>.</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin"><a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://help.megapbx.ru/outgoing_gsm" target="_blank">Подробнее о тарифах на звонки в Виртуальной АТС</a>.</p></div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Как подключить городские и номера 8‑800?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Как подключить городские и номера 8‑800?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Чтобы подключить городской номер к облачной АТС, на <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://www.megafon.ru/corporate/city_number">странице</a> нажмите кнопку «Оставить заявку» и заполните форму.</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Или <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://8800.megafon.ru/" target="_blank">подключите бесплатный номер 8‑800</a>.</p>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">А также к облачной АТС можно подключить к МегаФону <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="http://vats.megafon.ru/help/sip_nomera" target="_blank">городские номера других операторов</a> или <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://www.megafon.ru/corporate/mnp/">перенести в МегаФон</a> мобильные номера других операторов.</p></div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Могут ли несколько сотрудников звонить с одного номера?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Могут ли несколько сотрудников звонить с одного номера?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Да, в рамках услуги облачной АТС ваши сотрудники м␀огут звонить с одного номера, в том числе с городского или 8‑800.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Нужно ли менять сим‑карту для подключения к Виртуальной АТС?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Нужно ли менять сим‑карту для подключения к Виртуальной АТС?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Нет, можно <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://wizard.megapbx.ru/" target="_blank">подключить</a> любой номер МегаФона. Если у вас номер другого оператора, вы можете перейти в МегаФон со своим номером.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Я могу подключить к Виртуальной АТС сим‑карту физического лица?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Я могу подключить к Виртуальной АТС сим‑карту физического лица?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Да, вы можете использовать обычную сим‑карту, но услуга «Виртуальная АТС» может быть оформлена только на юридическое лицо. Поэтому будет нужна хотя бы одна корпоративная сим‑карта.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Чем отличается Виртуальная АТС от обычной?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Чем отличается Виртуальная АТС от обычной?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Виртуальная АТС или IP‑телефония — это звонки через интернет.</p>

<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Чтобы пользоваться Виртуальной АТС, не нужно дорогое оборудование со специальным техническим обслуживанием, в отличие от обычной АТС.</p>

<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Подключение к звонку через Виртуальную АТС происходит через специальную программу или шлюзы — устройства, похожие на роутер.</p></div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Как настроить Виртуальную АТС?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Как настроить Виртуальную АТС?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Для настройки Виртуальной IP‑АТС ознакомьтесь с <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://vats.megafon.ru/first" target="_blank">нашей инструкцией</a>.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Сколько хранятся записи разговоров внутри облачной АТС?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Сколько хранятся записи разговоров внутри облачной АТС?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">От 1 года до 10 лет.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Как настроить переадресацию звонков?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Как настроить переадресацию звонков?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Для настройки переадресации звонков IP‑телефонии ознакомьтесь с <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://vats.megafon.ru/sip_nomera" target="_blank">нашей инструкцией</a>.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Сколько стоит интеграция IP‑телефонии с CRM‑системой?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Сколько стоит интеграция IP‑␀телефонии с CRM‑системой?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Стоимость интеграции для услуг облачной АТС — от 1 000 ₽ в месяц.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Какое оборудование нужно для звонков через Виртуальную АТС?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Какое оборудование нужно для звонков через Виртуальную АТС?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Можно использовать:</p>
<div class="mfui-list mfui-list_color_default mfui-list_weight_regular"><ul class="mfui-list__inner mfui-list__inner_type_ul">
<li class="mfui-list-item">Стационарный IP‑телефон — оптимальное решение для офисных сотрудников.</li>
<li class="mfui-list-item">Гарнитура — наушники и микрофон в одном устройстве, можно использовать для звонков с компьютера.</li>
<li class="mfui-list-item">Мобильный телефон — для разъездных сотрудников, например, менеджеров по привлечению клиентов или курьеров. Можно звонить через Виртуальную АТС в любом месте, где есть доступ к интернету.</li>
</ul></div></div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Поддержка услуги «Виртуальная АТС»" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Поддержка услуги «Виртуальная АТС»</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content"><p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Если нужна помощь по настройке Виртуальной АТС:</p>
<div class="mfui-list mfui-list_color_default mfui-list_weight_regular"><ul class="mfui-list__inner mfui-list__inner_type_ul">
<li class="mfui-list-item">позвоните на <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="tel:88005502287">8 800 550‑22‑87</a> или закажите обратный звонок из личного кабинета Виртуальной АТС;</li>
<li class="mfui-list-item"> напишите на <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="mailto:vats@megafon.ru">vats@megafon.ru</a>.</li>
</ul></div>
<p class="mfui-paragraph mfui-paragraph_color_default mfui-paragraph_space_wide mfui-paragraph_has-margin">Менеджер ответит вам с понедельника по пятницу с 07:00 до 18:00 мск.</p></div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Кто может участвовать в акции «Бизнес уровня 800»?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Кто может участвовать в акции «Бизнес уровня 800»?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Индивидуальные предприниматели и юридические лица, которые раньше не пользовались номером 8‑800.</div></div></div></div></div></div></div></div></div><div class="mfui-accordion-box"><div class="mfui-grid"><div data-testid="AccordionBox-container" class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_h-align_left"><div data-testid="AccordionBox-column" class="mfui-grid-column mfui-grid-column_all_12 mfui-grid-column_wide_8 mfui-grid-column_desktop_10 mfui-grid-column_tablet_12 mfui-grid-column_mobile_12 mfui-grid-column_all-order_0 mfui-grid-column_wide-order_0 mfui-grid-column_desktop-order_0 mfui-grid-column_tablet-order_0 mfui-grid-column_mobile-order_0 mfui-grid__column"><div data-gtm-accordion-title="Как участвовать в акции «Бизнес уровня 800»?" class="mfui-accordion gtm-accordion-box"><div class="mfui-accordion__title-wrap gtm-accordion-box-title" tabindex="0" role="button"><h3 class="mfui-header mfui-header_color_default mfui-header_level_h5 mfui-header_h-align_inherit mfui-header_space_wide">Как участвовать в акции «Бизнес уровня 800»?</h3><div class="mfui-accordion__icon-box"><svg viewBox="0 0 32 32" class="mfui-accordion__icon"><path d="M11 14h10l-5 6z" fill-rule="evenodd" clip-rule="evenodd"></path></svg></div></div><div class="mfui-collapse mfui-accordion__content" style="height:0px"><div class="mfui-accordion__content-inner"><div class="mfui-text-box"><div class="mfui-text-box__content">Подключите на сайте <a class="mfui-text-link mfui-text-link_underline-visibility_hover mfui-text-link_underline-style_solid mfui-text-link_color_blue gtm-text-box-link" href="https://8800.megafon.ru/" target="_blank">номер 8‑800</a> и одну из услуг на выбор: Виртуальную АТС, Корпоративную АТС или Голосовой робот. Получите скидку 20% на абонентскую плату за номер 8‑800 и на пакеты минут для него.</div></div></div></div></div></div></div></div></div></div></div></div></div><div class="mfui-container mfui-container_bg-color_default gtm-constructor-container"><div class="mfui-container__inner mfui-container__inner_prevent gtm-constructor-container"><div class="mfui-content-area mfui-content-area_background-color_transparent"><div class="mfui-content-area__inner mfui-content-area__inner_background-color_transparent"><div class="mfui-download-links mfui-download-links_count_7"><div class="mfui-grid"><div class="mfui-grid__container mfui-grid__container_multi-row mfui-grid__container_gutters-left_medi