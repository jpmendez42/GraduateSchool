"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":8775,\"filename\":\"LIME-1080x324.jpg\",\"url\":\"/cms/media/LIME-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":19205,\"filename\":\"LIME-1920x576.jpg\",\"url\":\"/cms/media/LIME-1920x576.jpg\"},\"w3840\":{\"width\":3840,\"height\":1152,\"mimeType\":\"image/jpeg\",\"filesize\":58884,\"filename\":\"LIME-3840x1152.jpg\",\"url\":\"/cms/media/LIME-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:37:23.837Z\",\"updatedAt\":\"2025-08-29T10:51:22.371Z\",\"url\":\"/cms/media/LIME.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\"],\"isLanding\":{}},{\"id\":\"6578db3f7929e66c401c8baa\",\"name\":\"ZARINA\",\"description\":\"\",\"category\":[\"men\",\"women\",\"accessories\",\"children\",\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T22:14:23.298Z\",\"updatedAt\":\"2025-03-04T03:06:57.708Z\",\"logo\":{\"id\":\"65802cb7e2f304ddab7c2363\",\"alt\":\"logo\",\"filename\":\"ZARINA.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":13307,\"width\":450,\"height\":135,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/jpeg\",\"filesize\":427,\"filename\":\"ZARINA-32x9.jpg\",\"url\":\"/cms/media/ZARINA-32x9.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":782,\"filename\":\"ZARINA-64x19.jpg\",\"url\":\"/cms/media/ZARINA-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":38,\"mimeType\":\"image/jpeg\",\"filesize\":1758,\"filename\":\"ZARINA-128x38.jpg\",\"url\":\"/cms/media/ZARINA-128x38.jpg\"},\"w384\":{\"width\":384,\"height\":115,\"mimeType\":\"image/jpeg\",\"filesize\":7714,\"filename\":\"ZARINA-384x115.jpg\",\"url\":\"/cms/media/ZARINA-384x115.jpg\"},\"w640\":{\"width\":640,\"height\":192,\"mimeType\":\"image/jpeg\",\"filesize\":13352,\"filename\":\"ZARINA-640x192.jpg\",\"url\":\"/cms/media/ZARINA-640x192.jpg\"},\"w1080\":{\"width\":1080,\"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":24786,\"filename\":\"ZARINA-1080x324.jpg\",\"url\":\"/cms/media/ZARINA-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":49980,\"filename\":\"ZARINA-1920x576.jpg\",\"url\":\"/cms/media/ZARINA-1920x576.jpg\"},\"w3840\":{\"width\":3840,\"height\":1152,\"mimeType\":\"image/jpeg\",\"filesize\":131321,\"filename\":\"ZARINA-3840x1152.jpg\",\"url\":\"/cms/media/ZARINA-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:27:51.311Z\",\"updatedAt\":\"2025-08-29T10:51:28.408Z\",\"url\":\"/cms/media/ZARINA.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d91f7929e66c401c804f\",\"name\":\"CAVALLI CLASS\",\"description\":\"В линии Cavalli Class, характеризующейся универсальной элегантностью на каждый день, знаковый, впечатляющий и смелый дизайн Roberto Cavalli предстает в более благородном и изысканном воплощении. Утонченные силуэты, первоклассные ткани и практичные детали являются неотъемлемыми элементами богатого и разнообразного гардероба. Элегантные и удобные модели этой линии украшены культовыми элементами наследия Cavalli. Это лучший бренд для женщин и мужчин, которые не отказываются от стиля даже в окружении повседневных забот.\",\"category\":[\"men\",\"women\",\"accessories\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T22:05:19.709Z\",\"updatedAt\":\"2025-03-05T14:29:41.070Z\",\"logo\":{\"id\":\"65802868e2f304ddab7c04ac\",\"alt\":\"logo\",\"filename\":\"CAVALLI CLASS.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":11259,\"width\":450,\"height\":135,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/jpeg\",\"filesize\":426,\"filename\":\"CAVALLI CLASS-32x9.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-32x9.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":859,\"filename\":\"CAVALLI CLASS-64x19.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":38,\"mimeType\":\"image/jpeg\",\"filesize\":1739,\"filename\":\"CAVALLI CLASS-128x38.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-128x38.jpg\"},\"w384\":{\"width\":384,\"height\":115,\"mimeType\":\"image/jpeg\",\"filesize\":6831,\"filename\":\"CAVALLI CLASS-384x115.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-384x115.jpg\"},\"w640\":{\"width\":640,\"height\":192,\"mimeType\":\"image/jpeg\",\"filesize\":11825,\"filename\":\"CAVALLI CLASS-640x192.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-640x192.jpg\"},\"w1080\":{\"width\":1080,\"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":23398,\"filename\":\"CAVALLI CLASS-1080x324.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":49563,\"filename\":\"CAVALLI CLASS-1920x576.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-1920x576.jpg\"},\"w3840\":{\"width\":3840,\"height\":1152,\"mimeType\":\"image/jpeg\",\"filesize\":133847,\"filename\":\"CAVALLI CLASS-3840x1152.jpg\",\"url\":\"/cms/media/CAVALLI CLASS-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:09:28.416Z\",\"updatedAt\":\"2025-08-29T10:51:32.233Z\",\"url\":\"/cms/media/CAVALLI CLASS.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\"],\"isLanding\":{}},{\"id\":\"6578d91e7929e66c401c8047\",\"name\":\"CLARKS\",\"description\":\"Британский бренд Clarks появился в 1825 году. Компания была основана 1825 году в Англии братьями Сайрусом и Джеймсом Кларксами. Семейный бизнес вырос до международной сети из 2000 магазинов в 150 странах мира. Модели обуви Clarks создают в Центре технологий и дизайна. Особое внимание Clarks уделяет удобству обуви. Сегодня каждый опытный образец проходит 50 этапов тестирования, прежде чем пускается в производство.\",\"category\":[\"men\",\"women\",\"for_home\",\"children\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":true,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T22:05:18.084Z\",\"updatedAt\":\"2025-03-04T03:14:02.580Z\",\"logo\":{\"id\":\"658028bde2f304ddab7c052c\",\"alt\":\"logo\",\"filename\":\"Clarks.png\",\"mimeType\":\"image/png\",\"filesize\":82049,\"width\":2560,\"height\":686,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/Clarks-480x320.png\",\"width\":480,\"height\":320,\"mimeType\":\"image/png\",\"filesize\":29716,\"filename\":\"Clarks-480x320.png\"},\"portrait\":{\"url\":\"/cms/media/Clarks-768x1024.png\",\"width\":768,\"height\":1024,\"mimeType\":\"image/png\",\"filesize\":59078,\"filename\":\"Clarks-768x1024.png\"},\"hero\":{\"url\":\"/cms/media/Clarks-1920x1080.png\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/png\",\"filesize\":159159,\"filename\":\"Clarks-1920x1080.png\"},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/png\",\"filesize\":653,\"filename\":\"Clarks-32x9.png\",\"url\":\"/cms/media/Clarks-32x9.png\"},\"w64\":{\"width\":64,\"height\":17,\"mimeType\":\"image/png\",\"filesize\":1606,\"filename\":\"Clarks-64x17.png\",\"url\":\"/cms/media/Clarks-64x17.png\"},\"w128\":{\"width