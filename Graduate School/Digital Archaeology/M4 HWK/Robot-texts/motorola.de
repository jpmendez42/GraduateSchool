        <div    level="1"  width="100px" height="100px" _id="6b430fc8m1f09-4d18-b961-55fbd276d5c2" style="width:100%;" order='1' class="layoutBox-sm slot_cls6b430fc8m1f09-4d18-b961-55fbd276d5c2 cms_currency_layout  " tplConfig dischargeComponent floorname=""><div  compid='9c44c368-1b7f-4435-b889-ee8413831dbc' id="6b003861mc534-444d-ab12-ef2a5333a98e" type="3" tag="component" componentName="ofp-fe-moto-home-gridLayout-v2"><div class="app"><div><section class="gridLayoulSectionWrapper" style="background:#ffffff;color:;padding:;" data-v-9e540574><section class="gridLayoulSection" data-v-9e540574><div class="grid1" data-v-9e540574><!--[--><div class="allWrapperDiv" data-v-9e540574><a class="imgClass" href="https://www.motorola.com/de/de/family/moto-edge" data-category="" data-label data-event="Homepage" data-action="/family/moto-edge" style="border-radius:0px;" data-v-9e540574><img src="//p3-ofp.static.pub//fes/cms/2025/07/09/u1u68pe178j29qvz1kqwtpaw69sw63706316.jpg" alt="" style="border-radius:0px;" data-v-9e540574><!----></a><div class="displayItems" style="" data-v-9e540574><div class="textWrap" data-v-9e540574><img class="content-logo" alt="" style="object-fit:contain;" data-v-9e540574><div class="title" style="color:#ffffff;" data-v-9e540574><p style="text-align: center;">FINDEN SIE IHREN VORTEIL</p><p><script>function hideLearnMoreButtons(retries = 10) {
  if (window.location.pathname.includes('/affiliates/')) {
    const buttons = document.querySelectorAll('div.recommend_cta_btn.learnmore_CTA');
    if (buttons.length > 0) {
      buttons.forEach(btn => {
        btn.style.display = 'none';
      });
      console.log(buttons.length + ' Learn More buttons hidden');
    } else if (retries > 0) {
      // Retry after 500ms
      setTimeout(() => hideLearnMoreButtons(retries - 1), 500);
    } else {
      console.log('Learn More buttons not found after retries');
    }
  } else {
    console.log('This is not an affiliates page');
  }
}

        hideLearnMoreButtons();</script><style>.energy_rating img {
