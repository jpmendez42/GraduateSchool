    function set_block_30461(i){
        $(".it902-item-content_30461").children(".it902-tab-pdbox").hide();
        $("#it902-content30461_"+i).show();
        var now = new Date();
        var s_datetime,e_datetime,set_date,dword;
        s_datetime = new Date($("#it902-stime30461_"+i).val());
        e_datetime = new Date($("#it902-etime30461_"+i).val());

        if(now<s_datetime){
            set_date=s_datetime;
            $("#dword_30461").text('距離活動開始 ');
        } else {
            set_date=e_datetime;
            $("#dword_30461").text('距離結束 ');
        }

        /*countdown 要搭配jquery.countdown.min.js*/
        if(set_date!==undefined){
            $('#it902_countdown_30461').countdown(set_date, function(event) {
                let Day = event.strftime("%D");
                let Hour = event.strftime("%H");
                let Minutes = event.strftime("%M");
                let Seconds = event.strftime("%S");

                Hour = (Day*24)+parseInt(Hour)
                let _html = "";
                _html += "<p id=\"dword_30461\">"+$("#dword_30461").text()+ " </p>";
                _html += "<span>" + Hour + "</span>：";
                _html += "<span>" + Minutes[0] + Minutes[1] + "</span>：";
                _html += "<span>" + Seconds[0] + Seconds[1] + "</span>";

                $(this).html(_html);
            });
        }

    }

    $(function(){
        if('3'>0){
            set_block_30461('1');
            let wpitem_30461_list = [];

            document.querySelectorAll(".iopen-mall-item-container[data-wpitem='30461'] .iopen-mall-item-content .it902-carousel-box").forEach(el => {
                observerForViewItemList.observe(el);
                let num = $(el).data('num');
                wpitem_30461_list.push(num);
            });

