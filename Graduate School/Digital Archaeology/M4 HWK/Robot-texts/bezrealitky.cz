0 010 5.195 25.81 25.81 0 013.045.645c.424-.993.659-2.09.659-3.243s-.235-2.25-.66-3.246zm-4.534.835l-.223.023c-1.947.18-3.946.172-5.889-.022a15.064 15.064 0 000 4.82 30.942 30.942 0 016.111 0c.233-1.434.257-2.9.07-4.341l-.07-.48zM12 3.75l-.124.006a1.386 1.386 0 00-1.065.69 14.406 14.406 0 00-1.55 3.668c1.81.17 3.67.17 5.479 0a14.4 14.4 0 00-1.55-3.668 1.388 1.388 0 00-1.066-.69L12 3.75zm2.795.483l.06.11a15.984 15.984 0 011.388 3.588c.895-.133 1.77-.31 2.612-.53a8.24 8.24 0 00-3.75-3.05l-.31-.118zm-5.59 0l-.088.032A8.246 8.246 0 005.144 7.4c.842.221 1.718.398 2.614.532a15.995 15.995 0 011.448-3.7z"></path></svg></span></span><label for="lang-switcher">Čeština</label></div><div class="LangSwitcher_langSwitcherSelect__qdK5d"><select id="lang-switcher"><option value="cs" selected="">🇨🇿<!-- --> <!-- -->Čeština</option><option value="en">🇬🇧<!-- --> <!-- -->English</option><option value="sk">🇸🇰<!-- --> <!-- -->Slovenčina</option></select></div></div></span></div></div></div></div></div></footer><div class="toast-container bottom-0 end-0 position-fixed"></div></div><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"apolloCache":{"SimpleImage:{\"url\":\"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/185/1717162754_jak%20vybrat%20zahradn%C3%AD%20n%C3%A1bytek.png\"}":{"__typename":"SimpleImage","url":"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/185/1717162754_jak%20vybrat%20zahradn%C3%AD%20n%C3%A1bytek.png","size":{"__typename":"Size","width":1500,"height":600},"text":null},"BlogArticle:187":{"__typename":"BlogArticle","id":"187","title({\"locale\":\"CS\"})":"Jak vybrat perfektní zahradní nábytek","perex({\"locale\":\"CS\"})":"Ráno snídaně na zahradě, zatímco se příroda probouzí. Během dne homeoffice v křesílku s výhledem na stromy. Večer grilovačka a večeře s rodinou pod širým nebem. Abyste si tyto chvíle mohli užívat opravdu naplno, chce to kvalitní a komfortní zahradní nábytek. Jak ho vybrat s ohledem na vaše potřeby a prostor? Poradíme vám, co je při výběru zahradního nábytku důležité a jak si správně naplánovat jeho rozmístění.","slug({\"locale\":\"CS\"})":"jak-vybrat-zahradni-nabytek","mainImage({\"locale\":\"CS\"})":{"__ref":"SimpleImage:{\"url\":\"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/185/1717162754_jak%20vybrat%20zahradn%C3%AD%20n%C3%A1bytek.png\"}"}},"SimpleImage:{\"url\":\"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/184/1716980419_zahrada%20inspirace.png\"}":{"__typename":"SimpleImage","url":"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/184/1716980419_zahrada%20inspirace.png","size":{"__typename":"Size","width":1500,"height":600},"text":"Objevte inspiraci pro vaši zahradu"},"BlogArticle:186":{"__typename":"BlogArticle","id":"186","title({\"locale\":\"CS\"})":"9 inspirací a tipů pro krásnou zahradu","perex({\"locale\":\"CS\"})":"Dali jste si letos za cíl vylepšit nebo úplně proměnit vaši zahradu? Právě teď, když je konečně hezky, je nejvyšší čas. Připravili jsme pro vás inspiraci v podobě 9 tipů, jak na krásnější zahradu od malých změn po velké úpravy.","slug({\"locale\":\"CS\"})":"zahrada-inspirace","mainImage({\"locale\":\"CS\"})":{"__ref":"SimpleImage:{\"url\":\"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/184/1716980419_zahrada%20inspirace.png\"}"}},"SimpleImage:{\"url\":\"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/183/1716817638_%C3%BAtuln%C3%BD%20balkon%20tipy.png\"}":{"__typename":"SimpleImage","url":"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/183/1716817638_%C3%BAtuln%C3%BD%20balkon%20tipy.png","size":{"__typename":"Size","width":1500,"height":600},"text":"Útulný balkon vytvoříte levně i na malém prostoru."},"BlogArticle:185":{"__typename":"BlogArticle","id":"185","title({\"locale\":\"CS\"})":"Praktické tipy pro útulný balkon a terasu","perex({\"locale\":\"CS\"})":"Všichni toužíme po útulném místě, kde si můžeme odpočinout a načerpat nové síly. Balkon nebo terasa může být právě tímto útočištěm, ať už žijete v rušném městě nebo na klidném venkově. Přeměnit tuto venkovní plochu na oázu klidu a pohody nemusí být složité ani nákladné. V tomto článku vám přinášíme inspiraci a praktické tipy, jak zútulnit balkon nebo terasu pomocí jednoduchých a efektivních kroků.","slug({\"locale\":\"CS\"})":"balkon-terasa-tipy","mainImage({\"locale\":\"CS\"})":{"__ref":"SimpleImage:{\"url\":\"https://api.bezrealitky.cz/media/cache/record_main_nowm/data/images/blog/article/183/1716817638_%C3%BAtuln%C3%BD%20balkon%20tipy.png\"}"}},"ROOT_QUERY":{"__typename":"Query","blogNewsArticleList({\"limit\":3,\"locale\":\"CS\"})":{"__typename":"BlogArticleList","list":[{"__ref":"BlogArticle:187"},{"__ref":"BlogArticle:186"},{"__ref":"BlogArticle:185"}],"totalCount":3},"package({\"uri\":\"sc_contract_complete\"})":{"__ref":"Package:22"},"package({\"uri\":\"advert_activate_complete_1_sale\"})":{"__ref":"Package:129"}},"Package:22":{"__typename":"Package","id":"22","uri":"sc_contract_complete","title({\"locale\":\"CS\"})":"Advokátní služby","titleShort({\"locale\":\"CS\"})":null,"price":11990,"discount":0,"currency":"CZK","intention":"PAY_SERVICE","locale":"CS","priority":0,"default":false,"keyFeatures({\"locale\":\"CS\"})":[{"__typename":"PackageKeyFeature","value":"Ano","key":"contract_create"},{"__typename":"PackageKeyFeature","value":"Ano","key":"contract_registry_request"},{"__typename":"PackageKeyFeature","value":"Ano","key":"contract_protocol"},{"__typename":"PackageKeyFeature","value":"Ano","key":"contract_future"},{"__typename":"PackageKeyFeature","value":"Ano","key":"contract_deposit"},{"__typename":"PackageKeyFeature","value":"60 minut","key":"contract_changes"},{"__typename":"PackageKeyFeature","value":"Ano","key":"contract_documentation"}],"logos({\"locale\":\"CS\"})":null},"Package:129"