<style>
.chat-widget {position:fixed;bottom:0;right:20px;z-index:99;}
.chat-widget__title {font-size: 16px;color: var(--pic-orange);}
.chat-widget .chat-widget__button {display:none;position:relative;width:100px;padding:10px 12px;background-color:#fff;border-radius:5px 5px 0 0;justify-content:center;align-items:center;box-shadow:0 2px 10px 0 rgba(0, 0, 0, 0.2);cursor:pointer;transition:all 0.1s ease;color:var(--pic-orange,#F37721);}
.chat-widget.chat-widget__clickable .chat-widget__button {display:flex;}

.chat-widget i {margin-right:5px;font-size:16px;}
.chat-widget .chat-widget__button--has-unread .chat-widget__badge {position:absolute;right:-2px;top:-4px;background-color:var(--pic-red,#ED2525);border-radius:50%;width:12px;height:12px;}
.chat-widget .chat-widget__container {position:absolute;bottom:0;right:0;width:640px;height:500px;background-color:var(--pic-neutral-0,#fff);border-radius:5px 5px 0 0;box-shadow:0 2px 10px 0 rgba(0, 0, 0, 0.2);display:flex;flex-direction:column;overflow:hidden;opacity:0;transform:translateY(20px);pointer-events:none;visibility:hidden;transition:opacity 0.1s ease, transform 0.1s ease, visibility 0.1s ease;}
.chat-widget .chat-widget__container--open {opacity:1;transform:translateY(0);pointer-events:auto;visibility:visible;}
.chat-widget .chat-widget__header {padding:8px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom: 1px solid #e5e7eb;}
.chat-widget .chat-widget__close {display:none;cursor:pointer;padding:8px;font-size: 20px;}
.chat-widget .chat-widget__container .chat-widget__content {width:100%;height:100%;}
.chat-widget .chat-widget__container .chat-widget__iframe {width:100%;height:100%;} 

.login-guidance {display:none;padding: 8px;height:100%;position: relative;}
.login-guidance__detail{
    height: 444px;
    display: flex;
    justify-content: center;
    align-items: center;
