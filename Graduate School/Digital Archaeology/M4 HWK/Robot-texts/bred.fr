ere-campagne-marque-mobile\"&gt;\n  &lt;a href=\"https://www.bred.fr/articles/bred-banque-populaire-et-vos-projets-se-realisent\"&gt;&lt;img src=\"https://bredfrmedia.blob.core.windows.net/media/assets/sarah_campagne_marque_mobile_3462efef6e.png\" alt=\"Le jour où vous avez arrêté de dire un jour. BRED Banque Populaire vous aide à concrétiser vos projets, de l'idée à sa réalisation\"&gt;&lt;/a&gt;\n  &lt;/div&gt;\n &lt;/section&gt;\u003C/code>\u003C/pre>","visibleInTransacMode":true,"bottomSpacing":false}},{"__component":"section.s-custom","s_custom":{"customText":"\u003Cpre>\u003Ccode class=\"language-html\">&lt;style&gt;\n.bred-home-main-title {\n            background: url('https://bredfrmedia.blob.core.windows.net/media/assets/bred_home_line_fb3ef3feee.png') center center repeat-x;\n            margin: 16px 0 0 0;\n        }\n        \n        .bred-home-h1{\n            width: 80%;\n            text-align: center;\n            background: rgba(255, 255, 255, 1);\n            margin: auto;\n        }\n\n        .bred-home-h1 h1{\n            font-family: 'Roboto', sans-serif !important;\n            font-size: 24px !important;\n            line-height: 32px;\n            font-weight: 300;\n            color: #999999;\n            padding: 0 !important;\n            margin: 0 !important;\n        }\n&lt;/style&gt;\n&lt;section class=\"bred-home-main-title\"&gt;\n&lt;div class=\"container\"&gt;\n&lt;div class=\"row\"&gt;\n&lt;div class=\"col-xs-12 col-sm-12 col-md-12 col-lg-12\"&gt;\n&lt;div class=\"bred-home-h1\"&gt;\n&lt;h1&gt;BRED Banque Populaire, banque coopérative ancrée dans ses territoires !&lt;/h1&gt;\n&lt;/div&gt;\n&lt;/div&gt;\n&lt;/div&gt;\n&lt;/div&gt;\n&lt;/section&gt;\u003C/code>\u003C/pre>","visibleInTransacMode":true,"bottomSpacing":false}},{"__component":"section.card-grid","card_grid":{"text":"\u003Ch2>Un accompagnement dédié à votre situation :\u003C/h2>","products":[],"card_infos":[],"card_shortcuts":[{"title":"Fonction publique","image":{"name":"illu-card-cible-casden.png","width":352,"height":248,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/illu_card_cible_casden_18607d5753.png"},"url":"/particuliers/fonction-publique"},{"title":"Étudiants","image":{"name":"illu-card-cible-etudiant.jpg","width":352,"height":248,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/illu_card_cible_etudiant_d89e10b641.jpg"},"url":"/particuliers/vos-projets/financer-etudes"},{"title":"Gestion privée","image":{"name":"banque-privee-entree-cibles.jpg","width":340,"height":182,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/banque_privee_entree_cibles_5262312484.jpg","alternativeText":""},"url":"/banqueprivee"}],"card_actions":[],"card_icons":[],"card_bes":[],"buttonPlacement":"right","visibleInTransacMode":true,"gridType":"list","iconTexts":[],"backgroundColor":"#ffffff","bottomSpacing":false}},{"__component":"section.s-custom","tab_or_ancre_id":"0","s_custom":{"customText":"\u003Cpre>\u003Ccode class=\"language-html\">&lt;style&gt;\n.divider-48-fix {\ndisplay:block;\nheight:48px;\n}\n&lt;/style&gt;\n&lt;div class=\"divider-48-fix\"&gt;&lt;/div&gt;\u003C/code>\u003C/pre>","visibleInTransacMode":true,"bottomSpacing":false}},{"__component":"section.s-custom","s_custom":{"customText":"\u003Cpre>\u003Ccode class=\"language-html\"> &lt;style&gt;\n\n        .divider-24 {\n            height: 24px;\n        }\n\n        .divider-40 {\n            height: 40px;\n        }\n\n        .agk2025-header {\n            font-family: 'Roboto', sans-serif;\n            background: linear-gradient(145deg, rgba(64, 102, 142, 1) 0%, rgba(0, 72, 115, 1) 100%);\n            height: auto;\n            padding: 48px 0 48px 0;\n        }\n        \n        \n        .agk2025-header-mentions {\n            font-size: 20px;\n            font-weight: 500;\n            line-height: 28px;\n            color: #ffffff;\n            padding: 0 0 24px 0;\n        }\n\n        .agk2025-header-h1 {\n            font-size: 40px;\n            line-height: 48px;\n            font-weight: 700;\n            color: #ffffff;\n        }\n\n        .agk2025-header-accroche {\n            font-size: 24px;\n            line-height: 32px;\n            font-weight: 500;\n            color: #ffffff;\n        }\n\n        a.btn-regular-new {\n            font-family: 'Roboto', sans-serif;\n            font-size: 24px;\n            line-height: 32px;\n            color: #3e6bac;\n            background: #ffffff;\n            border: 1px solid #ffffff;\n            border-radius: 4px;\n            display: inline-block;\n            padding: 8px 16px 8px 16px;\n            margin: 0;\n            text-align: center;\n            text-decoration: none !important;\n            width: 300px;\n            font-weight: 500;\n        }\n\n        a.btn-regular-new:hover {\n            color: #ffffff;\n            background: #3e6bac;\n            text-decoration: none;\n            border: 1px solid #3e6bac;\n        }\n        \n        \n        .agk2025-content-mentions {\n            font-size: 14px;\n            line-height: 22px;\n            text-align: justify;\n            color: #ffffff;\n        }\n\n        /*** MEDIAS QUERIES ***/\n\n        @media (max-width: 1400px) {}\n\n        @media (max-width: 1200px) {}\n\n        @media (max-width: 992px) {}\n\n        @media (max-width: 768px) {}\n\n        @media (max-width: 576px) {}\n    &lt;/style&gt;\n    &lt;!-- HERO --&gt;\n    &lt;section class=\"agk2025-header\"&gt;\n        &lt;div class=\"container\"&gt;\n            &lt;div class=\"row\"&gt;\n                &lt;div class=\"col\"&gt;\n                    &lt;div class=\"agk2025-header-mentions\"&gt;Information à caractère promotionnel&lt;/div&gt;\n                    &lt;div class=\"agk2025-header-h1\"&gt;Devenez client sociétaire de la BRED Banque Populaire&amp;nbsp;!&lt;/div&gt;\n                    &lt;div class=\"agk2025-header-accroche\"&gt;Souscrivez à l’augmentation de capital du 22 septembre au 6 décembre 2025&lt;/div&gt;\n                    &lt;div class=\"divider-24\"&gt;&lt;/div&gt;\n                    &lt;a class=\"btn-regular-new\" href=\"/augmentation-de-capital-2025\" role=\"button\" aria-label=\"Je souscris à l'augmentation de capital\"&gt;Je souscris&lt;/a&gt;\n                    &lt;div class=\"divider-40\"&gt;&lt;/div&gt;\n                    &lt;div class=\"agk2025-content-mentions\"&gt;Le prospectus approuvé sous le numéro 25-359 par l'Autorité des marchés financiers (AMF) en date du 2 septembre 2025 est disponible, sans frais, au siège social de la BRED Banque Populaire et sur les sites internet de la BRED et de l’AMF. &lt;b&gt;L’attention des investisseurs est attirée sur la rubrique « Facteurs de risques » contenue dans le prospectus et notamment sur le risque de perte en capital&lt;/b&gt;.&lt;/div&gt;\n                &lt;/div&gt;\n            &lt;/div&gt;\n        &lt;/div&gt;\n    &lt;/section&gt;\u003C/code>\u003C/pre>","visibleInTransacMode":true,"bottomSpacing":false}},{"__component":"section.grid-doc","grid_doc":{"richText":"\u003Ch2>Découvrez des services pour tous vos besoins :\u003C/h2>","sidebar":{"category_tiles":[{"title":"Comptes et cartes","sub_category_tiles":[],"button":{"text":"Découvrez toutes nos offres Comptes et cartes","style":"primary","url":"/particuliers/compte-bancaire","linkType":"internal"},"files_and_faqs":[],"card_infos":[{"title":"Pilotez votre carte bancaire en toute autonomie !","description":"\u003Cp>\u003Cspan style=\"font-size:14px;\">Avec BREDConnect, découvrez les fonctionnalités qui vous facilitent la vie.\u003C/span>\u003C/p>","image":{"name":"card-guide-carte-bancaire.jpg","width":724,"height":483,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_guide_carte_bancaire_2d156a98b0.jpg","alternativeText":"card-guide-carte-bancaire.jpg"},"buttons":[],"tags":[],"links":[],"url":"/guides/guide-cartes-bancaires","isBarVisible":false,"orientation":"vertical"},{"title":"Gestion de compte sur internet","description":"\u003Cp style=\"margin-left:0px;\">Avec BREDConnect, consultez vos comptes en ligne et gérez vos opérations en toute sécurité.\u003C/p>","image":{"name":"card-solution-bredconnect-gris.jpg","width":350,"height":192,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_bredconnect_gris_df04e25506.jpg","alternativeText":"Solution BREDConnect"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/compte-bancaire/comptes-en-ligne/bredconnect-compte-ligne","isBarVisible":false,"orientation":"vertical"},{"title":"Vous êtes salarié de la Fonction Publique ?","description":"\u003Cp>Découvrez les avantages qui vous sont réservés avec la CASDEN !\u003C/p>","image":{"name":"card-solution-casden.jpg","width":803,"height":434,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_casden_8a8f596bd8.jpg","alternativeText":"Image"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/fonction-publique","isBarVisible":false,"orientation":"vertical"}]},{"title":"Emprunter","sub_category_tiles":[],"button":{"text":"Découvrez toutes nos offres de Prêt","style":"primary","url":"/particuliers/credit","linkType":"internal"},"files_and_faqs":[],"card_infos":[{"title":"Prêt Auto","description":"\u003Cp>Changez de voiture grâce au financement d’un véhicule neuf ou d’occasion.\u003C/p>\u003Cp>\u003Cstrong>UN CRÉDIT&nbsp;VOUS ENGAGE ET DOIT ETRE REMBOURSÉ. VÉRIFIEZ&nbsp;VOS CAPACITÉS&nbsp;DE REMBOURSEMENT AVANT DE VOUS ENGAGER.\u003C/strong>\u003C/p>","image":{"name":"card-solution-le-pret-auto.jpg","width":265,"height":145,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_le_pret_auto_0a0235b50e.jpg","alternativeText":"homme qui conduit une voiture avant l'achat"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/credit/financer-projet/pret-auto","orientation":"vertical"},{"title":"Rachat de crédit(s)","description":"\u003Cp>La BRED vous accompagne dans votre quotidien en rachetant et en regroupant tous vos prêts en un crédit avec une échéance unique.\u003C/p>\u003Cp>\u003Cstrong>UN CRÉDIT&nbsp;VOUS ENGAGE ET DOIT ETRE REMBOURSÉ. VÉRIFIEZ&nbsp;VOS CAPACITÉS&nbsp;DE REMBOURSEMENT AVANT DE VOUS ENGAGER.\u003C/strong>\u003C/p>","image":{"name":"card-solution-pret-serenite.jpg","width":265,"height":145,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_pret_serenite_0b81e81d96.jpg","alternativeText":"une femme qui sert la main Ã  un conseiller"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/credit/financer-projet/rachat-credit","orientation":"vertical"},{"title":"Prêt à la consommation ","description":"\u003Cp>Une envie particulière ou un besoin en trésorerie&nbsp;? Demandez un prêt adapté à votre projet.\u003C/p>\u003Cp>\u003Cstrong>UN CRÉDIT&nbsp;VOUS ENGAGE ET DOIT ETRE REMBOURSÉ. VÉRIFIEZ&nbsp;VOS CAPACITÉS&nbsp;DE REMBOURSEMENT AVANT DE VOUS ENGAGER.\u003C/strong>\u003C/p>","image":{"name":"card-nv1-pret-conso.jpg","width":256,"height":297,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_nv1_pret_conso_d6571c22ed.jpg","alternativeText":"Image"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/credit/financer-projet/pret-personnel","orientation":"vertical"}]},{"title":"Epargner","sub_category_tiles":[],"button":{"text":"Découvrez toutes nos offres d'épargne","style":"primary","url":"/particuliers/epargne","linkType":"internal"},"files_and_faqs":[],"card_infos":[{"title":"Plan Epargne Retraite Individuel (PERI)","description":"\u003Cp>Préparez votre retraite et constituez une épargne sur mesure à la fiscalité incitative.\u003C/p>","image":{"name":"actu-peri.jpg","width":214,"height":144,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/actu_peri_fd0665b488.jpg","alternativeText":"Image"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/epargne/epargne-retraite/plan-epargne-retraite-individuel","isBarVisible":false,"orientation":"vertical"},{"title":"Livret A   ","description":"\u003Cp>Une solution idéale pour constituer une épargne rémunérée de précaution, sans frais.\u003C/p>","image":{"name":"card-solution-livret-a.jpg","width":265,"height":145,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_livret_a_935bbc3bbc.jpg","alternativeText":"Image"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/epargne/livrets-comptes/livret-a","orientation":"vertical"},{"title":"Assurance vie Filio","description":"\u003Cp>Souscrivez une assurance vie dont le capital est destiné à vos enfants ou petits-enfants.\u003C/p>","image":{"name":"card-solution-lassurance-vie-filio.jpg","width":265,"height":145,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_lassurance_vie_filio_85e8afbf7c.jpg","alternativeText":"une famille qui jouent sur la plage"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/epargne/assurance-vie/assurance-vie-enfant-filio","orientation":"vertical"}]},{"title":"Assurer","sub_category_tiles":[],"button":{"text":"Découvrez toutes nos offres d'assurance","style":"primary","url":"/particuliers/assurance","linkType":"internal"},"files_and_faqs":[],"card_infos":[{"title":"Assurance habitation","description":"\u003Cp style=\"margin-left:0px;\">\u003Cspan style=\"font-size:14px;\">Un contrat d’habitation avec des garanties modulables qui s’adaptent à votre situation et à votre logement.\u003C/span>\u003C/p>\u003Cp>\u003Cbr>&nbsp;\u003C/p>","image":{"name":"card-solution-assurance-habitation.jpg","width":265,"height":145,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_assurance_habitation_1d398331e5.jpg","alternativeText":"des mains qui protÃ¨gent une petite maison"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/assurance/assurer-habitation/assurance-habitation","isBarVisible":false,"orientation":"vertical"},{"title":"Complémentaire santé","description":"\u003Cp>Optimisez vos remboursements de frais de santé grâce à une formule adaptée à vos besoins.\u003C/p>","image":{"name":"card-solution-complementaire-sante-famille.jpg","width":258,"height":150,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/card_solution_complementaire_sante_famille_cbe6ba2236.jpg","alternativeText":"card-solution-complementaire-sante-famille.jpg"},"buttons":[],"tags":[],"links":[],"url":"/particuliers/assurance/prevoyance/complementaire-sante","orientation":"vertical"}]}]},"visibleInTransacMode":false,"bottomSpacing":true}},{"__component":"section.card-grid","card_grid":{"text":"\u003Ch2>Découvrez l'actualité BRED\u003C/h2>","products":[],"card_infos":[{"title":"Économie Allemande et changement de cap","description":"\u003Cp>\u003Cspan style=\"color:rgb(16,17,17);font-family:Roboto, sans-serif;\">L’Allemagne, premier partenaire de l’UE en termes de PIB, est aussi l’un de ceux qui sont les plus exposés depuis quelques années aux multiples assauts d’un monde plus mouvementé.\u003C/span>\u003C/p>","image":{"name":"illu-actu-chronique-economie.jpg","width":554,"height":352,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/illu_actu_chronique_economie_77fe7677cb.jpg","alternativeText":"Image"},"date":"2025-10-13","buttons":[],"tags":[{"text":"Économie","size":"small"}],"links":[],"url":"/actualites/economie-allemande-et-changement-de-cap","isBarVisible":false,"orientation":"vertical"},{"title":"Point d’attention sur les faux conseillers bancaires, ne vous faites pas piéger !","description":"\u003Cp>\u003Cspan style=\"font-family:&quot;Aptos&quot;,sans-serif;\">Les arnaques bancaires par \u003Cstrong>usurpation d'identité\u003C/strong> sont en \u003Cstrong>très forte augmentation\u003C/strong>. Que vous soyez un particulier ou un professionnel, les \u003Cstrong>fraudeurs\u003C/strong> se font passer pour des conseillers bancaires afin de voler vos informations confidentielles et votre argent.&nbsp;\u003C/span>\u003C/p>","image":{"name":"illu-actu-faux conseiller-septembre-2025-2.jpg","width":724,"height":483,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/illu_actu_faux_conseiller_septembre_2025_2_6f5310d316.jpg"},"date":"2025-10-13","buttons":[],"tags":[{"text":"Sécurité","size":"small"}],"links":[],"url":"/actualites/point-attention-faux-conseillers-bancaires","isBarVisible":false,"orientation":"vertical"},{"title":"Envie de découvrir des courts-métrages passionnants ? ","description":"\u003Cp>\u003Cspan style=\"color:rgb(79,79,79);font-family:Aptos, sans-serif;font-size:16px;\">Rendez-vous du 13 au 15 octobre 2025 avec les 12 Courts de Minuit&nbsp;!&nbsp;\u003C/span>\u003C/p>","image":{"name":"12courtsdeminuit-vignette.jpg","width":563,"height":328,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/12courtsdeminuit_vignette_bf15ed9be8.jpg"},"date":"2025-10-10","buttons":[],"tags":[{"text":"Sociétariat","size":"small"}],"links":[],"url":"actualites/envie-de-decouvrir-des-courts-metrages-passionnants","orientation":"vertical"},{"title":"Envie de vous lancer dans l’entrepreneuriat ? ","description":"\u003Cp style=\"margin-left:0px;\">\u003Cstrong>Rendez-vous du 13 au 17 octobre pour faire avancer votre projet.\u003C/strong>\u003C/p>\u003Cp>\u003Cspan style=\"font-family:Aptos, sans-serif;\">Plus de 500 événements d’information seront accessibles pour tous, en ligne et en présentiel, en français et en plusieurs langues.\u003C/span>\u003C/p>","image":{"name":"illu-actu-semaine-entreprendre-adie-octobre-2025.jpg","width":724,"height":483,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/illu_actu_semaine_entreprendre_adie_octobre_2025_a3fda5855b.jpg"},"date":"2025-10-06","buttons":[],"tags":[],"links":[],"url":"/actualites/envie-de-vous-lancer-dans-lentrepreneuriat","isBarVisible":false,"orientation":"vertical"}],"card_shortcuts":[],"card_actions":[],"card_icons":[],"card_bes":[],"buttonPlacement":"right","button":{"text":"Voir toutes les actualités","style":"secondary","url":"/actualites","linkType":"internal","adobeEventName":"cta_click"},"visibleInTransacMode":true,"footnotes":"","gridType":"list","iconTexts":[],"backgroundColor":"#fafafa","bottomSpacing":true}},{"__component":"section.s-custom","s_custom":{"customText":"\u003Cpre>\u003Ccode class=\"language-html\">&lt;style&gt;\n  .section-be-background {\n            background: url('https://bredfrmedia.blob.core.windows.net/media/assets/background_ban_bred_espace_ec10ab5706.jpg') no-repeat top right #badce9;\n            padding: 64px 0 40px 0;\n            height: 350px;\n        }\n\n        .section-be-box {\n            padding: 40px 0 0 40px;\n        }\n\n        .section-be-titre {\n            font-size: 32px;\n            line-height: 40px;\n            font-weight: 700;\n            letter-spacing: normal;\n            color: #393896;\n            font-family: 'Roboto', sans-serif;\n            padding: 0 0 16px 0;\n        }\n\n        .btn-regular-new-be {\n            font-family: 'Roboto', sans-serif;\n            font-size: 20px;\n            font-weight: 500;\n            line-height: 28px;\n            color: #ffffff;\n            background: #3e6bac;\n            border: 1px solid #3e6bac;\n            border-radius: 4px;\n            display: inline-block;\n            padding: 8px 16px 8px 16px;\n            margin: 0;\n            text-align: center;\n            text-decoration: none;\n        }\n\n        .btn-regular-new-be:hover {\n            color: #3e6bac;\n            background: #ffffff;\n        }\n\n        .section-be-desktop-only {\n            display: none;\n        }\n\n\n        @media (max-width: 1400px) {}\n\n        @media (max-width: 1200px) {}\n\n        @media (max-width: 992px) {\n            .section-be-background {\n                background: url('https://bredfrmedia.blob.core.windows.net/media/assets/background_ban_bred_espace_ec10ab5706.jpg') no-repeat top right -150px #badce9;\n                padding: 40px 0 40px 0;\n                height: 350px;\n            }\n\n            .section-be-box {\n                padding: 40px 0 0 0;\n            }\n        }\n\n        @media (max-width: 768px) {\n            .section-be-background {\n                background: #badce9;\n                height: auto;\n                text-align: center;\n            }\n\n            .section-be-box {\n                padding: 32px;\n                margin: 32px 0 0 0;\n                text-align: center;\n            }\n\n            .btn-regular-new {\n                width: auto;\n            }\n        }\n\n        @media (max-width: 576px) {}\n\n&lt;/style&gt;\n\n    &lt;section class=\"section-be-background\"&gt;\n        &lt;div class=\"container\"&gt;\n            &lt;div class=\"row\"&gt;\n                &lt;div class=\"col-xxl-12 col-xl-8 col-lg-8 col-md-10 col-sm-12 col-12\"&gt;\n                    &lt;img src=\"https://bredfrmedia.blob.core.windows.net/media/assets/logo_be_section_8cf94939e3.png\" class=\"img-fluid\" alt=\"logo BRED Espace, la banque en ligne qui sait vous conseiller\" /&gt;\n                    &lt;div class=\"section-be-box\"&gt;\n                        &lt;div class=\"section-be-titre\"&gt;Et si vous faisiez le choix d'une\n                            &lt;!--&lt;br class=\"section-be-desktop-only\" /&gt;--&gt;banque en ligne qui vous connaît&nbsp;?&lt;/div&gt;\n                        &lt;a href=\"particuliers/bred-espace\" class=\"btn-regular-new-be\" role=\"button\" aria-label=\"Découvrez la banque en ligne BRED Espace\"&gt;Je découvre BRED Espace&lt;/a&gt;\n                    &lt;/div&gt;\n                &lt;/div&gt;\n            &lt;/div&gt;\n        &lt;/div&gt;\n    &lt;/section&gt;\u003C/code>\u003C/pre>","visibleInTransacMode":true,"bottomSpacing":false}},{"__component":"section.card-grid","card_grid":{"text":"\u003Ch2>Construisons une relation dans la confiance\u003C/h2>","products":[],"card_infos":[],"card_shortcuts":[],"card_actions":[],"card_icons":[{"description":"\u003Cp style=\"text-align:center;\">\u003Cspan style=\"color:hsl( 0, 0%, 82% );\">__________\u003C/span>\u003Cspan style=\"color:hsl(0,0%,82%);\">__________\u003C/span>\u003C/p>\u003Cp style=\"text-align:center;\">La BRED est une Banque Populaire coopérative. Elle appartient à ses clients sociétaires qui participent au développement et au financement de l’économie réelle.\u003C/p>","infoTexts":[],"fontAwesomeIds":[{"text":"fa-duotone fa-solid fa-people-group"}],"buttons":[],"storeButtons":[],"links":[]},{"description":"\u003Cp style=\"text-align:center;\">\u003Cspan style=\"color:hsl( 0, 0%, 82% );\">__________\u003C/span>\u003Cspan style=\"color:hsl(0,0%,82%);\">__________\u003C/span>\u003C/p>\u003Cp style=\"text-align:center;\">A la BRED, votre conseiller dédié vous connait et comprend vos besoins. Quels que soient vos projets de vie, grands ou petits, il vous conseille et vous propose les meilleures solutions pour un accompagnement sur mesure.\u003C/p>","infoTexts":[],"fontAwesomeIds":[{"text":"fa-duotone fa-solid fa-user-check"}],"buttons":[],"storeButtons":[],"links":[]},{"description":"\u003Cp style=\"text-align:center;\">\u003Cspan style=\"color:hsl( 0, 0%, 82% );\">__________\u003C/span>\u003Cspan style=\"color:hsl(0,0%,82%);\">__________\u003C/span>\u003C/p>\u003Cp style=\"text-align:center;\">Plus de 300 agences pour vous accueillir et des espaces en libre-service pour vos opérations bancaires, des téléconseillers disponibles jusqu'à 22h (horaires en Métropole) et une application mobile dédiée pour la gestion de vos comptes en toute autonomie.\u003C/p>","infoTexts":[],"fontAwesomeIds":[{"text":"fa-duotone fa-solid fa-building-circle-check"}],"buttons":[],"storeButtons":[],"links":[]}],"card_bes":[],"buttonPlacement":"center","button":{"text":"J'ouvre un compte","style":"primary","url":"/particuliers/ouvrir-un-compte","linkType":"internal"},"visibleInTransacMode":true,"footnotes":"","gridType":"list","iconTexts":[],"backgroundColor":"#FFFFFF","secondaryTitle":"Vous aussi devenez un client satisfait : rejoignez-nous !","bottomSpacing":false}},{"__component":"section.card-grid","card_grid":{"text":"","products":[],"card_infos":[],"card_shortcuts":[],"card_actions":[],"card_icons":[{"title":"Découvrez nos simulateurs","description":"\u003Cp style=\"text-align:center;\">\u003Cspan style=\"color:#FFF;\">Simples et pratiques à utiliser, nos outils vous aident à préparer vos projets.\u003C/span>\u003C/p>","infoTexts":[],"fontAwesomeIds":[{"text":"fa-light fa-chart-column"}],"buttons":[{"text":"Découvrir tous nos simulateurs","style":"secondary","url":"/outils-aide","linkType":"internal"}],"storeButtons":[],"links":[],"backgroundColor":"#3e6bac"},{"title":"Téléchargez l'appli mobile","description":"\u003Cp style=\"text-align:center;\">\u003Ca href=\"/particuliers/compte-bancaire/comptes-en-ligne/application-mobile-bred-iphone-android-windows\">\u003Cspan style=\"color:#FFF;font-size:16px;\">\u003Cu>L'application bancaire BRED\u003C/u>\u003C/span>\u003C/a>\u003Cspan style=\"color:#FFF;font-size:16px;\"> Banque Populaire, vos comptes bancaires à portée de main\u003C/span>\u003C/p>","infoTexts":[],"fontAwesomeIds":[{"text":"fa-light fa-mobile"}],"buttons":[],"storeButtons":[{"storeImage":{"name":"cta-apple-store.png","width":175,"height":48,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/cta_apple_store_3a4596733b.png","alternativeText":"Télécharger l'application dans l'App Store"},"url":"https://apps.apple.com/fr/app/bred/id470182955"},{"storeImage":{"name":"app-store-2023.png","width":172,"height":48,"url":"https://bredfrmedia.blob.core.windows.net/media/assets/app_store_2023_0d56c7b221.png","alternativeText":"Application disponible sur Google Play"},"url":"https://play.google.com/store/apps/details?id=fr.bred.fr&hl=fr"}],"links":[],"backgroundColor":"#3E6BAC"}],"card_bes":[],"visibleInTransacMode":true,"gridType":"list","iconTexts":[],"bottomSpacing":true}},{"__component":"section.s-custom","s_custom":{"customText":"\u003Cpre>\u003Ccode class=\"language-ht