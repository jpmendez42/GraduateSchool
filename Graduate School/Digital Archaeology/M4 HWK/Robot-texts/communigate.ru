// Easing function (easeIn)
function easeInQuad(t, b, c, d) {
    t /= d;
    return c * t * t + b;
}

document.addEventListener('DOMContentLoaded', function () {
    const scrollContainer = document.querySelector('#rec1245225071 .t396__artboard');
    const arrowLeft = document.querySelector('#rec767935806 .arrow-l');
    const arrowRight = document.querySelector('#rec767935806 .arrow-r');

    // Функция для плавной прокрутки с ease-in
    function smoothScroll(scrollTo, duration) {
        const start = scrollContainer.scrollLeft;
        const change = scrollTo - start;
        const increment = 20;
        let currentTime = 0;

        function animateScroll() {
            currentTime += increment;
            const val = easeInQuad(currentTime, start, change, duration);
            scrollContainer.scrollLeft = val;
            if (currentTime < duration) {
                requestAnimationFrame(animateScroll);
            } else {
                scrollContainer.scrollLeft = scrollTo;
            }
        }
        animateScroll();
    }

    if (arrowLeft && scrollContainer) {
        arrowLeft.addEventListener('click', function () {
            const targetScrollLeft = scrollContainer.scrollLeft - 300;
            smoothScroll(targetScrollLeft, 400);
        });
    }

    if (arrowRight && scrollContainer) {
        arrowRight.addEventListener('click', function () {
            const targetScrollLeft = scrollContainer.scrollLeft + 300;
            smoothScroll(targetScrollLeft, 400);
        });
    }
});
