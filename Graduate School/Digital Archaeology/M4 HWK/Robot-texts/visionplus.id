    // Script for dynamic set of the base href header. In order to work without Hash
    (function() {
        var loc = window.location;
        var pathParts = loc.pathname.split('/').filter(Boolean);
        var basePath = '/';

        var index = pathParts.indexOf('webclient');

        if (index !== -1) {
            if (loc.hostname === 'dev-webclient.dth.cloud' || loc.hostname === 'dev-webclient.dth-cloud.net' || loc.hostname === 'd3i427ijezn4sw.cloudfront.net' ) {
                basePath = '/' + pathParts.slice(0, index + 3).join('/') + '/';
            } else {
                basePath = '/' + pathParts.slice(0, index + 1).join('/') + '/';
            }
        }

        var base = document.createElement('base');
        base.href = loc.origin + basePath;
        document.head.appendChild(base);
    })();
