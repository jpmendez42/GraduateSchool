  --body-text-3-line-height-base-md-narrower: 16px;
  --body-text-3-font-size-base-xs-narrower: 14px;
  --body-text-3-line-height-base-xs-narrower: 16px;
  /** text on components **/
  --ui-text-N-light-font-weight: 300;
  --ui-text-N-standard-font-weight: 400;
  --ui-text-N-medium-font-weight: 500;
  --ui-text-N-bold-font-weight: 700;
  --ui-text-1-font-size-value: 28;
  --ui-text-1-line-height-value: 32;
  --ui-text-1-font-size: 28px;
  --ui-text-1-line-height: 32px;
  --ui-text-2-font-size-value: 20;
  --ui-text-2-line-height-value: 24;
  --ui-text-2-font-size: 20px;
  --ui-text-2-line-height: 24px;
  --ui-text-3-font-size-value: 14;
  --ui-text-3-line-height-value: 16;
  --ui-text-3-font-size: 14px;
  --ui-text-3-line-height: 16px;
  --ui-text-1-font-size-resize: 1.41414141414141vw;
  --ui-text-1-line-height-resize: 1.61616161616162vw;
  --ui-text-1-font-size-resize-xs-narrower: 1.41414141414141vw;
  --ui-text-1-line-height-resize-xs-narrower: 1.61616161616162vw;
  --ui-text-2-font-size-resize: 1.01010101010101vw;
  --ui-text-2-line-height-resize: 1.21212121212121vw;
  --ui-text-2-font-size-resize-xs-narrower: 1.01010101010101vw;
  --ui-text-2-line-height-resize-xs-narrower: 1.21212121212121vw;
  --ui-text-3-font-size-resize: 0.707070707070707vw;
  --ui-text-3-line-height-resize: 0.808080808080808vw;
  --ui-text-3-font-size-resize-xs-narrower: 0.707070707070707vw;
  --ui-text-3-line-height-resize-xs-narrower: 0.808080808080808vw;
  /** links */
  --link-primary-text-color: #294CA6;
  --link-primary-hover-text-color: #4C85BE;
  --link-secondary-text-color: #000000;
  --link-secondary-hover-text-color: #294CA6;
  --link-tertiary-text-color: #9CA5B5;
  --link-tertiary-hover-text-color: #294CA6;
  --link-accent-text-color: #FF522D;
  --link-accent-hover-text-color: #E24523;
  /** buttons */
  --button-N-border-radius: 16px;
  --button-N-disable-opacity: 60%;
  --button-primary-text-color: #000000;
  --button-primary-background-color: #F2F4F7;
  --button-primary-hover-text-color: #000000;
  --button-primary-hover-background-color: #D4DDEA;
  --button-primary-disable-text-color: #000000;
  --button-primary-disable-background-color: #D4DDEA;
  --button-secondary-text-color: #000000;
  --button-secondary-background-color: #FFFFFF;
  --button-secondary-hover-text-color: #000000;
  --button-secondary-hover-background-color: #D4DDEA;
  --button-secondary-disable-text-color: #000000;
  --button-secondary-disable-background-color: #D4DDEA;
  --button-tertiary-text-color: #FFFFFF;
  --button-tertiary-background-color: #FF522D;
  --button-tertiary-hover-text-color: #FFFFFF;
  --button-tertiary-hover-background-color: #E24523;
  --button-tertiary-disable-text-color: #FFFFFF;
  --button-tertiary-disable-background-color: #FF522D;
  --button-quaternary-text-color: #FFFFFF;
  --button-quaternary-background-color: #294CA6;
  --button-quaternary-hover-text-color: #FFFFFF;
  --button-quaternary-hover-background-color: #4C85BE;
  --button-quaternary-disable-text-color: #FFFFFF;
  --button-quaternary-disable-background-color: #294CA6;
  --button-fifth-text-color: #FFFFFF;
  --button-fifth-background-color: #9CA5B5;
  --button-fifth-hover-text-color: #FFFFFF;
  --button-fifth-hover-background-color: #475365;
  --button-fifth-disable-text-color: #FFFFFF;
  --button-fifth-disable-background-color: #9BA1A9;
  /** round buttons */
  --button-round-N-border-radius: 50%;
  --button-round-N-disable-opacity: 60%;
  --button-round-primary-text-color: #000000;
  --button-round-primary-background-color: #FFFFFF;
  --button-round-primary-hover-text-color: #000000;
  --button-round-primary-hover-background-color: #D4DDEA;
  --button-round-primary-disable-text-color: #000000;
  --button-round-primary-disable-background-color: #FFFFFF;
