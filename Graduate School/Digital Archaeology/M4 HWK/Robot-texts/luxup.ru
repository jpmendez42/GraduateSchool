    function vPopClose() {
        document.getElementById('v-pop-main').style.display='none';
        return true;
    }
    
    function vPopActive() {
        
        (function() {
            function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
            }

            function setCookie(name, value, days) {
                const expires = new Date(Date.now() + days * 864e5).toUTCString();
                document.cookie = `${name}=${value}; expires=${expires}; path=/`;
            }

            if (getCookie('pop') !== 'yes') {
            setTimeout(function(){document.getElementById('v-pop-main').style.display='block'; setCookie('pop', 'yes', 30);},30000);
            return true;
            }
        })();
        
    }
    
    vPopActive();
    
   
   function validateEmail() {
      var input = document.getElementById('v-pop-email');
      var email = input.value.trim();
      var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      input.classList.remove('v-pop-email-invalid');

      if (regex.test(email)) {
        input.classList.remove('v-pop-email-invalid');
        return true;
      } else {
        void input.offsetWidth;
        input.classList.add('v-pop-email-invalid');
        return false;
      }
    }
    
    function validateCheckbox() {
        var checkbox = document.getElementById('v-pop-privacy');
        var text = document.getElementById('v-pop-checkbox-text');
        var link = document.getElementById('v-pop-link');
        var toggle = document.getElementById('v-pop-checkbox-toggle');
        
        if (checkbox.checked) {
            text.classList.remove('v-pop-checkbox-text-invalid');
            link.classList.remove('v-pop-link-invalid');
            toggle.classList.remove('v-pop-checkbox-toggle-invalid');
            toggle.classList.add('v-pop-checkbox-toggle');
            return true;
        } else {
            text.classList.add('v-pop-checkbox-text-invalid');
            link.classList.add('v-pop-link-invalid');
            toggle.classList.remove('v-pop-checkbox-toggle');
            toggle.classList.add('v-pop-checkbox-toggle-invalid');
            return false;
        }
    }
    
    async function sendInfo() {
        const email = document.getElementById('v-pop-email').value;
        const divStart = document.getElementById('v-pop-cont-start');
        const divSuccess = document.getElementById('v-pop-cont-success');
        const pdfLink = document.getElementById('v-pop-link-pdf');
        const divError = document.getElementById('v-pop-error');
        const divButton = document.getElementById('v-pop-button-get');
        
        const response = await fetch('/img/popup/v-pop-send.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ email })
        });
        
        const result = await response.json();
        
        divError.style.display = 'none';
        
        if (result.error === "1") {
            divError.textContent = 'Вы ввели некорректный E-mail.';
            divError.style.display = 'block';
            return false;
        } else if (result.error === "2") {
            divError.textContent = 'Произошла ошибка. Попробуйте еще или свяжитесь с support@luxupnetwork.com';
            divError.style.display = 'block';
            return false;
        } else if (result.success) {
            // Плавное скрытие формы
            divStart.style.transition = 'opacity 0.1s ease';
            divStart.style.opacity = '0';
        
            setTimeout(() => {
                divStart.style.display = 'none';
                divButton.style.display = 'none';
                pdfLink.href = result.url;
                divSuccess.style.display = 'block';
                divSuccess.style.opacity = '0';
                divSuccess.style.transition = 'opacity 0.1s ease';
                setTimeout(() => divSuccess.style.opacity = '1', 10);
            }, 100);
            
        } else {
            divError.textContent = 'Произошла ошибка. Попробуйте еще или свяжитесь с support@luxupnetwork.com';
            divError.style.display = 'block';
            return false;
        }
    }
    
    function vSend() {
        const isEmailValid = validateEmail();
        const isCheckboxValid = validateCheckbox();

        if (isEmailValid && isCheckboxValid) {
            sendInfo();
        }
    }

</script> <style>
    .v-pop-main { position: fixed; display: none; width: 100%; height: 100%; background: rgba(55, 56, 51, 0.9); z-index: 99999999999; font-family: 'Raleway',Arial,sans-serif; color: #373833; letter-spacing: 0.5px; text-size-adjust: 100%; -webkit-text-size-adjust: 100%; -moz-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }

