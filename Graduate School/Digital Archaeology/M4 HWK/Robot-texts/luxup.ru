    .v-header-login-menu-login { position: absolute; width: 100%; height: 40px; top: 48px; border-radius: 0 0 10px 10px; }
        .v-header-login-menu-login:hover { background: #E2B400; cursor: pointer; }
        .v-header-login-menu-login:hover .v-header-login-menu-text { color: #373833; font-weight: 600; }
