<div >
    <div ><div class="section-title"><h2>County Spotlight</h2></div></div>    
</div><div class="row" data-sf-element="Row">
    <div id="ContentPlaceholderFeaturedItems_TB5860D3B012_Col00" class="sf_colsIn col-lg-4  p-3 d-flex align-items-stretch" data-sf-element="Column 1" data-placeholder-label="Column 1">


<div>
  <div class="card shadow-lg mt-1 h-100">
      <img class="card-img-top img-fluid" src="https://cuyahogacms.blob.core.windows.net/home/images/default-source/default-album/centro-villa.jpg?sfvrsn=6ec6d193_0" title="Centro Villa" alt="A public transit bus is driving on a city street near a modern looking building with murals on the side." width=600 height=185 />
    <div class="card-body">
        <h5 class="card-title">Program to Boost TOD</h5>
              <p class="card-text">County announces Transit-Oriented Development Loan Program to support projects near public transit.</p>

      <a class="stretched-link" href="https://cuyahogacounty.gov/county-news/county-news-detail/2025/08/25/cuyahoga-county-s-new-loan-program-to-boost-jobs-and-development-near-transit" aria-label='Program to Boost TOD'>Learn More and Apply </a>

