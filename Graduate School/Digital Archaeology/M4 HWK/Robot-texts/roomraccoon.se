  <style>
    .accordion {
      border-radius: 5px;
      width: 100%;
      max-width: 500px;
      font-family: 'Lato', sans-serif;
      overflow: hidden;
    }

    .accordion-header-container {
      background-color: #f6f6f6;
      border-radius: 5px;
      padding: 20px;
      cursor: pointer;
    }

    .accordion-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .accordion-left {
      display: flex;
      align-items: center;
    }

    .accordion-title {
      font-size: 16px;
      font-weight: bold;
    }

    .accordion-left img {
      width: 20px;
      height: 20px;
      margin-right: 10px;
    }

    .accordion-arrow {
      transition: transform 0.3s ease;
      width: 16px;
      height: 16px;
    }

    .accordion.active .accordion-arrow {
      transform: rotate(180deg);
    }

    .accordion-content {
      display: none;
      padding: 15px;
      background-color: #ffffff; /* ✅ Updated */
      border-radius: 0 0 5px 5px;
      margin-top: 10px;
    }

    .accordion.active .accordion-content {
      display: block;
    }

    .accordion-item {
      margin-bottom: 10px;
    }

    .accordion-item a {
      text-decoration: none;
      color: inherit;
      display: flex;
      align-items: center;
      cursor: pointer;
    }

    .accordion-item .accordion-title {
      font-size: 16px;
      font-weight: bold;
    }

    .accordion-item img {
      width: 20px;
      height: 20px;
      margin-right: 10px;
    }
  </style>



