		<style>
	/*it906-商店街元件*/   
	.it906-box { max-width: 1200px; width: 100%; height: auto; margin: 0 auto; display: flex; align-items: end;}
	.it906-box-L{ width:650px; height: 332px; margin-right: 40px; padding-top: 33px;}
	.it906-box-L .it906-pbox{ background: #fff6e7; padding: 25px 30px; border-radius: 10px; display: flex; align-items: center; height: 299px;}
	.it906-box-title {width: auto;position: absolute;}
	.it906-box-L .it906-box-title{ display:flex; align-items: center; margin-bottom: 5px;}
	.it906-box-L .it906-box-title span{ padding-left:0px; width: 6px; height: 24px; border-radius: 3px; background:url(images/it906_live.svg) 15px center no-repeat #f37721; background-size:30px ; display: block; color: #fff; font-size: 20px; line-height: 50px; font-weight: bold;}
	.it906-box-L .it906-box-title h3{ font-size: 22px; line-height: 28px; letter-spacing: 0.75px; color: #2f2f2f; margin-left: 10px;}
	.it906-pbox .owl-controls .owl-prev,.it906-pbox .owl-controls .owl-next{ width: 50px; height:50px; position: absolute; text-indent: -9999px; z-index: 99; top:50%; margin-top:-20px;}

	.it906-pbox .owl-controls .owl-prev{ left: -25px; background: url(css/images/carousel-arrow_left.png) center no-repeat; background-size: 50px;}
	.it906-pbox .owl-controls .owl-next{ right: -25px; background: url(css/images/carousel-arrow_right.png) center no-repeat; background-size: 50px;}

	.it906-box-R{ width: 530px;}
	.it906-box-R{ border-radius: 5px; max-width:510px; height: 332px; margin:0 auto; background:#bed4e0; -webkit-border-radius:8px; -moz-border-radius: 8px; border-radius:10px;}
	.it906-live { max-width:1180px; margin:0 auto; position:relative; height:320px; overflow:hidden;}
	.it906-live iframe,.it906-live object,.it906-live embed { position:absolute; top:0; left:0; width:100%; height:100%; max-height:658px;}
	
	.it906-live {height: 332px; border-radius: 10px;}
	.it906-box-R .it906-live a::after { content: ""; position: absolute; width: 100%; height: 332px; left: 0; top: 0; z-index: 2; background: url(css/images/pic/pic-icon-play.svg) center no-repeat rgba(0,0,0,.65); background-size: 66px; }
	.it906-live iframe, .it906-live object, .it906-live embed {display: none;}

	/* title 橘棒 */ 
	.it906-box-title h3 { position: relative; font-size: 22px; font-weight: 600; color: var(--pic-color-grey-100); line-height: 24px; text-align: left; padding-left: 16px; max-width:650px;overflow: hidden;text-overflow: ellipsis;white-space: nowrap; }
	.it906-box-title h3::before { position: absolute; left: 0; top: 0; display: block; content: ''; width: 6px; height: 24px; border-radius: 3px; background: var(--pic-orange); }
	
	@media screen and (max-width:1280px) { 
		.it906-live{ padding-bottom:56%;}
	}
	@media screen and (max-width: 960px){
		.it906-box-L .it906-box-title { padding: 10px 0 10px 10px;}
		.it906-box {width: 100%; flex-direction: column-reverse; padding: 0 2px;}
		.it906-box-R {width: 100%; border-radius: 10px !important;}
		.it906-box-L {width: 100%; margin-right: 0px; height: auto;}
	
		.it906-box-L .it906-pbox {padding: 10px 0 10px 10px;}
		.iopen-mall-item-box .iopen-mall-item-mb .it906-default .owl-theme .owl-dots,.it906-default .owl-theme .owl-nav {display: none;}
		.iopen-mall-item-box .iopen-mall-item-mb .it906-default .owl-stage { width: 3000px;}
	/* display */
		.it906-box-warp {width: 100%; display: flex; flex-wrap: wrap; flex-direction: column-reverse; }
		.it906-box-L {padding-top: 0px;}
		.it906-box-title {position: initial;}
		.it906-box-title h3 {margin: 0 10px 5px;}
	/* display END */

	/* 輪播 */
		.it906-box-L .it906-pbox {height: auto;}
		.it906-p {width: 100px;}
		.it906-p .it906-p-img { height: 100px; margin-bottom: 0px;}
		.it906-p .it906-p-price { flex-direction: column; height: 38px;}
		.it906-p .it906-p-price {letter-spacing: 0;font-size:14px;}
		h2.it906-p-name {margin: 3px 0px;}
		.it906-p .it906-p-price span {padding-left: 0px;}
		.iopen-mall-item-box .iopen-mall-item-mb .it906-default .owl-stage { display: flex; justify-content: space-around;}
		.iopen-mall-item-box .iopen-mall-item-mb .it906-default .owl-item { width: 100px !important;}
		.it906-box-L .it906-pbox {border-radius: 0px;}
		.it906-box-R{ border-radius: 0px; -webkit-border-radius:0px; -moz-border-radius: 0px; border-radius:0px;}
	}
	@media screen and (max-width: 640px){
		.it906-box-title h3 { font-size: 20px;}
	}
	</style>

