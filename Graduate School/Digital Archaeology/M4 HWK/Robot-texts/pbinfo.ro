		<script>
		function OperatiiPostareClick()
		{
			$(".link-modificare-postare").click(function(e){
				e.preventDefault();
				let id = $(this).data('id')
				try
				{
					IncarcareDialogModal("/ajx-module/postari/ajx-modal-postare-modificare.php", {id});
				}
				catch(error)
				{
					console.log(error)
				}
			});
			$(".btn-stergere-postare").click(function (e){
				e.preventDefault()
				StergerePostare($(this).data('id'));
			});
			$(".btn-prima-pagina").click(function (e){
				e.preventDefault()
				SchimbaPrimaPaginaPostare($(this).data('id'));
			});

			$(".link-duplicare-postare").click(function(e){
				e.preventDefault();
				let id = $(this).data('id')
				IncarcareDialogModal('/ajx-module/postari/ajx-modal-postare-duplicare.php', {id});
			});
		}
		$(document).ready(function(){
		
			OperatiiPostareClick();

			lista_postari = new Map();
			$('.postare_continut').each(function(){
				let t = $(this).html();
				lista_postari[$(this).data('id')] = t;
				let x = t.replace(/(<([^>]+)>)/ig,"");
				let maxlen = 300;
				if(x.length > maxlen)
				{
					let c = `<div class="text-restrans" onclick="$('#postare-${$(this).data('id')}').html(lista_postari[${$(this).data('id')}]); $.post('/ajx-module/articole/php-contorizare-afisare.php', {id: ${$(this).data('id')}}, function(data){}); ColorareSintaxa();$('pre').attr('contenteditable', true); $('pre').attr('editable', true);">`;
					let i = $(this).find('img');
					if(i.length > 0)
					{
						c += `<p class="text-center" style="max-height:250px !important; overflow:hidden;">
							<img src="${i[0].src}" class="img-responsive">
						</p>`;
					}
					c += `<p>` + x.substring(0,maxlen) + `... <span class="text-restrans-mai-mult">(mai mult)</span></p>`;
					let xc = `
					<p class="text-center">
						<button class="btn btn-warning" onclick="$('#postare-${$(this).data('id')}').html(lista_postari[${$(this).data('id')}]);$('pre').attr('contenteditable', true); $('pre').attr('editable', true);"><i class="fas fa-chevron-down"></i> Extinde</button>
					</p>
					`;
					c += `</div>`;
					$(this).html(c);
				}
							});
		});
	</script>
