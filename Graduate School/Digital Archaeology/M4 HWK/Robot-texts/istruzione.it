  $(document).ready(function() {
  // Nascondi tutti i pannelli tranne il primo
  $('.ministro-tabs [role="tabpanel"]').not(':first').addClass('is-hidden');

  // Gestisci il clic sui tab
  $('.ministro-tabs [role="tab"]').click(function() {
    // Imposta tutti i tab come non selezionati
    $('.ministro-tabs [role="tab"]').attr('aria-selected', 'false');
    // Imposta il tab cliccato come selezionato
    $(this).attr('aria-selected', 'true');

    // Nascondi tutti i pannelli
    $('.ministro-tabs [role="tabpanel"]').addClass('is-hidden');
    // Mostra il pannello corrispondente al tab cliccato
    $('#' + $(this).attr('aria-controls')).removeClass('is-hidden');
  });

  // Gestisci la navigazione con i tasti freccia
  $('.ministro-tabs [role="tab"]').keydown(function(e) {
    // Individua il tab attualmente attivo
    var currentTab = $(this);
    // Verifica se il tasto premuto è la freccia destra
    if (e.keyCode == 39) {
      // Passa al tab successivo o torna al primo se siamo all'ultimo
      var nextTab = currentTab.next('[role="tab"]');
      if (nextTab.length === 0) {
        nextTab = $('.ministro-tabs [role="tab"]').first();
      }
      nextTab.focus();
    }
    // Verifica se il tasto premuto è la freccia sinistra
    else if (e.keyCode == 37) {
      // Passa al tab precedente o torna all'ultimo se siamo al primo
      var prevTab = currentTab.prev('[role="tab"]');
      if (prevTab.length === 0) {
        prevTab = $('.ministro-tabs [role="tab"]').last();
      }
      prevTab.focus();
    }
  });

  // Gestisci l'attivazione del tabpanel premendo Invio
  $('.ministro-tabs [role="tab"]').keypress(function(e) {
    // Verifica se il tasto premuto è Invio (codice 13)
    if (e.which == 13) {
      // Nascondi tutti i pannelli
      $('.ministro-tabs [role="tabpanel"]').addClass('is-hidden');
      // Mostra il pannello corrispondente al tab cliccato
      $('#' + $(this).attr('aria-controls')).removeClass('is-hidden');
    }
  });
});
</script></div>
