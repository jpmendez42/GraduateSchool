y-size, var(--dp-body-size, 18px)) * 0.8);list-style: inherit;}#DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__button {  border-color: transparent;  display: inline-block;  text-decoration: none;  padding: 0.5em 1.2em;  transition: all 0.3s ease-in-out;  border: thin solid;  border-radius: 10px;  border-color:#95b874;  line-height: calc(3px + 2ex + 3px);  font-size: calc(var(--dp-g-body-size, var(--dp-body-size, 18px)) * 0.8);  color: #ffffff;  background-color: #95b874;width: max-content;}#DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__button:hover {  opacity: 1;background-color: #7ba554;  border-color: transparent;;}/* Animation */#DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 [style*="--dsgn-pck-animate"] {    opacity: 1;  }/* Landscape phones and down */@media (max-width: 480px) {  #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 {    margin-top: 0px;    margin-bottom: 0px;  }  #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__sizer {    min-width: 70%;    padding-top: 12px;    padding-bottom: 12px;  }#DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__sizer {      min-width: 100%;    }    #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__columns {      flex-wrap: nowrap;      -webkit-overflow-scrolling: touch;      overflow-x: scroll;      justify-content: flex-start;      scroll-snap-type: x mandatory;      margin: 0;      gap: 0;      padding-bottom: 20px;    }    #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__flex-item {      min-width: 75vw;      scroll-snap-align: start;      position: relative;      padding-left: 20px;    }    #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__flex-item:last-child {      margin-right: 20px;    }    #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__columns::-webkit-scrollbar {      -webkit-appearance: none;    }    #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__columns::-webkit-scrollbar:vertical {      width: 50%;    }    #DP--4e145be0-6c76-463d-97bb-33cdcaffeb79 .dsgn-pck__columns::-webkit-scrollbar