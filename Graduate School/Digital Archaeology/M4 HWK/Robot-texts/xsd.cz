,\"slug\":\"poledni-zpravy-97513598\",\"channelId\":\"818\"},{\"id\":\"97513599\",\"start\":\"2025-10-13T10:30:00.000Z\",\"stop\":\"2025-10-13T11:00:00.000Z\",\"title\":\"K věci\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"k-veci-97513599\",\"channelId\":\"818\"},{\"id\":\"97513600\",\"start\":\"2025-10-13T11:00:00.000Z\",\"stop\":\"2025-10-13T11:30:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"zpravy-97513600\",\"channelId\":\"818\"},{\"id\":\"97513601\",\"start\":\"2025-10-13T11:30:00.000Z\",\"stop\":\"2025-10-13T12:15:00.000Z\",\"title\":\"Speciál: Dění týdne\",\"description\":\"\",\"durationMin\":45,\"genre\":null,\"slug\":\"special-deni-tydne-97513601\",\"channelId\":\"818\"},{\"id\":\"97513602\",\"start\":\"2025-10-13T12:15:00.000Z\",\"stop\":\"2025-10-13T12:40:00.000Z\",\"title\":\"Prima Česko\",\"description\":\"\",\"durationMin\":25,\"genre\":5,\"slug\":\"prima-cesko-97513602\",\"channelId\":\"818\"},{\"id\":\"97513603\",\"start\":\"2025-10-13T12:40:00.000Z\",\"stop\":\"2025-10-13T13:00:00.000Z\",\"title\":\"Interview PLUS\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"interview-plus-97513603\",\"channelId\":\"818\"},{\"id\":\"97513604\",\"start\":\"2025-10-13T13:00:00.000Z\",\"stop\":\"2025-10-13T13:20:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"zpravy-97513604\",\"channelId\":\"818\"},{\"id\":\"97513605\",\"start\":\"2025-10-13T13:20:00.000Z\",\"stop\":\"2025-10-13T13:40:00.000Z\",\"title\":\"K věci\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"k-veci-97513605\",\"channelId\":\"818\"},{\"id\":\"97513606\",\"start\":\"2025-10-13T13:40:00.000Z\",\"stop\":\"2025-10-13T14:00:00.000Z\",\"title\":\"Prima PODZIM\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"prima-podzim-97513606\",\"channelId\":\"818\"},{\"id\":\"97513607\",\"start\":\"2025-10-13T14:00:00.000Z\",\"stop\":\"2025-10-13T14:30:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"zpravy-97513607\",\"channelId\":\"818\"},{\"id\":\"97513608\",\"start\":\"2025-10-13T14:30:00.000Z\",\"stop\":\"2025-10-13T14:55:00.000Z\",\"title\":\"Krimi zprávy\",\"description\":\"\",\"durationMin\":25,\"genre\":9,\"slug\":\"krimi-zpravy-97513608\",\"channelId\":\"818\"},{\"id\":\"97513609\",\"start\":\"2025-10-13T14:55:00.000Z\",\"stop\":\"2025-10-13T15:55:00.000Z\",\"title\":\"Zprávy z regionů\",\"description\":\"\",\"durationMin\":60,\"genre\":null,\"slug\":\"zpravy-z-regionu-97513609\",\"channelId\":\"818\"},{\"id\":\"97513610\",\"start\":\"2025-10-13T15:55:00.000Z\",\"stop\":\"2025-10-13T16:35:00.000Z\",\"title\":\"Co na to vaše peněženka\",\"description\":\"\",\"durationMin\":40,\"genre\":null,\"slug\":\"co-na-to-vase-penezenka-97513610\",\"channelId\":\"818\"},{\"id\":\"97513611\",\"start\":\"2025-10-13T16:35:00.000Z\",\"stop\":\"2025-10-13T16:55:00.000Z\",\"title\":\"K věci\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"k-veci-97513611\",\"channelId\":\"818\"},{\"id\":\"97513612\",\"start\":\"2025-10-13T16:55:00.000Z\",\"stop\":\"2025-10-13T17:40:00.000Z\",\"title\":\"Hlavní zprávy\",\"description\":\"\",\"durationMin\":45,\"genre\":null,\"slug\":\"hlavni-zpravy-97513612\",\"channelId\":\"818\"},{\"id\":\"97513613\",\"start\":\"2025-10-13T17:40:00.000Z\",\"stop\":\"2025-10-13T17:55:00.000Z\",\"title\":\"Krimi zprávy\",\"description\":\"\",\"durationMin\":15,\"genre\":9,\"slug\":\"krimi-zpravy-97513613\",\"channelId\":\"818\"},{\"id\":\"97513614\",\"start\":\"2025-10-13T17:55:00.000Z\",\"stop\":\"2025-10-13T18:15:00.000Z\",\"title\":\"Showtime\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"showtime-97513614\",\"channelId\":\"818\"},{\"id\":\"97513615\",\"start\":\"2025-10-13T18:15:00.000Z\",\"stop\":\"2025-10-13T19:00:00.000Z\",\"title\":\"Showtime magazín\",\"description\":\"\",\"durationMin\":45,\"genre\":null,\"slug\":\"showtime-magazin-97513615\",\"channelId\":\"818\"},{\"id\":\"97513616\",\"start\":\"2025-10-13T19:00:00.000Z\",\"stop\":\"2025-10-13T19:30:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"zpravy-97513616\",\"channelId\":\"818\"},{\"id\":\"97513617\",\"start\":\"2025-10-13T19:30:00.000Z\",\"stop\":\"2025-10-13T21:00:00.000Z\",\"title\":\"360°\",\"description\":\"\",\"durationMin\":90,\"genre\":null,\"slug\":\"360-97513617\",\"channelId\":\"818\"},{\"id\":\"97513618\",\"start\":\"2025-10-13T21:00:00.000Z\",\"stop\":\"2025-10-13T21:55:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":55,\"genre\":null,\"slug\":\"zpravy-97513618\",\"channelId\":\"818\"},{\"id\":\"97513619\",\"start\":\"2025-10-13T21:55:00.000Z\",\"stop\":\"2025-10-13T23:35:00.000Z\",\"title\":\"360°\",\"description\":\"\",\"durationMin\":100,\"genre\":null,\"slug\":\"360-97513619\",\"channelId\":\"818\"},{\"id\":\"97513620\",\"start\":\"2025-10-13T23:35:00.000Z\",\"stop\":\"2025-10-14T00:15:00.000Z\",\"title\":\"Prima Česko\",\"description\":\"\",\"durationMin\":40,\"genre\":5,\"slug\":\"prima-cesko-97513620\",\"channelId\":\"818\"}]}},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046804,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"tvGuide\"],\"queryHash\":\"[\\\"tvGuide\\\"]\"},{\"state\":{\"data\":{\"luckyNumbers\":[8,34,4,9,48,30],\"additionalNumber\":4,\"targetUrl\":\"https://www.maxa.cz/vsadit/megamaxa?cisla=%5B%7B%22key%22%3A%221%22%2C%22values%22%3A%5B8%2C34%2C4%2C9%2C48%2C30%5D%2C%22additional%22%3A%5B4%5D%7D%5D\u0026pid=33234\u0026sid=42560\u0026bid=48439\u0026tid=11758\",\"trackingPixelUrl\":\"https://ban.maxa.cz/c/1x1.php?pid=33234\u0026sid=42560\u0026bid=48439\u0026tid=11758\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046306,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"lotteryBox\"],\"queryHash\":\"[\\\"lotteryBox\\\"]\"},{\"state\":{\"data\":[{\"guid\":\"beran\",\"categories\":{\"General\":\"Vaším hlavním dnešním úkolem je pracovat na trpělivosti. Moc vám to nejde, vybuchujete kvůli maličkostem a děláte na pracovišti dusnou atmosféru.\",\"Sex a vztahy\":\"Umíte opravdově milovat a právě dnes budete dávat svému protějšku velkou lásku neustále najevo.\",\"Práce a peníze\":\"Rádi byste studovali, což by neměl být problém. Stačí vybrat z nabízených možností a přihlásit se.\",\"Děti a rodina\":\"Starost o některého člena rodiny vám dnes zabere veškerý váš volný čas. Vaše péče se ale vyplatí.\"}},{\"guid\":\"blizenci\",\"categories\":{\"General\":\"Drobné radosti vám zpříjemní den. Budete se radovat z maličkostí a myslet na pěkné věci. To je dobrý přístup - myslet pozitivně za všech okolností.\",\"Sex a vztahy\":\"Svůj protějšek si přestanete slepě idealizovat. Uvidíte na něm chyby, které jste dříve přehlíželi.\",\"Práce a peníze\":\"Pichlavé poznámky kolegy si už nenechte líbit. Jen si na vás léčí svůj vztek. To není profesionální.\",\"Děti a rodina\":\"Bolest hlavy u vás samozřejmě nesignalizuje žádné závažné onemocnění. Spíš nedodržený pitný režim.\"}},{\"guid\":\"byk\",\"categories\":{\"General\":\"Jste citliví na svůj milostný intimní život. Nemluvíte o něm rádi ani s blízkým přítelem. Najde se ale člověk, který vaše přání nebude respektovat.\",\"Sex a vztahy\":\"Ledy mezi vámi partnery konečně úplně roztály. Naplánujte usmiřovací večeři a nešetřete omluvou.\",\"Práce a peníze\":\"Máte v hlavě dva podnikatelské záměry a nevíte, jaký z nich si vybrat. Jeden bude určitě úspěšnější.\",\"Děti a rodina\":\"Máte problém naslouchat druhému. Ve sporu si pořád vedete svou a jiný názor nejste schopni přijmout.\"}},{\"guid\":\"kozoroh\",\"categories\":{\"General\":\"I když se budete sebevíc snažit, nedokážete v těchto dnech najít člověka, který by podpořil vaše pracovní nápady. Osvědčí se, když budete trpěliví.\",\"Sex a vztahy\":\"Pokud váš protějšek nebude o klábosení s vašimi kamarády moc stát, nenuťte ho se toho zúčastnit.\",\"Práce a peníze\":\"Malá příprava na zítřejší pracovní den vám jenom prospěje. Ráno se vám pak půjde do práce jistěji.\",\"Děti a rodina\":\"Celé vaší rodině by prospělo, kdybyste se víc hýbali. Zároveň budete trávit více času pohromadě.\"}},{\"guid\":\"lev\",\"categories\":{\"General\":\"Důvěru svých potomků si získáte, když v klidu vyslechnete jejich stesky a nabídnete pomoc. I když se v duchu budete rozčilovat, nedejte na sobě nic znát.\",\"Sex a vztahy\":\"Na návštěvě vám bude dost imponovat vážený osoba, se kterou vás seznámí váš milovaný protějšek.\",\"Práce a peníze\":\"Náhodou zjistíte, jaké jsou šéfovy úmysly, a dokážete bez velkého zdržení zařídit vše potřebné.\",\"Děti a rodina\":\"Samotné vás udiví, jak umíte být rafinovaní. Zatoužíte si povyrazit za zády milovaného protějšku.\"}},{\"guid\":\"panna\",\"categories\":{\"General\":\"Investice, zejména na poli kulturním by mohly přinést velkou úrodu. Možná zatoužíte zakoupit umělecké dílo nebo vybrat šperk pro svou polovičku.\",\"Sex a vztahy\":\"Nebudete věřit vlastním uším, v telefonu uslyšíte hlas někoho, s kým jste kdysi prožili pěkný vztah.\",\"Práce a peníze\":\"Klidně vezměte práci přesčas. Pár korun navíc se vám bude hodit a doma potom budete i vzácnější.\",\"Děti a rodina\":\"I když se vám to může zdát divné, potřebujete strávit pár dnů někde v klidu pouze se svou rodinou.\"}},{\"guid\":\"rak\",\"categories\":{\"General\":\"Blízká osoba, které jste zvyklí ustupovat, se s vámi i dnes pokusí manipulovat, aby si ulehčila práci. Tentokrát byste ji však už měli vyvést z omylu.\",\"Sex a vztahy\":\"Rozhodně přijměte pozvání na koncert nebo divadelní představení pod širým nebem. Bude to fajn.\",\"Práce a peníze\":\"Potřebujete cítit jistotu, co se týče hmotného zajištění. Berte to tak, že člověk nemá, co si neudělá.\",\"Děti a rodina\":\"Zkuste předložit své rodině nový jídelníček. Více ovoce a zeleniny potřebují nejenom vaši potomci.\"}},{\"guid\":\"ryby\",\"categories\":{\"General\":\"V práci vám bude chvíli trvat, než se proberete a pustíte do svých povinností. Značnou úlohu na tom bude mít únava, dnes byste neměli moc ponocovat.\",\"Sex a vztahy\":\"Známosti na jednu noc vám příliš štěstí nepřinesou, na to už jste asi přišli sami. Vyhovuje vám to?\",\"Práce a peníze\":\"Nesmíte podlehnout iluzi, že jste nestudovali správný obor, a tím pádem nevyděláváte dost peněz.\",\"Děti a rodina\":\"V rodinném prostředí se budete cítit nejlíp. Přátelé vás ven nedostanou, i kdyby se stavěli na hlavu.\"}},{\"guid\":\"strelec\",\"categories\":{\"General\":\"Náladu pod psa vám bohužel rozhodně nevylepší ani setkání s příbuznými. Vjedete si dnes totiž škaredě do vlasů kvůli jistým majetkovým záležitostem.\",\"Sex a vztahy\":\"Doma se teď vyskytne problém, který se musí hned řešit. Vy se ale zbaběle vyhnete zodpovědnosti.\",\"Práce a peníze\":\"Na nákup si dnes uděláte čas, jen když zatoužíte po něčem, co doma zrovna chybí. Aspoň ušetříte.\",\"Děti a rodina\":\"Snažte se jíst pravidelně. Jídelníček nemusí doznat zásadních změn, ale malé úpravy prospějí celé rodině.\"}},{\"guid\":\"vodnar\",\"categories\":{\"General\":\"Budete-li k sobě upřímní, přiznáte si, že svou práci trochu šidíte. Možná byste měli uvažovat o změně místa, a možná dokonce o dalším vzdělávání.\",\"Sex a vztahy\":\"Kamarád se k vám přijde vyplakat kvůli nešťastné lásce. Což váš partner nepochopí a bude žárlit.\",\"Práce a peníze\":\"Zkušenosti přátel či příbuzných se vám budou v zaměstnání jednou hodit. Vyslechněte jejich rady.\",\"Děti a rodina\":\"Sportu se věnujte tak, abyste se moc nepřetáhli. Blízcí se ale o vás i tak velmi rádi postarají.\"}},{\"guid\":\"vahy\",\"categories\":{\"General\":\"Vyjdete-li si dnes večer do společnosti, zažijete veselou příhodu, v níž budete právě vy hrát hlavní roli. I když se nejdřív málem studem propadnete.\",\"Sex a vztahy\":\"Váš partnerský vztah naruší událost, s níž si nebudete vědět rady. Zkoušku ale zanedlouho překonáte.\",\"Práce a peníze\":\"Nebojte se přiznat sami sobě, že vás tak úplně neuspokojuje práce, kterou vykonáváte. Napravte to.\",\"Děti a rodina\":\"Potřebujete se v klidu zamyslet nad svým denním režimem. Pravidelnost je to, co mu poněkud schází.\"}},{\"guid\":\"stir\",\"categories\":{\"General\":\"Zjistíte, že protějšek bere váš vztah vážně. Naprostá věrnost je přitom jednou z nejdůležitějších podmínek. Bohužel nedokážete zapírat svoje bokovky.\",\"Sex a vztahy\":\"Budete na tom špatně, ale protějšek vás ochotně vyslechne a pomůže vám najít nějaké vhodné řešení.\",\"Práce a peníze\":\"Překvapení vám připraví člověk, který se vám dřív jevil jako nepřející sobec. Svým činem vám pomůže.\",\"Děti a rodina\":\"Nemáte-li rádi kolektivní sportování, kupte si DVD s kvalitním cvičením a oddávejte se pohybu doma.\"}}],\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046150,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"horoscope\"],\"queryHash\":\"[\\\"horoscope\\\"]\"},{\"state\":{\"data\":[{\"guid\":\"EUR\",\"exchangeRate\":24.36},{\"guid\":\"GBP\",\"exchangeRate\":28.07},{\"guid\":\"USD\",\"exchangeRate\":21.05}],\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046144,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"exchange\"],\"queryHash\":\"[\\\"exchange\\\"]\"},{\"state\":{\"data\":{\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"partnerName\":\"Chalupáři-Zahrádkáři\",\"description\":\"Články z Chalupari-Zahradkari.cz nabízejí praktický pohled na vše, co souvisí s bydlením, zahradou, údržbou domu i radostmi chatařského života. Obsah je určen čtenářům, kteří ocení jednoduché návody, chytré vychytávky, přírodní postupy a zkušenosti vycházející z každodenní praxe.\\n\\nNechybí tipy na pěstování zeleniny, péči o stromy, ochranu rostlin, ale také rady ohledně vytápění, oprav, úklidu nebo prevence domácích problémů. Styl článků je věcný, srozumitelný a zaměřený na to, co skutečně funguje – bez složitých teorií a s úctou k tradičním řešením.\\n\\nObsah osloví nejen zahrádkáře a chalupáře, ale i městské čtenáře, kteří se chtějí naučit víc o soběstačnosti, sezónní péči o domov nebo o tom, jak si jednoduše a účelně poradit s běžnými úkoly kolem domu.\\n\\nChalupari-Zahradkari.cz přináší články, které čtenářům pomáhají zvládat domácnost a zahradu s klidem, nadhledem a často i s využitím osvědčených metod, které znaly už předchozí generace.\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\",\"partnerUrl\":\"https://chalupari-zahradkari.cz\",\"slug\":\"chalupari-zahradkari-z4c_qn_W_uRatgMUKGlJl\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046515,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"feedDetail\",\"z4c_qn_W_uRatgMUKGlJl\"],\"queryHash\":\"[\\\"feedDetail\\\",\\\"z4c_qn_W_uRatgMUKGlJl\\\"]\"},{\"state\":{\"data\":{\"id\":96541,\"guid\":\"633ec7a8-1813-5b98-8924-0829278e5035\",\"feed\":{\"id\":82,\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"companyId\":10,\"contactId\":null,\"type\":\"rss\",\"partnerName\":\"Chalupáři-Zahrádkáři\",\"partnerUrl\":\"https://chalupari-zahradkari.cz\",\"description\":\"Články z Chalupari-Zahradkari.cz nabízejí praktický pohled na vše, co souvisí s bydlením, zahradou, údržbou domu i radostmi chatařského života. Obsah je určen čtenářům, kteří ocení jednoduché návody, chytré vychytávky, přírodní postupy a zkušenosti vycházející z každodenní praxe.\\n\\nNechybí tipy na pěstování zeleniny, péči o stromy, ochranu rostlin, ale také rady ohledně vytápění, oprav, úklidu nebo prevence domácích problémů. Styl článků je věcný, srozumitelný a zaměřený na to, co skutečně funguje – bez složitých teorií a s úctou k tradičním řešením.\\n\\nObsah osloví nejen zahrádkáře a chalupáře, ale i městské čtenáře, kteří se chtějí naučit víc o soběstačnosti, sezónní péči o domov nebo o tom, jak si jednoduše a účelně poradit s běžnými úkoly kolem domu.\\n\\nChalupari-Zahradkari.cz přináší články, které čtenářům pomáhají zvládat domácnost a zahradu s klidem, nadhledem a často i s využitím osvědčených metod, které znaly už předchozí generace.\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\",\"sourceUrl\":\"https://chalupari-zahradkari.cz/wp-json/abc-media/v1/feed/centrum\",\"slug\":\"chalupari-zahradkari-z4c_qn_W_uRatgMUKGlJl\",\"note\":\"poznamka\",\"active\":true,\"economiaFeed\":false,\"downloadPeriod\":900,\"paywall\":false,\"skipImages\":false,\"autoPublishing\":true,\"canonical\":true,\"companySwitchedFrom\":null,\"createdAt\":\"2025-07-18T12:07:30.000Z\",\"updatedAt\":\"2025-07-31T06:07:17.000Z\"},\"feedId\":82,\"block\":null,\"blockId\":null,\"title\":\"Bramborové slupky dělají s úrodou divy. Stačí pár kroků a záhony plodí víc, než stíháte sklízet\",\"description\":\"Pokud chcete vyživit svou zahradu přírodně, naučte se, jak používat bramborové slupky jako hnojivo pro všechny plodiny\",\"url\":\"https://chalupari-zahradkari.cz/tipy/bramborova-slupka-hnojivo/\",\"slug\":\"bramborove-slupky-delaji-s-urodou-divy-staci-par-kroku-a-zahony-plodi-vic-nez-stihate-sklizet-633ec7a8-1813-5b98-8924-0829278e5035\",\"categories\":[\"Tipy\"],\"type\":\"article\",\"source\":null,\"label\":null,\"order\":0,\"verified\":false,\"canonical\":true,\"seoTitle\":null,\"hash\":\"a632cddb931b3316d1273b786ad1da93\",\"discussionId\":null,\"redirectOnly\":false,\"content\":\"$61\",\"readingTime\":2,\"note\":null,\"reviewRemovedImages\":false,\"reviewProcessedImages\":true,\"paywall\":false,\"alternativeTitle\":null,\"alternativeImage\":null,\"imagesChecked\":false,\"keywords\":null,\"recombee\":false,\"audio\":false,\"blockAddedAt\":null,\"originalPublishedAt\":\"2025-10-11T07:09:00.000Z\",\"publishedAt\":\"2025-10-11T07:09:00.000Z\",\"createdAt\":\"2025-10-11T05:15:37.000Z\",\"updatedAt\":\"2025-10-11T05:15:40.000Z\",\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/a0ac03a8-4043-4ef1-4b77-3175b9c53f00/public\",\"type\":\"image\",\"title\":\"Bramborové slupky dělají s úrodou divy. Stačí pár kroků a záhony plodí víc, než stíháte sklízet\",\"text\":\"Zdroj fotografie: iStock\",\"credit\":\"Zdroj fotografie: iStock\"}],\"processedContent\":\"$62\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046617,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"article\",\"633ec7a8-1813-5b98-8924-0829278e5035\"],\"queryHash\":\"[\\\"article\\\",\\\"633ec7a8-1813-5b98-8924-0829278e5035\\\"]\"},{\"state\":{\"data\":{\"items\":[{\"guid\":\"ad087861-985f-5bcb-8b8f-a917d87d6e46\",\"feed\":{\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"name\":\"Chalupáři-Zahrádkáři\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\"},\"title\":\"Majitelé skleníku musí na podzim jednat včas. Kdo zanedbá základní kroky, riskuje choroby plodů i přemnožení škůdců\",\"description\":\"Pokud nevíte, jak připravit skleník na novou sezónu, zopakujte si základní pravidla. Nepřekvapí vás choroby ani škůdci.\",\"url\":\"https://chalupari-zahradkari.cz/tipy/jak-vycistit-sklenik-podzim/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=chalupari-zahradkari.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"majitele-skleniku-musi-na-podzim-jednat-vcas-kdo-zanedba-zakladni-kroky-riskuje-choroby-plodu-i-premnozeni-skudcu-ad087861-985f-5bcb-8b8f-a917d87d6e46\",\"categories\":[\"Tipy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/fe8767f7-b80a-4a4f-bbdf-07cbdda61900/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: iStock\",\"title\":\"Majitelé skleníku musí na podzim jednat včas. Kdo zanedbá základní kroky, riskuje choroby plodů i přemnožení škůdců\",\"text\":\"Zdroj fotografie: iStock\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T08:12:00.000Z\"},{\"guid\":\"61b5d2a4-706a-5b1c-87f1-8aae98b698c6\",\"feed\":{\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"name\":\"Chalupáři-Zahrádkáři\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\"},\"title\":\"Není třeba kupovat novou. Připálená žehlička se dá snadno vyčistit díky babské radě a tajemství z lékárny\",\"description\":\"Žehlička stejně jako každý jiný spotřebič potřebuje údržbu. A pokud se připeče něco na její žehlicí plochu, musíte zasáhnout okamžitě.\",\"url\":\"https://chalupari-zahradkari.cz/tipy/levne-vycisteni-spalene-zehlicky/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=chalupari-zahradkari.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"neni-treba-kupovat-novou-pripalena-zehlicka-se-da-snadno-vycistit-diky-babske-rade-a-tajemstvi-z-lekarny-61b5d2a4-706a-5b1c-87f1-8aae98b698c6\",\"categories\":[\"Tipy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/043507f7-fe91-40ee-e455-e9f6f01c6c00/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: iStock\",\"title\":\"Není třeba kupovat novou. Připálená žehlička se dá snadno vyčistit díky babské radě a tajemství z lékárny\",\"text\":\"Zdroj fotografie: iStock\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T07:26:00.000Z\"},{\"guid\":\"e57c5653-263d-53e9-b494-03b646cdca0e\",\"feed\":{\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"name\":\"Chalupáři-Zahrádkáři\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\"},\"title\":\"Spíž plná potravinových molů dokáže rozčílit každého. Zlatá rada si ale poradí i s tou největší kolonií bez slitování\",\"description\":\"Potravinoví moli jsou v domácnosti vážným problémem. Dokážou velmi rychleji znehodnotit zásoby potravin, zbavte se jich.\",\"url\":\"https://chalupari-zahradkari.cz/tipy/jak-na-potravinove-moly/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=chalupari-zahradkari.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"spiz-plna-potravinovych-molu-dokaze-rozcilit-kazdeho-zlata-rada-si-ale-poradi-i-s-tou-nejvetsi-kolonii-bez-slitovani-e57c5653-263d-53e9-b494-03b646cdca0e\",\"categories\":[\"Tipy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/9b68084d-a53e-4ae9-5158-542a7ed3f900/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: iStock\",\"title\":\"Spíž plná potravinových molů dokáže rozčílit každého. Zlatá rada si ale poradí i s tou největší kolonií bez slitování\",\"text\":\"Zdroj fotografie: iStock\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":3,\"publishedAt\":\"2025-10-13T07:09:00.000Z\"},{\"guid\":\"2032491c-390a-5383-89c9-68410973eca4\",\"feed\":{\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"name\":\"Chalupáři-Zahrádkáři\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\"},\"title\":\"Povinné ošetření zahrady před zimou má svůj důvod. Jediná přísada z kuchyně zvládne plevel i přípravu půdy na další sezónu\",\"description\":\"Odplevelení zahrady na podzim je nezbytné, i když vyčerpávající opatření. Prováděné práce si však lze značně usnadnit.\",\"url\":\"https://chalupari-zahradkari.cz/tipy/jak-se-zbavit-plevele-2/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=chalupari-zahradkari.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"povinne-osetreni-zahrady-pred-zimou-ma-svuj-duvod-jedina-prisada-z-kuchyne-zvladne-plevel-i-pripravu-pudy-na-dalsi-sezonu-2032491c-390a-5383-89c9-68410973eca4\",\"categories\":[\"Tipy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/bade2896-6de5-41a0-2150-6616bd2cf300/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: iStock\",\"title\":\"Povinné ošetření zahrady před zimou má svůj důvod. Jediná přísada z kuchyně zvládne plevel i přípravu půdy na další sezónu\",\"text\":\"Zdroj fotografie: iStock\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T06:39:00.000Z\"},{\"guid\":\"7b67ad09-b0de-54b0-9001-a17363f87d0c\",\"feed\":{\"guid\":\"z4c_qn_W_uRatgMUKGlJl\",\"name\":\"Chalupáři-Zahrádkáři\",\"logo\":\"https://chalupari-zahradkari.cz/wp-content/uploads/2022/08/calipari-zahradkari-ico.png\"},\"title\":\"Rozdíl mezi ručním mytím a myčkou není takový, jak si mnozí myslí. Experti prozradili, co je skutečně výhodnější\",\"description\":\"O výhodnosti nebo nevýhodnosti tohoto spotřebiče se stále vedou spory. Podívejte se, kolik elektřiny myčky nádobí reálně spotřebuje.\",\"url\":\"https://chalupari-zahradkari.cz/tipy/kolik-elektriny-spotrebuje-mycka-nadobi/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=chalupari-zahradkari.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"rozdil-mezi-rucnim-mytim-a-myckou-neni-takovy-jak-si-mnozi-mysli-experti-prozradili-co-je-skutecne-vyhodnejsi-7b67ad09-b0de-54b0-9001-a17363f87d0c\",\"categories\":[\"Tipy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/63e5c85d-419c-4e45-9d32-920219ba9300/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: iStock\",\"title\":\"Rozdíl mezi ručním mytím a myčkou není takový, jak si mnozí myslí. Experti prozradili, co je skutečně výhodnější\",\"text\":\"Zdroj fotografie: iStock\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T06:20:00.000Z\"}],\"count\":808},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393046675,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"detailRelated\",\"z4c_qn_W_uRatgMUKGlJl\",5,0],\"queryHash\":\"[\\\"detailRelated\\\",\\\"z4c_qn_W_uRatgMUKGlJl\\\",5,0]\"},{\"state\":{\"data\":{\"guid\":\"V3FHCvIMlehRMrn-Gev_o\",\"partnerName\":\"KINOTIP2.cz\",\"description\":\"Pokud vás baví filmy, seriály a život herců nejen na plátně, Kinotip2.cz má co nabídnout. Obsah se točí kolem známých tváří, oblíbených pořadů a toho, co se děje před kamerou i za ní. Vše podané svižně, přehledně a často s lehkým bulvárním odstínem – tak akorát pro nenáročné večerní čtení i rychlé novinky během dne.\\n\\nWeb se nebojí přinášet názory, komentáře a připomínat slavné scény, které diváci nosí v hlavě roky. Nechybí ani zákulisní informace, nové role, návraty na obrazovku nebo nostalgické ohlédnutí za hvězdami, které formovaly televizní i filmovou historii.\\n\\nKinotip2.cz mluví řečí fanoušků. Žádná suchá fakta, ale přístup k obsahu, který dává prostor emocím, vzpomínkám i malému šoku ze zvratů v životech slavných. Skvělé pro čtenáře, kteří si u čtení chtějí odpočinout a zároveň mít přehled, co právě běží, končí nebo se vrací na scénu.\",\"logo\":\"https://www.kinotip2.cz/kinotip-logo-32-32.png\",\"partnerUrl\":\"https://www.kinotip2.cz\",\"slug\":\"kinotip2cz-V3FHCvIMlehRMrn-Gev_o\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393047391,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"feedDetail\",\"V3FHCvIMlehRMrn-Gev_o\"],\"queryHash\":\"[\\\"feedDetail\\\",\\\"V3FHCvIMlehRMrn-Gev_o\\\"]\"},{\"state\":{\"data\":{\"id\":97718,\"guid\":\"6ef369cc-9693-5658-a78a-b683452a8f8a\",\"feed\":{\"id\":32,\"guid\":\"V3FHCvIMlehRMrn-Gev_o\",\"companyId\":7,\"contactId\":7,\"type\":\"rss\",\"partnerName\":\"KINOTIP2.cz\",\"partnerUrl\":\"https://www.kinotip2.cz\",\"description\":\"Pokud vás baví filmy, seriály a život herců nejen na plátně, Kinotip2.cz má co nabídnout. Obsah se točí kolem známých tváří, oblíbených pořadů a toho, co se děje před kamerou i za ní. Vše podané svižně, přehledně a často s lehkým bulvárním odstínem – tak akorát pro nenáročné večerní čtení i rychlé novinky během dne.\\n\\nWeb se nebojí přinášet názory, komentáře a připomínat slavné scény, které diváci nosí v hlavě roky. Nechybí ani zákulisní informace, nové role, návraty na obrazovku nebo nostalgické ohlédnutí za hvězdami, které formovaly televizní i filmovou historii.\\n\\nKinotip2.cz mluví řečí fanoušků. Žádná suchá fakta, ale přístup k obsahu, který dává prostor emocím, vzpomínkám i malému šoku ze zvratů v životech slavných. Skvělé pro čtenáře, kteří si u čtení chtějí odpočinout a zároveň mít přehled, co právě běží, končí nebo se vrací na scénu.\",\"logo\":\"https://www.kinotip2.cz/kinotip-logo-32-32.png\",\"sourceUrl\":\"https://www.kinotip2.cz/rss/msn-eco.html\",\"slug\":\"kinotip2cz-V3FHCvIMlehRMrn-Gev_o\",\"note\":\"Single Queen, s.r.o.\\nNa Folimance 15, 120 00 Praha 2\",\"active\":true,\"economiaFeed\":false,\"downloadPeriod\":600,\"paywall\":false,\"skipImages\":false,\"autoPublishing\":true,\"canonical\":true,\"companySwitchedFrom\":null,\"createdAt\":\"2024-10-09T11:51:05.000Z\",\"updatedAt\":\"2025-07-31T05:25:12.000Z\"},\"feedId\":32,\"block\":null,\"blockId\":null,\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"description\":\"Erik sice tvrdí, že si ji neobjednal, ale kamarádi mu moc nevěří. Tak nebo tak, u Klímových doma se ocitne bizarní nafukovací panna. Karla mezitím nalézá ztracenou Agátu a domlouvá pro ni chráněné bydlení. Šéf Mikeš se ale dozví něco, co ho nepotěší.\",\"url\":\"https://www.kinotip2.cz/clanky/ulice-zitra-4990-20251013-14623.html\",\"slug\":\"zitra-v-ulici-v-utery-nas-ceka-humorna-epizoda-s-nafukovaci-pannou-a-vytoceny-mikes-6ef369cc-9693-5658-a78a-b683452a8f8a\",\"categories\":[\"Seriál Ulice\"],\"type\":\"article\",\"source\":null,\"label\":null,\"order\":0,\"verified\":false,\"canonical\":true,\"seoTitle\":null,\"hash\":\"afa5d8ef6d0b1446ef9cf17c85fa907b\",\"discussionId\":null,\"redirectOnly\":false,\"content\":\"$63\",\"readingTime\":2,\"note\":null,\"reviewRemovedImages\":false,\"reviewProcessedImages\":true,\"paywall\":false,\"alternativeTitle\":null,\"alternativeImage\":null,\"imagesChecked\":false,\"keywords\":null,\"recombee\":false,\"audio\":false,\"blockAddedAt\":null,\"originalPublishedAt\":\"2025-10-13T21:10:00.000Z\",\"publishedAt\":\"2025-10-13T21:10:00.000Z\",\"createdAt\":\"2025-10-13T21:16:46.000Z\",\"updatedAt\":\"2025-10-13T21:16:48.000Z\",\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/860648da-4046-4bf5-d56e-74455c31bb00/public\",\"type\":\"image\",\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"text\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"credit\":\"TV Nova\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/896c3ccc-fed8-4f41-b68a-ce779d2c6400/public\",\"type\":\"image\",\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"text\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"credit\":\"TV Nova\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/ce5ab40d-a828-4c90-c71d-b6c281936d00/public\",\"type\":\"image\",\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"text\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"credit\":\"TV Nova\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/fb3856bd-307f-4de0-8655-773682cc5600/public\",\"type\":\"image\",\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"text\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"credit\":\"TV Nova\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/df063053-94d9-4de1-fdc8-0c15e993ee00/public\",\"type\":\"image\",\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"text\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"credit\":\"TV Nova\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/8a3fc995-83ec-4897-4879-dd36540c2300/public\",\"type\":\"image\",\"title\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"text\":\"Zítra v Ulici: V úterý nás čeká humorná epizoda s nafukovací pannou a vytočený Mikeš\",\"credit\":\"TV Nova\"}],\"processedContent\":\"$64\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393047428,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"article\",\"6ef369cc-9693-5658-a78a-b683452a8f8a\"],\"queryHash\":\"[\\\"article\\\",\\\"6ef369cc-9693-5658-a78a-b683452a8f8a\\\"]\"},{\"state\":{\"data\":{\"items\":[{\"guid\":\"6cd36032-a6a7-567b-8a28-a99ed59a304f\",\"feed\":{\"guid\":\"V3FHCvIMlehRMrn-Gev_o\",\"name\":\"KINOTIP2.cz\",\"logo\":\"https://www.kinotip2.cz/kinotip-logo-32-32.png\"},\"title\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\",\"description\":\"Jako tichý stín se plazí detektivní hrou Zrádci spánková deprivace jejích účastníků. A to nejen hráčů, ale i štábu. Natáčení šestého dílu, který uvedla prima+, se podepsalo na všech, bez spánku totiž točili dva dny v kuse. Mohla za to náročná noční mise a zrádkyně Mia, která zkomplikovala natáčecí den.\",\"url\":\"https://www.kinotip2.cz/clanky/zradci-mia-neomylne-miri-do-finale-soutezici-ji-veri-stab-ji-proklina-kvuli-ni-jeli-bez-spanku-dva-dny-v-kuse-20251013-14625.html?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=www.kinotip2.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"zradci-mia-neomylne-miri-do-finale-soutezici-ji-veri-stab-ji-proklina-kvuli-ni-jeli-bez-spanku-dva-dny-v-kuse-6cd36032-a6a7-567b-8a28-a99ed59a304f\",\"categories\":[\"Reality show\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/096226f1-85d3-4a77-0bb8-019234914a00/public\",\"type\":\"image\",\"credit\":\"FTV Prima\",\"title\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\",\"text\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/eb45eec7-7b7f-4715-77cd-098fc7a4bb00/public\",\"type\":\"image\",\"credit\":\"FTV Prima\",\"title\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\",\"text\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/8a82ff8d-92d6-45e6-d5fe-a9f258344800/public\",\"type\":\"image\",\"credit\":\"FTV Prima\",\"title\":\"Zrádci: Mia neomylně míří