{"id":1148,"objectType":9,"contentType":1104,"name":1149,"text":1150,"segment":13,"type":1151,"image":2589},{"id":1108,"objectType":9,"contentType":92,"name":1109,"image":2590,"altText":1112,"alt":1112},{"id":1111,"objectType":96,"title":1112,"description":1112,"file":2591},{"url":1114,"details":2592,"fileName":1120,"contentType":1121},{"size":1116,"image":2593},{"width":1118,"height":1119},"2025-01-23",{"id":2596,"objectType":9,"contentType":1161,"name":2597,"width":1162,"alignment":1224,"aspectRatio":1399,"image":2598},"30PMVY96WdKEVADtn1DyuV","Galaxy S25 AI",{"id":2599,"objectType":9,"contentType":92,"name":2597,"image":2600},"70tmalZoOsF4n6XA3Dlyns",{"id":2601,"objectType":96,"title":2597,"description":50,"file":2602},"5iYWziiOZAZyZg55z01IUm",{"url":2603,"details":2604,"fileName":2607,"contentType":1142},"//images.ctfassets.net/zuadwp3l2xby/5iYWziiOZAZyZg55z01IUm/1b38f13e26bdcd55505e2c7a92a2cb25/Galaxy_S25_AI_Blog.jpg",{"size":2605,"image":2606},70828,{"width":2492,"height":2493},"Galaxy_S25_AI_Blog.jpg",{"id":2599,"objectType":9,"contentType":92,"name":2597,"image":2609},{"id":2601,"objectType":96,"title":2597,"description":50,"file":2610},{"url":2603,"details":2611,"fileName":2607,"contentType":1142},{"size":2605,"image":2612},{"width":2492,"height":2493},"Wat is Galaxy AI en wat kan je ermee?","Galaxy AI is het kunstmatige intelligentie systeem van Samsung. Het is jouw persoonlijke assistent die je steeds beter leert kennen. En je daardoor stapje bij beetje beter kan helpen om je dagelijkse handelingen makkelijker te maken. Galaxy AI zit ingebouwd in sommige Samsung smartphones, zoals de Samsung Galaxy S25 en S24. In deze blog lees je wat je zoal met Galaxy AI kan, zoals Circle to Search, Photo Assist en Chat Assist.",{"title":126},{"id":2617,"objectType":9,"contentType":300,"name":2618,"isVerticalView":20,"image":2619,"isImagePositionRight":20,"title":2635,"navigation":2636,"heading":2644},"7IzLSeFpVSRESwHcoBZaJY","KPN Online Ouderavond ‘Stukje van mij’ - Bl