.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob > li:not(:last-of-type){margin-bottom: 10px;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob > li > a{ color: #fff; line-height: 20px; font-size: 13px; font-weight: 400; letter-spacing: .05em;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob > li > a.telphone{display: inline-block;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob > li > a.seller-center span{ display: block; color: #fff; font-size: 14px; font-weight: 500; line-height: 20px;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob > li > a.seller-center img{width:62px; vertical-align: top; object-fit: contain;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob.link_blank_mob li{ margin-bottom: 15px;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob.link_blank_mob li:last-child{ margin-bottom: 0;}
.iopen-footer .iopen-footer-list-mob > ul > li > ul.footer_menutext_mob.link_blank_mob img{ position: relative; top: 4px;}
