    <script>
        $(document).ready(function () {
            $('body').click(function (e) {
                $('#MainBar .nav-item.show').removeClass('show');
                //$('.nav-item.clicked').removeClass('clicked');
                $('#MainBar .dropdown-menu.show').removeClass('show');
            });

            $(document).click(function (e) {
                if (!$(e.target).is('#MainBar')) {
                    $('#MainBar .collapse').collapse('hide');
                }
            });

            $('#MainBar .nav-item').click(function (e) {
                $(this).addClass('clicked');
            });

            $('#MainBar .nav-item').hover(function (e) {
                if ($('.nav-item.show').length < 1) {
                    $('.nav-item.clicked').removeClass('clicked');
                }
                if ($('.nav-item.clicked').length < 1) {
                    $('.nav-item.show').removeClass('show');
                    $('.dropdown-menu.show').removeClass('show');
                    $dd = $(this).find('.dropdown-menu');
                    $dd.parent().addClass('show');
                    $dd.addClass('show');
                }
            });
        });
    </script>

    <script src="../js/Matomo.js" type="text/javascript"></script>

    
    <!-- Script para el correcto funcionamiento de fancybox -->
    <script>

        //Inhabilitamos las cookies en los modales que trabajan con iframes.
        $(".iframe").fancybox({
            type: 'iframe',
            //Reducimos el tamaño de la linea del modal
            padding: 7,
            afterShow: function () {
                $("iframe").contents().find("#cookieChoiceInfo").css({ "display": "none" });
            }
        });

        function CheckDomain2() {
            var dom_name = $('#txt_domain_name2').val().replace(/ /g, "");
            var dom_ext = $('#txt_domain_ext2').val().replace(/ /g, "");
            var op = $('input[name=domain_operation2]:radio:checked').val();

            if (op == "REG") {
                location.href = "Regdomain.aspx?d=" + dom_name + "&e=" + dom_ext;
            } else if (op == "TRA") {
                location.href = "Transferdomain.aspx?d=" + dom_name + "&e=" + dom_ext;
            }
        }

        //Los dos metodos siguientes se encargan de hacer funcionar la tecla enter en el search box de buscar dominios

        //Metodo que desactiva la tecla enter para los input (su uso por default)
        $(document).ready(function () {
            $(window).keydown(function (event) {
                if (event.keyCode == 13) {
                    event.preventDefault();
                    return false;
                }
            });
        });

        //Capturamos la tecla enter para hacerle un click al boton de busqueda
        function enterButtonSearchDomain(e) {
            if (e.keyCode === 13) {
                var searchButton = document.getElementById('searchButtonDomain');
                searchButton.click();
                window.removeEventListener('keydown', enterButtonSearchDomain);
            }
        }

        //Agrega el listener para el metodo enterButtonSearchDomain cuando se pulse una tecla
        window.addEventListener('keydown', enterButtonSearchDomain);




    </script>
    <script type="text/javascript">
        $("#a_affiliation").click(function () {
            $('#myModal').modal('show');
        });
    </script>

