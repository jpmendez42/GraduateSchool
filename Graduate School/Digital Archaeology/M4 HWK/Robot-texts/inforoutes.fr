<script id='script-653e8708c132c-js' type='text/javascript'>
// custom actions
jQuery(document).ready(function($){
    $('.btn-ico--plus').on( "click", function() {
        if ($(this).hasClass('closed')){
            $(this).toggleClass('closed').siblings('.branches_wrap').toggleClass('closed');
            $(this).siblings('.lire-la-suite').find('div').toggleClass('visible');
        } else if($(this).not('.closed')) {
            $(this).toggleClass('closed').addClass('scrollableUp').siblings('.branches_wrap ').toggleClass('closed');
            $(this).siblings('.lire-la-suite').find('div').toggleClass('visible');
        } 
    });
    $('.btn-ico--plus').on( "click", function() {
        if ($(this).hasClass('scrollableUp')){
            $(this).toggleClass('scrollableUp');
             $('html, body').animate({
                scrollTop: $(".branches_wrap .branches__wrap:last-child").offset().top
            }, 4000);
        } else if($(this).not('.scrollableUp')) {
           $('html, body').animate({
                scrollTop: $(".branches_wrap").offset().top
            }, 3000);
            $(this).toggleClass('scrollableUp');
        } 
    });
});

</script>
