                display: table-cell;
            }
            .no_javascript_box
            {
                text-align: center;
                padding: 2%;
                border: 3px solid lightpink;
                background-color: #FFE5D4;
                animation: color_pulse 2s infinite;
            }
            @keyframes color_pulse
