<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="cache-control" content="no-cache" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="googlebot" content="noarchive" />
    <title>Störung</title>
    <style>
      body {
        text-align: center;
        margin: 0px;
        font-family: "Roboto", sans-serif;
      }
      h1 {
        margin-bottom: 20px;
      }
      .beck-header-shape-container {
        height: 10px;
        position: relative;
        width: 100%;
      }
      .beck-header-shape-middle {
        position: relative;
        width: 100%;
        height: 10px;
      }
      .beck-header-shape-container {
        height: 10px;
        position: relative;
        width: 100%;
      }
      .beck-header-shape-attachment {
        position: absolute;
        left: -1px;
        margin-left: 85%;
        width: 20px;
        height: 10px;
      }
      .beck-header-shape-attachment-rotate {
        position: absolute;
        right: -1px;
        margin-right: 85%;
        width: 20px;
        height: 10px;
        transform: rotate(-180deg);
      }
      .beck-header-shape {
        right: 0px;
        width: 85%;
        position: absolute;
      }
      .beck-header {
        position: absolute;
        background: #bd2826;
        height: 10px;
      }
      .beck-header-shape-rotate {
        left: 0;
        width: 85%;
        transform: rotate(-180deg);
      }
      .beck-headline-1 {
        color: #bd2826;
        margin-bottom: 1rem;
        font-weight: 500;
        line-height: 1.2;
        font-size: max(3rem, 1.375rem + 1.5vw);
      }
      .beck-headline-2 {
        color: #bd2826;
        margin-top: 0;
        margin-bottom: 1rem;
        font-weight: 400;
        line-height: 1.2;
        font-size: max(1.5rem, 0.7rem + 1.5vw);
      }
      .beck-subheadline-1 {
        color: #737373;
        font-size: 18px;
      }
      .beck-link-primary {
        color: #bd2826;
        text-decoration: none;
      }
      .beck-header-container {
        padding-right: 24px;
        padding-left: 24px;
        display: flex;
        flex-wrap: inherit;
        align-items: center;
        justify-content: space-between;
        margin: 0% 15%;
        padding-top: 8px;
        padding-bottom: 8px;
      }
      ul {
        list-style: none;
      }
      .social-media li {
        padding-top: 5px;
      }
      footer {
        display: flex;
        flex-direction: row;
        justify-content: center;
        margin-top: 50px;
        font-size: 0.917em;
      }
      footer div > ul.separated > li:before {
        content: "|";
        padding: 0 2px 0 4px;
        display: inline-block;
        color: gray;
      }
      footer div > ul.separated > li:first-child:before {
        content: "";
      }
      footer div > ul > li,
      footer div > ul > li > a {
        color: #bd2826;
        text-decoration: none;
      }
      footer ul {
        flex: 0 1 auto;
        display: flex;
        margin: 5px 0;
      }
      .beck-separator {
        color: #9f9f9f;
      }
      hr {
        margin: 1rem 0;
        color: inherit;
        border: 0;
        border-top: 1px solid;
        opacity: 0.25;
      }
      @media only screen and (min-width: 768px) {
        .beck-page-container {
          margin: 0 15%;
        }
      }
      .triangle-container {
        padding-top: 22px;
        padding-bottom: 10px;
        position: relative;
      }
      .triangle {
        position: relative;
        background-color: #bd2826;
        text-align: left;
        margin-top: 25px;
        margin-left: 49%;
      }
      .triangle:before,
      .triangle:after {
        content: "";
        position: absolute;
        background-color: inherit;
      }
      .triangle,
      .triangle:before,
      .triangle:after {
        width: 4em;
        height: 4em;
        border-top-right-radius: 30%;
      }

      .triangle {
        transform: rotate(-60deg) skewX(-30deg) scale(1, 0.866);
      }
      .triangle:before {
        transform: rotate(-135deg) skewX(-45deg) scale(1.414, 0.707) translate(0, -50%);
      }
      .triangle:after {
        transform: rotate(135deg) skewY(-45deg) scale(0.707, 1.414) translate(50%);
      }
      .triangle-exclamation {
        display: block;
        position: absolute;
        top: 48px;
        margin-left: 49%;
        left: 21px;
        font-size: max(5rem, 1.375rem + 1.5vw);
        color: white;
      }
    </style>
  </head>
  <body>
    <div class="beck-header-container">
      <img
        src="data:image/png;base64,"
        alt=""
      />
    </div>
    <div>
      <div class="beck-header-shape-container">
        <svg viewBox="0 0 100 100" preserveAspectRatio="none" class="beck-header-shape-attachment-rotate">
          <path d="M0,0 L100,0 C25,50 50,75 0,100z" fill="#BD2826"></path>
        </svg>
        <div class="beck-header beck-header-shape"></div>
      </div>
      <!-- <div class="beck-header beck-header-shape-middle"></div> -->
      <div class="beck-header-shape-container">
        <svg viewBox="0 0 100 100" preserveAspectRatio="none" class="beck-header-shape-attachment">
          <path d="M0,0 L100,0 C25,50 50,75 0,100z" fill="#BD2826"></path>
        </svg>
        <div class="beck-header beck-header-shape-rotate"></div>
      </div>
    </div>

    <div class="beck-page-container">
      <div class="triangle-container">
        <div class="triangle"></div>
        <div class="triangle-exclamation">!</div>
      </div>
      <h1 class="beck-headline-1">Seite nicht gefunden</h1>
      <h2 class="beck-headline-2">Die von Ihnen angegebene Seite existiert nicht.</h2>
    </div>

    <footer class="footer">
      <div class="service">
        <ul class="column separated">
          <li>
            <a href="https://rsw.beck.de/impressum" title="Impressum" target="_blank">Impressum</a>
          </li>
          <li>
            <a href="https://rsw.beck.de/datenschutz" target="_blank" title="Datenschutzerklärung">Datenschutz</a>
          </li>
          <li>
            <a href="https://rsw.beck.de/agb" target="_blank">AGB</a>
          </li>
        </ul>
      </div>
    </footer>
  </body>
</html>
