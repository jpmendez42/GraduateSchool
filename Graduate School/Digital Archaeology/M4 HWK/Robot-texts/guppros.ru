<!-- Cкрипт для остановки слайдов при наведении курсора -->
<script>
	document.addEventListener('DOMContentLoaded', () => {
		document
			.querySelectorAll('.js-uikit-slider')
			.forEach(el => {
				const pauseOnHover = el.dataset.mouseOverStop === '1';
				if (!pauseOnHover) return;

				const slider = UIkit.slider(el);

				el.addEventListener('mouseenter', () => slider.stopAutoplay());
				el.addEventListener('mouseleave', () => slider.startAutoplay());
			});

		document.querySelectorAll('.header-slider .js-uikit-slider').forEach(item => {
			const slider_items = item.querySelectorAll('.header-slider__container__photo').length ? Array.from(item.querySelectorAll('.header-slider__container__photo')) : Array.from(item.querySelectorAll('.item-title-container'));
			function sliderItemShown(event, cur_slide){
				const slider = UIkit.slider(event.target);
				const current_slider_item = cur_slide??event.srcElement;
				const detail_button = item.querySelector('.uk-slider-controls-block .slide-container__button');
				const detail_button_text = detail_button.querySelector('span');
				console.log(current_slider_item, current_slider_item.getAttribute('data-btn-link'), current_slider_item.getAttribute('data-btn-text'));

				if (current_slider_item.getAttribute('data-btn-link') && current_slider_item.getAttribute('data-btn-text')) {
					detail_button.onclick = () => location.href = current_slider_item.getAttribute('data-btn-link');
					detail_button_text.innerText = current_slider_item.getAttribute('data-btn-text');
					detail_button.classList.remove('displayN');
				} else {
					detail_button.classList.add('displayN');
				}

			}
			item.addEventListener('itemshown', sliderItemShown);
			sliderItemShown(item, slider_items[0]);
		})
	});
</script><br>
