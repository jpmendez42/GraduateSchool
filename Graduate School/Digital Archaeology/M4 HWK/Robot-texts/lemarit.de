	<script type="text/javascript">window.addEventListener('DOMContentLoaded', function() {
        window.addEventListener("load", () => {
            const $ = (clazz) => {
                const elements = document.getElementsByClassName(clazz);
                if (elements.length === 0) return null;
                else return elements[0];
            };

            const navigateTo = (page) => {
                if (window.location.href.includes("/en/")) {
                    window.location = `https://www.lemarit.com/en/${page}`;
                } else {
                    window.location = `https://www.lemarit.com/${page}`;
                }
            };

            // Home
            const dbp = $("dbp-home");
            if (dbp != null) {
                dbp.addEventListener("click", () => {
                    navigateTo("digital-brand-protection");
                });
            }
            const cdm = $("cdm-home");
            if (cdm != null) {
                cdm.addEventListener("click", () => {
                    navigateTo("corporate-domain-management");
                });
            }
            const dbs = $("dbs-home");
            if (dbs != null) {
                dbs.addEventListener("click", () => {
                    navigateTo("dotbrand-services");
                });
            }
            const dsec = $("ds-home");
            if (dsec != null) {
                dsec.addEventListener("click", () => {
                    navigateTo("digital-security");
                });
            }

			const dkon = $("kontakt");
            if (dkon != null) {
                dkon.addEventListener("click", () => {
                    navigateTo("kontakt");
                });
            }
			const dcon = $("contact");
            if (dcon != null) {
                dcon.addEventListener("click", () => {
                    navigateTo("contact");
                });
            }
			const dkar = $("karriere");
            if (dkar != null) {
                dkar.addEventListener("click", () => {
                    navigateTo("karriere");
                });
            }
			const dcar = $("career");
            if (dcar != null) {
                dcar.addEventListener("click", () => {
                    navigateTo("career");
                });
            }

			const danm = $("anmelden");
            if (danm != null) {
                danm.addEventListener("click", () => {
                    navigateTo("kundenveranstaltung-2023/#anmelden");
                });
            }
			
			try {
				document.getElementById("kundenveranstaltung-2020-section-2").id = "programm";
				document.getElementById("kundenveranstaltung-2020-section-3").id = "referenten";
				document.getElementById("kundenveranstaltung-2020-section-4").id = "faq";
			} catch (error) {
				// NOOP
			}

			const addIcon = (portfolioItem, iconUrl) => {
				const wrapper = document.createElement("div");
				wrapper.className = "portfolio-icon";

				const icon = document.createElement("img");
				icon.src = iconUrl;
				wrapper.append(icon);

				portfolioItem.append(wrapper);
			};

			// https://www.lemarit.com/hh/
			for (const bars of document.getElementsByClassName("portfolio-bars")) {
				addIcon(bars, "/wp-content/uploads/2023/08/bars.svg");
			}

			for (const restaurants of document.getElementsByClassName("portfolio-restaurants")) {
				addIcon(restaurants, "/wp-content/uploads/2023/08/restaurants.svg");
			}

			for (const shopping of document.getElementsByClassName("portfolio-shopping")) {
				addIcon(shopping, "/wp-content/uploads/2023/08/shopping.svg");
			}

			for (const sightseeing of document.getElementsByClassName("portfolio-sightseeing")) {
				addIcon(sightseeing, "/wp-content/uploads/2023/08/sightseeing.svg");
			}

			for (const outsideHamburg of document.getElementsByClassName("portfolio-outside-hamburg")) {
				addIcon(outsideHamburg, "/wp-content/uploads/2023/09/outside-hamburg.svg");
			}

			for (const element of document.getElementsByClassName("portfolio_tag-tips")) {
				const text = document.createElement("span");
				text.innerText = "Tip!";
				element.append(text);
			}
        });
	});</script>
</body>

</html>

