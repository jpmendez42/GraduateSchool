        </li><li class="b-brands__item">
          <a
            href="/uk/brands/primark"
            class="b-brands__link"
          >
            <img
              class="b-brands__img js-lazy-img"
              src="https://shafa.c.prom.st/img/brand-placeholder.png"
              alt="Primark"
              data-placeholder="https://shafa.c.prom.st/img/brand-placeholder.png"
              data-src="https://uploads.shafastatic.net/uploads/brands/image_10_xMWOwCu.png"
            />
          </a>
        </li><li class="b-brands__item">
          <a
            href="/uk/brands/marks-spencer"
            class="b-brands__link"
          >
            <img
              class="b-brands__img js-lazy-img"
