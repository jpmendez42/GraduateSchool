<script type="text/javascript">

	function changeSection(section){

		// set the tab nav active state
		document.querySelectorAll('.nav-tabs li a.nav-link').forEach(function(el){
			el.classList.remove('active');
		})
		document.getElementById('tab-' + section).classList.add('active');

		// Hide all sections by removing active class
		document.querySelectorAll('.modules-section').forEach(function(el){
			el.classList.remove('active-section');
		});
    	
		// Show the selected section by adding active class
		if(document.getElementById(section + "-modules")){
    		document.getElementById(section + "-modules").classList.add('active-section');
    	}		
	}

	document.addEventListener('DOMContentLoaded', function() {
		
		// click tabbed nav section
		document.querySelectorAll('.module-tabbed-content .nav-tabs li.nav-item').forEach(function(el){
		    el.addEventListener('click',function(e){
				changeSection(e.target.id.split('-')[1]);
		    });
		});

		// change section for mobile dropdown
		document.querySelector('.module-tabbed-content .form-control.mobile-nav-select').addEventListener('change', function(){
	        changeSection(this.value);
	    });

		// change news year using dropdown
		document.getElementById('new-year-select').addEventListener('change', function(){

	        var year = this.value;
			var url = new URL(window.location.href);
			var searchParams = url.searchParams;
			searchParams.set('section', 'news');
			searchParams.set('year-date', year);
			window.location.replace(url.toString());
	    });    

	    // show hidden analyst reviews when 'view all' clicked
	    document.getElementById("view-all-reviews").addEventListener('click',function(){
	    	document.querySelectorAll('.analyst-review-cards .analyst-card .hidden').forEach(function(el){
	    		el.classList.remove('hidden')
	    	});
	    });	

	    // awards icon year clicked
	    document.querySelectorAll('.awards-section .awards-years li').forEach(function(el) {
	        el.addEventListener('click', function() {

	        	 var year = this.id.split('year-label-')[1];
	            
	            // handle selected style for year links
	            document.querySelectorAll('.awards-section ul.awards-years li').forEach(function(li){
	            	li.classList.remove('selected')
	            });
	            document.getElementById('year-label-' + year).classList.add('selected');

	            // show respective awards icons
	            document.querySelectorAll('.awards-section .awards-icons .row').forEach(function(el){
	            	el.classList.add('hidden');
	            });
	            document.querySelector('.awards-section .awards-icons .row.awards-' + year).classList.remove('hidden');
	        });
	    });

	    // map legacy slugs to sections (news, insights, awards)
	    const pathname = window.location.pathname;
	    const segments = pathname.split('/');
		const lastSlug = segments.filter(segment => segment !== "").pop();
		var lang_slug = getLang();

		// console.log("The last slug of the pathname is:", lastSlug);
		// console.log("The language slug is:", lang_slug);

		var lastSlug_translations = {
			'actualites':'news',
			'noticias':'news',
			'notizie':'news',
			'recherche':'research',
			'investigacion':'research',
			'ricerca':'research',
			'reconnaissance-analyste':'awards',
			'reconocimiento-analista':'awards',
			'riconoscimento-degli-analisti':'awards'	
		}

		var translated_last_slug = (lang_slug != 'uk' && lang_slug != 'us') ? lastSlug_translations[lastSlug] : lastSlug;
		// console.log("The translated last slug is:", translated_last_slug);

		switch(translated_last_slug){
			case 'overview':
				changeSection('overview');
				break;
			case 'news':
				changeSection('news');
				break;
			case 'research':
				changeSection('insights');
				break;
			case 'analyst-recognition':
				changeSection('awards');
				break;		
			case lastSlug_translations[lastSlug]:
				changeSection(lastSlug_translations[lastSlug]);
				break;
			default:
				changeSection('overview');
		}

	    // programatically select a section from URL params
		const urlParams = new URLSearchParams(window.location.search);
		if(urlParams.has('section')) {
		    const section = urlParams.get('section');
		    changeSection(section);
		}

	});

</script>


