 <script>class DoofinderAddToCartError extends Error {
        constructor(reason, status = "") {
            const message = "Error adding an item to the cart. Reason: " + reason + ". Status code: " + status;
            super(message);
            this.name = "DoofinderAddToCartError";
        }
    } 
    
    function addToCart(product_id, amount, statusPromise){
        product_id = parseInt(product_id);
        let properties = {
            jtl_token : "8ece8e7ee4378ee31738361e744997ccc9a4491ce3414dbefca1c0ad7a27549c"
        };
        $.evo.io().call('pushToBasket', [product_id, amount, properties], this, function(error, data) {

            if(error) {
                statusPromise.reject(new DoofinderAddToCartError(error));
            }

            let response = data.response;

            if(response){
                switch (response.nType) {
                    case 0:
                        statusPromise.reject(new DoofinderAddToCartError(response.cHints.join(' , ')));
                        break;
                    case 1:
                        statusPromise.resolve("forwarding..");
                        window.location.href = response.cLocation;
                        break;
                    case 2:
                        statusPromise.resolve("The item has been successfully added to the cart.");
                        $.evo.basket().updateCart();
                        $.evo.basket().pushedToBasket(response);
                        break;
                }
            }
        })
    }
     
    document.addEventListener("doofinder.cart.add", function(event) {
        const { item_id, amount, grouping_id, link, statusPromise } = event.detail;

        $.ajax({
            url: "https://shop.retoura.de/plugins/ws5_doofinder/addToCart.php",
            type: "POST",
            data: {
                action: 'checkForVariations',
                id: item_id,
                link: link
            },
            success: function(response) {
                if (response == 'true') {
                    window.location.href = link;
                } else {
                    addToCart(item_id, amount, statusPromise);
                }
            },
        });   
    });</script><script type="text/plain" data-consent="retoura_rtbhouse_consent">window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
        'uid': '',
        'catid': ''
    });</script> </head><body
data-headtype="0" data-page="18" class="body-offcanvas no-yt usps-visible bxt-nb mmlca-n"> <script>(function() {
    if(localStorage.consent) {
        var consent = JSON.parse(localStorage.consent);
        if(consent.settings) {
            $.post('https://shop.retoura.de/', {
                    'action': 'updateconsent',
                    'jtl_token': '8ece8e7ee4378ee31738361e744997ccc9a4491ce3414dbefca1c0ad7a27549c',
                    'data': consent.settings,
                }
            );
        }
    }
})();</script><script>(function() {
    document.addEventListener('consent.updated', function(e) {
        var denied = '';
        var granted = '';

        ['functionality_storage','personalization_storage','security_storage','retoura_bing_consent','retoura_criteo_consent','retoura_facebook_consent','retoura_ga_consent','retoura_ladenzeile_consent','retoura_rtbhouse_consent','retoura_shopping24_consent','retoura_sovendus_consent','ws5_billigerde_consent','ws5_doofinder_consent','ws5_sendinblue_consent','upwaveEtrackerIntegrationConsent','jtl_paypal_commerce_consent'].forEach(cid => {
            var consentId = cid;
            if(cid == 'retoura_ga_consent') {
                consentId = cid + ',analytics_storage,ad_storage';
            }
            if(e.detail[cid]) {
                granted += ',' + consentId;
            } else {
                denied += ',' + consentId;
            }
        });
                            
        window.retouraConsentSettings = {
            denied: denied.replace(/^,/, ''),
            granted: granted.replace(/^,/, '')
        };

        //trigger consent changed first
        dataLayer.push({ 'event': 'consentChanged' });

        //then enable scripts to let events work normally without beeing blocked by consent settings
        Object.keys(e.detail).forEach(function(prop) { 
            if(e.detail[prop] == true) {
            Array.from(document.querySelectorAll('script[type="text/plain"][data-consent="' + prop + '"]'))
                .forEach(function(s) {
                s.setAttribute("type", "text/javascript");
                eval(s.innerHTML);
                });
            }        
        });                    
    });
})();</script>
