":1120,"contentType":1121},{"size":1116,"image":1396},{"width":1118,"height":1119},{"id":1398,"objectType":9,"contentType":1161,"name":1359,"width":1162,"alignment":1224,"aspectRatio":1399,"image":1400},"1hl86jROTM8HBHVLNDX9Qq","auto",{"id":1358,"objectType":9,"contentType":92,"name":1359,"image":1401},{"id":1361,"objectType":96,"title":1359,"description":50,"file":1402},{"url":1363,"details":1403,"fileName":1367,"contentType":106},{"size":1365,"image":1404},{"width":1089,"height":510},{"id":1358,"objectType":9,"contentType":92,"name":1359,"image":1406},{"id":1361,"objectType":96,"title":1359,"description":50,"file":1407},{"url":1363,"details":1408,"fileName":1367,"contentType":106},{"size":1365,"image":1409},{"width":1089,"height":510},"iPhone 17 Pro review: dit schrijven de experts","Met de komst van de iPhone 17 Pro zet Apple weer een flinke stap vooruit. Dit nieuwe Pro-model is krachtiger, slimmer en veelzijdiger dan ooit. In onze iPhone 17 Pro review ontdek je wat dit toestel zo bijzonder maakt. Van het scherpe 6,3-inch OLED-scherm tot de razendsnelle A19 Pro-chip en de professionele 48-megapixel camera: alles aan dit model ademt kwaliteit. Dankzij slimme software zoals Apple Intelligence haal je nog meer uit je foto’s, video’s en dagelijkse gebruik. Je leest in deze review van de iPhone 17 Pro alles wat je van deze nieuwe smartphone van Apple mag verwachten.",{"title":126},{"id":1414,"objectType":9,"contentType":300,"name":1415,"isVerticalView":20,"theme":137,"image":1416,"isImagePositionRight":20,"title":1427,"navigation":1428,"heading":1480},"3s8coCl2sG9OCQ90pnHi8","iPhone 17 Pro vs. iPhone 16 Pro - Beleef - iPhone - forwardlink",{"id":1417,"objectType":9,"contentType":92,"name":1418,"image":1419},"83jFW2lKKq8yg3pOvA2YK","iPhone 17 Pro vs. iPhone 16 Pro - media",{"id":1420,"objectType":96,"title":1418,"description":50,"file":1421},"5nXFH4adRwDcs524LM2MIv",{"url":1422,"details":1423,"fileName":1426,"contentType":106},"//images.ctfassets.net/zuadwp3l2xby/5nXFH