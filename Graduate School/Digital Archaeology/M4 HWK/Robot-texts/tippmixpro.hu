  _vwo_code.setFilterConfigAndApplyFilter({
    popupSelector: '.CookieConsentPopup',
    filterTime: 'best',
    isConsentGiven: function () {
      var nameEQ = 'cookie_consent=';
      var documentCookies = document.cookie.split(';');
      var res = documentCookies.find(function (cookie) {
        var cookieString = cookie;
        if (cookie.charAt(0) === ' ') {
            cookieString = cookie.substring(1, cookie.length);
        }
        return cookieString.indexOf(nameEQ) === 0;
      });
      var consentCookieVal = res ? res.split('=')[1] : '';

      switch (consentCookieVal) {
        case 'enable':
          return '1';
        case 'disable':
          return '2';
        default:
          return '3';
      }
