        </div>
    </div>
</section>
<style>
#titreMiddle {
    color: #000;
    background-color: #fff;
    margin: 0 auto;
    text-align: center;
    padding: 90px 20px 80px;
    margin-top: -132px;
}

#titreMiddle .titre--M {
    font-size: 20px;
    font-family: 'SFR-Regular', Arial;
    font-weight: normal;
    margin: 0;
    line-height: normal;
    padding-top: 20px;
}
    
    #titreMiddle .titre--XL {
        font-size: 44px;
        font-family: 'SFR-Light', 'SFR-Thin', Arial;
        font-weight: normal;
        line-height: normal;
        margin: 0;
    }
    
    @media (max-width: 991px) {    
    #titreMiddle {
    padding: 69px 20px 80px;
}
}
    @media (max-width: 600px) {
        #titreMiddle .titre--XL {
