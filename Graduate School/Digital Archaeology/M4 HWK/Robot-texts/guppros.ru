<script>
    const MOBILE_WIDTH = 768;
    let isMobileMenuOpen = false;
    const desktopMenu = document.getElementById("multimenu-wrapper");
    const mobileMenuWrapper = document.getElementById("mobile-multimenu-wrapper");
    const firstLevelContainer = document.getElementById("mobile-first-level-container");
    const otherLevelContainer = document.getElementById("mobile-other-level-container");
    const backButton = document.getElementById("mobile-back-button");
    const closeButton = document.getElementById("mobile-close-button");
    const menuTitle = document.getElementById("mobile-menu-title");

    let currentMobileParent = null;

    function getBrowser() {
        const userAgent = navigator.userAgent;

        if (userAgent.indexOf("Firefox") > -1) {
            return "Mozilla Firefox";
        } else if (userAgent.indexOf("SamsungBrowser") > -1) {
            return "Samsung Internet";
        } else if (userAgent.indexOf("Opera") > -1 || userAgent.indexOf("OPR") > -1) {
            return "Opera";
        } else if (userAgent.indexOf("Edg") > -1) {
            return "Microsoft Edge";
        } else if (userAgent.indexOf("Chrome") > -1) {
            return "Google Chrome";
        } else if (userAgent.indexOf("Safari") > -1) {
            return "Apple Safari";
        } else if (userAgent.indexOf("MSIE") > -1 || userAgent.indexOf("Trident") > -1) {
            return "Internet Explorer";
        } else {
            return "Неизвестный браузер";
        }
    }

    const userAgent = getBrowser();

    // Обработчик клика по пунктам первого уровня в мобильном меню
    document.querySelectorAll('#mobile-first-level-container .multimenu--first-level-item').forEach(link => {
        link.addEventListener('click', function(e) {
            if (e.target.closest('a') === this || e.target.closest('.dont-prevent')) {
                return;
            }

            e.preventDefault();

            const chain = this.getAttribute('data-chain');
            const parentData = pages[chain];

            if (!parentData || !parentData.children) return;

            // Скрываем первый уровень
            document.getElementById("mobile-first-level-container").classList.add("hidden");
            document.getElementById("mobile-back-button").classList.remove("hidden");

            // Показываем кнопку "Назад" с HTML-содержимым
            const backButton = document.getElementById("mobile-back-button");
            const backButtonText = document.getElementById("mobile-back-button-text");

            // Используем innerHTML для поддержки HTML-разметки
            backButtonText.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15 18L9 12L15 6" stroke="#4370B7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> ' + chain;

            backButton.classList.remove("hidden");

            // Очищаем предыдущий контент
            const container = document.getElementById("mobile-other-level-container");
            container.innerHTML = "";
            container.classList.remove("hidden");

            // Кнопка "Назад"
            document.getElementById("mobile-back-button").addEventListener("click", () => {
                // Возвращаем первый уровень меню
                document.getElementById("mobile-first-level-container").classList.remove("hidden");

                // Скрываем кнопку "Назад"
                document.getElementById("mobile-back-button").classList.add("hidden");

                // Очищаем и скрываем контейнер с подменю
                const otherLevelContainer = document.getElementById("mobile-other-level-container");
                otherLevelContainer.innerHTML = ""; // очищаем содержимое
                otherLevelContainer.classList.add("hidden"); // скрываем блок
            });

            let openThirdLevelMenu = null; // Для хранения текущего открытого подменю

            function renderSubMenu(children, depth = 1, parentElement = container) {
                if (depth > 3) return;

                Object.values(children).forEach(item => {
                    // Создаём родительский <p>
                    const p = document.createElement("p");
                    p.classList.add("multimenu--other-level-container--wrapper");

                    // Создаём ссылку <a>
                    const a = document.createElement("a");
                    a.href = item.LINK;
                    a.textContent = item.TEXT;
                    a.classList.add("mobile-link-depth-level-" + depth);

                    // Если это пункт третьего уровня — добавляем нужный класс к <a>
                    if (item.DEPTH_LEVEL === 3) {
                        a.classList.add("submenu-third-level--items");
                    }

                    // Добавляем <a> внутрь <p>
                    p.appendChild(a);

                    // Если это пункт второго уровня и имеет дочерние элементы
                    if (item.IS_PARENT && item.DEPTH_LEVEL === 2) {
                        p.classList.add("mobile-depth-level-2");

                        // Проверяем, есть ли среди дочерних элементов 3-го уровня те, у которых есть текст
                        const hasVisibleChildren = item.children &&
                            Object.values(item.children).some(child => child.TEXT && child.TEXT.trim() !== "");

                        // Если есть видимые пункты — показываем иконку и включаем логику открытия подменю
                        if (hasVisibleChildren) {
                            const img = document.createElement("img");
                            img.src = "/upload/images/last-level.svg";
                            img.className = "last-level";
                            img.setAttribute("aria-expanded", "false");

                            // Контейнер для подменю 3 уровня
                            const subContainer = document.createElement("div");
                            subContainer.classList.add("submenu-third-level", "hidden-option");

                            // Рекурсивно рендерим подменю 3 уровня
                            if (item.children && Object.keys(item.children).length > 0) {
                                renderSubMenu(item.children, depth + 1, subContainer);
                            }

                            // Обработчик клика по контейнеру с пунктом 2 уровня
                            p.addEventListener("click", function(e) {
                                e.stopPropagation(); // Предотвращаем повторный вызов события у родителя

                                // Если уже есть открытое меню — закрываем его
                                if (openThirdLevelMenu && openThirdLevelMenu !== subContainer) {
                                    openThirdLevelMenu.classList.add("hidden-option");

                                    // Убираем поворот у предыдущей иконки
                                    const prevIcon = openThirdLevelMenu.previousSibling?.querySelector(".last-level");
                                    if (prevIcon) {
                                        prevIcon.classList.remove("rotated");
                                        prevIcon.setAttribute("aria-expanded", "false");
                                    }
                                }

                                // Переключаем видимость текущего подменю
                                const isVisible = !subContainer.classList.contains("hidden-option");
                                subContainer.classList.toggle("hidden-option", isVisible);
                                img.classList.toggle("rotated", !isVisible);
                                img.setAttribute("aria-expanded", !isVisible);

                                // Обновляем текущее открытое меню
                                openThirdLevelMenu = isVisible ? null : subContainer;

                                // Если контейнер ещё не добавлен — вставляем его после <p>
                                if (!subContainer.parentElement) {
                                    p.insertAdjacentElement('afterend', subContainer);
                                }

                                // Применяем или убираем hidden-option у дочерних элементов
                                const childrenElements = subContainer.querySelectorAll(".multimenu--other-level-container--wrapper");
                                childrenElements.forEach(child => {
                                    child.classList.toggle("hidden-option", isVisible);
                                });
                            });

                            p.appendChild(img); // Иконка остаётся внутри <p>
                            parentElement.appendChild(p); // Вставляем <p>
                            parentElement.appendChild(subContainer); // Вставляем контейнер третьего уровня
                        } else {
                            // Нет видимых пунктов — просто выводим пункт 2 уровня без иконки и подменю
                            parentElement.appendChild(p);
                        }
                    } else {
                        // Просто добавляем пункт без подменю
                        parentElement.appendChild(p);
                    }
                });
            }

            renderSubMenu(parentData.children);
            // Обновляем заголовок
            document.getElementById("mobile-menu-title").textContent = chain;
        });
    });

    // Кнопка "Назад"
    document.getElementById("mobile-back-button").addEventListener("click", () => {
        document.getElementById("mobile-first-level-container").classList.remove("hidden");
        document.getElementById("mobile-back-button").classList.add("hidden");
        document.getElementById("mobile-menu-title").textContent = "Меню";
        document.getElementById("mobile-other-level-container").innerHTML = "";
    });

    // Переключатель между мобильным и десктопным меню
    function toggleMenus() {
        if (window.innerWidth <= MOBILE_WIDTH) {
            // Только если меню открыто через кнопку
            !desktopMenu.classList.contains("hidden") && desktopMenu.classList.add("hidden");
            if (isMobileMenuOpen) {
                mobileMenuWrapper.classList.remove("hidden");
            } else {
                mobileMenuWrapper.classList.add("hidden");
            }
        } else {
            // На десктопе всегда показываем десктопное меню
            desktopMenu.classList.remove("hidden");
            mobileMenuWrapper.classList.add("hidden");
        }
    }

    document.addEventListener("DOMContentLoaded", () => {console.log("toggleMenus call"); toggleMenus()})

    // Слушатель изменения размера окна
    window.addEventListener("resize", () => {
        toggleMenus();
    });

    // Обработчик клика по кнопке
    document.getElementById("multimenu-btn").addEventListener("click", () => {
        if (window.innerWidth <= MOBILE_WIDTH) {
        toggleMobileMenu(); // Функция, которая управляет display и overflow
        }
    });

    // Открытие/закрытие мобильного меню
    function toggleMobileMenu(open = !isMobileMenuOpen) {
        isMobileMenuOpen = open;
        mobileMenuWrapper.style.display = open ? "flex" : "none";
        document.body.style.overflow = open ? "hidden" : "auto";
        document.body.style.position = open ? "fixed" : "unset";

        open && toggleMenus()

        // Если меню открыто, устанавливаем высоту после рендера
        if (open) {
            setTimeout(() => {
                const tmp_multimenu_top = document.querySelector("header#header")?.clientHeight + (document.querySelector("#bx-panel-top")?.clientHeight || 0);
                if (userAgent === "Apple Safari") {
                    otherLevelContainer.style.maxHeight = "100% !important;"
                }
                mobileMenuWrapper.style.height = `calc(90vh - ${tmp_multimenu_top}px)`;
            }, 50);
        }
    }

    document.addEventListener('click', (e) => {
    const multimenu_btn = document.querySelector("#multimenu-btn");
        if (!e.target.closest("#mobile-multimenu-wrapper") && isMobileMenuOpen && !e.target.closest("#multimenu-btn")) {
            toggleMobileMenu();
        }
    });
</script>

<script>
    const path = new URL(window.location.href);
    let multimenu_btn = document.querySelector("#multimenu-btn");
    let multimenu = document.querySelector("#multimenu");
    let multimenu_wrapper = document.querySelector("#multimenu-wrapper");
	let multimenu_top = document.querySelector("header#header").clientHeight + (document.querySelector("#bx-panel")?.clientHeight || 0) + (document.querySelector(".accessibility-panel").getAttribute("hidden") !== false?document.querySelector(".accessibility-panel").clientHeight:0);
    let __multimenu_current_tab;
    const levels_a_class = ["multimenu--other-level-container--first-header", "multimenu--other-level-container--second-header", "multimenu--other-level-container--third-header"];
    const __multimenu_pages = document.querySelector("#multimenu--other-level-container");
    const desktopScrollContainer = document.querySelector(".desktop-menu-scroll-container");
    const pages = {};

    multimenu_wrapper.style.height = `calc(100vh - ${multimenu_top}px)`;
    multimenu_wrapper.style.top = `${multimenu_top}px`;
	multimenu.style.maxHeight = `calc(100vh - ${multimenu_top}px) - 20`;

    const updateSubMenuVisibility = () => {
        if (!__multimenu_current_tab || !pages[__multimenu_current_tab]) {
            // Очищаем только дочерние элементы, но оставляем сам контейнер
            __multimenu_pages.innerHTML = '';
            return;
        }

        const selectedItem = pages[__multimenu_current_tab];

        // Проверяем, есть ли дочерние элементы второго уровня
        // const hasSecondLevelItems = selectedItem.children &&
        //     Object.values(selectedItem.children).some(child => child.DEPTH_LEVEL === 2);

            const hasSecondLevelItems = true; // Пока что так, но хотелось бы не так, а как выше... Но пока всё именно так.

        if (hasSecondLevelItems) {
            __multimenu_pages.innerHTML = '';
            __multimenu_pages.appendChild(selectedItem.tab);
        } else {
            __multimenu_pages.innerHTML = ''; // Скрываем только дочерние элементы
        }
    }

    const __toggleMenu = (e) => {
        if (multimenu_btn.classList.contains("multimenu-btn-clicked")) {
            // Закрываем меню
            window.scrollTo({ top: __scroll });
            multimenu_wrapper.style.display = "none";
            document.body.style.overflow = "auto"; // Включаем общий скролл
            document.body.style.position = "unset";
        } else {
            // Открываем меню
            const tmp_multimenu_top = document.querySelector("header#header").clientHeight + (document.querySelector("#bx-panel")?.clientHeight || 0)  + (document.querySelector(".accessibility-panel").getAttribute("hidden") !== false?document.querySelector(".accessibility-panel").clientHeight:0);
            if (tmp_multimenu_top !== multimenu_top) {
                multimenu_top = tmp_multimenu_top;
                multimenu_wrapper.style.height = `calc(100vh - ${multimenu_top}px)`;
                multimenu_wrapper.style.top = `${multimenu_top}px`;
				multimenu.style.maxHeight = `calc(100vh - ${multimenu_top}px) - 20`;
            }
            __scroll = window.scrollY;
            multimenu_wrapper.style.display = "flex";
            document.body.style.overflow = "hidden"; // Отключаем общий скролл
            document.body.style.position = "fixed"; // Фиксируем позицию, чтобы не было сдвига
        }
        multimenu_btn.classList.toggle("multimenu-btn-clicked");
    };

    const __upDownMenu = (up = true) => {
        const keys = Object.keys(pages);
        if (keys.length === 0) return;

        if (__multimenu_current_tab) {
            document.querySelector(`.multimenu--first-level-item[data-chain="${__multimenu_current_tab}"]`).classList.toggle("multimenu--first-level-item-clicked");
            if ((keys.indexOf(__multimenu_current_tab) + (up ? -1 : 1) < 0))
                __multimenu_current_tab = keys[keys.length - 1];
            else if ((keys.indexOf(__multimenu_current_tab) + (up ? -1 : 1) >= keys.length))
                __multimenu_current_tab = keys[0];
            else
                __multimenu_current_tab = keys[keys.indexOf(__multimenu_current_tab) + (up ? -1 : 1)];
        } else
            __multimenu_current_tab = keys[up ? keys.length - 1 : 0];
        document.querySelector(`.multimenu--first-level-item[data-chain="${__multimenu_current_tab}"]`).classList.toggle("multimenu--first-level-item-clicked");
        __multimenu_pages.innerHTML = '';
        __multimenu_pages.appendChild(pages[__multimenu_current_tab].tab);
    };

    multimenu_btn.addEventListener("click", __toggleMenu);

    document.addEventListener('click', (e) => {
        // Проверяем, открыто ли десктопное меню и клик вне его области
        if (
            !e.target.closest("#multimenu") &&
            !e.target.closest("#mobile-multimenu-wrapper") &&
            multimenu_btn &&
            multimenu_btn.classList.contains("multimenu-btn-clicked") &&
            !e.target.closest("#multimenu-btn") && !e.target.closest(".accessibility-panel")
        ) {
            __toggleMenu(e);
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === "Escape" && multimenu_btn && multimenu_btn.classList.contains("multimenu-btn-clicked")) {
            __toggleMenu(e);
        }
        if (multimenu_btn && multimenu_btn.classList.contains("multimenu-btn-clicked") && (e.key === "ArrowUp" || e.key === "ArrowDown")) {
            __upDownMenu(e.key === "ArrowUp");
        }
    });

    multimenu_config.forEach((item) => {
        let parent = null;
        let parent_children = pages;
        const link = document.createElement("a");
        if (item.PARAMS.link !== false)
            link.href = item.LINK;
        link.innerHTML = item.TEXT;
        if (levels_a_class[item.DEPTH_LEVEL - 1])
            link.classList.add(levels_a_class[item.DEPTH_LEVEL - 1]);
        if (item.SELECTED)
            link.classList.add("multimenu--other-level-container--header-clicked");
            const wrapperLinkContainer = document.createElement("div");
            wrapperLinkContainer.classList.add("multimenu--other-level-link__container");

            // Добавляем ссылку в контейнер
            wrapperLinkContainer.appendChild(link);

            // Создаем внешний div и добавляем в него контейнер со ссылкой
            const wrapper = document.createElement("div");
            wrapper.appendChild(wrapperLinkContainer);

        if (item.IS_PARENT && item.DEPTH_LEVEL === 2) {
            var img = document.createElement("img");
            img.setAttribute("src", "/upload/images/last-level.svg");
            img.setAttribute("class", "last-level");
            item.i = 0;
            img.onclick = function () {
                Array.from(img.parentNode.children).forEach(sibling => {
                    if (sibling !== img && sibling !== link) {
                        if (item.i % 2) sibling.classList.add("hidden-option");
                        else sibling.classList.remove("hidden-option");
                    }
                });
                item.i++;
            }
            wrapper.appendChild(img);
        }
        if (item.DEPTH_LEVEL === 3) {
            wrapper.classList.add("hidden-option");
        }
        if (item.DEPTH_LEVEL === 1) {
            item.tab = document.createElement("div");
            item.tab.appendChild(wrapper);
            item.node = document.createElement("div");
            const containers = [document.createElement("div"), document.createElement("div")];
            containers.forEach(n => item.node.appendChild(n));
            item.tab.appendChild(item.node);
            item.node.classList.add("multimenu--other-level-container--links-container");
        } else {
            wrapper.classList.add("multimenu--other-level-container--wrapper");
            item.node = wrapper;
        }
        item.node.setAttribute('data-chain', item.CHAIN.at(-1));

        item.CHAIN.forEach((el, i, arr) => {
            if (parent && item.SELECTED) {
                parent.SELECTED_CHILD = true;
                parent.SELECTED = false;
            }
            if (!parent_children[el]) {
                parent_children[el] = {
                    children: {}
                };
            }
            if (i === arr.length - 1) {
                parent_children[el] = { ...parent_children[el], ...item };
            } else {
                parent = parent_children[el];
                parent_children = parent.children;
            }
        });
    });

    const genMenuTabs = (config, parent_node = null, depth = 0, parent = null) => {
        if (!parent || parent.PARAMS.childrens !== false)
            config.forEach((item, index) => {
                genMenuTabs(Object.values(item.children), item.node, depth + 1, item);
                if (parent_node) {
                    if (depth === 1)
                        if (index % 2 === 0)
                            parent_node.firstChild.appendChild(item.node);
                        else
                            parent_node.lastChild.appendChild(item.node);
                    else
                        parent_node.appendChild(item.node);
                }

                // Добавляем логику открытия подменю только для пунктов 2 уровня
                if (item.DEPTH_LEVEL === 2 && item.IS_PARENT && item.children && Object.keys(item.children).length > 0) {
                    const wrapper = item.node;
                    const img = wrapper.querySelector('.last-level');

                    wrapper.classList.add("submenu-style__container");

                    // Создаем общий контейнер для пунктов 3 уровня
                    const subContainer = document.createElement("div");
                    subContainer.classList.add("submenu-third-level-container", "hidden-option");

                    // Перемещаем все дочерние .multimenu--other-level-container--wrapper в общий контейнер
                    const childrenNodes = Array.from(wrapper.querySelectorAll(".multimenu--other-level-container--wrapper"));
                    childrenNodes.forEach(child => {
                        if (!child.closest(".submenu-third-level-container")) {
                            child.classList.remove("hidden-option"); // Убираем display: none
                            subContainer.appendChild(child);
                        }
                    });

                    // Вставляем контейнер после текущего пункта
                    wrapper.insertAdjacentElement('afterend', subContainer);

                    // Функция для открытия/закрытия подменю
                    const toggleSubMenu = () => {
                        // Закрываем другие открытые подменю
                        document.querySelectorAll(".submenu-third-level-container").forEach(cont => {
                            if (cont !== subContainer) {
                                cont.classList.add("hidden-option");
                                const otherImg = cont.previousElementSibling?.querySelector('.last-level');
                                if (otherImg) otherImg.classList.remove("rotated");

                                // Убираем active у других пунктов
                                const otherWrapper = cont.previousElementSibling;
                                if (otherWrapper && otherWrapper.classList.contains("submenu-style__container")) {
                                    otherWrapper.classList.remove("active");
                                }
                            }
                        });

                        // Переключаем видимость текущего подменю
                        subContainer.classList.toggle("hidden-option");
                        if (img) img.classList.toggle("rotated");

                        // Добавляем/убираем класс active у контейнера
                        wrapper.classList.toggle("active", !subContainer.classList.contains("hidden-option"));
                    };

                    // Назначаем обработчики кликов
                    if (img) {
                        img.addEventListener('click', (e) => {
                            e.stopPropagation();
                            toggleSubMenu();
                        });
                    }

                    // Добавляем обработчик клика на весь пункт меню
                    wrapper.addEventListener('click', (e) => {
                        // Проверяем, что клик не был по ссылке или иконке
                        if (e.target.closest('a') || e.target.closest('.last-level')) {
                            return;
                        }
                        toggleSubMenu();
                    });
                }

                // Логика для выделения активного пункта и т.д.
                if (!parent_node && (item.SELECTED_CHILD || item.SELECTED)) {
                    if (item.SELECTED_CHILD && item.tab.querySelector(".multimenu--other-level-container--header-clicked")) {
                        item.tab.querySelector(".multimenu--other-level-container--header-clicked").classList.toggle("multimenu--other-level-container--header-clicked");
                    }
                    const btn = document.querySelector(`.multimenu--first-level-item[data-chain="${item.TEXT}"]`);
                    if (btn) btn.classList.toggle("multimenu--first-level-item-clicked");
                    __multimenu_current_tab = item.TEXT;
                }
            });
    };
    genMenuTabs(Object.values(pages));
    if (__multimenu_current_tab)
        __multimenu_pages.appendChild(pages[__multimenu_current_tab].tab);

    let __multimenu_over_timeout;
    Array.from(document.querySelectorAll(`.multimenu--first-level-item`)).map(item => {
        item.addEventListener('mouseover', () => {
            if (!item.classList.contains("multimenu--first-level-item-clicked")) {
                Array.from(document.querySelectorAll(`.multimenu--first-level-item-clicked`)).forEach(el => el.classList.remove("multimenu--first-level-item-clicked"));
                item.classList.add("multimenu--first-level-item-clicked");
                __multimenu_current_tab = item.getAttribute("data-chain");
                updateSubMenuVisibility();
            }
        });

        item.addEventListener('click', () => {
            Array.from(document.querySelectorAll(`.multimenu--first-level-item-clicked`)).forEach(el => el.classList.remove("multimenu--first-level-item-clicked"));
            item.classList.add("multimenu--first-level-item-clicked");
            __multimenu_current_tab = item.getAttribute("data-chain");
            updateSubMenuVisibility();
        });
        item.addEventListener('focus', (e) => {
            if (item.classList.contains("multimenu--first-level-item-clicked"))
                return;
            Array.from(document.querySelectorAll(`.multimenu--first-level-item.multimenu--first-level-item-clicked`)).forEach(item => item.classList.toggle("multimenu--first-level-item-clicked"));
            __multimenu_current_tab = item.getAttribute("data-chain");
            item.classList.toggle("multimenu--first-level-item-clicked");

            __multimenu_pages.innerHTML = '';
            __multimenu_pages.appendChild(pages[__multimenu_current_tab].tab);
        });
    });
</script>
        </div>
    </header>

