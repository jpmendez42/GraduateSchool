                    dateTimeText: "%(date)s, %(time)s",
                    events: [{"category": "\u0411\u043e\u0435\u0432\u043e\u0439 \u043f\u0440\u043e\u043f\u0443\u0441\u043a", "color": "azure", "edited": 1759140946, "end": 1760326200, "icon": "battle-pass", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/bp-october-special-key-visual-200-88_v2.jpg", "link": "https://worldoftanks.eu/ru/news/general-news/battle-pass-special-october-2025/", "start": 1759379400, "tag": true, "title": "\u0421\u043f\u0435\u0446\u0432\u044b\u043f\u0443\u0441\u043a \u0411\u043e\u0435\u0432\u043e\u0433\u043e \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430: Wolfenstein"}, {"category": "\u041f\u0440\u044f\u043c\u0430\u044f \u0442\u0440\u0430\u043d\u0441\u043b\u044f\u0446\u0438\u044f", "color": "purple", "edited": 1757592628, "end": 1760367600, "icon": "signal-stream", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/token_store_2_0_200x88.jpg", "link": "https://worldoftanks.eu/ru/news/live-streams/update-2-0-token-store/", "start": 1756890000, "tag": true, "title": "\u041c\u0430\u0433\u0430\u0437\u0438\u043d \u0436\u0435\u0442\u043e\u043d\u043e\u0432 2.0: \u043d\u0430\u0433\u0440\u0430\u0434\u044b \u0437\u0430 \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440 \u0441\u0442\u0440\u0438\u043c\u043e\u0432"}, {"category": "\u0410\u043a\u0446\u0438\u044f", "color": "yellow", "edited": 1756982020, "end": 1760484600, "icon": "star", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/wot_plus_7_200x88.png", "link": "https://worldoftanks.eu/ru/news/general-news/wot-plus-guide/", "start": 1756978194, "tag": true, "title": "WoT Plus: \u043f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 30 \u0434\u043d\u0435\u0439 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e (\u043e\u043f\u044f\u0442\u044c)!"}, {"category": "\u041e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435", "color": "red", "edited": 1760343959, "end": 1760488260, "icon": "arrow-down-to-line", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/2-0-1-200x88.jpg", "link": "https://worldoftanks.eu/ru/news/updates/wot-2-0-1/", "start": 1760488200, "tag": false, "title": "\u041e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435 2.0.1: \u041f\u0435\u0440\u0435\u0440\u0438\u0441\u043e\u0432\u043a\u0430 \u043a\u043e\u043d\u0442\u0443\u0440\u043e\u0432"}, {"category": "\u0422\u0443\u0440\u043d\u0438\u0440\u044b", "color": "orange", "edited": 1758899903, "end": 1762736400, "icon": "swords", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/onslaught-(rush-mode)_200x88_1YI0W8a.png", "link": "https://worldoftanks.eu/ru/news/general-news/onslaught-season-of-the-dragon-1/", "start": 1759109400, "tag": true, "title": "\u00ab\u041d\u0430\u0442\u0438\u0441\u043a\u00bb: \u0441\u0435\u0437\u043e\u043d \u041b\u0430\u0437\u0443\u0440\u043d\u043e\u0433\u043e \u0434\u0440\u0430\u043a\u043e\u043d\u0430"}, {"category": "\u0422\u0443\u0440\u043d\u0438\u0440\u044b", "color": "orange", "edited": 1759135087, "end": 1763283600, "icon": "swords", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/ols_season_4_200x88.jpg", "link": "https://worldoftanks.eu/ru/news/live-streams/token-store-september-2025/", "start": 1759222800, "tag": true, "title": "\u0421\u043c\u043e\u0442\u0440\u0438\u0442\u0435 \u0438 \u043f\u043e\u0431\u0435\u0436\u0434\u0430\u0439\u0442\u0435 \u0432 4-\u043c \u0441\u0435\u0437\u043e\u043d\u0435 \u0421\u0422\u041b\u041d!"}, {"category": "\u0411\u043e\u0435\u0432\u043e\u0439 \u043f\u0440\u043e\u043f\u0443\u0441\u043a", "color": "azure", "edited": 1756558287, "end": 1764113400, "icon": "battle-pass", "image": "//eu-wotp.wgcdn.co/dcont/fb/image/battle_pass_season_xviii_200x88_event_calendar_image.png", "link": "https://worldoftanks.eu/ru/news/general-news/battle-pass-season-18/", "start": 1756882800, "tag": true, "title": "XVIII \u0441\u0435\u0437\u043e\u043d \u0411\u043e\u0435\u0432\u043e\u0433\u043e \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u0430"}],
