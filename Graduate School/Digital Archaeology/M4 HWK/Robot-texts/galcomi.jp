.l_comicList_item {
  display: inline-block;
  margin: 10px 0 10px 10px;
  width: calc((100% - 70px)/6);
}

@media screen and (max-width: 480px) {
  .l_comicList_item {
      width: calc((100% - 50px) / 4);
  }
}

@media screen and (max-width: 375px) {
