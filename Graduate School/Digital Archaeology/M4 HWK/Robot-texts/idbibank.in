	.blink {
            animation: blink 1s linear infinite;
            color: #ff0000;
            font-size: 12px;
            font-family: "Montserrat", sans-serif;
        }
        .blink_1 {
            color: #fff !important;
        }
        @keyframes blink {
            0% {
                opacity: 0;
            }
            50% {
                opacity: 0.5;
            }
            100% {
                opacity: 1;
            }
        }
	.mega-dropdown-menu {
