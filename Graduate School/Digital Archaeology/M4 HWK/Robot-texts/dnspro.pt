#top-menu li {
    top: 6px;    
}
#top-menu-nav > ul > li > a:hover {
    opacity: 1;
    color: #eb1d24;    
}
.nav ul li a:hover {
    opacity: 1;
    background-color: #eee;
}
.et-fixed-header #top-menu li li a {
    font-size: 16px;
}
#top-menu li li a {
    width: auto;
    padding: 8px 20px;
    font-size: 16px;
    font-family: 'Source Sans Pro', Helvetica, Arial, Lucida, sans-serif !important;
    font-weight: initial;
}
.nav li li {
    line-height: 1.6em;
    width: 100%;
}
#top-menu li li {
    padding: 0;
}
.nav li ul {
    padding: 8px 0;
    border-radius: 2px;
}
#top-menu .menu-item-has-children > a:first-child::after {
    top: 20px;    
}
.et_header_style_left #et-top-navigation nav > ul > li > a {
    padding-bottom: 10px !important;
    padding-top: 20px;    
    font-weight: initial;
}
#top-menu > li:first-child::before, #top-menu li li::before {
    display: none;
}
