ory\":[\"men\",\"women\",\"accessories\",\"children\",\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":true,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:53:23.955Z\",\"updatedAt\":\"2025-03-04T03:11:19.465Z\",\"logo\":{\"id\":\"65802d75e2f304ddab7c24b5\",\"alt\":\"logo\",\"filename\":\"TOM TAILOR.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":12178,\"width\":450,\"height\":135,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/jpeg\",\"filesize\":448,\"filename\":\"TOM TAILOR-32x9.jpg\",\"url\":\"/cms/media/TOM TAILOR-32x9.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":874,\"filename\":\"TOM TAILOR-64x19.jpg\",\"url\":\"/cms/media/TOM TAILOR-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":38,\"mimeType\":\"image/jpeg\",\"filesize\":1782,\"filename\":\"TOM TAILOR-128x38.jpg\",\"url\":\"/cms/media/TOM TAILOR-128x38.jpg\"},\"w384\":{\"width\":384,\"height\":115,\"mimeType\":\"image/jpeg\",\"filesize\":6779,\"filename\":\"TOM TAILOR-384x115.jpg\",\"url\":\"/cms/media/TOM TAILOR-384x115.jpg\"},\"w640\":{\"width\":640,\"height\":192,\"mimeType\":\"image/jpeg\",\"filesize\":11435,\"filename\":\"TOM TAILOR-640x192.jpg\",\"url\":\"/cms/media/TOM TAILOR-640x192.jpg\"},\"w1080\":{\"width\":1080,\"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":21725,\"filename\":\"TOM TAILOR-1080x324.jpg\",\"url\":\"/cms/media/TOM TAILOR-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":46824,\"filename\":\"TOM TAILOR-1920x576.jpg\",\"url\":\"/cms/media/TOM TAILOR-1920x576.j