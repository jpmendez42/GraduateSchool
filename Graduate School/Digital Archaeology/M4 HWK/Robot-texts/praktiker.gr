<script src="//code.tidio.co/pese8rzmh17pnw6vo4pvylsac3liwkr4.js"></script>
<script>
    const button = document.querySelector('.chat-button');

    button.addEventListener('click', function() {
        tidioChatApi.track('BubbleClicked');
        window.tidioChatApi.show();
        window.tidioChatApi.open();
        button.style.display = 'none';
    });
    var lastStatus = false;

    function onTidioChatApiReady() {
        window.tidioChatApi.setFeatures({ chatOptions: { rate: false } });
        window.tidioChatApi.on('setStatus', function(status) {
            if (lastStatus !== status) {
                if (status === 'online') {
                    button.style.display = 'inline';
                    window.tidioChatApi.hide();
                    window.tidioChatApi.on('close', function() {
                        window.tidioChatApi.hide();
                        button.style.display = 'inline';
                    });
                } else {
                    button.style.display = 'none';
                }
            }
            lastStatus = status;
        });

    }

    if (window.tidioChatApi) {
        window.tidioChatApi.on('ready', onTidioChatApiReady);
    } else {
        document.addEventListener('tidioChat-ready', onTidioChatApiReady);
    }
    ;

</script>

    
    <script type="application/ld+json">
{
