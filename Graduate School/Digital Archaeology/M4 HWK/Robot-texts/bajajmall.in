<link rel="stylesheet" href="/etc.clientlibs/bajajmall-site/clientlibs/generated-clientlib-homepage-react.min.a7e22432dd3bd00d2be15b47ca66dce2.css" type="text/css">



<script>

        document.addEventListener('DOMContentLoaded', function() {
            // Lazy load footer and modal after page load
            const footer = document.querySelector('.footer-bajaj');
            const microIntDiv = document.querySelector('.micro-int-div');
            
            
            if (footer) {
              footer.classList.remove('hidden');
            }
           
            if (microIntDiv) {
              microIntDiv.classList.remove('hidden');
            }
      
          const storedData = localStorage.getItem("utmsource");
          var utm_source;
          var utm_medium;
          var utm_campaign;
          var utm_content;
          if (storedData) {
            try {
              let dataObj = JSON.parse(storedData);
              let utmString = dataObj.utm_source;
              let params = new URLSearchParams(utmString.substring(1));
              utm_source = params.get('utm_source');
              utm_medium = params.get('utm_medium');
              utm_campaign = params.get('utm_campaign');
              utm_content = params.get('utm_content');
            } catch (err) {
              console.error("Failed to parse UTM data from localStorage", err);
            }
          }
          function getCookieValue(name) {
            const cookies = document.cookie;
            const cookiesArray = cookies.split(';');
            for (let i = 0; i < cookiesArray.length; i++) {
              let cookie = cookiesArray[i].trim();
              if (cookie.startsWith(name + "=")) {
                return cookie.substring(name.length + 1);
              }
            }
            return null;
          }
          const getValueOrNA = (value) => value || 'NA';
          window.dataLayer = window.dataLayer || [];
          const page_url = window.location.href;
          const urlParams = new URLSearchParams(window.location.search);
          const productCode = urlParams.get('productCode') || "NA";
          const previousPage = document.referrer;
          const transactionId = sessionStorage.getItem('transaction_id') || "NA";
          const cookieValue = getCookieValue('bmall_user_flags');
          const parsedData = JSON.parse(cookieValue) || null;
          const pincode = parsedData?.pincode || "NA";
          const customer_type = parsedData?.customer_type || "NA";
          const customer_limit = parsedData?.available_limit || "NA";
          const model_id = localStorage.getItem('model_id') || "NA";
          const pin_code = localStorage.getItem('pincode') || "NA";
          const cityId = localStorage.getItem('cityId') || "NA";
          const card_status = parsedData?.card_type || "NA";
          const myhomepage = {
            event: "page_view",
            product_name: "NA",
            product_code: 'NA',
            page_type: "HP",
            page_title :document.title,
            product_category: "NA",
            page_url: page_url,
            page_title: "NA",
            page_lang: "NA",
            products_count: "NA",
            source_page: previousPage || 'NA',
            card_status: card_status || "NA",
            is_loggedin : parsedData ? "loggedin" : "nonloggedin",
            customer_type: customer_type,
            customer_limit: customer_limit,
            product_impression_event: "NA",
            model_id: "NA",
            magento_id: sessionStorage.getItem("magento_id"),
            customer_id: sessionStorage.getItem("customer_id"),
            client_id: getCookieValue("_ga") || "NA",
            dealer_id: "NA",
            clever_tap_id: decodeURIComponent(localStorage.getItem("WZRK_G")).slice(1, -1) || "NA",
            mobile_hash: "NA",
            pin_code: getValueOrNA(sessionStorage.getItem('pincode')),
            city_id: cityId || "NA",
            tag1: "NA",
            tag2: "NA",
            tag3: "NA"
          };
          if (window.dataLayer) {
            window.dataLayer.push(myhomepage);
          } else {
            console.error("dataLayer is not available");
          };
          const envPageData = document.querySelector('.global-dataset-wrapper');
          const pageType = envPageData?.getAttribute('data-pageType');
          function getCookie(name) {
            let decodedCookie = decodeURIComponent(document.cookie);
            let cookies = decodedCookie.split(';');
      
            for (let i = 0; i < cookies.length; i++) {
              let cookie = cookies[i].trim();
              if (cookie.indexOf(name + "=") === 0) {
                return true;
              }
            }
            return false;
          }
      
          const currentUrl = window.location.href;
          const loadTime = performance.now().toString() || "NA";
          const cityName = sessionStorage.getItem("cityName") || "NA";
          const cookieString = document.cookie.split("; ").find(row => row.startsWith("campaignCookienew="));
          const campaignCookie = cookieString ? JSON.parse(decodeURIComponent(cookieString.split("=")[1])) : {};
          const bm_token = getCookieValue("bm_token");
          const p_token = getCookieValue("p_token");
          const isWebSSO = (getCookieValue('src') && bm_token)? 'SSO' : 'NONSSO';
          const isAPP_3in1 = (getCookieValue('src') == "3in1" || getCookieValue('webViewMode') == "on") ? "3in1App" : "Web";
      
          try {
            const clevertTapobj = {
              EP_PAGE_TYPE: pageType?.toString() || "NA",
              EP_PAGE_NAME: document.title || "NA",
              EP_LOADTIME: loadTime?.toString() || 'NA',
              EP_SSO: isWebSSO,
              EP_PLATFORM: isAPP_3in1,
              EP_CUSTOMER_TYPE: customer_type?.toString() || 'NA',
              EP_PAGE_URL: currentUrl?.toString() || 'NA',
              EP_UTM_SOURCE: utm_source?.toString() || 'NA',
              EP_UTM_MEDIUM: utm_medium?.toString() || 'NA',
              EP_UTM_CAMPAIGN: utm_campaign?.toString() || 'NA',
              EP_UTM_CONTENT: utm_content?.toString() || 'NA',
              EP_SOURCE: previousPage?.toString() || 'NA',
              EP_CITY: cityName?.toString() || 'NA',
              EP_CUSTOMER_IDENTIFIER: parsedData ? "Identified" : "Unidentified"
            };
            if (window.clevertap) {
              window.clevertap.event.push("BAJAJMALL_PAGE_VIEWED", clevertTapobj);
            }
          }
          catch (error) {
            console.error(error, 'Clevertap for Homepage Page On Load error.');
          }
        });
    </script>    
    
    
    

    

    
    
    

    
    
