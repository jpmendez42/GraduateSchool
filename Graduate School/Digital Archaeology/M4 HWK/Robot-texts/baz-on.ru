983-3.323 3.783 3.783 0 0 1 7.564-.122h3.05a6.83 6.83 0 0 0-6.829-6.714 6.837 6.837 0 0 0-6.839 6.836 6.82 6.82 0 0 0 3.75 6.089c.342.2.985.41 1.169.458.627.164 1.47.277 2.154.327.253.02 1.49.03 1.752.032v.005H49.6V15.84H27.77Zm-1.842 4.966c-.95-.063-2.048-.23-2.913-.48a14.518 14.518 0 0 1-1.003-.372c-3.01-1.395-5.108-4.44-5.108-7.972 0-4.846 3.941-8.791 8.79-8.791 4.805 0 8.72 3.879 8.786 8.668h3.175C37.59 5.32 32.25.02 25.695.02c-6.598 0-11.966 5.366-11.966 11.963 0 4.548 2.557 8.504 6.304 10.525.675.358 1.646.726 1.976.827 1.066.318 2.377.528 3.544.618.396.03 1.778.045 2.181.047h21.868v-3.163H27.77c-.29 0-1.558-.011-1.842-.03Z" clip-rule="evenodd"></path><path d="M43.953 4.063c-.95 0-1.77-.748-1.77-1.767 0-.969.82-1.735 1.77-1.735.951 0 1.766.766 1.766 1.735a1.754 1.754 0 0 1-1.766 1.767Zm0-3.838c-1.151 0-2.105.918-2.105 2.07a2.12 2.12 0 0 0 2.105 2.106 2.096 2.096 0 0 0 2.105-2.105c0-1.153-.917-2.07-2.105-2.07Z"></path><path d="M44.053 2.179H43.6v-.652h.386c.268 0 .45.083.45.335 0 .132-.065.317-.384.317Zm.702.683c0-.233-.034-.448-.3-.533.333-.116.366-.335.366-.467 0-.535-.485-.603-.685-.603h-.918V3.33h.383v-.85h.301c.434 0 .47.2.47.382 0 .353 0 .42.083.468h.384c-.084-.084-.051-.15-.084-.468Z"></path></g><defs><clipPath id="i-431583863__a"><path fill="#fff" d="M.395 0h49.21v24H.396z"></path></clipPath></defs></svg></div></div></div></div></div><div class="block-wrapper block-top-margin-medium" id="escort" data-v-cd58d090 data-v-29719f68><h2 class="block-header" data-v-29719f68><span class="number" data-v-29719f68>04</span><span data-v-29719f68>Сопровождение</span></h2><h3 class="sub-header" data-v-29719f68> Внедряем. Обучаем. Сопровождаем. </h3><div class="sub-text" data-v-29719f68> Бесплатно и навсегда </div><div class="tabs hide-scrollbar" data-v-29719f68><!--[--><div class="tab is-active" data-v-29719f68>Внедрение</div><div class="tab" data-v-29719f68>Обучение</div><div class="tab" data-v-29719f68>Помощь</div><div class="tab" data-v-29719f68>Экономия</div><div class="tab" data-v-29719f68>Безопасность</div><!--]--></div><div class="slider-wrapper" data-v-29719f68><!--[--><div class="arrow-left h-c-pointer" data-v-29719f68><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-24" data-v-29719f68><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg></div><div class="arrow-right h-c-pointer" data-v-29719f68><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-24" data-v-29719f68><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg></div><!--]--><div class="slider" data-v-29719f68><div class="empty-slide" style="margin-left:0%;" data-v-29719f68></div><!--[--><div class="slide" data-v-29719f68><div class="slide-text-wrapper" data-v-29719f68><h3 class="slide-header" data-v-29719f68>Внедрим и настроим<br>систему «под ключ»</h3><div class="slide-text" data-v-29719f68>Адаптируем систему именно под ваши задачи. Перенесем остатки, настроим выгрузки на рекламные площадки.<br><br>А так же подберем и настроим все необходимое оборудование: принтеры штрих-кодов, кассы и другое.</div></div><picture class="slide-image" data-v-29719f68><source srcset="/images/slides/slide-1.webp, /images/slides/slide-1x2.webp 2x" type="image/webp" data-v-29719f68><img src="/images/slides/slide-1.png" fetchpriority="low" loading="lazy" decoding="async" alt="Все необходимые инструменты для учёта б/у автозапчастей в одном месте" title="Пазл" data-v-29719f68></picture><img class="svg-glare" src="/images/glare/glare-slide.svg" alt="" fetchpriority="low" loading="lazy" decoding="async" data-v-29719f68></div><div class="slide" data-v-29719f68><div class="slide-text-wrapper" data-v-29719f68><h3 class="slide-header" data-v-29719f68>Обучим сотрудников<br>и руководителей компании</h3><div class="slide-text" data-v-29719f68>Уделим столько времени, сколько необходимо именно вам, ответим на любые вопросы.<br><br>Нам важно, чтобы вы разобрались во всех нюансах и получили результат.</div></div><picture class="slide-image" data-v-29719f68><source srcset="/images/slides/slide-2.webp, /images/slides/slide-2x2.webp 2x" type="image/webp" data-v-29719f68><img src="/images/slides/slide-2.png" fetchpriority="low" loading="lazy" decoding="async" alt="Постоянная поддержка клиентов, помощь в внедрении инструментов учёта запчастей" title="Техподдержка" data-v-29719f68></picture><img class="svg-glare" src="/images/glare/glare-slide.svg" alt="" fetchpriority="low" loading="lazy" decoding="async" data-v-29719f68></div><div class="slide" data-v-29719f68><div class="slide-text-wrapper" data-v-29719f68><h3 class="slide-header" data-v-29719f68>Поможем решить любые вопросы</h3><div class="slide-text" data-v-29719f68>Даже если они не связаны напрямую с работой системы.<br><br>Модерация на площадках, выстраивание процессов в компании, найм/адаптация/работа сотрудников и другие вопросы.</div></div><picture class="slide-image" data-v-29719f68><source srcset="/images/slides/slide-3.webp, /images/slides/slide-3x2.webp 2x" type="image/webp" data-v-29719f68><img src="/images/slides/slide-3.png" fetchpriority="low" loading="lazy" decoding="async" alt="Помогаем решить вопросы даже не связанные с системой учёта" title="Диалог с клиентом" data-v-29719f68></picture><img class="svg-glare" src="/images/glare/glare-slide.svg" alt="" fetchpriority="low" loading="lazy" decoding="async" data-v-29719f68></div><div class="slide" data-v-29719f68><div class="slide-text-wrapper" data-v-29719f68><h3 class="slide-header" data-v-29719f68>Помогаем экономить на штате компании</h3><div class="slide-text" data-v-29719f68>С Bazon один сотрудник успевает делать больше и качественнее за тоже время.<br><br>Не нужно держать тех. специалистов в штате, мы удаленно решим технические вопросы.</div></div><picture class="slide-image" data-v-29719f68><source srcset="/images/slides/slide-4.webp, /images/slides/slide-4x2.webp 2x" type="image/webp" data-v-29719f68><img src="/images/slides/slide-4.png" fetchpriority="low" loading="lazy" decoding="async" alt="Экономия на технических специалистах, оптимизация процессов" title="Экономия" data-v-29719f68></picture><img class="svg-glare" src="/images/glare/glare-slide.svg" alt="" fetchpriority="low" loading="lazy" decoding="async" data-v-29719f68></div><div class="slide" data-v-29719f68><div class="slide-text-wrapper" data-v-29719f68><h3 class="slide-header" data-v-29719f68>Обеспечиваем сохранность данных</h3><div class="slide-text" data-v-29719f68>От случайных ошибок сотрудников или преднамеренной порчи данных.<br><br>Мы производим ежедневное резервное копирование всех данных и размещаем их в надёжных дата-центрах на территории РФ, соответствующих стандарту Tier3.</div></div><picture class="slide-image" data-v-29719f68><source srcset="/images/slides/slide-5.webp, /images/slides/slide-5x2.webp 2x" type="image/webp" data-v-29719f68><img src="/images/slides/slide-5.png" fetchpriority="low" loading="lazy" decoding="async" alt="Защита данных вашей компании от злоумышленников и случайных ошибок" title="Защита данных" data-v-29719f68></picture><img class="svg-glare" src="/images/glare/glare-slide.svg" alt="" fetchpriority="low" loading="lazy" decoding="async" data-v-29719f68></div><!--]--></div></div><div class="dots" data-v-29719f68><!--[--><div class="dot is-active" data-v-29719f68></div><div class="dot" data-v-29719f68></div><div class="dot" data-v-29719f68></div><div class="dot" data-v-29719f68></div><div class="dot" data-v-29719f68></div><!--]--></div></div><div class="block-wrapper block-top-margin-medium" data-v-cd58d090 data-v-024baa00><div class="block-content" data-v-024baa00><h3 class="header" data-v-024baa00>Что хотите получить?</h3><div class="tags" data-v-024baa00><!--[--><div class="tag h-c-pointer" data-v-024baa00>Увеличить продажи</div><div class="tag h-c-pointer" data-v-024baa00>Ускорить занесение</div><div class="tag h-c-pointer" data-v-024baa00>Найти сотрудников</div><div class="tag h-c-pointer" data-v-024baa00>Навести порядок</div><div class="tag h-c-pointer" data-v-024baa00>Разместиться на множество площадок</div><div class="tag h-c-pointer" data-v-024baa00>Запустить интернет-магазин</div><div class="tag h-c-pointer" data-v-024baa00>Исключить воровство со склада</div><!--]--></div><p class="text" data-v-024baa00>Мы каждый день помогаем с этим нашим клиентам. Готовы рассказать на презентации.</p><button class="pb-button large dark f_text-20 is-bold" data-v-024baa00 data-v-2b04b5e0><!--[-->Заказать презентацию<!--]--></button></div></div><div class="block-wrapper block-top-margin-medium" id="clients-and-cases" data-v-cd58d090 data-v-e503f70a><!--[--><h2 class="block-header" data-v-e503f70a><span class="number" data-v-e503f70a>05</span><span data-v-e503f70a>Клиенты и кейсы</span></h2><h3 class="sub-header" data-v-e503f70a> Делимся честной<br data-v-e503f70a>обратной связью </h3><!--]--><div class="slider-wrapper" data-v-e503f70a><!--[--><!----><div class="arrow-right h-c-pointer" data-v-e503f70a><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-24" data-v-e503f70a><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg></div><!--]--><div class="slider" data-v-e503f70a><div class="empty-slide" style="margin-left:calc(0% - 0px);" data-v-e503f70a></div><!--[--><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>С Bazon стало гораздо проще работать: раньше объявления на Drom плохо выгружались, клиенты нас не находили. Сейчас всё настроено — объявления загружаются, видны, начали приносить реальные продажи...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Сергей, руководитель «Чип и Дэйл»</div><div class="company" data-v-6256584d>г.&nbsp;Ростов-на-Дону, 13&nbsp;000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2021&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>После внедрения Bazon стало на 100% проще находить товар — теперь даже человек без опыта может просто взять номер и найти нужную деталь, не разбираясь, как она выглядит. Это сильно упростило обучение новых сотрудников…</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Александр, соучредитель «Автолэнд»</div><div class="company" data-v-6256584d>г.&nbsp;Бийск, 18&nbsp;000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2017&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Выручка увеличилась, я статистику по месяцам вижу. Статистика по машинам, продажам, поставкам — крайне важная вещь. Оцениваем: за сколько купили, за сколько продали, что получили...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Антон, собственник «Brorazbor»</div><div class="company" data-v-6256584d>г.&nbsp;Москва, 4000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Основное, за что ценим Bazon — это простота, удобство и заточка под специфику нашей работы. Приходование стало быстрее, всё оцифровывается, автозагрузка на площадки работает стабильно — чем быстрее товар занесён, тем быстрее он продаётся...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Игорь, директор «ZapJapan22»</div><div class="company" data-v-6256584d>г.&nbsp;Барнаул, 12&nbsp;000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2020&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Вносить стало гораздо проще: марку, модель, применимость — всё это теперь не нужно писать вручную, всё быстро подставляется. Плюс справочники помогают. Благодаря этому мы начали продавать всякую мелочёвку, которая раньше просто лежала мёртвым грузом...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Владимир, собственник «JapanParts MSK»</div><div class="company" data-v-6256584d>г.&nbsp;Москва, 20&nbsp;000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2021&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Раньше запчасти вручную на Drom заносили, каждое объявление, а теперь через Bazon делаем выгрузки — реально намного быстрее…</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Сергей, собственник «SSGparts»</div><div class="company" data-v-6256584d>г.&nbsp;Владивосток, 4000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>До перехода на Bazon работали через Japancar и FarPost. Приемка велась вручную: фото на фотоаппарат, скидывали на компьютер, заносили на сайт. Это занимало много времени. Сейчас товары фотаем на телефон, сразу заносим в Bazon, это экономит недели, а то и месяцы работы...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Андрей, соучредитель «RICH Group» </div><div class="company" data-v-6256584d>г.&nbsp;Москва, 4000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>До Bazonа работали с другой системой. С Bazon стало удобнее работать — всё автоматизировано: приход, остатки, выгрузки. Быстро перенесли базу и без потерь данных...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Максим, владелец «МБ Ликино»</div><div class="company" data-v-6256584d>г.&nbsp;Одинцово, 10&nbsp;000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2022&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Когда пришел к Bazon, прям счастья не было предела. Базу мою перенесли за один день — я поверить не мог! У старых хозяев пришлось свою базу выкупать, они сказали: «Бесплатно не отдадим»…</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Вячеслав, владелец «Славянин 23»</div><div class="company" data-v-6256584d>г.&nbsp;Краснодар, 14&nbsp;000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2021&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>С Bazonом работать проще стало. Помогают справочники и подсказки. OEM Номера ставим, кросс-номера, фотки делаем...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Василий, партнёр «Автобот22»</div><div class="company" data-v-6256584d>г.&nbsp;Барнаул, 7000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2023&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>С внедрением системы намного проще стало, все улучшилось. Всё начало работать так, как должно было работать, как я себе предполагал. В плане поиска запчастей, в плане применимости — короче говоря, во всех планах лучше стало...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Денис, собственник «Седьмой Новый»</div><div class="company" data-v-6256584d>г.&nbsp;Таганрог, 7000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2022&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Я могу найти любую запчасть, посмотреть, где она лежит, какое у неё состояние — всё через штрих-код. Это уже не гараж, а нормальная, системная работа. Даже новичок — просто сканирует и находит нужное. Раньше, чтобы что-то найти, нужно было вспоминать, где это лежит, или идти и на месте разбираться...</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Святослав, собственник «Джип Разбор»</div><div class="company" data-v-6256584d>г.&nbsp;Владивосток, 3000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года</div><!----><!----></div><div class="feedback-card slide" data-v-e503f70a data-v-6256584d><div class="feedback-text" data-v-6256584d>Сайт от Bazon реально помогает продавать. Причём не просто продавать, а увеличивать средний чек и запускать дополнительные продажи. Фишка в том, что можно генерировать живые ссылки на подборки по марке, модели и поколению машины…</div><button class="pb-button tiny stroke f_text-14 is-bold feedback-button" data-v-6256584d data-v-2b04b5e0><!--[--><span data-v-6256584d>Читать полностью</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 21 20" class="nuxt-icon nuxt-icon--fill h-icon-size-20" data-v-6256584d><path fill="#fff" fill-rule="evenodd" d="M8.303 14.697a.75.75 0 0 0 1.06 0l4.167-4.166a.75.75 0 0 0 0-1.061L9.364 5.303a.75.75 0 1 0-1.061 1.06L11.939 10l-3.636 3.636a.75.75 0 0 0 0 1.061Z" clip-rule="evenodd"></path></svg><!--]--></button><div class="author" data-v-6256584d>Михаил, собственник «Быстрые Детали»</div><div class="company" data-v-6256584d>г.&nbsp;Новосибирск, 6000+&nbsp;товаров,<br>работают с&nbsp;Bazon&nbsp;с&nbsp;2023&nbsp;года</div><!----><!----></div><!--]--></div></div><button class="pb-button tiny stroke f_text-14 is-bold show-all-button-is-down" data-v-e503f70a data-v-2b04b5e0><!--[--> Все отзывы <!--]--></button><div class="dots-wrapper" data-v-e503f70a><div class="dots" data-v-e503f70a><!--[--><div class="dot is-active" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><div class="dot" data-v-e503f70a></div><!--]--></div><!----></div><!----></div><div data-v-cd58d090><div class="block-wrapper f_text-16 h-t-c-white-50 block-top-margin-medium" data-v-cd58d090 data-v-f2cf0956><!--[--><div class="feedback-block-wrapper h-c-pointer" data-v-f2cf0956><img src="/images/feedback-previews/feedback-preview-allsubaru.jpg" class="preview-image" fetchpriority="low" loading="lazy" decoding="async" alt="" data-v-f2cf0956><div class="video-name" data-v-f2cf0956>Компания «ALLsubaru», 22&nbsp;000+&nbsp;товаров</div><div data-v-f2cf0956>Использует Bazon с&nbsp;2019&nbsp;года</div></div><div class="feedback-block-wrapper h-c-pointer" data-v-f2cf0956><img src="/images/feedback-previews/feedback-preview-razboravto.jpg" class="preview-image" fetchpriority="low" loading="lazy" decoding="async" alt="" data-v-f2cf0956><div class="video-name" data-v-f2cf0956>Компания «Razboravto 18», 10&nbsp;000+&nbsp;товаров</div><div data-v-f2cf0956>Использует Bazon с&nbsp;2019&nbsp;года</div></div><div class="feedback-block-wrapper h-c-pointer" data-v-f2cf0956><img src="/images/feedback-previews/feedback-preview-motorcity.jpg" class="preview-image" fetchpriority="low" loading="lazy" decoding="async" alt="" data-v-f2cf0956><div class="video-name" data-v-f2cf0956>Компания «Motorcity Moscow», 30&nbsp;000+&nbsp;товаров</div><div data-v-f2cf0956>Использует Bazon с 2021&nbsp;года</div></div><div class="feedback-block-wrapper h-c-pointer" data-v-f2cf0956><img src="/images/feedback-previews/feedback-preview-amggarage.jpg" class="preview-image" fetchpriority="low" loading="lazy" decoding="async" alt="" data-v-f2cf0956><div class="video-name" data-v-f2cf0956>Компания «AMGgarage», 55&nbsp;000+&nbsp;товаров</div><div data-v-f2cf0956>Использует Bazon с&nbsp;2019&nbsp;года</div></div><div class="feedback-block-wrapper h-c-pointer" data-v-f2cf0956><img src="/images/feedback-previews/feedback-preview-3rcompany.jpg" class="preview-image" fetchpriority="low" loading="lazy" decoding="async" alt="" data-v-f2cf0956><div class="video-name" data-v-f2cf0956>Компания «3R Сompany», 9000+&nbsp;товаров</div><div data-v-f2cf0956>Использует Bazon с&nbsp;2016&nbsp;года</div></div><!--]--><div class="feedback-block-wrapper show-all-button h-c-pointer f_text-16 is-bold" data-v-f2cf0956> Посмотреть все </div><!----><!----></div></div><div class="steps-help-block-wrapper block-top-margin-medium" id="steps-help-block" data-v-cd58d090 data-v-dd9bf142><div class="steps-help-block" data-v-dd9bf142><h3 class="header" data-v-dd9bf142>Мы помогли многим компаниям выйти на новый уровень</h3><div class="steps-wrapper" style="--progress:0;" data-v-dd9bf142><!--[--><div class="step number-1" data-v-dd9bf142>Повысилось доверие и узнаваемость компании <picture class="number" data-v-dd9bf142><source srcset="/images/numbers/1.webp, /images/numbers/1x2.webp 2x" type="image/webp" data-v-dd9bf142><img src="/images/numbers/1.png" fetchpriority="low" loading="lazy" alt="" decoding="async" data-v-dd9bf142></picture></div><div class="step number-2" data-v-dd9bf142>Выстроились понятные и прозрачные процессы <picture class="number" data-v-dd9bf142><source srcset="/images/numbers/2.webp, /images/numbers/2x2.webp 2x" type="image/webp" data-v-dd9bf142><img src="/images/numbers/2.png" fetchpriority="low" loading="lazy" alt="" decoding="async" data-v-dd9bf142></picture></div><div class="step number-3" data-v-dd9bf142>Появилась система удержания клиентов и повторных продаж <picture class="number" data-v-dd9bf142><source srcset="/images/numbers/3.webp, /images/numbers/3x2.webp 2x" type="image/webp" data-v-dd9bf142><img src="/images/numbers/3.png" fetchpriority="low" loading="lazy" alt="" decoding="async" data-v-dd9bf142></picture></div><div class="step number-4" data-v-dd9bf142>Увеличилась выручка при тех же затратах <picture class="number" data-v-dd9bf142><source srcset="/images/numbers/4.webp, /images/numbers/4x2.webp 2x" type="image/webp" data-v-dd9bf142><img src="/images/numbers/4.png" fetchpriority="low" loading="lazy" alt="" decoding="async" data-v-dd9bf142></picture></div><!--]--></div><div class="quote-wrapper" data-v-dd9bf142 data-v-20d2c489><div class="header f_text-caps-14" data-v-20d2c489>Клиенты о Bazon</div><div class="quote-text" data-v-20d2c489><div class="text h-t-italic h-margin-bottom-16" data-v-20d2c489>«Теперь я могу спокойно зайти в систему, найти любую запчасть, посмотреть, где она лежит, какое у неё состояние — всё через штрих-код. Это уже не гараж, а нормальная, системная работа. Даже если человек новичок — он просто сканирует и находит нужное. Раньше, чтобы что-то найти, нужно было вспоминать, где это лежит, или идти и на месте разбираться. Сейчас — подошёл, отсканировал, отдал клиенту…»</div><div class="sub-text" data-v-20d2c489>Святослав, собственник «Джип Разбор»</div><div class="h-t-c-white-50" data-v-20d2c489>г. Владивосток, 3000+ товаров, работают с Bazon с 2024 года</div></div></div></div></div><div class="block-wrapper" data-v-cd58d090 data-v-66415383><div class="block-content" data-v-66415383><h3 class="header" data-v-66415383>Не знаете, с чего начать?</h3><!----><div class="flex-wrapper" data-v-66415383><div class="h-w-100" data-v-66415383><div class="text" data-v-66415383> Обсудим ваши цели и задачи, составим план решения с помощью системы Bazon </div><!--[--><div class="separator" data-v-66415383></div><div class="text" data-v-66415383>или позвоните по номеру</div><a href="tel:88001007501" class="phone" data-v-66415383>8 800 100 75 01</a><!--]--></div><div class="h-w-100" form_id="501" data-v-66415383><label class="pb-input-wrapper large h-margin-bottom-16" type="name" data-v-66415383 data-v-33806b09><input class="f_text-16 is-bold ym-record-keys" type="name" name="namev-0-1" autocomplete="aucv-0-0" placeholder=" " value data-v-33806b09><span class="input-bg" data-v-33806b09></span><span class="f_text-16 is-bold label" data-v-33806b09>Ваше имя</span></label><label class="pb-input-wrapper large h-margin-bottom-16" type="phone" data-v-66415383 data-v-33806b09><input class="f_text-16 is-bold ym-record-keys" type="phone" name="namev-0-3" autocomplete="aucv-0-2" placeholder=" " value data-v-33806b09><span class="input-bg" data-v-33806b09></span><span class="f_text-16 is-bold label" data-v-33806b09>Ваш телефон</span></label><label class="pb-input-wrapper large" type="email" data-v-66415383 data-v-33806b09><input class="f_text-16 is-bold ym-record-keys" type="email" name="namev-0-5" autocomplete="aucv-0-4" placeholder=" " value data-v-33806b09><span class="input-bg" data-v-33806b09></span><span class="f_text-16 is-bold label" data-v-33806b09>Ваша почта</span></label><button class="pb-button large dark f_text-20 is-bold submit-button" data-v-66415383 data-v-2b04b5e0><!--[--> Свяжитесь со мной <!--]--></button><div class="h-ta-center h-t-c-black-50 f_text-12 is-bold" data-v-66415383> Нажимая на кнопку вы соглашаетесь с условиями<br data-v-66415383><a href="/policy/" target="_blank" class="h-t-c-black-100" data-v-66415383>политики конфиденциальности</a></div></div><!----></div></div></div></div><!--]--><div class="footer-wrapper f_text-12 h-margin-top" data-v-3d9e0f81 data-v-ef4f0edb><div class="flex-wrapper" data-v-ef4f0edb><div class="block-wrapper" data-v-ef4f0edb><div class="h-t-c-white-50 h-margin-bottom-8" data-v-ef4f0edb>© Bazon — 2016-2025</div><a href="/policy/" class="h-margin-bottom-8" data-v-ef4f0edb>Политика конфиденциальности</a><a href="/eula/" class="h-margin-bottom-8" data-v-ef4f0edb>Лицензионный договор</a></div><div class="block-wrapper" data-v-ef4f0edb><div class="h-t-c-white-50 h-margin-bottom-8" data-v-ef4f0edb>Удаленная служба поддержки</div><a href="https://account.aeroadmin.com/customization/signed/585617716037/AeroAdmin.exe?roistat_visit=438801" class="h-margin-bottom-8 h-flex-ai-center" target="_blank" data-v-ef4f0edb><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 16" class="nuxt-icon h-icon-size-16 h-margin-right-8" data-v-ef4f0edb><path fill="#fff" fill-rule="evenodd" d="M14.328 0H1.653A1.686 1.686 0 0 0 .48.495c-.31.31-.482.73-.48 1.166v12.678c-.002.438.172.858.483 1.17.312.311.736.488 1.18.491h6.742c-.998-.004-1.578-.08-2.015-.197-1.41-.382-2.469-1.159-2.94-2.16-.224-.475-.25-.634-.25-1.542 0-.915.024-1.061.251-1.521.5-1.014 1.513-1.754 2.91-2.127.623-.166 1.074-.199 3.252-.239l2.529-.046-.06-.426c-.096-.68-.219-.972-.538-1.278-.355-.34-.603-.443-1.277-.527-.955-.119-2.092.207-2.582.738-.434.472-.855.591-2.093.593-1.41.003-1.566-.082-1.548-.843.022-.953.59-1.813 1.503-2.278.474-.24 1.546-.53 2.37-.642.967-.13 3.671-.053 4.384.125.884.221 1.746.668 2.304 1.193.576.542.885 1.031 1.156 1.83.182.538.196.804.227 4.517.007.828.012 1.5.012 2.046V1.661a1.635 1.635 0 0 0-.487-1.173A1.676 1.676 0 0 0 14.328 0ZM16 13.332c0 .542-.006.954-.02 1.269a1.63 1.63 0 0 0 .02-.262v-1.007Zm-1.14 2.581c-.122.027-.253.055-.386.08a1.68 1.68 0 0 1-.136.007H8.56m6.3-.087a1.694 1.694 0 0 1-.386.08l.386-.08Zm-7.8-3.656c-.067-.698.205-1.12.879-1.359.246-.087.905-.124 2.266-.127l1.92-.004v1.718l-.486.243c-.88.44-1.563.63-2.451.682-1.38.08-2.043-.279-2.128-1.153Z" clip-rule="evenodd"></path></svg> Скачать AeroAdmin </a></div><div class="apps-wrapper" data-v-ef4f0edb><div class="h-t-c-white-50 h-margin-bottom-8" data-v-ef4f0edb>Мобильное приложение Bazon</div><a href="https://itunes.apple.com/ru/app/bazon/id1340817905?roistat_visit=438801" target="_blank" aria-label="Ссылка на мобильное приложение Bazon в appstore" data-v-ef4f0edb><picture class="appstore-icon" data-v-ef4f0edb><source srcset="/images/appstore/app-store.webp, /images/appstore/app-store2x.webp 2x" type="image/webp" data-v-ef4f0edb><img src="/images/appstore/app-store.png" fetchpriority="low" loading="lazy" decoding="async" alt="Ссылка на мобильное приложение Bazon в appstore" data-v-ef4f0edb></picture></a><a href="https://play.google.com/store/apps/details?id=ru.bazon.android&amp;roistat_visit=438801" target="_blank" aria-label="Ссылка на мобильное приложение Bazon в google play" data-v-ef4f0edb><picture class="appstore-icon h-margin-left-8" data-v-ef4f0edb><source srcset="/images/appstore/google-play.webp, /images/appstore/google-play2x.webp 2x" type="image/webp" data-v-ef4f0edb><img src="/images/appstore/google-play.png" fetchpriority="low" loading="lazy" decoding="async" alt="Ссылка на мобильное приложение Bazon в google play" data-v-ef4f0edb></picture></a></div></div><div class="h-t-c-white-50 h-margin-top-16" data-v-ef4f0edb> ООО «Мастер веб» ИНН 5406528760 ОГРН 1095406011854 Адрес 630009, г. Новосибирск, ул. Добролюбова, дом 2А, офис 216 </div></div><span data-v-3d9e0f81></span></div></div></div><div id="teleports"></div><script type="application/json" data-nuxt-data="nuxt-app" data-ssr="true" id="__NUXT_DATA__">[["ShallowReactive",1],{"data":2,"state":4,"once":115,"_errors":116,"serverRendered":118,"path":119},["ShallowReactive",3],{},["Reactive",5],{"$sviewportState":6,"$sfeedbacks":7,"$sfeedbacksvideos":85,"$scompanyConfig":114},"desktop",[8,14,20,26,32,38,44,49,55,61,67,73,79],{"key":9,"smalltext":10,"text":11,"author":12,"company":13},0,"С Bazon стало гораздо проще работать: раньше объявления на Drom плохо выгружались, клиенты нас не находили. Сейчас всё настроено — объявления загружаются, видны, начали приносить реальные продажи...","С Bazon стало гораздо проще работать: раньше объявления на Drom просто плохо выгружались, клиенты нас не находили. Сейчас всё настроено — объявления загружаются, видны, начали приносить реальные продажи. Используем адресное хранение — всё понятно, доступно, ускоряет поиск запчастей.\u003Cbr>\u003Cbr>Даже с большим количеством товара справляемся, потому что Bazon автоматизировал много рутинных процессов. Продажи и учет стали организованнее. Некоторые задачи удалось делегировать, теперь все сотрудники работают через систему.\u003Cbr>\u003Cbr>Поддержка тоже радует — любые вопросы решаются быстро, всегда объясняют всё по делу.","Сергей, руководитель «Чип и Дэйл»","г.&nbsp;Ростов-на-Дону, 13&nbsp;000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2021&nbsp;года",{"key":15,"smalltext":16,"text":17,"author":18,"company":19},1,"После внедрения Bazon стало на 100% проще находить товар — теперь даже человек без опыта может просто взять номер и найти нужную деталь, не разбираясь, как она выглядит. Это сильно упростило обучение новых сотрудников…","С Bazon работаем давно — у нас два филиала: Горно-Алтайск и Бийск, еще один в Новосибирске под другим названием. В компании около 20 человек.\u003Cbr>\u003Cbr>После внедрения Bazon стало на 100% проще находить товар — теперь даже человек без опыта может просто взять номер и найти нужную деталь, не разбираясь, как она выглядит. Это сильно упростило обучение новых сотрудников.\u003Cbr>\u003Cbr>Контроль за бизнесом и сотрудниками стал прозрачнее — всё понятно, всё удобно. Если возникают какие-то вопросы, просто созвонились с техподдержкой и быстро всё решили. Обычно в течение трёх часов вопрос уже закрыт. Каких-то долгих проблем или серьёзных глюков в системе не было за эти годы.\u003Cbr>\u003Cbr>Приходом занимаюсь лично, потому что вся применимость деталей в моей голове, но при этом многие процессы уже работают по доверию — не надо всё держать под полным контролем.\u003Cbr>\u003Cbr>Работаем, всё устраивает. Если и возникают мелкие доработки, вроде отображения номера производителя в товарном чеке — передаём, ребята реагируют и правят. Всё по-человечески.","Александр, соучредитель «Автолэнд»","г.&nbsp;Бийск, 18&nbsp;000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2017&nbsp;года",{"key":21,"smalltext":22,"text":23,"author":24,"company":25},2,"Выручка увеличилась, я статистику по месяцам вижу. Статистика по машинам, продажам, поставкам — крайне важная вещь. Оцениваем: за сколько купили, за сколько продали, что получили...","Адресное хранение в Bazon — это супер удобно, супер важная вещь. Мы ничего не ищем, точно знаем, где что лежит, без этого — как без рук. Когда одна-две машины — то еще можно как то помнить, а когда 20 уже не можешь всё помнить, сотрудники разные — кто-то помнит, кто-то нет, кто-то занес, кто-то не занес. А тут всё по местам, единственная правильная тема, если у вас действительно много машин.\u003Cbr>\u003Cbr>\u003Cbr>Сотрудников нанимали уже с Bazonом, когда начинали с вами — было три человека, сейчас 13. Беру даже без опыта, потому что стало сильно легче их обучать. Всё интуитивно понятно, не сложно. Беру линейных сотрудников говорю им как и что делать, они делают. Для меня комфортно — и я вижу результаты.\u003Cbr>\u003Cbr>\u003Cbr>Приемка товара быстрее заносится, всё отлажено, понятно.  Без системы учета торговать невозможно, мы с нуля это знали точно.\u003Cbr>Контролировать компанию проще, безусловно стало. Раньше нанимал кладовщиков, платил за смену, а сейчас говорю: смена столько-то, но план: 50 деталей в день на Bazon. Выполнил — молодец, перевыполнил — мотивация, не выполнил — извини, не получил.\u003Cbr>\u003Cbr>Выручка увеличилась, я статистику по месяцам вижу. Статистика по машинам, продажам, поставкам — крайне важная вещь. Оцениваем: за сколько купили, за сколько продали, что получили.\u003Cbr>\u003Cbr>С поддержкой вашей — мне комфортно и удобно работать. Все вопросы решаете, всегда на связи, написал — через какое-то время ответ. Главное — человеческая обратная связь, вы разбираетесь в нашей специфике, понимаете, о чём речь, это чертовски важно. Спасибо вам огромное, очень приятно. Глюков с системой не замечал..\u003Cbr>\u003Cbr>Для меня окупается программа за счет удобства в работе, цена прекрасна у вас за использование. Качественный продукт, хорошая поддержка, труд должен оплачиваться, люди тратят время, силы, энергию, и за эти деньги — просто подарок.","Антон, собственник «Brorazbor»","г.&nbsp;Москва, 4000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года",{"key":27,"smalltext":28,"text":29,"author":30,"company":31},3,"Основное, за что ценим Bazon — это простота, удобство и заточка под специфику нашей работы. Приходование стало быстрее, всё оцифровывается, автозагрузка на площадки работает стабильно — чем быстрее товар занесён, тем быстрее он продаётся...","С Bazon работаем с 2020&nbsp;года. За это время компания выросла, увеличилось количество сотрудников и объем работы. Конечно, нельзя сказать, что всё это исключительно заслуга Bazon, но вклад системы в процессы — очевидный.\u003Cbr>\u003Cbr>Основное, за что ценим Bazon — это простота, удобство и заточка под специфику нашей работы. Приходование стало быстрее, всё оцифровывается, автозагрузка на площадки работает стабильно — чем быстрее товар занесён, тем быстрее он продаётся. Плюс порядок на складе: используем адресное хранение, это экономит и время, и пространство. Даже в небольшом ящике можем держать сотню деталей, и при этом легко всё находим.\u003Cbr>\u003Cbr>С обучением новых сотрудников тоже стало проще. Программа интуитивно понятна, даже если человек без опыта — быстро вникает. Не нужно настраивать логистику вручную или объяснять, где и что должно лежать. Просто кладем на свободную полку и указываем в системе адрес.\u003Cbr>\u003Cbr>В целом всё работает, поддержка на связи, вопросы решаются оперативно.","Игорь, директор «ZapJapan22»","г.&nbsp;Барнаул, 12&nbsp;000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2020&nbsp;года",{"key":33,"smalltext":34,"text":35,"author":36,"company":37},4,"Вносить стало гораздо проще: марку, модель, применимость — всё это теперь не нужно писать вручную, всё быстро подставляется. Плюс справочники помогают. Благодаря этому мы начали продавать всякую мелочёвку, которая раньше просто лежала мёртвым грузом...","С Bazon я работаю уже лет пять-шесть. Начинал одним из первых среди знакомых — увидел их случайно в Яндексе, попробовал, и пошло-поехало. Потом и другие подтянулись, глядя на меня. До этого вообще ничего не было — всё вручную, всё на бумаге. Ни учёта, ни аналитики, ни нормальной организации процессов.\u003Cbr>\u003Cbr>Раньше, когда приходил контейнер, мы просто вытаскивали машины, фоткали где попало, и всё растаскивали по складу. Сейчас уже построили фотозону, купили нормальные телефоны, которые хорошо фотографируют. Стали указывать производителей, дефекты, начали всё более грамотно и системно заносить в Bazon.\u003Cbr>\u003Cbr>Вносить стало гораздо проще: марку, модель, применимость — всё это теперь не нужно писать вручную, всё быстро подставляется. Плюс справочники помогают. Благодаря этому мы начали продавать всякую мелочёвку, которая раньше просто лежала мёртвым грузом.\u003Cbr>\u003Cbr>Сейчас работаем в основном с Авито и Дромом. Раньше тоже ими пользовались, но всё делали вручную. Максимум 50 объявлений в день получалось. Сейчас — массовые выгрузки. У нас сейчас чёткое разделение: одни заносят в Bazon, другие продают, кто-то пакует, кто-то отправляет. Полностью выстроили процессы.\u003Cbr>\u003Cbr>До Bazon всё лежало где попало. Кладовщик уходил искать товар — и мог пропасть на полдня. Сейчас раскладываем всё по полкам: радиаторы отдельно, двери отдельно. Даже кладовщику ставим лимит по времени — если товар один, он должен быстро найти и принести. Сейчас на поиск в среднем уходит 2–3 минуты.\u003Cbr>\u003Cbr>Адресное хранение пока не внедрили, но к этому идём.\u003Cbr>\u003Cbr>Раньше вся аналитика была — пальцем по бумаге. Что-то сам себе считал, какие-то записи вёл. Сейчас в Bazon смотрим продажи, остатки, выручку, сравниваем с тем, по чём привезли. Это реально помогает понимать, куда дальше двигаться, что усиливать.\u003Cbr>\u003Cbr>Внедряли Bazon с нуля. Ни 1С, ни других систем не было. Постепенно всё выстраивали, улучшали. Конечно, ещё есть, что доделывать. Например, выгрузка объявлений — у вас пока работает на два аккаунта, а нам бы уже хотя бы на четыре. Этот вопрос буду отдельно уточнять.","Владимир, собственник «JapanParts MSK»","г.&nbsp;Москва, 20&nbsp;000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2021&nbsp;года",{"key":39,"smalltext":40,"text":41,"author":42,"company":43},5,"Раньше запчасти вручную на Drom заносили, каждое объявление, а теперь через Bazon делаем выгрузки — реально намного быстрее…","Новых сотрудников не нанимали, так же трое человек, но зарабатывать стали больше. \u003Cbr>После внедрения принтера с наклейками проще стало находить запчасти на складе, раньше у нас его не было, всё из головы бралось — кто что помнит. Сейчас информация на наклейке, отсканировал — и готово, реально проще. \u003Cbr>\u003Cbr>Узнаваемость выросла, клиенты возвращаются.\u003Cbr>\u003Cbr>Раньше запчасти вручную на Drom заносили, каждое объявление, а теперь через Bazon делаем выгрузки — реально намного быстрее, в несколько раз.\u003Cbr>\u003Cbr>Свободного времени стало больше, контролировать процессы и компанию целиком стало проще.\u003Cbr>\u003Cbr>Поддержкой довольны, быстро реагирует, всё хорошо. Глюков вроде не замечали, если что-то и было, быстро налаживается.\u003Cbr>","Сергей, собственник «SSGparts»","г.&nbsp;Владивосток, 4000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года",{"key":45,"smalltext":46,"text":47,"author":48,"company":25},6,"До перехода на Bazon работали через Japancar и FarPost. Приемка велась вручную: фото на фотоаппарат, скидывали на компьютер, заносили на сайт. Это занимало много времени. Сейчас товары фотаем на телефон, сразу заносим в Bazon, это экономит недели, а то и месяцы работы...","До перехода на Bazon работали через Japancar и FarPost. Приемка велась вручную: фотографировали на фотоаппарат, скидывали на компьютер, заносили на сайт. Это занимало много времени, особенно при больших поставках.\u003Cbr>\u003Cbr>С Bazon процесс стал гораздо быстрее и удобнее. Сейчас в Корее, до отправки контейнера, товары фотографируются на телефон, сразу заносятся в Bazon, наклеиваются этикетки. Когда контейнер приезжает в Россию, остается только \"пикнуть\" товары — все уже заведено. Это экономит недели, а то и месяцы работы. Например, раньше на три контейнера уходило четыре месяца приемки, теперь — значительно быстрее, даже несмотря на то, что пока тестируется.\u003Cbr>\u003Cbr>Полноценный складской учет пока не внедрен. Я планирую организовать зоны, полки, адресное хранение, но для этого нужен отдельный сотрудник.\u003Cbr>\u003Cbr>Выгружаемся в основном на Avito и Drom. Avito вызывает наибольшее количество проблем: нестабильная выдача, ограничения на повторяющиеся фото, частые изменения правил. С Drom ситуация стабильнее — там товары легче найти, и логика поиска более понятна.\u003Cbr>\u003Cbr>Аналитикой в Bazon пользуюсь ежедневно. Смотрю продажи, возвраты, статистику. Информацию о донорах заносим, но полноценный учет по окупаемости донора пока не ведется — основной приоритет сейчас на увеличение продаж.\u003Cbr>\u003Cbr>Пока Bazon — единственное, что реально помогает систематизировать бизнес.\u003Cbr>","Андрей, соучредитель «RICH Group» ",{"key":50,"smalltext":51,"text":52,"author":53,"company":54},7,"До Bazonа работали с другой системой. С Bazon стало удобнее работать — всё автоматизировано: приход, остатки, выгрузки. Быстро перенесли базу и без потерь данных...","До Bazonа работали с другой системой. С Bazon стало удобнее работать — всё автоматизировано: приход, остатки, выгрузки. Быстро перенесли базу и без потерь данных.\u003Cbr>Доходы у нас идут: 80% — это Avito, 20% это другие ресурсы и кто-то через сайт заказывает, который Bazon делал, кто-то по рекомендациям приходят.\u003Cbr>\u003Cbr>\u003Cbr>Все проще стало, всем рекомендуем, у меня уже несколько человек от нас к вам пришли. Контролировать компанию тоже проще стало.\u003Cbr>\u003Cbr>Глюков практически не возникало, не помню такого. \u003Cbr>Что нравится непосредственно в Bazon — техподдержка ваша, что можно всегда позвонить, написать.\u003Cbr>\u003Cbr>\u003Cbr>Система окупается, за счет удобства работы с остатками товарными, прихода и автовыгрузки.","Максим, владелец «МБ Ликино»","г.&nbsp;Одинцово, 10&nbsp;000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2022&nbsp;года",{"key":56,"smalltext":57,"text":58,"author":59,"company":60},8,"Когда пришел к Bazon, прям счастья не было предела. Базу мою перенесли за один день — я поверить не мог! У старых хозяев пришлось свою базу выкупать, они сказали: «Бесплатно не отдадим»…","До Bazonа со складом плохо работали, пытался что-то делать. Понимал, что надо автоматизировать. Работал с программой какой-то, питерский товарищ разработал для авторазборок, но там всё настолько не отработано, что два&nbsp;года мучился. Там якобы автовыгрузка была, а в итоге ничего не работало. \u003Cbr>\u003Cbr>Когда пришел к Bazon, прям счастья не было предела. Базу мою перенесли за один день — я поверить не мог! У старых хозяев пришлось свою базу выкупать, они сказали: «Бесплатно не отдадим». В Bazon мне нравится, что не надо платить за фильтры дополнительные. В комплекте с программой сделали сайт. Очень доволен, оптимизировано именно под разбор. Раньше на сайты выкладывал две-три фотки в среднем, ограничение по месту на сервере было, а Bazon говорят: хоть сколько выкладывайте. Это меня очень впечатлило — больше фотографий, качественных, соответственно больше продаж.\u003Cbr>\u003Cbr>Продажи с тех пор выросли минимум в 2 раза. Сначала был рост на 50%, а сейчас уже 100–150% относительно того, что было. Bazon, конечно, помогает — я всегда ребятам вашим говорю, что очень доволен отношением, работой, как всё слаженно.\u003Cbr>\u003Cbr>Контролировать компанию намного удобнее стало. В той программе не оптимизировано было, а здесь у пользователей права ограниченные — кому какие посчитал, такие сделал. На Avito, на Drom своему менеджеру логин, пароль отдельный дал — вижу, что он делает, как отвечает, могу контролировать, но это всё равно связано с Bazon. Очень хорошая программа у вас.\u003Cbr>\u003Cbr>Работаю с вами давно, может, четыре&nbsp;года — время быстро идет. Глюки, если появлялись, всегда очень быстро решали, поразительно быстро. Позвонил — сразу решили. \u003Cbr>\u003Cbr>Система окупается за счет модернизации, автоматизации. Самое главное — это когда всё работает самостоятельно, это мега круто. Ведешь базу в одном месте, а она отображается везде — на сайте, на Avito, на Drom, в X-BAZE. Вот это прям очень круто! Раньше отдельно в Avito магазин вел, отдельно на Drom, за сайт вообще никто не мечтал. А тут в одном месте и везде доступ — из телефона, с одного компьютера, с другого. Это самый офигенный результат, максимально автоматизировано всё, мне кажется.\u003Cbr>","Вячеслав, владелец «Славянин 23»","г.&nbsp;Краснодар, 14&nbsp;000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2021&nbsp;года",{"key":62,"smalltext":63,"text":64,"author":65,"company":66},9,"С Bazonом работать проще стало. Помогают справочники и подсказки. OEM Номера ставим, кросс-номера, фотки делаем...","Я считаю, Bazon — это в ногу со временем, удобно, понятно, прозрачно, быстро работает. Даже в отпуск на Новый год ездил, стало скучно, открыл бук и начал работать — нет привязки к рабочему месту, сиди, работай откуда угодно.\u003Cbr>\u003Cbr>С Bazonом работать проще стало. Помогают справочники и подсказки. OEM Номера ставим, кросс-номера, фотки делаем. Мы даже эксперимент проводили с друзьями, кто в Bazonе сидит: брали непродаваемые позиции, типа боковых стекол, массово добавляли точку в описание чтобы внести изменение в описание и пошевелить объявления — и реально начались продажи. В этом нам помогла крутая функция массовых замен описания. \u003Cbr>\u003Cbr>Раньше вообще в экселях сидели старые разборы в Барнауле, лет 25 работают, до сих пор в тетрадках и экселях заплняют, не знают, что делать. Цена нормальная абсолютно, не дорого. Мир меняется, услуги дорожают, а тут с экселей и тетрадок переходишь — и все довольны.\u003Cbr>\u003Cbr>Окупается сама система в совокупности. Как бухгалтерская система учета — уже это всё окупает. Плюс удобность, структурированность, всё в одном месте, взаимосвязано. Вот даже лично для меня удобно.Поддержка нормальная, затыков не было, всё решалось быстро.","Василий, партнёр «Автобот22»","г.&nbsp;Барнаул, 7000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2023&nbsp;года",{"key":68,"smalltext":69,"text":70,"author":71,"company":72},10,"С внедрением системы намного проще стало, все улучшилось. Всё начало работать так, как должно было работать, как я себе предполагал. В плане поиска запчастей, в плане применимости — короче говоря, во всех планах лучше стало...","Мы с Bazonом работаем уже давно у нас сейчас 7 человек занимается разбором, второй склад открыли. Раньше в основном одной БУшкой занимались, а сейчас и новые запчасти.\u003Cbr>\u003Cbr>С внедрением системы намного проще стало, все улучшилось. Всё начало работать так, как должно было работать, как я себе предполагал. В плане поиска запчастей, в плане применимости — короче говоря, во всех планах лучше стало.\u003Cbr>\u003Cbr>Раньше учет вели, скажем так, на коленке в экселевском файле. Когда начали, просто расширяли его, добавляли новые страницы с наименованиями запчастей. Постоянно это всё расширялось, расширялось, расширялось, потом начали вносить оригинальные номера деталей, краткое описание, выделять определенным цветом и так далее. Аналитику тоже там же вели, конечно.\u003Cbr>\u003Cbr>Поддержка у вас отличная. Всегда вы на связи, всегда помогаете, причем очень всё это быстро происходит, оперативно, без всяких бюрократических проволочек. Вопросы, которые можно решить сразу, подсказать, объяснить — решаются в этот же день. Какие-то более длительные вопросы, пожелания — со временем. В общем плане, очень довольны.\u003Cbr>\u003Cbr>Bazon — это недорого, цена прямо радует. А окупается она, во-первых, тем, что очень ускоряет работу. Без системы потребовалось бы гораздо больше часов работы для наполнения одновременно нескольких площадок. Отдельно вести кому-то и добавлять объявления в Drom, отдельно в Avito, отдельно еще где-то, отдельно сайт вести и так далее. А сейчас, имея эту базу и возможности выгрузки уже готовой базы по разным направлениям, это ускоряет многократно работу. Только за счет этого уже все окупается.","Денис, собственник «Седьмой Новый»","г.&nbsp;Таганрог, 7000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2022&nbsp;года",{"key":74,"smalltext":75,"text":76,"author":77,"company":78},11,"Я могу найти любую запчасть, посмотреть, где она лежит, какое у неё состояние — всё через штрих-код. Это уже не гараж, а нормальная, системная работа. Даже новичок — просто сканирует и находит нужное. Раньше, чтобы что-то найти, нужно было вспоминать, где это лежит, или идти и на месте разбираться...","Когда мы только начинали, никакой полноценной системы учета не было — в основном работали на Дроме, пробовали какую-то Cloud-разработку, но толку от неё было немного. Всё больше как хранилище информации, без порядка. После перехода на Bazon — небо и земля.\u003Cbr>\u003Cbr>Теперь я могу спокойно зайти в систему, найти любую запчасть, посмотреть, где она лежит, какое у неё состояние — всё через штрих-код. Это уже не гараж, а нормальная, системная работа. Даже если человек новичок — он просто сканирует и находит нужное. Раньше, чтобы что-то найти, нужно было вспоминать, где это лежит, или идти и на месте разбираться. Сейчас — подошёл, отсканировал, отдал клиенту.\u003Cbr>По работе с персоналом тоже стало проще. Мы взяли нового человека под фотосъёмку. Он просто фотографирует запчасти, зная, какие ракурсы и детали важны. У него конкретная задача, и это сильно упрощает обучение если сотрудник не шарит в запчастях. Он просто делает фото, добавляет видео через приложение, а я потом спокойно в системе дополняю нужную информацию. Такой подход даёт хороший результат.\u003Cbr>\u003Cbr>Процесс приёмки товара упростился капитально. Особенно, если используется донор — всё проставляется почти автоматически. Фотки прикрепил, название поправил — и всё. Раньше вручную выставлять на Drom было просто мучение, а теперь — удобно и быстро.\u003Cbr>\u003Cbr>С клиентами работать тоже проще: позвонил человек — я зашёл в систему, посмотрел, что есть, скинул ссылку на сайт — он сам выбрал нужное. Это реально экономит время и снижает нагрузку. Тот же сайт от Bazon’а работает отлично: отображает применимости, фото, всё, что нужно. Людям удобно.\u003Cbr>\u003Cbr>Что особенно радует — я теперь вижу, как отработал каждый день, даже не приезжая на склад. Могу делегировать задачи: ребята сами принимают машины, фотографируют, запускают в продажу. Я просто вечером захожу в систему и вижу, что и как сделано. Раньше это было невозможно.\u003Cbr>\u003Cbr>Появилась прозрачность по донорам. Я могу полностью посчитать каждую машину: до болта. Понимаю, сколько потратил, сколько заработал. Это серьёзный инструмент для анализа. А по продажам — реально начали продаваться позиции, которые раньше просто лежали и пылились. А теперь они в системе, и о них люди узнают.\u003Cbr>\u003Cbr>Поддержка — на высоте. Обратная связь всегда есть, помогают, если что-то не получается. Один раз были сложности с фотографиями — решили. Всё работает стабильно. И главное — за те деньги, что стоит система, это просто находка. Всё окупается в комплексе: и временем, и упрощением процессов, и ростом продаж. Не жалею ни на минуту, что выбрали Bazon.","Святослав, собственник «Джип Разбор»","г.&nbsp;Владивосток, 3000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2024&nbsp;года",{"key":80,"smalltext":81,"text":82,"author":83,"company":84},12,"Сайт от Bazon реально помогает продавать. Причём не просто продавать, а увеличивать средний чек и запускать дополнительные продажи. Фишка в том, что можно генерировать живые ссылки на подборки по марке, модели и поколению машины…","Сайт от Bazon реально помогает продавать. Причём не просто продавать, а увеличивать средний чек и запускать дополнительные продажи практически без усилий.\u003Cbr>\u003Cbr>Когда клиент ищет конкретную запчасть — почти всегда есть сопутствующие потребности. Например, ставит суппорт — нужны и колодки. И если ты грамотно работаешь с базой применимости и кросс-номерами, то сайт Bazon позволяет собрать подборку актуальных запчастей под нужную модель. Без привязки к конкретному донору, который уже через полгода распродан.\u003Cbr>\u003Cbr>Фишка Bazon в том, что можно генерировать живые ссылки на подборки по марке, модели и поколению машины. Эти ссылки ведут на реальный остаток, всё в наличии и с актуальными ценами. Скинул клиенту такую — и он сам выбирает нужное, без лишних вопросов.\u003Cbr>\u003Cbr>Бонус — эти ссылки живут своей жизнью. Клиенты передают их друг другу в чатах, клубах и переписках, только ваши товары, без конкурентов, как на досках объявлений. Был случай: продали панель приборов, скинули ссылку — через два дня прилетел заказ от мужа той самой покупательницы, ещё на 30+ тысяч. Просто по той же ссылке он всё нашёл сам и оформил.\u003Cbr>\u003Cbr>Самое главное — мы не делаем скидки. Всё уходит по цене, которая указана на сайте. Клиенту удобно, нам — прибыльно. А один простой вопрос \"А вам ещё что-то нужно?\" — и часто в ответ прилетает список деталей, которые тоже оказываются в наличии.\u003Cbr>\u003Cbr>Bazon — это инструмент, который работает на тебя, даже когда ты спишь.","Михаил, собственник «Быстрые Детали»","г.&nbsp;Новосибирск, 6000+&nbsp;товаров,\u003Cbr>работают с&nbsp;Bazon&nbsp;с&nbsp;2023&nbsp;года",[86,92,97,103,108],{"embedVideoLink":87,"videoLink":88,"preview":89,"name":90,"time":91},"https://rutube.ru/play/embed/97af44c395d7d9071863a1bdd9b3cda0","https://rutube.ru/video/97af44c395d7d9071863a1bdd9b3cda0/?r=plwd","/images/feedback-previews/feedback-preview-allsubaru.jpg","Компания «ALLsubaru», 22&nbsp;000+&nbsp;товаров","Использует Bazon с&nbsp;2019&nbsp;года",{"embedVideoLink":93,"videoLink":94,"preview":95,"name":96,"time":91},"https://rutube.ru/play/embed/1e281de3b9b83dab26702ed5c19b5ea7","https://rutube.ru/video/1e281de3b9b83dab26702ed5c19b5ea7/?r=plwd","/images/feedback-previews/feedback-preview-razboravto.jpg","Компания «Razboravto 18», 10&nbsp;000+&nbsp;товаров",{"embedVideoLink":98,"videoLink":99,"preview":100,"name":101,"time":102},"https://rutube.ru/play/embed/8b1d1edd3207dcae5c159979bfe90ce2","https://rutube.ru/video/8b1d1edd3207dcae5c159979bfe90ce2/?r=plwd","/images/feedback-previews/feedback-preview-motorcity.jpg","Компания «Motorcity Moscow», 30&nbsp;000+&nbsp;товаров","Использует Bazon с 2021&nbsp;года",{"embedVideoLink":104,"videoLink":105,"preview":106,"name":107,"time":91},"https://rutube.ru/play/embed/7b06944d9a1c0a007eb5b94a57245c6a","https://rutube.ru/video/7b06944d9a1c0a007eb5b94a57245c6a/?r=plwd","/images/feedback-previews/feedback-preview-amggarage.jpg","Компания «AMGgarage», 55&nbsp;000+&nbsp;товаров",{"embedVideoLink":109,"videoLink":110,"preview":111,"name":112,"time":113},"https://rutube.ru/play/embed/b069ebdbc024fe2833854a65c7850f20","https://rutube.ru/video/b069ebdbc024fe2833854a65c7850f20/?r=plwd","/images/feedback-previews/feedback-preview-3rcompany.jpg","Компания «3R Сompany», 9000+&nbsp;товаров","Использует Bazon с&nbsp;2016&nbsp;года",{},["Set"],["ShallowReactive",117],{},true,"/"]</script>
