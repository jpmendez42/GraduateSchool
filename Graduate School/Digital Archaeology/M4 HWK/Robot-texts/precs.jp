}

.pc-images img:nth-child(1),
.mobile-image img:nth-child(1) {
    animation-delay: 0s;
}

.pc-images img:nth-child(2),
.mobile-image img:nth-child(2) {
    animation-delay: 6s;
}

           
 .pc-images img:nth-child(3),
.mobile-image img:nth-child(3) {
    animation-delay: 12s;
}
           
.pc-images img:nth-child(4),
.mobile-image img:nth-child(4) {
    animation-delay: 18s;
}           
           
           
@keyframes fadeAnimation {
    0% {
        opacity: 0;
    }
    12.5% {
        opacity: 1;
    }
    37.5% {
        opacity: 1;
    }
    50% {
