<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>Error 404</title>
<style>
    .bg {
    -webkit-background-size: cover;
    -moz-background-size: cover;
    -o-background-size: cover;
    -ms-background-size: cover;
    background-size: cover; 
    background-image: url(../img/background-6.webp);
    background-repeat: no-repeat;
    }
    
    .logo {
        width:100%;
        text-align: center;
        padding-top:50px;
    }
    
    .err404 {
        padding-top:150px;
        width:100%;
        text-align: center;
    }
    
    .img-err404 {
        max-width:512px;
        width:100%;
    }
    
    .text_err {
        padding-top:50px;
        font-size:22px;
        width:100%;
        text-align:center;
        color: #646464;
    }
    
    .btn_err {
        padding-top:50px;
        width:100%;
        text-align:center; 
    }
    
    .btn {
        width:150px;
        height:45px;
        background: #01A7F6;
        border-radius: 10px;
        border: none;
        outline: none;
        color: #FFFFFF;
        cursor: pointer;
        font-size: 16px;
    }
</style>
    
</head>

<body class="bg">
    <div class="logo"><a href="/"><img alt="Craft Hosting" src="../img/logo.svg"></a></div>
    <div class="err404"><img class="img-err404" alt="Craft Hosting" src="../img/error404.svg"></div>
    <div class="text_err">Такой страницы не существует!</div>
    <div class="btn_err"><a href="/"><button class="btn">На главную</button></a></div>
</body>
</html>
