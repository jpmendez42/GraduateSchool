.extrawide-container .container {
    max-width: 1800px;
}

.col-set.hp-stats span.stat-number {
	font-size: 2em;
}

.col-set.hp-stats a {
    text-decoration: none !important;
    display: block;
    width: 100%;
}

.feedzy-rss-1 ul {
    list-style: disc !important;
}

.feedzy-rss-1 ul li {
    display: list-item !important;
}

ul.timeline {
  padding-left: 20px;
}
ul.timeline li {
  position: relative;
  list-style: none;
  padding: 0 0 0.5rem 30px;
  margin-bottom: -20px;
  border-left: 2px solid #05262d;
}
ul.timeline li:before {
  content: "";
  display: block;
  position: absolute;
  left: -11.3px;
  top: 3px;
  width: 20px;
  height: 20px;
  border: 2px solid #3bad49;
  border-radius: 50%;
  background-color: #3bad49;
  box-shadow: 0 0 0 5px white;
}
ul.timeline li:last-of-type {
  padding-bottom: 0 !important;
  margin-bottom: 0 !important;
}

.tagline {
	text-transform: uppercase;
	font-weight: 500;
	letter-spacing: 1px;
}

.no-padding-bottom .content-padding {
    padding-bottom: 0 !important;
}

.domainpricing tr > th:nth-child(2), .domainpricing tr > td:nth-child(2) {
    display: none;
}

.tabbed {
    margin: 30px auto;
    text-align: center;
}

.tabbed > input {
    display: none;
}

.tabbed label {
    display: inline-block;
    float: unset;
    padding: 15px 30px;
	  margin-bottom: 1rem;
    margin-right: 1rem;
    font-size: 22px;
    transition: border .4s;
    border-radius: 30px;
    border-top-right-radius: 0;
    border: 2px solid transparent;
}

.tabbed > label:hover,
.tabbed > input:checked + label {
    background: #ffffff;
    color: #04272c;
    border: 2px solid #04272c;
    text-decoration: underline;
}

.tabbed > label:hover {
    border: 2px solid rgba(4, 39, 44,.6);
    text-decoration: none;
    transition: border .2s;
}

.tabs {
    display: block;
    position: relative;
    height:fit-content;
}

.tabs > div {
    display: none;
}

#tab-nav-1:checked ~ .tabs > div:nth-child(1),
#tab-nav-2:checked ~ .tabs > div:nth-child(2),
#tab-nav-3:checked ~ .tabs > div:nth-child(3) {
    display: block;
		margin-top: 2rem;
}

.products-toggle {
	text-align: center;
}

.products-toggle summary {
    display: inline-block;
    margin: 2rem 0 1rem;
    border: 2px solid #05262d;
    padding: 1rem 2rem;
    border-radius: 50px;
}

.products-toggle summary i {
    transition: .2s transform ease-in-out;
}

.products-toggle[open] summary i {
    transform: rotate(180deg);
}

#site-notice a.btn {
    margin-left: 1rem;
}
footer#site-footer a {
	opacity: 1;
	transition: 0.3s opacity ease-in-out;
}

footer#site-footer a:hover {
	color: #fff;
	opacity: .7;
}

.some-links a:hover .fa-facebook {
    color: #9AC837;
}

.some-links a:hover .fa-instagram {
    color: #9AC837;
}

.some-links a:hover .fa-youtube {
    color: #9AC837;
}		</style>
