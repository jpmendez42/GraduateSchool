F4ByuPP" data-sstype="slide" data-pm="default"><div class="n2-ss-layer n2-ow n-uc-qMuV1EBOTeG6" data-pm="default" data-sstype="content" data-hasbackground="0"><div class="n2-ss-section-main-content n2-ss-layer-with-background n2-ss-layer-content n2-ow n-uc-qMuV1EBOTeG6-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-5bpIWwQmROmp" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-5bpIWwQmROmp-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-8Rt88ahCaZem" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-8Rt88ahCaZem-inner"><div class="n2-ss-layer n2-ow n-uc-Bkg2J4fKq4Uh" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item197" class="n2-font-bb8a8ebbef82965b045c7cc66415e973-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Bertrand Piccard</div></div><div class="n2-ss-layer n2-ow n-uc-3UmJLFKAAljY" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.05,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item198" class="n2-font-53800138ef911fbb422d999cedf39f67-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Prendre de l’altitude d’esprit</div></div><div class="n2-ss-layer n2-ow n-uc-peha30PzDveq" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-hidemobileportrait="1" data-sstype="layer"><div class="n2-ss-item-content n2-ss-text n2-ow-all"><div class=""><p class="n2-font-d90a9b84626b12a176d70e24355b0ebb-paragraph   ">L’UTC a eu le plaisir d’accueillir à la Maison de la Culture d’Amiens le « savanturier » Bertrand Piccard. Il a donné une conférence sur le thème : « l’esprit pionnier pour inventer le futur » sur fond de son expérience avec le Solar Impulse. Retour sur la dose de créativité et d’improvisation qu’il faut pour réaliser l’impossible parfois. </p>
</div></div></div><div class="n2-ss-layer n2-ow n-uc-13448b613378c n2-ss-layer--auto" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bas&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div class="n2-ss-button-container n2-ss-item-content n2-ow n2-font-beb2df7d76a016c9d6eab777c4c577a1-link  n2-ss-nowrap n2-ss-button-container--non-full-width"><a class="n2-style-cdb60a339019064a62b500c95f67f4e3-heading  n2-ow " target="_blank" href="https://interactions.utc.fr/thematiques/regards-sur-le-monde/prendre-de-laltitude-desprit-avec-le-pionnier-bertrand-piccard/"><div><div>Lire</div></div></a></div></div><div class="n2-ss-layer n2-ow n2-ss-layer--auto n2-ss-has-self-align n-uc-mGOOD3rQ4pCh" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.25,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-mGOOD3rQ4pCh-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-JhWdYXtLPq1L" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'previous');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-JhWdYXtLPq1L-inner"><div class="n2-ss-layer n2-ow n-uc-J7ENvEigg7KZ n2-ss-layer--auto" data-pm="normal" data-sstype="layer"><span class="n2i  n2-ss-859item201 nicomoon nicomoon-arrow-left2 n2-ss-item-content" style="font-size:125%;"></span></div></div></div><div class="n2-ss-layer n2-ow n-uc-09MG2cimUG38" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'next');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer