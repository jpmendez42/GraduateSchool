                    <div class="results-block__image">
                      <picture>
                        <source media="(max-width: 767px)"
                          srcset="https://a-static.sber.ru/assets/images/results-counter-mob@2x.png 2x">
                        <source media="(max-width: 1224px)"
                          srcset="https://a-static.sber.ru/assets/images/results-counter-tab@2x.png 2x"><img
