<!-- CUSTOM TABS AND SCROLL TO TAB -->

<script type="rocketlazyloadscript">
    document.addEventListener('DOMContentLoaded', function() {
        var isSpecificPage = false;

        function switchTab(tabName, updateHash = true) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active-tab');
            });

            // Show the selected tab
            document.querySelectorAll('.' + tabName).forEach(tab => {
                tab.classList.add('active-tab');
            });

            // Remove 'active-tab-button' class from all buttons
            document.querySelectorAll('.tab-button').forEach(button => {
                button.classList.remove('active-tab-button');
            });

            // Add 'active-tab-button' class to the clicked button
            var activeButton = document.querySelector('[data-tab="' + tabName + '"]');
            if (activeButton) {
                activeButton.classList.add('active-tab-button');
            }

            // Update the URL hash if the selected tab is not 'reservations' and updateHash is true
            if (updateHash && isSpecificPage) {
                if (tabName !== 'reservations') {
                    window.location.hash = 'pmsSection#' + tabName;
                } else {
                    // Remove the hash if 'reservations' is selected
                    history.pushState("", document.title, window.location.pathname + window.location.search + '#pmsSection');
                }
            }
        }

        function handleHashChange() {
            const hash = window.location.hash.substring(1); // Remove the '#' character
            if (hash) {
                const parts = hash.split('#');
                if (parts.length === 2 && parts[0] === 'pmsSection') {
                    switchTab(parts[1], false);
                } else {
                    switchTab(hash, false);
                }
            } else {
                // If there's no hash, switch to 'reservations' without updating the hash
                switchTab('reservations', false);
            }
        }

        // Attach event listeners to tab buttons
        document.querySelectorAll('.tab-button').forEach(button => {
            button.addEventListener('click', function() {
                var tabName = this.getAttribute('data-tab');
                switchTab(tabName);
            });
        });

        // Listen for hash change events
        window.addEventListener('hashchange', handleHashChange);

        // Handle the initial load
        document.addEventListener('DOMContentLoaded', () => {
            const initialHash = window.location.hash.substring(1);
            if (initialHash) {
                const parts = initialHash.split('#');
                if (parts.length === 2 && parts[0] === 'pmsSection') {
                    // Scroll to the tab section only if explicitly specified in the link
                    const pmsSection = document.getElementById('pmsSection');
                    if (pmsSection) {
                        pmsSection.scrollIntoView();
                    }
                }
            }
            handleHashChange();
        });
    });
</script>

<!-- END CUSTOM TABS AND SCROLL TO TAB -->

<script type="rocketlazyloadscript">
    window.addEventListener("load", function() {

        var imagesInSlickSlide = document.querySelectorAll('.slick-slide img');

        imagesInSlickSlide.forEach(function(image) {
            // Modify src attribute
            var srcValue = image.getAttribute('src');
            var srcWithoutSizes = srcValue.replace(/-\d+x\d+/g, '');
            image.setAttribute('src', srcWithoutSizes);

            var srcsetValue = image.getAttribute('srcset');
            if (srcsetValue) {
                var srcsetWithoutSizes = srcsetValue.replace(/-\d+x\d+/g, '');
                image.setAttribute('srcset', srcsetWithoutSizes);
            }
        });
    });
</script>

