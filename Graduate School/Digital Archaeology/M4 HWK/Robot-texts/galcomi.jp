$(function () {
  //cookieの値がonじゃなかったら表示させる
  if ($.cookie('galaponMinPopBox_galapon--close') != 'on') {
    $('.galaponMinPopBox_inn').show();
    $('.galaponMinPopBox').show();
  }

  //隠すボタンをクリックしたらバナーを隠す
  $('#galaponMinPopBox_galapon--close , .galaponMinPopBox_inn , .galaponMinPopBox_galapon--close2').click(function() {
    $('.galaponMinPopBox_inn').hide();
    $.cookie('galaponMinPopBox_galapon--close', 'on', {
        expires: 1, //cookieの有効日数
        path:'/' //有効にするパス
      });
    });
});
</script></div><style>.abgBox_footer{background:#222;border-bottom:1px solid #555;text-align:center;padding-bottom:10px}.lnk_abj{display:block;width:100px;margin:auto}.lnk_abjTxt{color:#ddd;display:inline-block;margin:auto;text-align:center;text-decoration:underline !important}</style><div class="abgBox_footer">
