.side_txt {
display: block;
font-style: normal;
margin-top: -10px;
text-align: right;
}

.bgColor_txt {
background: linear-gradient(transparent 50%, yellow 50%);
color: #e73562;
font-weight: bold;
}

.bgColor_pale {
  background: linear-gradient(transparent 50%,#ffc 0);
