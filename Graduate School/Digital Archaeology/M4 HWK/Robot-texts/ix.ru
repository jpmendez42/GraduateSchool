<!doctype html><html lang=ru prefix="og: http://ogp.me/ns#"><head><meta name=generator content="msk-ix"><meta charset=utf-8><meta content="IE=edge" http-equiv=x-ua-compatible><meta content="width=device-width,initial-scale=1,user-scalable=no,maximum-scale=1" name=viewport><meta name=robots content="index,follow"><meta http-equiv=content-language content="ru"><meta property="og:title" content="MSK-IX"><meta property="og:locale" content="ru_RU"><meta name=keywords content="IX,medialogistika,DNS,peering"><meta name=Description content="MSK-IX помогает компаниям развивать сети и сервисы в интернете быстрее и с меньшими затратами, предоставляя доступ к Internet eXchange, сервисным платформам и дата-центрам."><meta property="og:site_name" content="Мультисервисные платформы MSK-IX"><meta property="og:description" content="MSK-IX помогает компаниям развивать сети и сервисы в интернете быстрее и с меньшими затратами, предоставляя доступ к Internet eXchange, сервисным платформам и дата-центрам."><meta property="og:url" content="https://msk-ix.ru/"><meta property="og:type" content="website"><meta property="og:image" content="https://msk-ix.ru/images/_dev/logo.png"><meta property="og:image:type" content="image/png"><meta property="og:image:width" content="200"><meta property="og:image:height" content="100"><meta name=google-site-verification content="R8gBlbpzb0Q7FatH6ewvUCYct8WtvKPjuweFIWMCN_c"><link rel="shortcut icon" href="/favicon.ico?v=20240226" type=image/x-icon><link rel=icon href="/favicon.ico?v=20240226" type=image/x-icon><link rel=apple-touch-icon sizes=57x57 href="/apple-icon-57x57.png?v=20240226"><link rel=apple-touch-icon sizes=60x60 href="/apple-icon-60x60.png?v=20240226"><link rel=apple-touch-icon sizes=72x72 href="/apple-icon-72x72.png?v=20240226"><link rel=apple-touch-icon sizes=76x76 href="/apple-icon-76x76.png?v=20240226"><link rel=apple-touch-icon sizes=114x114 href="/apple-icon-114x114.png?v=20240226"><link rel=apple-touch-icon sizes=120x120 href="/apple-ic