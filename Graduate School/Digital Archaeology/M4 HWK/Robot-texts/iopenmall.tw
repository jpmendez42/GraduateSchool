<script>
    var loop = true;
    var nav = true;
    var autoplay_status = "1"=="1" ? true : false;
    var autoplayTimeout_value = "5" ? parseInt("5") * 1000 : 0;

    /* 電腦 */
        $('.it908-default .iopen-mall-item-content .it908-carousel-box_30463').owlCarousel({
        loop:loop,
        margin:20,
        nav:nav,
        dots:false,
        autoplay:autoplay_status,
        autoplayTimeout:autoplayTimeout_value,
        autoplayHoverPause:autoplay_status,
        responsive:{
            0:{
                items:4
            },
            1000:{
                items:4
            }
        }
    });
    
    $('.it908-video-mask').on('click',function (){
        $(this).hide();
        let video_href = $(this).attr('video-link');
        if (/facebook|fb/.test(video_href)){
            video_href = "https://www.facebook.com/plugins/video.php?href="+video_href+"&show_text=false&appId&width=320&height=478";
            $(this).next().attr('src', video_href);
        } else {
            const regex = /(?:https?:\/\/)?(?:www\.)?(?:m\.)?(?:youtube\.com|youtu\.be)\/(?:v\/|watch\?v=|embed\/)?([a-zA-Z0-9_-]{11})(&\S+)?/gi;
            const match = video_href.match(regex);
            if(match) {
                const videoId = match[0].replace(regex, '$1');
                video_href = 'https://www.youtube.com/embed/' + videoId + "?autoplay=1";
            }
                $(this).next().attr('src', video_href);
        }
    })

