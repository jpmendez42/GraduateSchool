<script type="text/javascript" src="https://static.pedaily.cn/head/js/jquery.nanoscroller.min.js"></script>
<script type="text/javascript">
  $(function () {
    $('.box-tab .tab-nav').find('li').click(function () {
      var cur = $(this), tabul = cur.parent(), i = tabul.children().index(cur);
      tabul.children().removeClass('on');
      cur.addClass('on');
      loadnews(i,cur);
    });
    $(".nano").nanoScroller();
	firstadd(1,false);
    firstlineInit();
  });
  function firstlineTab(){
        $("#ulFirst li h4.title").unbind('click').click(function(){
        var pli = $(this).parent('li')
        if (pli.hasClass("current")) {
            pli.find(".desc").slideUp(500,function(){
            pli.removeClass("current");
            });
        }else{
            pli.siblings().removeClass("current").find(".desc").slideUp();
            pli.find(".desc").slideToggle(500,function(){
            pli.addClass("current");
            });
        }
        }); 
    }
  
  function firstlineInit (){
	$(".nano > .nano-content").scroll(function() {
        var dHight = $(this).height(), scrollHeight = $(this)[0].scrollHeight, scrollTop = $(this)[0].scrollTop;
        if (scrollTop + dHight >= scrollHeight) {
            var divFirst = $("#divFirst")
              , pageIndex = parseInt(divFirst.data("pageindex")) + 1;
            if ( pageIndex < 1 || isNaN(pageIndex))
                return;
            firstadd(pageIndex,true);
        }
    });
  }
  function firstadd(p,isadd){
	$.ajax({ type: "get",url: "/firstnews.aspx?action=post&type=home&p=" + p + "&pagesize=10",success: function(data) {
			var divFirst = $("#divFirst")
			divFirst.data("pageindex",p)
			if(data.length>0){
				var datalist=$('#ulFirst');
				if (datalist.length > 0) {
					if(isadd){
						datalist.html(datalist.html() + data);
					}else{
						datalist.html(data);
					}
					 _sharelist.init();
					 firstlineTab();
				}
			}
		}
	});
  }
    
function loadnews(type,cur) {
    var posturl = '/top/handlers/Handler.ashx?action=newslist-all&pagesize=22&p=1&url=https://www.pedaily.cn/top/newslist.aspx?', loadmore = $('#news-loadmore'), newslistall = $('#news-list-all'), newslistother = $('#news-list-other'); ;
    if (type == 0) { newslistall.show(); newslistother.hide(); } else { newslistall.hide(); newslistother.show(); }
	var loadtype=cur.attr('data-loadtype');
	var ulcss='';
	if(loadtype=='firstnews-list')
	{
			posturl = 'https://www.pedaily.cn/firstnews.aspx?action=post&';
			ulcss='list-time hot-online';
	}
	posturl += ''+cur.attr('data-url');
	loadmore.attr('href', cur.attr('data-href'));
   
  if(type!=0){
    loadmore.hide();
    posturl=posturl.replace('www.','www.');
	newslistother.html('<div class="loading"><span>玩命加载中...</span></div>');
    $.post(posturl, function (result) {
        if (newslistother) {
            newslistother.html('<ul class="'+ulcss+'">' + result + '</ul>');
          	loadmore.show();
            callBackFunc();
        }
    });
  }
}
</script>
