	function generateTemplate(item, type) {
		const text = item.PREVIEW_TEXT || item.NAME || '';
		const name = item.NAME || '';
		const date = item.DISPLAY_ACTIVE_FROM || '';
		const tags = item.DISPLAY_PROPERTIES?.NEWS_TAGS?.VALUE || [];
		const imgSrc = item.PREVIEW_PICTURE?.SRC || '/local/templates/images/preview.png';
		const tagHtml = tags[0] ? `<div class="item-meta__tag"><p class="meta-tag__text">${tags[0]}</p></div>` : '';
		const shortText = text.length > 300 ? text.substring(0, 300).trim() : text;
		const href = '' + item.DETAIL_PAGE_URL;

		let imgTemplate = `<img src="${imgSrc}" alt="${name}" loading="lazy" onerror="this.onerror=null; this.src='/local/templates/images/preview.png';" />`;

		switch (type) {
			case 'main':
				return `
				<a href="${href}">
					<div class="info-list__item">
						<div class="list-item__description">
							<p class="item-description__text">${shortText}</p>
						</div>
						<div class="list-item__meta">
							<p class="item-meta__date">${date}</p>
							${tagHtml}
						</div>
						<div class="list-item__img ">
							${imgTemplate}
						</div>
						<div class="list-item__block--hover">
							<div class="list-item__description_container">
								<div class="list-item__description">
									<p class="item-description__text">${text}</p>
								</div>
								<div style="display: flex; flex-wrap: wrap; gap: 15px; margin-top: 20px;">
									${tags.slice(0, 3).map(tag => `
										<div class="item-meta__tag">
											<p class="meta-tag__text">${tag}</p>
										</div>`).join('')}
								</div>
							</div>
							<p class="item-meta__date">${date}</p>
						</div>
					</div>
				</a>`;
			case 'secondary':
				const editAreaId = 'bx_fde7daa13a9fbedf4e67bd572975ba5f_' + item.ID;
				return `
				<a href="${href}" class="info-list__item" id="${editAreaId}">
					<div class="list-item__meta">
						<p class="item-meta__date">${date}</p>
						${tagHtml}
					</div>
					<div class="list-item__description">
						<p class="item-description__text">${name}</p>
					</div>
				</a>`;
			case 'all':
			default:
				return `
				<a href="${href}">
					<div class="info-list__item">
						<div class="list-item__description">
							<p class="item-description__text">${shortText}</p>
						</div>
						<div class="list-item__meta">
							<p class="item-meta__date">${date}</p>
							${tagHtml}
						</div>
						<div class="list-item__img ">
							${imgTemplate}
						</div>
					</div>
				</a>`;
		}
	}

	function renderList(containerId, limit, type) {
		const container = document.getElementById(containerId);
		if (!container) return;

		const items = getItemsForRender().slice(0, limit);
		container.innerHTML = '';

		if (type === 'all') {
			const staticContainer = document.querySelector('.news-info');
			const mobileContainer = document.getElementById('news-items-main__container');
			const mobileList = document.getElementById('news-items-main');

			if (window.innerWidth < 600) {
				staticContainer.style.display = 'none';
				mobileContainer.style.marginTop = "unset";
				mobileContainer.style.display = 'flex';
				mobileList.style.display = 'flex';
			} else {
				staticContainer.style.display = 'flex';
				mobileContainer.style.display = 'none';
				mobileList.style.display = 'none';
			}
		}

		items.forEach(item => {
			container.insertAdjacentHTML('beforeend', generateTemplate(item, type));
		});
	}

	document.addEventListener('DOMContentLoaded', function () {
		function reRenderAllLists() {
			const width = window.innerWidth;
			renderList('news-items', width < 830 ? 2 : 4, 'main');
			renderList('news-items-list', width < 830 ? 2 : 4, 'secondary');
			renderList('news-items-main', width < 600 ? 2 : 4, 'all');
		}

		reRenderAllLists();

		window.addEventListener('resize', function () {
			if (!window.resizeLocked) {
				window.resizeLocked = true;
				requestAnimationFrame(function () {
					reRenderAllLists();
					window.resizeLocked = false;
				});
			}
		});
	});
</script> <br>
