      try {
        const redirectUrl = new URL(state);
        if (window.location.host !== redirectUrl.host) {
          console.log('unsecure call, forbidden');
          return;
        }
        if (!url.searchParams.has('logged_out')) {
          redirectUrl.searchParams.set('logged_in', 'true');
