<script type="text/javascript">

	function updateCookie(value) {
		var i = 1;
		for(i = 1; i <=9; i++) {
			if (getCookie('cookiefascia-0'+i) != null) {
				document.cookie = "cookiefascia-0"+i+"=" + value;
			} else {
				createCookie('cookiefascia-0'+i, '', 10000);
			}
			
		}
	}
	
	function updateSingoleCookie(c_name, value) {
		var cookieValue = getCookie(c_name);
		if (cookieValue != null) {
			document.cookie = c_name+"=" + value;
		} else {
			createCookie(c_name, '', 10000);
		}
	}		

	function createCookie(name, value, days) {
		var expires;
		if (days) {
			var date = new Date();
			date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
			expires = "; expires=" + date.toGMTString();
		} else {
			expires = "";
		}
		document.cookie = name + "=" + value + expires + "; path=/web/guest";
	}

	function getCookie(c_name) {
		if (document.cookie.split(';').filter(function(c_name) {
		    return c_name.indexOf(c_name) >= 0
		}).length) {
			c_start = document.cookie.indexOf(c_name);
			if (c_start != -1) {
				c_start = c_start + c_name.length + 1;
				c_end = document.cookie.indexOf(";", c_start);
				if (c_end == -1) {
					c_end = document.cookie.length;
				}
				
				return unescape(document.cookie.substring(c_start,
						c_end));
			}
		}
		return null;
	}
	
	var cookie;

	function onLoad() {
		var i = 1;
		for(i = 1; i <=9; i++) {
			var cookie = getCookie('cookiefascia-0'+i);
			if (cookie != null && cookie == 'collapsed') {
				$(".fascia-0"+i).removeClass(cookie);
				$(".fascia-0"+i).addClass(cookie);
			} else if(cookie != null && cookie == '') {
				$(".fascia-0"+i).removeClass('collapsed');
				$(".fascia-0"+i).addClass(cookie);
			} else {
				$(".fascia-0"+i).removeClass(cookie);
				$(".fascia-0"+i).addClass(cookie);
			}
		}		
		
	}
	
	$(window).on("load", function() {
		
	   checkScreenSize();
	   
	    function checkScreenSize(){
	        var newWindowWidth = $(window).width();
	        if (newWindowWidth < 767) {
	            $('.fascia-01').css("height","50px");
	            $('.fascia-02').css("height","50px");
	            $('.fascia-03').css("height","50px");
	            $('.fascia-04').css("height","50px");
	            $('.fascia-05').css("height","50px");
	            $('.fascia-06').css("height","50px");
	            $('.fascia-07').css("height","50px");
	            $('.fascia-08').css("height","50px");
	            $('.fascia-09').css("height","50px");
	            $('.fascia-10').css("height","50px");
	                
	            $('.fascia-01').addClass("collapsed");
	            $('.fascia-02').addClass("collapsed");
	            $('.fascia-03').addClass("collapsed");
	            $('.fascia-04').addClass("collapsed");
	            $('.fascia-05').addClass("collapsed");
	            $('.fascia-06').addClass("collapsed");
	            $('.fascia-07').addClass("collapsed");
	            $('.fascia-08').addClass("collapsed");
	            $('.fascia-09').addClass("collapsed");
	            $('.fascia-10').addClass("collapsed");
	                
	        	for(i = 1; i <=10; i++) {
	        		var cookie = 'collapsed';
	        		if(i<=9)
	        			updateSingoleCookie('cookiefascia-0'+i, cookie);
	        		else
	        			updateSingoleCookie('cookiefascia-'+i, cookie);
	        	}
	        } else {
	        	
	    		for(i = 1; i <=10; i++) {
	    			if(i<=9) {
		    			var cookie = getCookie('cookiefascia-0'+i);
		    			updateSingoleCookie('cookiefascia-0'+i, cookie);
	    			} else {
	    				var cookie = getCookie('cookiefascia-'+i);
		    			updateSingoleCookie('cookiefascia-'+i, cookie);
	    			}
	    		}
	        	
	        }
	    }		
		
		onLoad();		
	});
	
	$(window).on('resize', function(){
	   $(".fascia").not(".collapsed").css('height','auto');
	});
		
	$(function(){
		
		var nav = $('.fascia-01'),
		animateTime = 300,
		navLink = $('.collapse-button-01,.fascia-01 h1');
		
		cookie = getCookie('cookiefascia-01');

		navLink.click(function(){
		    if(nav.height() < 51){
				nav.removeClass("collapsed");
		     	autoHeightAnimate(nav, animateTime);
		     	updateSingoleCookie('cookiefascia-01','');
		    } else {
		      	nav.stop().animate({ height: '50' }, animateTime);
			  	nav.addClass("collapsed");
			  	updateSingoleCookie('cookiefascia-01','collapsed');
		    }
		  });
	})

