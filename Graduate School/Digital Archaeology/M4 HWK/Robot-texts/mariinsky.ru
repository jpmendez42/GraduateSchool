							<div class="col-md-8 col-sm-12 col-xs-12" id="banner_c">
								
			<script>var banner_JSON_data={"179318":{"big_banner":"\/images\/cms\/data\/opera_repertoire2014\/semen_kotko\/_kotko.jpg","banner_text":"<p style=\"text-align: center;\">\u043e\u043f\u0435\u0440\u0430 \u0421\u0435\u0440\u0433\u0435\u044f \u041f\u0440\u043e\u043a\u043e\u0444\u044c\u0435\u0432\u0430<\/p>  <p style=\"text-align: center;\"><br \/>\u0418\u0433\u043e\u0440\u044c \u041c\u043e\u0440\u043e\u0437\u043e\u0432<br \/>\u0421\u0432\u0435\u0442\u043b\u0430\u043d\u0430 \u041a\u0430\u0440\u043f\u043e\u0432\u0430<br \/>\u041a\u0440\u0438\u0441\u0442\u0438\u043d\u0430 \u041a\u0430\u043f\u0438\u0446\u044b\u043d\u0430<br \/>\u0415\u043a\u0430\u0442\u0435\u0440\u0438\u043d\u0430 \u0421\u043e\u043b\u043e\u0432\u044c\u0451\u0432\u0430<br \/>\u041e\u043b\u0435\u0433 \u0421\u044b\u0447\u0451\u0432<br \/> \u0410\u043d\u0434\u0440\u0435\u0439 \u0421\u0435\u0440\u043e\u0432<br \/>\u0412\u0430\u0434\u0438\u043c \u041a\u0440\u0430\u0432\u0435\u0446<\/p>","perf_name":"\u0421\u0435\u043c\u0435\u043d \u041a\u043e\u0442\u043a\u043e ","perf_date":"14 \u043e\u043a\u0442\u044f\u0431\u0440\u044f","perf_place":"160234","place":"","place_color":"cca31d","top_img_preview":"/images/cms/thumbs/8fa2cdb113aa0201f8d84c1ce900856736cd8570/_kotko_56_37_jpg.jpg","spec_id":"UnNUaFR4NDhJQWpFaEVZRndwL01rUT09","name":"\u0421\u0435\u043c\u0435\u043d \u041a\u043e\u0442\u043a\u043e 14\/10","vhodnoy_za_chas_flag":"0","ticket_txt":"Купить билет","link":"\/playbill\/playbill\/2025\/10\/14\/2_1900\/","target_blank":"0"},"179423":{"big_banner":"\/images\/cms\/data\/opera_repertoire2014\/makbet\/_macbeth_banner_ru.jpg","banner_text":"<p style=\"text-align: center;\">\u043e\u043f\u0435\u0440\u0430 \u0414\u0436\u0443\u0437\u0435\u043f\u043f\u0435 \u0412\u0435\u0440\u0434\u0438<\/p>  <p style=\"text-align: center;\"><br \/> \u0412\u043b\u0430\u0434\u0438\u0441\u043b\u0430\u0432 \u0421\u0443\u043b\u0438\u043c\u0441\u043a\u0438\u0439<br \/>\u0410\u043b\u0435\u043d\u0430 \u0414\u0438\u044f\u043d\u043e\u0432\u0430<br \/> \u0410\u043b\u0435\u043a\u0441\u0430\u043d\u0434\u0440 \u041c\u0438\u0445\u0430\u0439\u043b\u043e\u0432<br \/> \u042e\u0440\u0438\u0439 \u0412\u043e\u0440\u043e\u0431\u044c\u0451\u0432<\/p>","perf_name":"\u041c\u0430\u043a\u0431\u0435\u0442 ","perf_date":"15 \u043e\u043a\u0442\u044f\u0431\u0440\u044f","perf_place":"26927","place":"","place_color":"007575","top_img_preview":"/images/cms/thumbs/22272b8a539a025c0d512eb403fa366455297a57/_macbeth_banner_ru_56_37_jpg.jpg","spec_id":"YmJaT2E3T0lPVXZGK3RPWEFwYzhYdz09","name":"\u041c\u0430\u043a\u0431\u0435\u0442 15\/10","vhodnoy_za_chas_flag":"0","ticket_txt":"Купить билет","link":"\/playbill\/playbill\/2025\/10\/15\/1_1900\/","target_blank":"0"},"179425":{"big_banner":"\/images\/cms\/data\/opera_repertoire2014\/carmen2016\/carmen_rus.jpg","banner_text":"<p style=\"text-align: center;\">\u043e\u043f\u0435\u0440\u0430 \u0416\u043e\u0440\u0436\u0430 \u0411\u0438\u0437\u0435<\/p>  <p style=\"text-align: center;\"><br \/>\u0415\u043a\u0430\u0442\u0435\u0440\u0438\u043d\u0430 \u041b\u0443\u043a\u0430\u0448<br \/>\u0410\u0445\u043c\u0435\u0434 \u0410\u0433\u0430\u0434\u0438<\/p>  <p style=\"text-align: center;\"><br \/><em>\u041a \u044e\u0431\u0438\u043b\u0435\u044e \u041b\u044e\u0434\u043c\u0438\u043b\u044b \u0424\u0438\u043b\u0430\u0442\u043e\u0432\u043e\u0439<\/em><\/p>","perf_name":"\u041a\u0430\u0440\u043c\u0435\u043d ","perf_date":"16 \u043e\u043a\u0442\u044f\u0431\u0440\u044f","perf_place":"26927","place":"","place_color":"007575","top_img_preview":"/images/cms/thumbs/3efa85bc99c8922228de40794e9f90ab3f7e1195/carmen_rus_56_37_jpg.jpg","spec_id":"YVdYYVA3bmtHSlNKRWY5Q0pXQTlVQT09","name":"\u041a\u0430\u0440\u043c\u0435\u043d 16\/10","vhodnoy_za_chas_flag":"0","ticket_txt":"Купить билет","link":"\/playbill\/playbill\/2025\/10\/16\/1_1900\/","target_blank":"0"},"178894":{"big_banner":"\/images\/cms\/data\/ballet_repertoire\/sylphide\/silfida_by_vilchuk_banner.jpg","banner_text":"<p style=\"text-align: center;\">\u0431\u0430\u043b\u0435\u0442 \u0425\u0435\u0440\u043c\u0430\u043d\u0430 \u041b\u0435\u0432\u0435\u043d\u0441\u043a\u044c\u043e\u043b\u044c\u0434\u0430<\/p>  <p style=\"text-align: center;\"><br \/>\u041c\u0435\u0439&nbsp;\u041d\u0430\u0433\u0430\u0445\u0438\u0441\u0430, \u0415\u0432\u0433\u0435\u043d\u0438\u0439&nbsp;\u041a\u043e\u043d\u043e\u0432\u0430\u043b\u043e\u0432<\/p>","perf_name":"\u0421\u0438\u043b\u044c\u0444\u0438\u0434\u0430 ","perf_date":"18 \u043e\u043a\u0442\u044f\u0431\u0440\u044f","perf_place":"26927","place":"","place_color":"007575","top_img_preview":"/images/cms/thumbs/772b9b384a2078cfc37d0cc216241125385f24be/silfida_by_vilchuk_banner_56_37_jpg.jpg","spec_id":"bEw1bkI1UnN3MzE0KzFVSlBSdlg0dz09","name":"\u0421\u0438\u043b\u044c\u0444\u0438\u0434\u0430 18\/10","vhodnoy_za_chas_flag":"0","ticket_txt":"Купить билет","link":"\/playbill\/playbill\/2025\/10\/18\/1_1900\/","target_blank":"0"},"179452":{"big_banner":"\/images\/cms\/data\/ballet_repertoire\/carnaval\/8_carnaval_by_razina.jpg","banner_text":"<p style=\"text-align: center;\">\u0431\u0430\u043b\u0435\u0442\u044b \u041c\u0438\u0445\u0430\u0438\u043b\u0430 \u0424\u043e\u043a\u0438\u043d\u0430<\/p>  <p style=\"text-align: center;\"><br \/>\u0415\u043a\u0430\u0442\u0435\u0440\u0438\u043d\u0430&nbsp;\u041a\u043e\u043d\u0434\u0430\u0443\u0440\u043e\u0432\u0430, \u041a\u0440\u0438\u0441\u0442\u0438\u043d\u0430&nbsp;\u0428\u0430\u043f\u0440\u0430\u043d, \u0410\u043d\u0430\u0441\u0442\u0430\u0441\u0438\u044f&nbsp;\u041b\u0443\u043a\u0438\u043d\u0430, \u0412\u0430\u043b\u0435\u0440\u0438\u044f&nbsp;\u041a\u0443\u0437\u043d\u0435\u0446\u043e\u0432\u0430, \u041a\u043e\u043d\u0441\u0442\u0430\u043d\u0442\u0438\u043d&nbsp;\u0417\u0432\u0435\u0440\u0435\u0432, \u0415\u0432\u0433\u0435\u043d\u0438\u0439&nbsp;\u041a\u043e\u043d\u043e\u0432\u0430\u043b\u043e\u0432, \u0412\u043b\u0430\u0434\u0438\u0441\u043b\u0430\u0432&nbsp;\u0428\u0443\u043c\u0430\u043a\u043e\u0432<\/p>  <p style=\"text-align: center;\">\u041e\u043b\u0435\u0441\u044f&nbsp;\u041d\u043e\u0432\u0438\u043a\u043e\u0432\u0430, \u041e\u043a\u0441\u0430\u043d\u0430&nbsp;\u0421\u043a\u043e\u0440\u0438\u043a, \u041a\u0440\u0438\u0441\u0442\u0438\u043d\u0430&nbsp;\u0428\u0430\u043f\u0440\u0430\u043d, \u041a\u0430\u043c\u0438\u043b\u043b\u0430&nbsp;\u041c\u0430\u0446\u0446\u0438, \u0415\u0432\u0433\u0435\u043d\u0438\u0439&nbsp;\u041a\u043e\u043d\u043e\u0432\u0430\u043b\u043e\u0432, \u041a\u0438\u0430\u043d \u041c\u0430\u043d\u0433\u0438\u0441, \u0418\u0432\u0430\u043d&nbsp;\u0421\u043e\u0442\u043d\u0438\u043a\u043e\u0432<\/p>  <p style=\"text-align: center;\">\u0412\u0438\u043a\u0442\u043e\u0440\u0438\u044f&nbsp;\u0422\u0435\u0440\u0451\u0448\u043a\u0438\u043d\u0430, \u0415\u043a\u0430\u0442\u0435\u0440\u0438\u043d\u0430&nbsp;\u041a\u043e\u043d\u0434\u0430\u0443\u0440\u043e\u0432\u0430, \u0415\u043b\u0435\u043d\u0430&nbsp;\u0415\u0432\u0441\u0435\u0435\u0432\u0430, \u041a\u0440\u0438\u0441\u0442\u0438\u043d\u0430&nbsp;\u0428\u0430\u043f\u0440\u0430\u043d, \u0420\u043e\u043c\u0430\u043d&nbsp;\u0411\u0435\u043b\u044f\u043a\u043e\u0432, \u0410\u043a\u0438\u043c&nbsp;\u0411\u0430\u043a\u0430\u0435\u0432, \u0422\u0440\u043e\u0444\u0438\u043c&nbsp;\u041c\u0430\u043b\u0430\u043d\u043e\u0432<\/p>","perf_name":"\u041a\u0430\u0440\u043d\u0430\u0432\u0430\u043b. \u0412\u0438\u0434\u0435\u043d\u0438\u0435 \u0440\u043e\u0437\u044b. \u041b\u0435\u0431\u0435\u0434\u044c. \u0428\u0435\u0445\u0435\u0440\u0430\u0437\u0430\u0434\u0430 ","perf_date":"17, 21, 28 \u043e\u043a\u0442\u044f\u0431\u0440\u044f","perf_place":"26927","place":"","place_color":"007575","top_img_preview":"/images/cms/thumbs/9c04115a6eddcc3d14a1e6d0d9ee89a2727a1328/8_carnaval_by_razina_56_37_jpg.jpg","spec_id":"SnpwRkJybGxMSFlwZlE1dCtSTGw5QT09","name":"\u0411\u0430\u043b\u0435\u0442\u044b \u0424\u043e\u043a\u0438\u043d\u0430 17, 21, 28 \/10","vhodnoy_za_chas_flag":"0","ticket_txt":"Купить билет","link":"\/playbill\/playbill\/2025\/10\/17\/1_1901\/","target_blank":"0"},"179