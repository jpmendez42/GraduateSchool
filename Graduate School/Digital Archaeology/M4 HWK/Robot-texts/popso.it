				(function(){
					
					var 
						idFabObj = 3,
						fabtool = document.getElementById("tool-fabbisogno-"+idFabObj)
					;

					var handleClickFabbisogno = function(e) {

						var data = {};

						if(e.target.classList.contains("btn-fabbisogno")) {
							data.tg = e.target.dataset.target;
							data.hs = e.target.dataset.hs;
						}

						if(e.target.classList.contains("btn-history") && e.target.dataset.back != 1) {
							data.tg = e.target.dataset.back;
							data.hs = e.target.dataset.backhs;
						}

						if(
							(e.target.classList.contains("btn-fabbisogno-start") 
							|| e.target.classList.contains("btn-fabbisogno")
							|| e.target.classList.contains("btn-history"))
							&& e.target.classList.contains("ending") === false
						) {
							
							FlexJS.Ajax.post("toolfabbisogno", data, function(data) {
								
								fabtool.innerHTML = data.node;
							});
						}
					}
					
					fabtool.addEventListener("click", handleClickFabbisogno);
				
				})();
			


  


                (function(){

                    var displayErrors = function(errorList) {

                        errorList.forEach((element) => {
                            
                            var 
                                el = $("#"+element.field),
                                pa = el.parent(),
                                la = $("label[for="+element.field+"]")
                            ;

                            pa.addClass("validation-error");
                            la.append("<span class='validation-error-message'>"+element.msg+"</span>");
                        });
                    }

                    var cleanErrors = function() {
                        
                        var 
                            errorfields = $(".validation-error"),
                            errormessages = $(".validation-error-message")
                        ;

                        errorfields.removeClass("validation-error");
                        errormessages.remove();
                    }

                    var checkValidations = function(fields) {
                        
                        var errors = [];

                        var mandatory = [
                            "nome-fri-83",
                            "cognome-fri-83",
                            "email-fri-83",
                            "nome-fri-83",
                            "messaggio-fri-83",
                        ];

                        var privacy = false;

                        fields.forEach((element) => {
                            if(element.name == "messaggio-fri-83" && element.value.length > 1000)
                                errors.push({ field: element.name, msg: "Lunghezza massima 1000 caratteri" });
                            if(mandatory.includes(element.name) && element.value == "")
                                errors.push({ field: element.name, msg: "Campo obbligatorio" });
                            if(element.name == "privacy-fri-83") privacy = true;
                            if(element.name == "categoria-fri-83" && element.value == "-1") 
                                errors.push({ field: element.name, msg: "Campo obbligatorio" });
                        });

                        if(!privacy) errors.push({ field: "privacy-fri-83", msg: "Campo obbligatorio" });

                        if(errors.length === 0) return true;

                        displayErrors(errors);
                        return false;
                    }

                    $("#form-richiesta-info-fri-83").on("submit", function(e) {
                        
                        e.preventDefault();
                        e.stopPropagation();

                        cleanErrors();

                        var
                            form = $(this),
                            formvalues = form.serializeArray(),
                            validations = checkValidations(formvalues)
                        ;

                        if(validations) {
                            
                            FlexJS.Ajax.post("pospsorichiestainfo", form.serialize(), function(data) {

                                if (data["status"] == "ok") {

                                    if(data["err"] == "r") return false;
                                  
                                    $().toastmessage("showSuccessToast", "Richiesta inviata.");
                                    form.get(0).reset();
                                } else {

                                    if(Object.keys(data["err"]).length > 0) {
                                        displayErrors(data["err"]);
                                    }
                                }
                                return false;
                            });
                        }
                    });

                    $("#messaggio-fri-83").on("keydown", function(e) {

                        var
                            el = $(this),
                            va = el.val(),
                            max = 1000,
                            actual = va.length >= max ? max : va.length
                        ;

                        if(va.length >= max) {
                            $(this).val(va.substr(0, max));
                        }

                        el.next(".limit").text(actual+"/"+max);
                    });
                })();
            


  



  

window.__flex__eu_cookie_enabled = true;

$(window).on('load', function() {

	if (! window.__flex__eu_cookie_enabled)
		return;

		// nel caso di contenuto in cache (usa il doppio if per non inserire il doppio ampersand - cfr. w3c)

	if (document.cookie)
		if (document.cookie.match(/fx-eu-privacy/))
			return;

	var
		lt = String.fromCharCode(60),
		amp = String.fromCharCode(38),
		tpl = $('#eu-privacy-tpl').html().replace(/&lt;/g, lt).replace(/&gt;/g, '>').replace(/&amp;/g, amp),
		div = lt + 'div />'
	;

	var d = $(div)
		.attr({
			id: 'eu-privacy'
		})
		.on('click', '#eu-privacy-close', function() { sc(); d.removeClass('open').addClass('close'); return false; })
		.append(
			$(div).attr('id', 'eu-privacy-inner').html(tpl)
		)
		.appendTo('body')
	;

	setTimeout(function() { d.addClass('open'); }, 500);

	var sc = function() {

		fjs.ajax.get('euCookie', fjs.noop);
	};
});

});
</script>


