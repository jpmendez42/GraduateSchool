0%\"},\"className\":\"brand_logo__5MiJq\"}]}],[\"$\",\"div\",null,{\"className\":\"brand_wrapper__GHC_9 all-scrolling_brand__WPurE\",\"onClick\":\"$undefined\",\"children\":[\"$\",\"img\",null,{\"src\":\"https://familia-prod-cms-storage.obs.ru-moscow-1.hc.sbercloud.ru/S Oliver-1.JPG\",\"alt\":\"logo\",\"sizes\":\"100px\",\"style\":{\"objectFit\":\"contain\",\"left\":\"50%\",\"top\":\"50%\"},\"className\":\"brand_logo__5MiJq\"}]}],[\"$\",\"div\",null,{\"className\":\"brand_wrapper__GHC_9 all-scrolling_brand__WPurE\",\"onClick\":\"$undefined\",\"children\":[\"$\",\"img\",null,{\"src\":\"https://familia-prod-cms-storage.obs.ru-moscow-1.hc.sbercloud.ru/topshop_logo-2.jpg\",\"alt\":\"logo\",\"sizes\":\"100px\",\"style\":{\"objectFit\":\"contain\",\"left\":\"50%\",\"top\":\"50%\"},\"className\":\"brand_logo__5MiJq\"}]}]]}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"all-scrolling_head__BRnXx all-scrolling_mobile__4pFPn\",\"children\":[[\"$\",\"$L43\",null,{}],[\"$\",\"$L44\",null,{\"className\":\"all-scrolling_subscribeButton__dqera\",\"children\":[\"$\",\"span\",null,{\"children\":\"Подписаться\"}]}]]}],[\"$\",\"div\",null,{\"className\":\"all-scrolling_brands__y1HO_ all-scrolling_mobile__4pFPn\",\"children\":[\"$\",\"$L45\",null,{\"brands\":[{\"id\":\"6590d9850ee85feaaf40702b\",\"name\":\"Dr Martens\",\"description\":\"Dr. Martens — культовый британский бренд обуви, основанный в 1960 году. Его главная особенность — прочная кожа, фирменная жёлтая строчка и амортизирующая подошва AirWair. Изначально ботинки создавались как рабочая обувь, но позже стали символом бунтарства и самовыражения в субкультурах. Сегодня Dr. Martens ценят за сочетание практичности, долговечности и узнаваемого дизайна.\",\"category\":[\"women\",\"men\",\"accessories\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":true},\"subscriptionOnBlock\":{\"subscriptionOn\":true,\"subscriptionOnSync\":false},\"forMain\":true,\"sort\":null,\"createdAt\":\"2023-12-31T03:01:25.948Z\",\"updatedAt\":\"2025-04-09T07:08:49.975Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\"],\"logo\":{\"id\":\"67f61c9025da8c3792ed7f1b\",\"filename\":\"9we1669udh882t5fozgm5h.png\",\"mimeType\":\"image/png\",\"filesize\":142133,\"width\":1200,\"height\":684,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/9we1669udh882t5fozgm5h-480x320.png\",\"width\":480,\"height\":320,\"mimeType\":\"image/png\",\"filesize\":74413,\"filename\":\"9we1669udh882t5fozgm5h-480x320.png\"},\"portrait\":{\"url\":\"/cms/media/9we1669udh882t5fozgm5h-768x1024.png\",\"width\":768,\"height\":1024,\"mimeType\":\"image/png\",\"filesize\":231978,\"filename\":\"9we1669udh882t5fozgm5h-768x1024.png\"},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":18,\"mimeType\":\"image/png\",\"filesize\":1879,\"filename\":\"9we1669udh882t5fozgm5h-32x18.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-32x18.png\"},\"w64\":{\"width\":64,\"height\":36,\"mimeType\":\"image/png\",\"filesize\":4986,\"filename\":\"9we1669udh882t5fozgm5h-64x36.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-64x36.png\"},\"w128\":{\"width\":128,\"height\":73,\"mimeType\":\"image/png\",\"filesize\":12425,\"filename\":\"9we1669udh882t5fozgm5h-128x73.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-128x73.png\"},\"w384\":{\"width\":384,\"height\":219,\"mimeType\":\"image/png\",\"filesize\":49942,\"filename\":\"9we1669udh882t5fozgm5h-384x219.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-384x219.png\"},\"w640\":{\"width\":640,\"height\":365,\"mimeType\":\"image/png\",\"filesize\":97581,\"filename\":\"9we1669udh882t5fozgm5h-640x365.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-640x365.png\"},\"w1080\":{\"width\":1080,\"height\":616,\"mimeType\":\"image/png\",\"filesize\":201433,\"filename\":\"9we1669udh882t5fozgm5h-1080x616.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-1080x616.png\"},\"w1920\":{\"width\":1920,\"height\":1094,\"mimeType\":\"image/png\",\"filesize\":431905,\"filename\":\"9we1669udh882t5fozgm5h-1920x1094.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-1920x1094.png\"},\"w3840\":{\"width\":3840,\"height\":2189,\"mimeType\":\"image/png\",\"filesize\":1551112,\"filename\":\"9we1669udh882t5fozgm5h-3840x2189.png\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h-3840x2189.png\"}},\"createdAt\":\"2025-04-09T07:06:56.913Z\",\"updatedAt\":\"2025-08-29T07:41:31.096Z\",\"url\":\"/cms/media/9we1669udh882t5fozgm5h.png\"},\"isLanding\":{}},{\"id\":\"65922b1a0ee85feaaf407d72\",\"name\":\"GEOX\",\"description\":\"GEOX - известный итальянский бренд, специализирующийся на производстве комфортной повседневной обуви, верхней одежды и аксессуаров. Запатентованные технологии, используемые Geox, наделяют продукцию бренда абсолютно уникальными свойствами.    Благодаря специальной мембране, разработанной в лабораториях Geox, обувь позволяет ноге дышать, сокращая тем самым уровень естественных испарений стопы, и в то же время не допускает проникновения влаги внутрь. Схожий принцип используется и при создании верхней одежды бренда, главными характеристиками которой являются терморегуляция, водонепроницаемость и ветроустойчивость, в сочетании с изысканным итальянским дизайном. Таким образом, обувь и одежда Geox являются уникальной синергией стиля и максимального комфорта, как для городской среды, так и за ее пределами.\",\"category\":[\"women\",\"men\",\"children\",\"accessories\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":1,\"createdAt\":\"2024-01-01T03:01:46.729Z\",\"updatedAt\":\"2025-03-04T03:11:39.585Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"logo\":{\"id\":\"66fa9c73e0713d40a26ed6c4\",\"filename\":\"44529ki0cucf2lgbb7hqfb.png\",\"mimeType\":\"image/png\",\"filesize\":11079,\"width\":1736,\"height\":309,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-480x320.png\",\"width\":480,\"height\":320,\"mimeType\":\"image/png\",\"filesize\":8297,\"filename\":\"44529ki0cucf2lgbb7hqfb-480x320.png\"},\"portrait\":{\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-768x1024.png\",\"width\":768,\"height\":1024,\"mimeType\":\"image/png\",\"filesize\":43186,\"filename\":\"44529ki0cucf2lgbb7hqfb-768x1024.png\"},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":6,\"mimeType\":\"image/png\",\"filesize\":416,\"filename\":\"44529ki0cucf2lgbb7hqfb-32x6.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-32x6.png\"},\"w64\":{\"width\":64,\"height\":11,\"mimeType\":\"image/png\",\"filesize\":871,\"filename\":\"44529ki0cucf2lgbb7hqfb-64x11.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-64x11.png\"},\"w128\":{\"width\":128,\"height\":23,\"mimeType\":\"image/png\",\"filesize\":2107,\"filename\":\"44529ki0cucf2lgbb7hqfb-128x23.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-128x23.png\"},\"w384\":{\"width\":384,\"height\":68,\"mimeType\":\"image/png\",\"filesize\":7044,\"filename\":\"44529ki0cucf2lgbb7hqfb-384x68.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-384x68.png\"},\"w640\":{\"width\":640,\"height\":114,\"mimeType\":\"image/png\",\"filesize\":12175,\"filename\":\"44529ki0cucf2lgbb7hqfb-640x114.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-640x114.png\"},\"w1080\":{\"width\":1080,\"height\":192,\"mimeType\":\"image/png\",\"filesize\":23345,\"filename\":\"44529ki0cucf2lgbb7hqfb-1080x192.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-1080x192.png\"},\"w1920\":{\"width\":1920,\"height\":342,\"mimeType\":\"image/png\",\"filesize\":41992,\"filename\":\"44529ki0cucf2lgbb7hqfb-1920x342.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-1920x342.png\"},\"w3840\":{\"width\":3840,\"height\":684,\"mimeType\":\"image/png\",\"filesize\":148803,\"filename\":\"44529ki0cucf2lgbb7hqfb-3840x684.png\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb-3840x684.png\"}},\"createdAt\":\"2024-09-30T12:41:23.049Z\",\"updatedAt\":\"2025-08-29T08:51:14.528Z\",\"url\":\"/cms/media/44529ki0cucf2lgbb7hqfb.png\"},\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d6777929e66c401c72c3\",\"name\":\"PUMA\",\"description\":\"Puma — легендарный немецкий бренд, который уже много лет задаёт тренды в мире спортивной моды. Бренд сочетает в себе стиль, качество и инновации, создавая одежду, обувь и аксессуары для людей, ведущих активный образ жизни. Каждая коллекция Puma — это гармония комфорта и функциональности, где продуманы все детали для спорта, тренировок и отдыха. Современные силуэты, фирменные логотипы и качественные материалы делают продукцию Puma идеальным выбором для тех, кто ценит свободу движений и яркий стиль каждый день.\",\"category\":[\"women\",\"men\",\"children\",\"accessories\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":true,\"subscriptionOnSync\":false},\"forMain\":true,\"sort\":1,\"createdAt\":\"2023-12-12T21:53:59.155Z\",\"updatedAt\":\"2025-03-18T13:10:40.896Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\"],\"logo\":{\"id\":\"67d96faf1102e2eefd970fc8\",\"filename\":\"u4k2wt935fjaubulw6r2oo.png\",\"mimeType\":\"image/png\",\"filesize\":20430,\"width\":1200,\"height\":612,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-480x320.png\",\"width\":480,\"height\":320,\"mimeType\":\"image/png\",\"filesize\":17544,\"filename\":\"u4k2wt935fjaubulw6r2oo-480x320.png\"},\"portrait\":{\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-768x1024.png\",\"width\":768,\"height\":1024,\"mimeType\":\"image/png\",\"filesize\":43234,\"filename\":\"u4k2wt935fjaubulw6r2oo-768x1024.png\"},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":16,\"mimeType\":\"image/png\",\"filesize\":677,\"filename\":\"u4k2wt935fjaubulw6r2oo-32x16.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-32x16.png\"},\"w64\":{\"width\":64,\"height\":33,\"mimeType\":\"image/png\",\"filesize\":1495,\"filename\":\"u4k2wt935fjaubulw6r2oo-64x33.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-64x33.png\"},\"w128\":{\"width\":128,\"height\":65,\"mimeType\":\"image/png\",\"filesize\":3465,\"filename\":\"u4k2wt935fjaubulw6r2oo-128x65.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-128x65.png\"},\"w384\":{\"width\":384,\"height\":196,\"mimeType\":\"image/png\",\"filesize\":12207,\"filename\":\"u4k2wt935fjaubulw6r2oo-384x196.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-384x196.png\"},\"w640\":{\"width\":640,\"height\":326,\"mimeType\":\"image/png\",\"filesize\":23013,\"filename\":\"u4k2wt935fjaubulw6r2oo-640x326.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-640x326.png\"},\"w1080\":{\"width\":1080,\"height\":551,\"mimeType\":\"image/png\",\"filesize\":47208,\"filename\":\"u4k2wt935fjaubulw6r2oo-1080x551.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-1080x551.png\"},\"w1920\":{\"width\":1920,\"height\":979,\"mimeType\":\"image/png\",\"filesize\":95145,\"filename\":\"u4k2wt935fjaubulw6r2oo-1920x979.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-1920x979.png\"},\"w3840\":{\"width\":3840,\"height\":1958,\"mimeType\":\"image/png\",\"filesize\":334939,\"filename\":\"u4k2wt935fjaubulw6r2oo-3840x1958.png\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo-3840x1958.png\"}},\"createdAt\":\"2025-03-18T13:05:51.984Z\",\"updatedAt\":\"2025-08-29T07:48:00.231Z\",\"url\":\"/cms/media/u4k2wt935fjaubulw6r2oo.png\"},\"isLanding\":{}},{\"id\":\"6578db7f7929e66c401c8cec\",\"name\":\"LOVE REPUBLIC\",\"description\":\"\",\"category\":[\"men\",\"women\",\"accessories\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T22:15:27.999Z\",\"updatedAt\":\"2025-03-04T03:07:42.766Z\",\"l