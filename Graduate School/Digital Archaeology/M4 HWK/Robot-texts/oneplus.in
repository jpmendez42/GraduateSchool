t/service-center&quot;},&quot;clickType&quot;:&quot;link&quot;,&quot;showBtn&quot;:true,&quot;openInApp&quot;:&quot;inApp&quot;,&quot;openInBrowser&quot;:&quot;newTab&quot;,&quot;showFlag&quot;:false,&quot;appLinkType&quot;:&quot;h5&quot;,&quot;buttonType&quot;:&quot;text-link&quot;}]},&quot;backgroundLinkInfo&quot;:{&quot;showFlag&quot;:false,&quot;link&quot;:{&quot;storeLink&quot;:&quot;&quot;,&quot;membershipLink&quot;:&quot;&quot;,&quot;inAppWebLink&quot;:&quot;https://www.oneplus.in/support/service-center&quot;,&quot;webLink&quot;:&quot;https://www.oneplus.in/support/service-center&quot;},&quot;openInApp&quot;:&quot;inApp&quot;,&quot;openInBrowser&quot;:&quot;newTab&quot;,&quot;appLinkType&quot;:&quot;h5&quot;},&quot;imagePc&quot;:&quot;/content/dam/oneplus/2024/in/home/1114/RepairService_Desktop.jpg&quot;,&quot;imageMobile&quot;:&quot;/content/dam/oneplus/2024/in/home/1114/RepairService_Mobile.jpg&quot;,&quot;imagePad&quot;:&quot;/content/dam/oneplus/2024/in/home/1114/RepairService_Tablet.jpg&quot;,&quot;pictureGroups&quot;:{&quot;pictureAlt&quot;:&quot;Two minimalist smartphone icons in black and red shapes.&quot;,&quot;noT9n_pictureAlt&quot;:&quot;Two minimalist smartphone icons in black and red shapes.&quot;}}]},&quot;articleType&quot;:2,&quot;layoutType&quot;:1,&quot;cardStyle&quot;:&quot;1&quot;},&quot;style&quot;:{&quot;theme&quot;:&quot;theme-light&quot;,&quot;showInApp&quot;:&quot;app-display&quot;,&quot;backgroundColor&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpArticleCard_f2356c55_&quot;,&quot;name&quot;:&quot;Article Card_f2356c55&quot;},&quot;CmpQuickLink_2e2801ec_&quot;:{&quot;type&quot;:&quot;CmpQuickLink&quot;,&quot;attr&quot;:{&quot;quickLinkData&quot;:[{&quot;showFlag&quot;:false,&quot;btnName&quot;:&quot;Production help&quot;,&quot;openInApp&quot;:&quot;inApp&quot;,&quot;openInBrowser&quot;:&quot;newTab&quot;,&quot;_sortSymbol&quot;:&quot;1731651657113-5678&quot;,&quot;appLinkType&quot;:&quot;h5&quot;,&quot;link&quot;:{&quot;storeLink&quot;: