meType\":\"image/jpeg\",\"filesize\":1419,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-64x43.jpg\"},\"w128\":{\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09-128x85.jpg\",\"width\":128,\"height\":85,\"mimeType\":\"image/jpeg\",\"filesize\":4026,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-128x85.jpg\"},\"w384\":{\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09-384x255.jpg\",\"width\":384,\"height\":255,\"mimeType\":\"image/jpeg\",\"filesize\":25368,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-384x255.jpg\"},\"w640\":{\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09-640x426.jpg\",\"width\":640,\"height\":426,\"mimeType\":\"image/jpeg\",\"filesize\":61142,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-640x426.jpg\"},\"w1080\":{\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09-1080x718.jpg\",\"width\":1080,\"height\":718,\"mimeType\":\"image/jpeg\",\"filesize\":146908,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-1080x718.jpg\"},\"w1920\":{\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09-1920x1277.jpg\",\"width\":1920,\"height\":1277,\"mimeType\":\"image/jpeg\",\"filesize\":350982,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-1920x1277.jpg\"},\"w3840\":{\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09-3840x2554.jpg\",\"width\":3840,\"height\":2554,\"mimeType\":\"image/jpeg\",\"filesize\":914644,\"filename\":\"8qb5fuvrgwpzq4nr2cue09-3840x2554.jpg\"}},\"createdAt\":\"2025-06-06T14:31:25.016Z\",\"updatedAt\":\"2025-08-29T07:24:21.544Z\",\"url\":\"/cms/media/8qb5fuvrgwpzq4nr2cue09.jpg\"},\"overlayColor\":\"white\",\"overlayTransperency\":0,\"meta\":{\"title\":\"Магазины Familia — карта, адреса и контакты магазинов Familia\",\"description\":\"Контакты магазинов сети off-price магазинов Familia в вашем городе.\"},\"infoTextDiscount\":{\"title\":\" Откуда в Familia скидки до -85%?\",\"description\":[{\"children\":[{\"text\":\"Как увидеть реальную выгоду и понять размер скидки на товары в Familia по сравнению с ценами на них же в других магазинах?\"}]}],\"infoTextDiscountSlider\":[{\"title\":\"Основные принципы закупок\",\"description\":[{\"children\":[{\"text\":\"Мы поставляем в свои магазины более чем 6500 брендов со всего мира. Наши закупщики ежедневно заключают сделки по выкупу остатков коллекций прошлых сезонов, нераспроданных образцов из шоурумов, излишне произведенных объемов товара при избыточном производстве. \"}]},{\"children\":[{\"text\":\"Мы работаем только с владельцами торговых марок или с авторизованными компаниями, обладающими правами по реализации этих стоков. Мы закупаем как большими, так и маленькими партиями, у нас нет требований к полноте размерного или глубине модельного ряда.\"}]}],\"imageDesktop\":{\"id\":\"6842fc6dc6f90588d89b8411\",\"filename\":\"umopqgvpcwpq1vgayg2tid.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":220374,\"width\":1644,\"height\":1109,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-480x320.jpg\",\"width\":480,\"height\":320,\"mimeType\":\"image/jpeg\",\"filesize\":14979,\"filename\":\"umopqgvpcwpq1vgayg2tid-480x320.jpg\"},\"portrait\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-768x1024.jpg\",\"width\":768,\"height\":1024,\"mimeType\":\"image/jpeg\",\"filesize\":45425,\"filename\":\"umopqgvpcwpq1vgayg2tid-768x1024.jpg\"},\"hero\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-1920x1080.jpg\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":94713,\"filename\":\"umopqgvpcwpq1vgayg2tid-1920x1080.jpg\"},\"w32\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-32x22.jpg\",\"width\":32,\"height\":22,\"mimeType\":\"image/jpeg\",\"filesize\":498,\"filename\":\"umopqgvpcwpq1vgayg2tid-32x22.jpg\"},\"w64\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-64x43.jpg\",\"width\":64,\"height\":43,\"mimeType\":\"image/jpeg\",\"filesize\":949,\"filename\":\"umopqgvpcwpq1vgayg2tid-64x43.jpg\"},\"w128\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-128x86.jpg\",\"width\":128,\"height\":86,\"mimeType\":\"image/jpeg\",\"filesize\":2278,\"filename\":\"umopqgvpcwpq1vgayg2tid-128x86.jpg\"},\"w384\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-384x259.jpg\",\"width\":384,\"height\":259,\"mimeType\":\"image/jpeg\",\"filesize\":11047,\"filename\":\"umopqgvpcwpq1vgayg2tid-384x259.jpg\"},\"w640\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-640x432.jpg\",\"width\":640,\"height\":432,\"mimeType\":\"image/jpeg\",\"filesize\":23075,\"filename\":\"umopqgvpcwpq1vgayg2tid-640x432.jpg\"},\"w1080\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-1080x729.jpg\",\"width\":1080,\"height\":729,\"mimeType\":\"image/jpeg\",\"filesize\":48385,\"filename\":\"umopqgvpcwpq1vgayg2tid-1080x729.jpg\"},\"w1920\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-1920x1295.jpg\",\"width\":1920,\"height\":1295,\"mimeType\":\"image/jpeg\",\"filesize\":105639,\"filename\":\"umopqgvpcwpq1vgayg2tid-1920x1295.jpg\"},\"w3840\":{\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid-3840x2590.jpg\",\"width\":3840,\"height\":2590,\"mimeType\":\"image/jpeg\",\"filesize\":272600,\"filename\":\"umopqgvpcwpq1vgayg2tid-3840x2590.jpg\"}},\"createdAt\":\"2025-06-06T14:34:21.675Z\",\"updatedAt\":\"2025-08-29T07:24:10.317Z\",\"url\":\"/cms/media/umopqgvpcwpq1vgayg2tid.jpg\"},\"imageMobile\":{\"id\":\"6842fc73d1c4e4d30626af53\",\"filename\":\"cjmy7n4r0siog17hgb90mr.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":220374,\"width\":1644,\"height\":1109,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-480x320.jpg\",\"width\":480,\"height\":320,\"mimeType\":\"image/jpeg\",\"filesize\":14979,\"filename\":\"cjmy7n4r0siog17hgb90mr-480x320.jpg\"},\"portrait\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-768x1024.jpg\",\"width\":768,\"height\":1024,\"mimeType\":\"image/jpeg\",\"filesize\":45425,\"filename\":\"cjmy7n4r0siog17hgb90mr-768x1024.jpg\"},\"hero\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-1920x1080.jpg\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":94713,\"filename\":\"cjmy7n4r0siog17hgb90mr-1920x1080.jpg\"},\"w32\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-32x22.jpg\",\"width\":32,\"height\":22,\"mimeType\":\"image/jpeg\",\"filesize\":498,\"filename\":\"cjmy7n4r0siog17hgb90mr-32x22.jpg\"},\"w64\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-64x43.jpg\",\"width\":64,\"height\":43,\"mimeType\":\"image/jpeg\",\"filesize\":949,\"filename\":\"cjmy7n4r0siog17hgb90mr-64x43.jpg\"},\"w128\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-128x86.jpg\",\"width\":128,\"height\":86,\"mimeType\":\"image/jpeg\",\"filesize\":2278,\"filename\":\"cjmy7n4r0siog17hgb90mr-128x86.jpg\"},\"w384\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-384x259.jpg\",\"width\":384,\"height\":259,\"mimeType\":\"image/jpeg\",\"filesize\":11047,\"filename\":\"cjmy7n4r0siog17hgb90mr-384x259.jpg\"},\"w640\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-640x432.jpg\",\"width\":640,\"height\":432,\"mimeType\":\"image/jpeg\",\"filesize\":23075,\"filename\":\"cjmy7n4r0siog17hgb90mr-640x432.jpg\"},\"w1080\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-1080x729.jpg\",\"width\":1080,\"height\":729,\"mimeType\":\"image/jpeg\",\"filesize\":48385,\"filename\":\"cjmy7n4r0siog17hgb90mr-1080x729.jpg\"},\"w1920\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-1920x1295.jpg\",\"width\":1920,\"height\":1295,\"mimeType\":\"image/jpeg\",\"filesize\":105639,\"filename\":\"cjmy7n4r0siog17hgb90mr-1920x1295.jpg\"},\"w3840\":{\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr-3840x2590.jpg\",\"width\":3840,\"height\":2590,\"mimeType\":\"image/jpeg\",\"filesize\":272600,\"filename\":\"cjmy7n4r0siog17hgb90mr-3840x2590.jpg\"}},\"createdAt\":\"2025-06-06T14:34:27.527Z\",\"updatedAt\":\"2025-08-29T07:24:10.563Z\",\"url\":\"/cms/media/cjmy7n4r0siog17hgb90mr.jpg\"},\"id\":\"669fdd51fac4762c009b6282\"},{\"title\":\"Как формируются цены\",\"description\":[{\"children\":[{\"text\":\"С поставщиками мы всегда обсуждаем размер скидки, чтобы в дальнейшем предоставить ее своим покупателем в расчете от Рекомендованной Розничной цены. РРЦ — это первая розничная цена на товар, которую рекомендует владелец бренда и по которой товар впервые попадает в розничные магазины. Эта цена не учитывает возможных скидок от самого бренда в его собственных магазинах, что является элементом ценовой политики отдельной торговой марки. Каждый товар имеет свой жизненный цикл, и его цена в магазинах партнеров меняется в зависимости от многих факторов: возраста товара, курса валют, новизны коллекции, сезонности и других.\"}]},{\"children\":[{\"text\":\"Именно РРЦ является отправной точкой для переговоров и ориентиром для покупателя с точки зрения понимания экономии и размера скидки, которую он получает, приобретая товар в магазинах Familia.\"}]}],\"imageDesktop\":{\"id\":\"6842fc7dcd84519c74f9119b\",\"filename\":\"ulgdkn6xvc7fsjvyxuywj.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":453936,\"width\":1644,\"height\":1109,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-480x320.jpg\",\"width\":480,\"height\":320,\"mimeType\":\"image/jpeg\",\"filesize\":27345,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-480x320.jpg\"},\"portrait\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-768x1024.jpg\",\"width\":768,\"height\":1024,\"mimeType\":\"image/jpeg\",\"filesize\":130042,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-768x1024.jpg\"},\"hero\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-1920x1080.jpg\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":231571,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-1920x1080.jpg\"},\"w32\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-32x22.jpg\",\"width\":32,\"height\":22,\"mimeType\":\"image/jpeg\",\"filesize\":643,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-32x22.jpg\"},\"w64\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-64x43.jpg\",\"width\":64,\"height\":43,\"mimeType\":\"image/jpeg\",\"filesize\":1438,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-64x43.jpg\"},\"w128\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-128x86.jpg\",\"width\":128,\"height\":86,\"mimeType\":\"image/jpeg\",\"filesize\":3619,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-128x86.jpg\"},\"w384\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-384x259.jpg\",\"width\":384,\"height\":259,\"mimeType\":\"image/jpeg\",\"filesize\":19741,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-384x259.jpg\"},\"w640\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-640x432.jpg\",\"width\":640,\"height\":432,\"mimeType\":\"image/jpeg\",\"filesize\":43685,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-640x432.jpg\"},\"w1080\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-1080x729.jpg\",\"width\":1080,\"height\":729,\"mimeType\":\"image/jpeg\",\"filesize\":104324,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-1080x729.jpg\"},\"w1920\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-1920x1295.jpg\",\"width\":1920,\"height\":1295,\"mimeType\":\"image/jpeg\",\"filesize\":262382,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-1920x1295.jpg\"},\"w3840\":{\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj-3840x2590.jpg\",\"width\":3840,\"height\":2590,\"mimeType\":\"image/jpeg\",\"filesize\":732179,\"filename\":\"ulgdkn6xvc7fsjvyxuywj-3840x2590.jpg\"}},\"createdAt\":\"2025-06-06T14:34:37.306Z\",\"updatedAt\":\"2025-08-29T07:24:10.328Z\",\"url\":\"/cms/media/ulgdkn6xvc7fsjvyxuywj.jpg\"},\"imageMobile\":{\"id\":\"6842fc83d1c4e4d30626afbd\",\"filename\":\"c4jqppdf3jcuksb4lnp7uj.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":453936,\"width\":1644,\"height\":1109,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-480x320.jpg\",\"width\":480,\"height\":320,\"mimeType\":\"image/jpeg\",\"filesize\":27345,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-480x320.jpg\"},\"portrait\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-768x1024.jpg\",\"width\":768,\"height\":1024,\"mimeType\":\"image/jpeg\",\"filesize\":130042,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-768x1024.jpg\"},\"hero\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-1920x1080.jpg\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":231571,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-1920x1080.jpg\"},\"w32\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-32x22.jpg\",\"width\":32,\"height\":22,\"mimeType\":\"image/jpeg\",\"filesize\":643,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-32x22.jpg\"},\"w64\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-64x43.jpg\",\"width\":64,\"height\":43,\"mimeType\":\"image/jpeg\",\"filesize\":1438,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-64x43.jpg\"},\"w128\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-128x86.jpg\",\"width\":128,\"height\":86,\"mimeType\":\"image/jpeg\",\"filesize\":3619,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-128x86.jpg\"},\"w384\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-384x259.jpg\",\"width\":384,\"height\":259,\"mimeType\":\"image/jpeg\",\"filesize\":19741,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-384x259.jpg\"},\"w640\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-640x432.jpg\",\"width\":640,\"height\":432,\"mimeType\":\"image/jpeg\",\"filesize\":43685,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-640x432.jpg\"},\"w1080\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-1080x729.jpg\",\"width\":1080,\"height\":729,\"mimeType\":\"image/jpeg\",\"filesize\":104324,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-1080x729.jpg\"},\"w1920\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-1920x1295.jpg\",\"width\":1920,\"height\":1295,\"mimeType\":\"image/jpeg\",\"filesize\":262382,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-1920x1295.jpg\"},\"w3840\":{\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj-3840x2590.jpg\",\"width\":3840,\"height\":2590,\"mimeType\":\"image/jpeg\",\"filesize\":732179,\"filename\":\"c4jqppdf3jcuksb4lnp7uj-3840x2590.jpg\"}},\"createdAt\":\"2025-06-06T14:34:43.247Z\",\"updatedAt\":\"2025-08-29T07:24:10.572Z\",\"url\":\"/cms/media/c4jqppdf3jcuksb4lnp7uj.jpg\"},\"id\":\"669fddabfac4762c009b6283\"},{\"title\":\"Выгодный шопинг\",\"description\":[{\"children\":[{\"text\":\"Экономия при покупках - это ключевое преимущество нашего бизнеса и формата off-price в целом, и его отличительная черта от других ритейлеров, и мы заинтересованы в достижении максимальной скидки на товар и информировании покупателя о том, какую выгоду он получает при покупке. Именно поэтому на ценниках на товар мы указываем как текущую цену в нашем магазине, так и РРЦ от поставщика, а также выгоду от разницы этих цен.\"}]}],\"imageDesktop\":{\"id\":\"6842fc8dcd84519c74f9124e\",\"filename\":\"rh2je3qz1zjw8ihr26qyrc.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":583664,\"width\":1644,\"height\":1109,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-480x320.jpg\",\"width\":480,\"height\":320,\"mimeType\":\"image/jpeg\",\"filesize\":34549,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-480x320.jpg\"},\"portrait\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-768x1024.jpg\",\"width\":768,\"height\":1024,\"mimeType\":\"image/jpeg\",\"filesize\":130947,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-768x1024.jpg\"},\"hero\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-1920x1080.jpg\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":297905,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-1920x1080.jpg\"},\"w32\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-32x22.jpg\",\"width\":32,\"height\":22,\"mimeType\":\"image/jpeg\",\"filesize\":679,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-32x22.jpg\"},\"w64\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-64x43.jpg\",\"width\":64,\"height\":43,\"mimeType\":\"image/jpeg\",\"filesize\":1591,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-64x43.jpg\"},\"w128\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-128x86.jpg\",\"width\":128,\"height\":86,\"mimeType\":\"image/jpeg\",\"filesize\":4248,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-128x86.jpg\"},\"w384\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-384x259.jpg\",\"width\":384,\"height\":259,\"mimeType\":\"image/jpeg\",\"filesize\":24387,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-384x259.jpg\"},\"w640\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-640x432.jpg\",\"width\":640,\"height\":432,\"mimeType\":\"image/jpeg\",\"filesize\":56357,\"filename\":\"rh2je3qz1zjw8ihr26qyrc-640x432.jpg\"},\"w1080\":{\"url\":\"/cms/media/rh2je3qz1zjw8ihr26qyrc-1080x729.jpg\",\"width\":1080,\"height\":729,\"mimeType\":\"image/jpeg\",\"filesize\":13828