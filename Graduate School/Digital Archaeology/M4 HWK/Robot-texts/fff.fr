50w "> <source media="(max-width: 550px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/cover=550:812/resize=550 550w, https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/cover=550:812/resize=1100 1100w "> <source media="(max-width: 768px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/cover=768:1024/resize=768 768w, https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/cover=768:1024/resize=1536 1536w "> <source media="(max-width: 1024px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=1024 1024w, https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=2048 2048w "> <source media="(min-width: 1024px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=1024 1024w, https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=1200 1200w, https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=1400 1400w, https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=1600 1600w "> <img class="objectfit" title="Hugo PFEIFFER / ICON SPORT" data-credit="Hugo PFEIFFER / ICON SPORT" src="https://fff.twic.pics/https://media.fff.fr/uploads/images/f0c98f2ac834b34138b9902f90fa314d.jpg?twic=v1/focus=2921x1553/resize=1024" alt="Michael Olise"> </picture> </div> </article> </a> <a onclick="getPage()" href="/article/15513-au-presque-parfait-devant-l-estonie.html"> <article class="flex flex_jc_center"> <div data-title="Au presque parfait devant l’Estonie" class="container flex flex_column bold absolute_slider white flex_ai_start row desc_slider"> <div class="column"> <h4 class="tag white font_12 margin_b8 uppercase">Équipe de France Espoirs</h4> <h3 data-title="Au presque parfait devant l’Estonie" class="title_slide margin_b16 margin_t16 uppercase font_hero header_title">Au presque parfait devant l’Estonie</h3> <p data-title="Au presque parfait devant l’Estonie" class="font_18 regular margin_b30 large_5 small_12 desc_header">Les Bleuets se sont logiquement imposés devant l’Estonie (6-1), lundi 13 octobre à Grenoble, pour confirmer leurs débuts réussis en qualifications à l’Euro U21 2027.</p> </div> </div> <div class="header_slider_content img_ie"> <picture> <source class="" media="(max-width: 320px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=320:568/resize=320 320w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=320:568/resize=640 640w "> <source media="(max-width: 375px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=375:812/resize=375 375w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=375:812/resize=750 750w "> <source media="(max-width: 550px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=550:812/resize=550 550w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=550:812/resize=1100 1100w "> <source media="(max-width: 768px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=768:1024/resize=768 768w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/cover=768:1024/resize=1536 1536w "> <source media="(max-width: 1024px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=1024 1024w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=2048 2048w "> <source media="(min-width: 1024px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=1024 1024w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=1200 1200w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=1400 1400w, https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=1600 1600w "> <img class="objectfit" title="Baptiste FERNANDEZ / ICON SPORT" data-credit="Baptiste FERNANDEZ / ICON SPORT" src="https://fff.twic.pics/https://media.fff.fr/uploads/images/98bcedbd3ef66280dbb5c97e30b100a7.jpg?twic=v1/focus=2729x1138/resize=1024" alt="France-Estonie Espoirs octobre 2025"> </picture> </div> </article> </a> <a onclick="getPage()" href="/article/15454-l-epopee-chilienne-continue.html"> <article class="flex flex_jc_center"> <div data-title="L&#039;épopée chilienne continue" class="container flex flex_column bold absolute_slider white flex_ai_start row desc_slider"> <div class="column"> <h4 class="tag white font_12 margin_b8 uppercase">U20</h4> <h3 data-title="L&#039;épopée chilienne continue" class="title_slide margin_b16 margin_t16 uppercase font_hero header_title">L&#039;épopée chilienne continue</h3> <p data-title="L&#039;épopée chilienne continue" class="font_18 regular margin_b30 large_5 small_12 desc_header">La France s&#039;est qualifiée pour le dernier carré de la Coupe du monde U20 en éliminant la Norvège (2-1) en quarts de finale, cette nuit. Elle sera opposée au Maroc en demi-finales, mercredi. </p> </div> </div> <div class="header_slider_content img_ie"> <picture> <source class="" media="(max-width: 320px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=320:568/resize=320 320w, https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=320:568/resize=640 640w "> <source media="(max-width: 375px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=375:812/resize=375 375w, https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=375:812/resize=750 750w "> <source media="(max-width: 550px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=550:812/resize=550 550w, https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=550:812/resize=1100 1100w "> <source media="(max-width: 768px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=768:1024/resize=768 768w, https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/cover=768:1024/resize=1536 1536w "> <source media="(max-width: 1024px)" srcset=" https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4e3ff641c39c74.jpg?twic=v1/focus=2485x1657/resize=1024 1024w, https://fff.twic.pics/https://media.fff.fr/uploads/images/c0778ba51dbb1f7c0b4