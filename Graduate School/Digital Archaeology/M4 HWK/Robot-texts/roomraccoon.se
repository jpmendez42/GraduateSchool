/* .sec-menu .elementor-nav-menu li:nth-child(1) {
    border-width: 0;
    width: 40%;
    float: left;
} */


.sec-menu .elementor-nav-menu li:nth-child(2) {
    border-width: 0;
    width: 60%;
    float: left;
}	

.sec-menu .elementor-nav-menu--dropdown a {
    color: #ffffff;
	float: right;
	padding: 3px 20px;
}
		
		.table-col1 {
			width: 100%;
			display: block;
		}
	}
	
	.elementor-field-group.elementor-field-type-submit {
    align-items: flex-start;
}
	
/* 	#blog-subscribe-btn {
		margin-top: -10px;
	} */
	
</style>
