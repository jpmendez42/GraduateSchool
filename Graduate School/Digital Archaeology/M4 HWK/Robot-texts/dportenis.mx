loating_Content","baseMarketingSpotDataType":"MarketingContent","activityIdentifierID":"0","MarketingContentDescription":[{}],"marketingContentDescription":[{"marketingText":"\u003cdp-floating-whatsapp   href=\"https://wa.me/526699155300?text=Hola%20tienda%20en%20línea%20dportenis,%20me%20contacto%20desde%20su%20sitio%20principal\"   img=\"https://dpjye2wk9gi5z.cloudfront.net/wcsstore/DportenisStorefrontAssetStore/images/icons/whatsapp.svg\"    alt=\"WhatsApp\"   hover=\"Chatea con nosotros\" /\u003e","language":"-5"}],"contentFormatId":"2","activityPriority":"1","properties":[{"baseMarketingKey":"mktActivityDescription"},{"baseMarketingValue":"1.0","baseMarketingKey":"displaySequence"}],"contentStoreId":"1"}]}],"resourceId":"https://www.dportenis.mx:5443/wcs/resources/store/1/espot/DPV2_WhatsAppFloating_Spot?langId=-5","resourceName":"espot"},"@#query:#_s:\"-5\",_n:true,_m:\"TopCategoriesDisplay\",_l:false,_a:\"3074457345616677668\",,_o:\"DPV2_SEO\",_C:\"1\",,\"ESpotDataFromName\",":{"MarketingSpotData":[{"nextTimeLimit":"-1","defaultContentDisplaySequence":[{"resultId":"716167114","resultFormat":"MarketingContent","displaySequence":"1.0"}],"marketingSpotIdentifier":"716157449","behavior":"0","eSpotName":"DPV2_SEO","baseMarketingSpotActivityData":[{"contentFormatName":"Text","baseMarketingSpotActivityName":"DPV2_SEO_Content","contentClickAction":"None","contentId":"716167114","baseMarketingSpotActivityID":"716167114","contentName":"DPV2_SEO_Content","baseMarketingSpotDataType":"MarketingContent","activityIdentifierID":"0","MarketingContentDescription":[{}],"marketingContentDescription":[{"marketingText":"\n\u003cdp-seo-frame\u003e\n    \u003cdp-seo-section\u003e\n        \u003cdp-seo-title\u003eLo mejor en tenis de hombre, mujer y niño, ropa deportiva y accesorios deportivos lo encuentras en dportenis\u003c/dp-seo-title\u003e\n        \u003cdp-seo-text\u003e\n            ¿Listo para llevar tu desempeño al siguiente nivel? En \n            \u003ca class=\"link\" href=\"http://dportenis.mx\" variant=\"primary\"\u003edportenis\u003c/a\u003e, encontrarás una amplia selección de \n            \u003cstrong\u003e\n                \u003ca class=\"link\" href=\"https://www.dportenis.mx/nuevo-dportenis/nuevo-calzado-dportenis\" variant=\"primary\"\u003etenis de hombre\u003c/a\u003e, \n                \u003ca class=\"link\" href=\"https://www.dportenis.mx/nuevo-dportenis/nuevo-calzado-dportenis\" variant=\"primary\"\u003emujer\u003c/a\u003e y \n                \u003ca class=\"link\" href=\"https://www.dportenis.mx/nino-dportenis\" variant=\"primary\"\u003eniños\u003c/a\u003e\n            \u003c/strong\u003e, \n            \u003ca class=\"link\" href=\"https://www.dportenis.mx/nuevo-dportenis/nuevo-ropa-dportenis\" variant=\"primary\"\u003eropa deportiva\u003c/a\u003e y \n            \u003ca class=\"link\" href=\"https://www.dportenis.mx/nuevo-dportenis/nuevo-accesorios-dportenis\" variant=\"primary\"\u003etodo tipo de accesorios\u003c/a\u003e para que tu pasión por el deporte se vea reflejada en cada paso.\n            \u003cbr\u003e\n            \u003cbr\u003e\n            Contamos con más de 250 tiendas físicas y nuestra tienda virtual \n            \u003ca class=\"link\" href=\"https://dportenis.mx/\" variant=\"primary\"\u003edportenis.mx\u003c/a\u003e\n            , donde podrás descubrir más de 6,000 productos en una variedad impresionante de estilos y marcas reconocidas para toda la familia, incluyendo mujeres y niños.\n            \u003cbr\u003e\n            \u003cbr\u003e\n            Si te estás iniciando en un deporte o ya tienes experiencia, aquí hallarás el par perfecto para potenciar tu rendimiento y tu comodidad. Nuestra colección incluye \n            \u003cstrong\u003etenis adidas, Puma, Under Armour, Reebok, Nike,\u003c/strong\u003e así como \n            \u003cstrong\u003etenis Lacoste de hombre y mujer\u003c/strong\u003e con diseños que fusionan elegancia y funcionalidad, y \n            \u003cstrong\u003etenis New Balance de hombre y mujer\u003c/strong\u003e ideales para running o entrenamiento de alto impacto.\n            \u003cbr\u003e\n            \u003cbr\u003e\n            En definitiva, tenemos todos los \n            \u003cstrong\u003e\u003ca class=\"link\" href=\"https://www.dportenis.mx/hombre-dportenis/calzado-hombre-dportenis\" variant=\"primary\"\u003etenis para hombre\u003c/a\u003e\u003c/strong\u003e que necesitas para alcanzar tus metas, además de opciones especiales para \n            \u003ca class=\"link\" href=\"https://www.dportenis.mx/mujer-dportenis/calzado-mujer\" variant=\"primary\"\u003emujeres\u003c/a\u003e y \n            \u003ca class=\"link\" href=\"https://www.dportenis.mx/nino-dportenis\" variant=\"primary\"\u003eniños\u003c/a\u003e.\n        \u003c/dp-seo-text\u003e\n    \u003c/dp-seo-section\u003e\n    \u003cdp-seo-section\u003e\n        \u003c!--\u003cdp-seo-title\u003eLas marcas que encontrarás en nuestra tienda en línea o físicas son oficiales.\u003c/dp-seo-title\u003e--\u003e\n        \u003cdp-seo-text\u003e\n            Nuestra gama de ropa deportiva no se queda atrás: playeras, shorts, conjuntos y más, todos diseñados con materiales transpirables y estilos innovadores para que te sientas cómodo en cada entrenamiento o rutina. No olvides darte una vuelta por nuestra sección de accesorios deportivos, donde te esperan lentes de sol, relojes, mochilas, maletas, bandas, gorras y calcetas para completar tu look.\n            \u003cbr\u003e\n            \u003cbr\u003e\n            En dportenis, solo trabajamos con marcas oficiales y de calidad comprobada. Colaboramos directamente con adidas, Nike, Puma, Under Armour, K-Swiss, Skechers, Reebok, Casio, Oakley, New Balance, Asics, Lacoste y muchas otras más. Cada producto que encuentres en nuestra tienda es auténtico y respaldado por las mejores tecnologías del mercado.\n            \u003cbr\u003e\n            \u003cbr\u003e\n            Visita nuestras tiendas físicas o compra en línea para descubrir la mejor selección de tenis de hombre y mujer y ropa deportiva. ¡Renueva tu armario con lo último en tendencias y disfruta de un estilo fitness único con dportenis!\n        \u003c/dp-seo-text\u003e\n    \u003c/dp-seo-section\u003e\n\u003c/dp-seo-frame\u003e\n","language":"-5"}],"contentFormatId":"2","activityPriority":"1","properties":[{"baseMarketingKey":"mktActivityDescription"},{"baseMarketingValue":"1.0","baseMarketingKey":"displaySequence"}],"contentStoreId":"1"}]}],"resourceId":"https://dpprodlivets-app:5443/wcs/resources/store/1/espot/DPV2_SEO?catalogId=3074457345616677668\u0026DM_ReturnCatalogGroupId=true\u0026DM_FilterResults=false\u0026langId=-5\u0026DM_ReqCmd=TopCategoriesDisplay","resourceName":"espot"},"@#query:#_s:\"-5\",_n:true,_m:\"TopCategoriesDisplay\",_l:false,_a:\"3074457345616677668\",,_o:\"DpPopUpPromotion_spot\",_C:\"1\",,\"ESpotDataFromName\",":{"MarketingSpotData":[{"nextTimeLimit":"-1","marketingSpotIdentifier":"716163726","behavior":"0","eSpotName":"DpPopUpPromotion_spot"}],"resourceId":"https://dpprodlivets-app:5443/wcs/resources/store/1/espot/DpPopUpPromotion_spot?catalogId=3074457345616677668\u0026DM_ReturnCatalogGroupId=true\u0026DM_FilterResults=false\u0026langId=-5\u0026DM_ReqCmd=TopCategoriesDisplay","resourceName":"espot"},"@#_z:\"Footer\",_t:\"es-ES\",,\"Localization\",":{"CompanyLinks":{"Label":"Acerca de","Us":"Nosotros","Billing":"Facturación","Blog":"Blog","SiteMap":"Mapa del sitio","JoinUp":"Únete al equipo","Distributor":"Quiero ser distribuidor","OurStory":"Nuestra historia","Careers":"Carreras"},"DpGroup":{"Label":"Grupo DP","DpStreet":"Dpstreet","DpVale":"Dpvale","ClubDp":"Clubdp","DpDirecto":"Dpdirecto","DpApp":"Dp APP"},"CallCenter":{"Label":"Call Center","PhoneNumber":"66 99 15 53 00","Schedule":"Lun a Dom; 9:00 a 21:00 hrs. (CDMX)","ReceiveOffers":"Recibe ofertas a tu correo","ReceiveMessageOffers":"Al registrarte, aceptas nuestra Politica de Privacidad","EmailLabel":"Correo electrónico","Subscribe":"Suscribirme","