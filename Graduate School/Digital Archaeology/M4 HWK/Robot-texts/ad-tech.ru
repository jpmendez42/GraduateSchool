                  <li><a class="js-header-menu-mobile-link" href="https://ads.sber.ru/help"
                      data-cv-name="spravka_header">Справка</a></li>
                  <li><a class="js-header-menu-mobile-link" href="#feedback" data-cv-name="zadat_vopros_header">Задать
                      вопрос</a></li>
