</script><script type="text/javascript">
document.addEventListener("DOMContentLoaded", function () {
  if (window.innerWidth <= 991) {
    // Na malých obrazovkách nedělej nic
    return;
  }

  const boxes = document.querySelectorAll(".domain-promotions-box");
  const btn = document.querySelector(".btn-show-more-boxes");
  const visibleCount = 4; // Počet viditelných boxů (čtveřice)

  // Funkce pro nastavení výšek pro .promotion-box_title pro každou čtveřici boxů
  function setHeightsForPromotions() {
    const boxGroups = []; // Pole pro uchování skupin čtyř boxů

    // Rozdělíme boxy do skupin po 4
    for (let i = 0; i < boxes.length; i += 4) {
      const group = [boxes[i], boxes[i + 1], boxes[i + 2], boxes[i + 3]].filter(Boolean); // Filtrujeme prázdné boxy, pokud je jich méně než 4
      if (group.length > 0) {
        boxGroups.push(group);
      }
    }

    // Pro každou skupinu čtyř boxů
    boxGroups.forEach(group => {
      let titleHeights = [];
      
      // Získáme výšky pro titulek pro každou čtveřici
      group.forEach(box => {
        const title = box.querySelector('.promotion-box_title');
        titleHeights.push(title.offsetHeight);
      });

      // Určíme maximální výšku pro titulek v rámci této čtveřice
      const maxTitleHeight = Math.max(...titleHeights);

      // Nastavíme minimální výšku pro všechny titulky v této čtveřici
      group.forEach(box => {
        const title = box.querySelector('.promotion-box_title');
        title.style.minHeight = maxTitleHeight + 'px';
      });
    });
  }

  // Funkce pro skrytí extra boxů
  function hideExtraBoxes() {
    boxes.forEach((box, index) => {
      if (index >= visibleCount) {
        box.classList.remove('visible');
      } else {
        box.classList.add('visible');
      }
    });

    setHeightsForPromotions(); // Po změně viditelnosti boxů znovu nastavíme výšky pro čtveřice
  }

  // Funkce pro zobrazení všech boxů
  function showAllBoxes() {
    boxes.forEach(box => box.classList.add('visible'));
    setHeightsForPromotions(); // Po zobrazení všech boxů nastavíme výšky pro čtveřice
  }

  // Funkce pro aktualizaci textu tlačítka
  // function updateButtonText() {
  //   const hiddenCount = [...boxes].filter(box => !box.classList.contains('visible')).length;
  //   if (btn.classList.contains("expanded")) {
  //     btn.textContent = "Zobrazit méně";
  //   } else {
  //     btn.textContent = `Zobrazit další (${hiddenCount})`;
  //   }
  // }

  // Inicializace
  setHeightsForPromotions(); // Ihned při načítání stránky nastavíme výšky pro čtveřice
  hideExtraBoxes();
  updateButtonText();

  // Tlačítko pro zobrazení/skrytí boxů
  btn.addEventListener("click", function (e) {
    e.preventDefault();
    btn.classList.toggle("expanded");

    if (btn.classList.contains("expanded")) {
      showAllBoxes();
    } else {
      hideExtraBoxes();
      const target = document.getElementById("domain-promotions");
      if (target) {
        const offset = 100;
const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
window.scrollTo({ top: targetPosition, behavior: "smooth" });
      }
    }

    updateButtonText();
  });
});
</script><script type="text/javascript">
document.addEventListener('DOMContentLoaded', function () {
  class SliderAlwaysVisible {
    constructor(selector) {
      this.slider = document.querySelector(selector);
      if (!this.slider) return;

      this.wrapper = this.slider.querySelector('.slides-wrapper');
      this.slides = Array.from(this.slider.querySelectorAll('.slide-item'));
      this.prevBtn = document.querySelector('.slider-wrapper-outer .prev-visible');
      this.nextBtn = document.querySelector('.slider-wrapper-outer .next-visible');
      this.caption = this.slider.querySelector('.caption-visible');
      this.dotsContainer = this.slider.querySelector('.dots-visible');

      this.slideIndex = 0;
      this.slidesPerView = 1;
      this.totalPages = 0;

      // Drag state
      this.isDragging = false;
      this.isClick = true;
      this.startX = 0;
      this.currentTranslate = 0;
      this.prevTranslate = 0;
      this.movedDistance = 0;
      this.isTouch = false;

      this.init();
    }

    init() {
      this.setup();
      this.createDots();
      this.update();
      this.attachEvents();
    }

    setup() {
      const width = window.innerWidth;
      if (width >= 1200) {
        this.slidesPerView = 3;
      } else if (width >= 992) {
        this.slidesPerView = 2;
      } else {
        this.slidesPerView = 1;
      }
      this.totalPages = Math.ceil(this.slides.length / this.slidesPerView);
    }

    createDots() {
      this.dotsContainer.innerHTML = '';
      for (let i = 0; i < this.totalPages; i++) {
        const dot = document.createElement('span');
        dot.addEventListener('click', () => {
          this.slideIndex = i;
          this.setPositionByIndex();
        });
        this.dotsContainer.appendChild(dot);
      }
    }

    update() {
      this.setPositionByIndex(false);
    }

    next() {
      this.slideIndex = (this.slideIndex + 1) % this.totalPages;
      this.setPositionByIndex();
    }

    prev() {
      this.slideIndex = (this.slideIndex - 1 + this.totalPages) % this.totalPages;
      this.setPositionByIndex();
    }

    setPositionByIndex(withTransition = true) {
       this.slides.forEach((slide, index) => {
    const start = this.slideIndex * this.slidesPerView;
    const end = start + this.slidesPerView;
    if (index >= start && index < end) {
      slide.classList.add('visible-box');
    } else {
      slide.classList.remove('visible-box');
    }
  });
      const slideWidth = this.slider.offsetWidth / this.slidesPerView;
      const offset = slideWidth * this.slidesPerView * this.slideIndex;
      this.currentTranslate = -offset;
      this.prevTranslate = this.currentTranslate;
      this.wrapper.style.transition = withTransition ? 'transform 0.5s ease-out' : 'none';
      this.wrapper.style.transform = `translateX(${this.currentTranslate}px)`;
      this.caption.textContent = `${this.slideIndex + 1} / ${this.totalPages}`;
      Array.from(this.dotsContainer.children).forEach((dot, index) => {
        dot.classList.toggle('active', index === this.slideIndex);
      });
     
    }

    attachEvents() {
      this.nextBtn.addEventListener('click', () => this.next());
      this.prevBtn.addEventListener('click', () => this.prev());

      window.addEventListener('resize', () => {
        const oldSlidesPerView = this.slidesPerView;
        this.setup();
        if (oldSlidesPerView !== this.slidesPerView) {
          this.slideIndex = 0;
          this.createDots();
        }
        this.setPositionByIndex();
      });

      // Mouse
      this.wrapper.addEventListener('mousedown', e => { this.isTouch = false; this.touchStart(e); });
      this.wrapper.addEventListener('mousemove', e => { if (!this.isTouch) this.touchMove(e); });
      this.wrapper.addEventListener('mouseup', e => { if (!this.isTouch) this.touchEnd(e); });
      this.wrapper.addEventListener('mouseleave', e => { if (!this.isTouch) this.touchEnd(e); });

      // Touch
      this.wrapper.addEventListener('touchstart', e => { this.isTouch = true; this.touchStart(e); });
      this.wrapper.addEventListener('touchmove', e => { if (this.isTouch) this.touchMove(e); });
      this.wrapper.addEventListener('touchend', e => { if (this.isTouch) this.touchEnd(e); });
    }

    getPositionX(e) {
      return e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
    }

    touchStart(e) {
      this.isDragging = true;
      this.isClick = true;
      this.startX = this.getPositionX(e);
      this.movedDistance = 0;
      this.wrapper.style.transition = 'none';
    }

    touchMove(e) {
      if (!this.isDragging) return;
      const currentX = this.getPositionX(e);
      const moved = currentX - this.startX;
      this.movedDistance = moved;

      if (!this.isTouch) {
        // Desktop – okamžitý posun
        if (Math.abs(moved) > 5) this.isClick = false;
        this.currentTranslate = this.prevTranslate + moved;
        this.wrapper.style.transform = `translateX(${this.currentTranslate}px)`;
      }
      // Mobile – neposouváme fyzicky, jen měříme movedDistance
    }

    touchEnd(e) {
      if (!this.isDragging) return;
      this.isDragging = false;

      if (this.isTouch) {
        // Mobile – reagujeme až po puštění
        if (this.movedDistance < -50) {
          this.slideIndex = (this.slideIndex + 1) % this.totalPages;
        } else if (this.movedDistance > 50) {
          this.slideIndex = (this.slideIndex - 1 + this.totalPages) % this.totalPages;
        }
      } else {
        // Desktop – klasická logika
        if (!this.isClick) {
          const movedBy = this.currentTranslate - this.prevTranslate;
          if (movedBy < -50) {
            this.slideIndex = (this.slideIndex + 1) % this.totalPages;
          } else if (movedBy > 50) {
            this.slideIndex = (this.slideIndex - 1 + this.totalPages) % this.totalPages;
          }
        }
      }

      this.setPositionByIndex(true);
    }
  }

  // INIT
  new SliderAlwaysVisible('.slider-always-visible');
});
</script><script type="text/javascript">
function setEqualHeight(selector) {
  const elements = document.querySelectorAll(selector);
  if (elements.length === 0) return;
  let maxHeight = 0;
  elements.forEach(el => { el.style.height = 'auto'; });
  elements.forEach(el => {
    const height = el.offsetHeight;
    if (height > maxHeight) maxHeight = height;
  });
  elements.forEach(el => { el.style.height = maxHeight + 'px'; });
}

function applyHeights() {
  setEqualHeight('h3.promotion-card_title');
  setEqualHeight('p.promotion-card_description');
}

window.addEventListener('load', applyHeights);
window.addEventListener('resize', function () {
  clearTimeout(window._resizeTimeout);
  window._resizeTimeout = setTimeout(applyHeights, 100);
});
</script><script type="text/javascript">
document.addEventListener('DOMContentLoaded', function () {
  class FpzSlider {
    constructor(container) {
      this.container = container;
      this.slider = container.querySelector('.fpz-slider, .fpz-slider-1, .fpz-slider-2, .fpz-slider-3');
      if (!this.slider) return;

      this.wrapper = this.slider.querySelector('.fpz-slides');
      this.slides = Array.from(this.slider.querySelectorAll('.fpz-slide'));
      this.dotsContainer = container.querySelector('.fpz-dots');

      this.slideIndex = 0;
      this.slidesPerView = 1;
      this.totalPages = 0;

      this.isDragging = false;
      this.isClick = true;
      this.startX = 0;
      this.startY = 0;
      this.currentTranslate = 0;
      this.prevTranslate = 0;
      this.movedDistance = 0;
      this.isTouch = false;

      this.init();

      // Uložíme instanci slideru pro šipky
      this.slider.fpzInstance = this;
    }

    init() {
      this.setup();
      this.createDots();
      this.update();
      this.attachEvents();
    }

setup() { const width = window.innerWidth; let slidesPerView = this.slider.dataset.slidesDefault || "1"; if (width >= 1200 && this.slider.dataset.slidesXl) slidesPerView = this.slider.dataset.slidesXl; else if (width >= 992 && this.slider.dataset.slidesLg) slidesPerView = this.slider.dataset.slidesLg; else if (width >= 768 && this.slider.dataset.slidesMd) slidesPerView = this.slider.dataset.slidesMd; if (slidesPerView === "none") { this.slidesPerView = this.slides.length; this.totalPages = 1; this.wrapper.style.transform = "none"; if (this.dotsContainer) this.dotsContainer.innerHTML = ""; return; } this.slidesPerView = parseInt(slidesPerView, 10) || 1; this.totalPages = Math.ceil(this.slides.length / this.slidesPerView); }


    createDots() {
      if (!this.dotsContainer) return;
      this.dotsContainer.innerHTML = '';
      for (let i = 0; i < this.totalPages; i++) {
        const dot = document.createElement('span');
        dot.addEventListener('click', () => {
          this.slideIndex = i;
          this.setPositionByIndex();
        });
        this.dotsContainer.appendChild(dot);
      }
    }

    update() {
      this.setPositionByIndex(false);
    }

    next() {
      this.slideIndex = (this.slideIndex + 1) % this.totalPages;
      this.setPositionByIndex();
    }

    prev() {
      this.slideIndex = (this.slideIndex - 1 + this.totalPages) % this.totalPages;
      this.setPositionByIndex();
    }

    setPositionByIndex(withTransition = true) {
      const slideWidth = this.slider.offsetWidth / this.slidesPerView;
      const offset = slideWidth * this.slidesPerView * this.slideIndex;
      this.currentTranslate = -offset;
      this.prevTranslate = this.currentTranslate;
      this.wrapper.style.transition = withTransition ? 'transform 0.5s ease-out' : 'none';
      this.wrapper.style.transform = `translateX(${this.currentTranslate}px)`;

      if (this.dotsContainer) {
        Array.from(this.dotsContainer.children).forEach((dot, index) => {
          dot.classList.toggle('active', index === this.slideIndex);
        });
      }
    }

    attachEvents() {
      window.addEventListener('resize', () => {
        const oldSlidesPerView = this.slidesPerView;
        this.setup();
        if (oldSlidesPerView !== this.slidesPerView) {
          this.slideIndex = 0;
          this.createDots();
        }
        this.setPositionByIndex();
      });

      this.wrapper.addEventListener('mousedown', e => { this.isTouch = false; this.touchStart(e); });
      this.wrapper.addEventListener('mousemove', e => { if (!this.isTouch) this.touchMove(e); });
      this.wrapper.addEventListener('mouseup', e => { if (!this.isTouch) this.touchEnd(e); });
      this.wrapper.addEventListener('mouseleave', e => { if (!this.isTouch) this.touchEnd(e); });

      this.wrapper.addEventListener('touchstart', e => { this.isTouch = true; this.touchStart(e); });
      this.wrapper.addEventListener('touchmove', e => { if (this.isTouch) this.touchMove(e); });
      this.wrapper.addEventListener('touchend', e => { if (this.isTouch) this.touchEnd(e); });
    }

    getPositionX(e) {
      return e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
    }

    touchStart(e) {
      this.isDragging = true;
      this.isClick = true;
      this.startX = this.getPositionX(e);
      this.startY = e.type.includes('mouse') ? e.pageY : e.touches[0].clientY;
      this.movedDistance = 0;
      this.wrapper.style.transition = 'none';
    }

    touchMove(e) {
      if (!this.isDragging) return;
      const currentX = this.getPositionX(e);
      const currentY = e.type.includes('mouse') ? e.pageY : e.touches[0].clientY;
      const diffX = currentX - this.startX;
      const diffY = currentY - this.startY;

      if (Math.abs(diffX) > Math.abs(diffY)) {
        e.preventDefault();
        if (Math.abs(diffX) > 5) this.isClick = false;
        this.currentTranslate = this.prevTranslate + diffX;
        this.wrapper.style.transform = `translateX(${this.currentTranslate}px)`;
        this.movedDistance = diffX;
      }
    }

    touchEnd(e) {
      if (!this.isDragging) return;
      this.isDragging = false;

      const movedBy = this.currentTranslate - this.prevTranslate;
      if (movedBy < -50) this.next();
      else if (movedBy > 50) this.prev();
      else this.setPositionByIndex(true);
    }
  }

  // Inicializace všech sliderů
  document.querySelectorAll('.fpz-slider-container').forEach(container => new FpzSlider(container));

  // Globální šipky uvnitř containeru
  document.querySelectorAll('.fpz-slider-container').forEach(container => {
    const prevBtn = container.querySelector('.fpz-prev');
    const nextBtn = container.querySelector('.fpz-next');
    const slider = container.querySelector('.fpz-slider, .fpz-slider-1, .fpz-slider-2, .fpz-slider-3');

    if (slider && slider.fpzInstance) {
      if (prevBtn) prevBtn.addEventListener('click', () => slider.fpzInstance.prev());
      if (nextBtn) nextBtn.addEventListener('click', () => slider.fpzInstance.next());
    }
  });
});
</script>




