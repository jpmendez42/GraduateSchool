<style>
#lame-zero {
    color: #000;
    background-color: #eaeaea;
    margin: 0 auto;
    text-align: center;
    padding: 100px 20px 30px;
}
#lame-zero .titre--XL {
    font-size: 44px;
    font-family: 'SFR-Light', 'SFR-Thin', Arial;
    font-weight: normal;
    line-height: normal;
    margin: 0;
}
    #lame-un {
        background: url(//static.s-sfr.fr/media/espace-client-background-min-13070.png) no-repeat center center #eaeaea;
        height: 548px;
        color: #ffffff;
        margin-top: -100px;
    }
    
    #lame-un .appear,
    #lame-un .dnc {
        display: none;
    }
    
    #lame-un .miniBlocTop {
        display: inline-block;
        padding: 40px 45px;
    }
    
#lame-un .miniBlocBottom {
    background-color: #fff;
    box-shadow: 0 21px 12px rgba(0,0,0,0.07);
}
    
    #lame-un .miniBlocBottom--contain {
        position: absolute;
    }
    
    #lame-un .miniBlocBottom--contain-text {
        float: left;
        padding: 173px 20px 10px 40px;
    }
    
    #lame-un .texte--L {
        padding-bottom: 18px;
    }
    
    #lame-un .std {
        text-align: left;
    }
    
    #lame-un .plus {
        text-align: left;
        font-size: 30px;
        line-height: 34px;
        padding-bottom: 27px;
        width: 490px;
    }
    
    #lame-un .bouton--S {
        font-family: 'SFR-Bold', arial;
        font-size: 13px;
        padding: 3px 16px;
        height: 40px;
        line-height: 32px;
    }
    
    .blocTop .bouton--primaire {
        background: #67a305;
        border: 1px solid #67a305;
        color: #FFF;
        margin: 24px 382px 0;
    }
    
    #lame-un .bouton--primaire {
        background: #67a305;
        border: 1px solid #67a305;
        color: #FFF;
    }
    
    #lame-un .bouton--primaire:hover {
        background: #8bbd3a;
        border: 1px solid #8bbd3a;
        color: #FFF;
    }
    
    #lame-un .row {
        max-width: 987px;
        margin: 0 auto;
    }
    #lame-un .blocDroit {
        vertical-align: middle;
        display: inline-block;
        color: #000;
        float: none;
        margin-left: 67px;
    }
    
    #lame-un .blocGauche {
        width: 40%;
        float: none;
        display: inline-block;
        vertical-align: middle;
        background-color: #eaeaea;
    }
    
    @media (max-width:991px) {
        #lame-un {
            background: none;
            background-color: #eaeaea;
            height: auto;
        }
        
      #lame-zero {
            padding: 63px 20px 30px;
        }
        
        
        #lame-un .container {
            width: 100%;
            padding: 0;
        }
       #lame-un .row {
           padding: 0;
        }
        #lame-un .appear {
            display: block;
        }
        #lame-un .blocGauche {
            width: 100%;
            margin: 0 auto;
            text-align: center;
        }
        #lame-un .col-md-5 {
            padding: 0;
        }
        #lame-un .col-md-7 {
            padding: 0;
        }
        #lame-un .blocDroit {
            width: 100%;
            margin: 0 auto;
            text-align: right;
            margin-left: 0;
            height: auto;
            padding-bottom: 72px;
}
        #lame-un .miniBlocTop {
            display: inline-block;
            padding: 12px 45px 24px;
            text-align: center;
            width: 100%;
        }
        #lame-un .miniBlocBottom {
            background-color: #fff;
            width: 564px;
            margin: 0 auto;
        }
        #lame-un .plus {
            width: 70%;
        }
        #lame-un .imageSizer {
            max-width: 100%;
            width: 100%;
        }
    }
    
    @media (max-width: 600px) {
        #lame-un .miniBlocBottom {
            width: 433px;
        }
        .blocTop .bouton--primaire{
            margin: 24px 60px 0;
        }
        #lame-un > div > div > div.col-sm-12.col-md-5 > div > div > div{
            top: -32px;
            background-color: white;
        }
        #titreMiddle > div > div > div{
                margin-top: 141px;
        }
        #lame-un .plus {
        width: 99%;
        }
     
        #lame-un .dnc {
            display: block;
        }
        #lame-un .miniBlocTop {
            padding: 0 45px 24px;
        }
        #lame-zero .titre--XL {
        font-size: 38px;
    }
    }
    
    
    @media (max-width: 480px) {
        
        #lame-zero {padding: 34px 8px 30px;}
        #lame-zero .titre--XL {
            font-size: 33px;
        }
        
        #lame-un .miniBlocBottom {
            width: 340px;
        }
        
        #lame-un .miniBlocBottom--contain-text {
            float: left;
            padding: 24px 20px 10px 30px;
        }
        #lame-un .plus {
            width: 100%;
        }
    }
    
    @media (max-width: 340px) {
        #lame-un .miniBlocBottom {
            width: 100%;
        }
          #lame-un .dnc {
            display: none;
        }
        #lame-zero {
        padding: 34px 0 30px;
}
        #lame-un .pict {
            height: 259px;
        }
        #lame-zero .titre--XL {
        font-size: 28px;
}
    }
</style>
<section id="lame-zero">
    <div class="container">
        <div class="row">
            <div class="col-xs-12 center blocTop">
                <div>
                    <h1 class="titre titre--XL">Numericable & SFR ne&nbsp;font&nbsp;plus&nbsp;qu'un</h1></div>
                    <div class="texte texte--L">
