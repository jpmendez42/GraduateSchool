0/Pluie.svg.webp?itok=1UVTqpEo\"}},\"imageAlt\":\"\",\"copyright\":\"Sebastien Morales\"},{\"title\":\"Zeus\",\"desc\":null,\"details\":\"\u003cp\u003eC’est le dieu grec de la foudre.\u003c/p\u003e\",\"isRight\":false,\"transformed_fieldMedia\":{\"filemime\":\"image/svg+xml\",\"sources\":{\"original\":\"https://www.groupe-sncf.com/medias-publics/2025-10/Orage.svg?VersionId=GnOvHkpb2FW4nWGvu9MnCLocOgj56b3D\",\"crop_1_1\":\"https://proxy-prod1220-sncg.sncf-communication-prod.aws.vsct.fr/s3/files/styles/crop_1_1/public/2025-10/Orage.svg.webp?itok=Rv6sZ8dx\"}},\"imageAlt\":\"\",\"copyright\":\"Sebastien Morales\"},{\"title\":\"Jupiter\",\"desc\":null,\"details\":\"\u003cp\u003eC’est l’équivalent de Zeus chez les Romains.\u003c/p\u003e\",\"isRight\":false,\"transformed_fieldMedia\":{\"filemime\":\"image/svg+xml\",\"sources\":{\"original\":\"https://www.groupe-sncf.com/medias-publics/2025-09/parapluie.svg?VersionId=zJw0Vy5oMEbrqIkOwlDTyxu2Cj_UYL2g\",\"crop_1_1\":\"https://proxy-prod1220-sncg.sncf-communication-prod.aws.vsct.fr/s3/files/styles/crop_1_1/public/2025-09/parapluie.svg.webp?itok=bqQLWUz7\"}},\"imageAlt\":\"\",\"copyright\":\"Sebastien Morales\"}],\"theme\":\"parme\"}],[\"$\",\"$L1a\",\"Component-3eb1539e-435e-4f37-ba5b-f447ec41cd25\",{\"text\":\"\u003cp\u003eAvec 290 000 collaborateurs dont 73 000 hors de France, notre Groupe réalise un tiers de son activité à l'international. Elle s'articule autour de trois principaux marchés : la logistique de marchandises dans un réseau de 170 pays, le mass transit sur les 5 continents et le transport de voyageurs à grande vitesse.\u003c/p\u003e\"}],[\"$\",\"$L1b\",\"Component-b3dfad23-2d19-437f-bb5c-e4a73fdba752\",{\"title\":\"Un champion français de taille mondiale\",\"desc\":\"\u003cp\u003eAvec 290 000 collaborateurs dont 73 000 hors de France, notre Groupe réalise un tiers de son activité à l'international. Elle s'articule autour de trois principaux marchés : la logistique de marchandises dans un réseau de 170 pays, le m