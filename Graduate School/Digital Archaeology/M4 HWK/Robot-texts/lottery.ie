s_copyright__eLvzX">©2025 National Lottery</p></section></footer></div><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"cmsHost":"https://cdn1.lottery.ie","iwgs":[{"id":"1027","contentId":"diamond-flare","slug":"diamond-flare","image":"","title":"Diamond Flare","name":"DIAMONDFLARE","url":"/instant-win-games/diamond-flare","popular":false,"backgroundImage":"https://cdn1.lottery.ie/uploads/landscape_1x_7da31d5a79.png","foregroundImage":"https://cdn1.lottery.ie/uploads/logo_1x_4b0e270758.png","appGameRules":"To aid player comprehension, the “General Rules for Account Management and Interactive Instant Win Games” and the “Interactive Instant Win Game Specific Rules” for each individual game have been updated. Please click on the links below to access these rules. ","gameRulesUrl":"https://cdn1.lottery.ie/uploads/game_rules_for_diamond_flare_cf8007e22e.pdf","gameRulesTitle":"Download a copy of the National Lottery Diamond Flare rules (PDF)","backgroundImageSmall":"https://cdn1.lottery.ie/uploads/square_1x_ba0bbe4452.png","foregroundImageSmall":"https://cdn1.lottery.ie/uploads/logo_1x_4b0e270758.png","lobbyOrder":5,"topPrize":12000000,"cost":500,"topPrizeOdds":"1M","odds":3,"provider":"pbl","isOnSale":true,"isNew":true,"isOrientationLocked":false,"howToPlayText":"","howToPlayPreviews":[{"title":"Screen 1","description":"Cash prizes up to €120,000 to be won in an instant!","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Splash_01_5aa40f0376.jpg","caption":"","altText":""}},{"title":"Screen 2","description":"Taps each of the eight diamond symbols to reveal the Winning Numbers and each of the twenty-four euro symbols to reveal Your Numbers.","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Congratulations_Youve_Won_01_9626e6c595.jpg","caption":"","altText":""}},{"title":"Screen 3","description":"If a Winning Number matches any of Your Numbers, you win the prize amount shown below Your Number.","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Congratulations_Youve_Won_03_7793813385.jpg","caption":"","altText":""}},{"title":"Screen 4","description":"Within the Winning Numbers is a Diamond Number.","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Mega_Win_02_3b5bce717c.jpg","caption":"","altText":""}},{"title":"Screen 5","description":"If you match the Diamond Number with one of the Your Numbers, the prize amount shown will be doubled!","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Mega_Win_03_1406d0774e.jpg","caption":"","altText":""}},{"title":"Screen 6","description":"Reveal three flare symbols to enter the bonus game!","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Big_Win_03_010f9abc98.jpg","caption":"","altText":""}},{"title":"Screen 7","description":"In the Bonus Game, tap the Spin button to spin the wheel.","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Big_Win_05_08a9ca540c.jpg","caption":"","altText":""}},{"title":"Screen 8","description":"The wheel will then animate to display the Bonus Prize!","image":{"url":"https://cdn1.lottery.ie/uploads/AGLC_Diamond_Flare_Desktop_Big_Win_07_67f2f569f1.jpg","caption":"","altText":""}}],"winBeliefTitle":"","winBeliefText":""},{"id":"1006","contentId":"digital-mega-money-multiplier","slug":"digital-mega-money-multiplier","image":"","title":"Digital Mega Money Multiplier","name":"DIGITALMMM","url":"/instant-win-games/digital-mega-money-multiplier","popular":false,"backgroundImage":"https://cdn1.lottery.ie/uploads/landscape_1x_c6826f88f8.png","foregroundImage":"https://cdn1.lottery.ie/uploads/logo_1x_6aaa901bba.png","appGameRules":"To aid player comprehension, the “General Rules for Account Management and Interactive Instant Win Games” and the “Interactive Instant Win Game Specific Rules” for each individual game have been updated. Please click on the links below to access these rules. ","gameRulesUrl":"https://cdn1.lottery.ie/uploads/game_rules_for_digital_mega_money_multiplier_2024_71597b9075.pdf","gameRulesTitle":"Download a copy of the National Lottery Digital Mega Money Multiplier rules (PDF)","backgroundImageSmall":"https://cdn1.lottery.ie/uploads/square_1x_373772051a.png","foregroundImageSmall":"https://cdn1.lottery.ie/uploads/logo_1x_6aaa901bba.png","lobbyOrder":22,"topPrize":25000000,"cost":1000,"topPrizeOdds":"1M","odds":2.81,"provider":"pbl","isOnSale":true,"isNew":false,"isOrientationLocked":false,"howToPlayText":"","howToPlayPreviews":[{"title":"Step 1","description":"The digital version of the popular Scratch Card with instant prizes up to €250,000!","image":{"url":"https://cdn1.lottery.ie/uploads/dmegamscreen1_065eb79975.png","caption":"","altText":""}},{"title":"Step 2","description":"Tap the five Gold Coin icons to reveal five WINNING NUMBERS. Tap the twenty Wad of Cash icons to reveal twenty YOUR NUMBERS with a prize amount for each. The MULTIPLIER BONUS will automatically reveal once all five YOUR NUMBERS are revealed in a row.","image":{"url":"https://cdn1.lottery.ie/uploads/dmegamscreen2_26c33d7334.png","caption":"","altText":""}},{"title":"Step 3","description":"Once rows 1 to 4 have been revealed, a green button labelled ‘PLAY ROWS 5 AND 6’ will animate on screen. Tap this button to move to the second game panel, where the remaining two rows and a LUCKY SPOT will be presented.","image":{"url":"https://cdn1.lottery.ie/uploads/dmegamscreen3new_e7c3a2f8f6.png","caption":"","altText":""}},{"title":"Step 4","description":"Complete rows 5 and 6 as on the previous screen and tap the ‘LUCKY SPOT’ play icon to reveal a symbol and an associated prize amount.","image":{"url":"https://cdn1.lottery.ie/uploads/dmegamscreen4_4547062b49.png","caption":"","altText":""}},{"title":"Step 5","description":"If a ‘Star’ symbol is revealed under the ‘LUCKY SPOT’, you win the ‘PRIZE’ revealed.","image":{"url":"https://cdn1.lottery.ie/uploads/dmegamscreen5_bc2053a093.png","caption":"","altText":""}}],"winBeliefTitle":"","winBeliefText":""},{"id":"2001","contentId":"digital-champions","slug":"digital-champions","image":"","title":"Digital Champions","name":"plichampions2025","url":"/instant-win-games/digital-champions","popular":false,"backgroundImage":"https://cdn1.lottery.ie/uploads/Landscape_background_medium_04a22f2103.jpg","foregroundImage":"https://cdn1.lottery.ie/uploads/Logo_medium_e83657c585.png","appGameRules":"To aid player comprehension, the “General Rules for Account Management and Interactive Instant Win Games” and the “Interactive Instant Win Game Specific Rules” for each individual game have been updated. Please click on the links below to access these rules. ","gameRulesUrl":"https://cdn1.lottery.ie/uploads/game_rules_for_digital_champions_f7adf36da5.pdf","gameRulesTitle":"Download a copy of the National Lottery Digital Champions rules (PDF)","backgroundImageSmall":"https://cdn1.lottery.ie/uploads/Square_background_medium_a023bdfacb.jpg","foregroundImageSmall":"https://cdn1.lottery.ie/uploads/Logo_medium_e83657c585.png","lobbyOrder":1,"topPrize":3000000,"cost":300,"topPrizeOdds":"1M","odds":3.35,"provider":"itf","isOnSale":true,"isNew":true,"isOrientationLocked":false,"howToPlayText":"","howToPlayPreviews":[{"title":"Screen 1","description":"Digital Champions offers three games to play with instant cash prizes up to €30,000!","image":{"url":"https://cdn1.lottery.ie/uploads/champ_screen1_d584b58fae.jpg","caption":"","altText":""}},{"title":"Screen 2","description":"🥇 Game 1: Beat the Score\nScore higher than your opponent to win! If your score beats theirs, you win the prize shown.","image":{"url":"https://cdn1.lottery.ie/uploads/champ_screen2_ab6cb52a71.jpg","caption":"","altText":""}},{"title":"Screen 3","description":"🏆 Game 2: Tap the Cup\nTap each of the 8 cups to uncover hidden symbols. Winning symbols will be highlighted along with their prize amounts!","image":{"url":"https://cdn1.lottery.ie/uploads/champ_screen3_9244897e8e.jpg","caption":"","altText":""}},{"title":"Screen 4","description":"⚽ Game 3: Match 3\nTap all 8 balls to reveal prize amounts. Find 3 matching amounts to win that prize!","image":{"url":"https://cdn1.lottery.ie/uploads/champ_screen4_50174e540f.jpg","caption":"","altText":""}}],"winBeliefTitle":"","winBeliefText":""},{"id":"1018","contentId":"cash-bonanza","slug":"cash-bonanza","image":"","title":"Cash Bonanza","name":"CASHBONANZA","url":"/instant-win-games/cash-bonanza","popular":false,"backgroundImage":"https://cdn1.lottery.ie/uploads/landscape_1x_503eebd1ab.png","foregroundImage":"https://cdn1.lottery.ie/uploads/logo_1x_e6cbe7915c.png","appGameRules":"To aid player comprehension, the “General Rules for Account Management and Interactive Instant Win Games” and the “Interactive Instant Win Game Specific Rules” for each individual game have been updated. Please click on the links below to access these rules. ","gameRulesUrl":"https://cdn1.lottery.ie/uploads/game_rules_for_cash_bonanza_014721ae4e.pdf","gameRulesTitle":"Download a copy of the National Lottery Cash Bonanza rules (PDF)","backgroundImageSmall":"https://cdn1.lottery.ie/uploads/square_1x_52586a9fe4.png","foregroundImageSmall":"https://cdn1.lottery.ie/uploads/logo_1x_e6cbe7915c.png","lobbyOrder":10,"topPrize":10000000,"cost":500,"topPrizeOdds":"2M","odds":2.7,"provider":"pbl","isOnSale":true,"isNew":false,"isOrientationLocked":false,"howToPlayText":"","howToPlayPreviews":[{"title":"Screen 1","description":"Introducing Cash Bonanza! Play 3 exciting games plus a bonus round for a shot at cash prizes up to €100,000!","image":{"url":"https://cdn1.lottery.ie/uploads/Screen1_74fd6d3b21.png","caption":"","altText":""}},{"title":"Screen 2","description":"PICK YOUR NUMBERS: At the start of play, choose five from six question mark symbols to reveal YOUR NUMBERS.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen2_e0d477de82.png","caption":"","altText":""}},{"title":"Screen 3","description":"Game 1: there are fifteen coin symbols, each with an associated prize, to tap and reveal.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen3_4c4d86c350.png","caption":"","altText":""}},{"title":"Screen 4","description":"Game 1: Match any of ‘YOUR NUMBERS’ to any of the revealed numbers to win the Prize amount associated with that number.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen4_a4b10c3fbe.png","caption":"","altText":""}},{"title":"Screen 5","description":"Game 2: there are six columns, each with two cash symbols and an associated prize to tap and reveal.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen7_896cd338be.png","caption":"","altText":""}},{"title":"Screen 6","description":"Game 2: If the two revealed numbers in a column match with any of ‘YOUR NUMBERS’, you win the associated prize for that panel.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen8_6ce66ae609.png","caption":"","altText":""}},{"title":"Screen 7","description":"Game 3: there are four rows, each with three money bag symbols and an associated prize to click and reveal.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen5_4263faf8e7.png","caption":"","altText":""}},{"title":"Screen 8","description":"Game 3: If all three of the revealed numbers in a row match with ‘YOUR NUMBERS’, you win the associated prize amount for that row.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen6_e4beb20d8a.png","caption":"","altText":""}},{"title":"Screen 9","description":"Bonus Game! Pick one of the three safe symbols to reveal a bonus ‘YOUR NUMBER’. The revealed number will be added to ‘YOUR NUMBERS’.","image":{"url":"https://cdn1.lottery.ie/uploads/Screen9_b55247a0e5.png","caption":"","altText":""}},{"title":"Screen 10","description":"Bonus Game: The game then automatically goes through each of the game screens checking for any numbers in each game that match with the bonus number added to ‘YOUR NUMBERS’.","image":{"url":"https://cdn1.lottery.ie/u