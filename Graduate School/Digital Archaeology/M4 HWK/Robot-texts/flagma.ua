<style>
	.bl1 {
		font-size: 32px;
		color: #000;
		margin: 220px 0 50px;
	}
	.bl2 {
		font-size: 16px;
		line-height: 1.4em;
		color: #5a5a5a;
		margin: 0 0 35px;
	}
	.g-recaptcha {display: inline-block;}
	@media screen and (max-width: 650px) {
		.bl1 {
