lass="n2-ss-layers-container n2-ss-slide-limiter n2-ow"><div class="n2-ss-layer n2-ow n-uc-aV7J0IT6K3rs" data-sstype="slide" data-pm="default"><div class="n2-ss-layer n2-ow n-uc-Iz6aQsBrgqW6" data-pm="default" data-sstype="content" data-hasbackground="0"><div class="n2-ss-section-main-content n2-ss-layer-with-background n2-ss-layer-content n2-ow n-uc-Iz6aQsBrgqW6-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n2-ss-stretch-layer n-uc-yG5nufprbsnc" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-yG5nufprbsnc-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-NHxBavpwJPbP" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-NHxBavpwJPbP-inner"><div class="n2-ss-layer n2-ow n-uc-R5UbJOmcdpga n2-ss-layer--auto" data-pm="normal" data-sstype="layer"><div id="n2-ss-851item91" class="n2-font-688ca467402603d00e77490478ffafed-hover n2-style-1df4a3fd7ae6358be27561c5452e93c6-heading   n2-ss-item-content n2-ss-text n2-ow" style="display:inline-block;">FORMATION</div></div><div class="n2-ss-layer n2-ow n-uc-RCktDDGaeeHq" data-pm="normal" data-sstype="layer"><div id="n2-ss-851item92" class="n2-font-cd8573d8a507c95a4dc96d2cf74b8d59-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Une nouvelle filière en génie des procédés</div></div><div class="n2-ss-layer n2-ow n-uc-iNWKs2gw2GOl" data-pm="normal" data-hidemobileportrait="1" data-sstype="layer"><div class="n2-ss-item-content n2-ss-text n2-ow-all"><div class=""><p class="n2-font-d59dca73119e9ed568f3684d94eea568-paragraph   ">« Procédés Pharmaceutiques et Cosmétiques » (PPC), tel est le nom de la nouvelle filière proposée en génie des procédés. Les premiers étudiants ont intégré la filière PPC au semestre de printemps 2024 et ont commencé leur année en apprentissage en septembre dernier. L’objectif serait d’avoir des promotions de 16 à 20 étudiants.</p>
</div></div></div><div class="n2-ss-layer n2-ow n-uc-H2V4eW07RCr6 n2-ss-layer--auto" data-pm="normal" data-click="n2ss.trigger(e.currentTarget, 'details');" data-sstype="layer"><div class="n2-ss-button-container n2-ss-item-content n2-ow n2-font-b6843e460493f4d2e4f47b6d9745514d-link  n2-ss-nowrap n2-ss-button-container--non-full-width"><a class="n2-style-c6c5507bd4502a08633174b84f534e5b-heading  n2-ow " target="_blank" href="https://interactions.utc.fr/thematiques/genie-des-procedes-chimie-developpement-durable-agroressources/une-nouvelle-filiere-en-genie-des-procedes/"><div><div>En savoir plus</div></div></a></div></div></div></div></div></div></div><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-FwRuaMA8rjJT" data-pm="normal" data-hidedesktopportrait="1" data-hidetabletportrait="1" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-FwRuaMA8rjJT-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-YuPJdvVmUwaZ" data-pm="default" data-hidemobileportrait="1" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-YuPJdvVmUwaZ-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-ogG9WdGlv4At" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-ogG9WdGlv4At-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-QgJ00yxv7QRY" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-QgJ00yxv7QRY-inner"><div class="n2-ss-layer n2-ow n-uc-6Hy1H39yDQJ2 n2-ss-layer--auto" data-pm="normal" data-sstype="layer"><div id="n2-ss-851item95" class="n2-font-321dc5071321283da51868cafdcfd437-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:inline-block;">Signature d’un accord de double diplôme avec l’Université Française d’Egypte (UFE)</div></div></div></div></div></div></div></div></div><div class="n2