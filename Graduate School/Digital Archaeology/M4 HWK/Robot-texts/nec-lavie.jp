         <li class="splide__slide"> 
          <div> 
           <img src="//p2-nec.static.pub/resource/NEC_Public_Resource/common/images/img_step_06.webp" alt="魅力6 国内保守サービス拠点による最短１日のスピード修理"> 
          </div> </li> 
        </ul> 
       </div> 
