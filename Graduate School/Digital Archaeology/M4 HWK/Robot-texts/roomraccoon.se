<!-- New Pricing Page - Built In BeBuilder Start with unique class-->
<script type="rocketlazyloadscript">
    jQuery(document).ready(function($) {
        var allowedDomain = "wordpress-932407-5083860.cloudwaysapps.com";

        var currentDomain = window.location.hostname;

       if (currentDomain === allowedDomain) {
        $.getJSON('https://get.geojs.io/v1/ip/geo.json', function(data) {
            var countryCode = data.country_code;

            if (countryCode === 'CA') {
                $('.bb-price-table__currency').text('CA$');
            } else {
                $('.bb-price-table__currency').text('$');
            }
        });
        }else {
            console.log("This script is not running on the allowed domain.");
        }
    });
</script>
