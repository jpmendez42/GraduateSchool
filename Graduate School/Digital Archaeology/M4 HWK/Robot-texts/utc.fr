-slide-limiter n2-ow"><div class="n2-ss-layer n2-ow n-uc-kELNChlyhMMc" data-sstype="slide" data-pm="default"><div class="n2-ss-layer n2-ow n-uc-oaBldC9iqfjZ" data-pm="default" data-sstype="content" data-hasbackground="0"><div class="n2-ss-section-main-content n2-ss-layer-with-background n2-ss-layer-content n2-ow n-uc-oaBldC9iqfjZ-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-N1bT8HoZQWUe" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-N1bT8HoZQWUe-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-pyZs2B52nM9D" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-pyZs2B52nM9D-inner"><div class="n2-ss-layer n2-ow n-uc-l3AA1m3j7Kcq" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item225" class="n2-font-bb8a8ebbef82965b045c7cc66415e973-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Antoine Macret</div></div><div class="n2-ss-layer n2-ow n-uc-ASYMsj9pxwXw" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.05,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item226" class="n2-font-53800138ef911fbb422d999cedf39f67-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Regard sur l’Innovation et le développement en temps de crise<br></div></div><div class="n2-ss-layer n2-ow n-uc-HBxPwYLxM5X2" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-hidemobileportrait="1" data-sstype="layer"><div class="n2-ss-item-content n2-ss-text n2-ow-all"><div class=""><p class="n2-font-d90a9b84626b12a176d70e24355b0ebb-paragraph   ">Antoine Macret est le directeur de Hauts-de-France Innovation Développement depuis mars 2019. Cet UTCéen pose son regard mais surtout son action sur la gestion d’une crise économique sans précédent. Quel rôle l’agence régionale de développement et d’innovation Hauts-de-France joue-t-elle dans l’accompagnement des entreprises et la stratégie régionale d’innovation ?</p>
</div></div></div><div class="n2-ss-layer n2-ow n-uc-1aecd08576a87 n2-ss-layer--auto" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bas&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div class="n2-ss-button-container n2-ss-item-content n2-ow n2-font-beb2df7d76a016c9d6eab777c4c577a1-link  n2-ss-nowrap n2-ss-button-container--non-full-width"><a class="n2-style-cdb60a339019064a62b500c95f67f4e3-heading  n2-ow " target="_blank" href="https://interactions.utc.fr/thematiques/regards-sur-le-monde/regard-sur-linnovation-et-le-developpement-en-temps-de-crise/"><div><div>Lire</div></div></a></div></div><div class="n2-ss-layer n2-ow n2-ss-layer--auto n2-ss-has-self-align n-uc-RTgZeV5GkccE" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.25,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-RTgZeV5GkccE-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-KRf8aOrPP7Dq" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'previous');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-KRf8aOrPP7Dq-inner"><div class="n2-ss-layer n2-ow n-uc-v2qtJdRt8l6V n2-ss-layer--auto" data-pm="normal" data-sstype="layer"><span class="n2i  n2-ss-859item229 nicomoon nicomoon-arrow-left2 n2-ss-item-content" style="font-size:125%;"></span></div></div></div><div class="n2-ss-layer n2-ow n-uc-howdKSmRnXJI" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'next');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-c