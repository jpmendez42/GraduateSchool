UTmVoYA7BK" data-sstype="slide" data-pm="default"><div class="n2-ss-layer n2-ow n-uc-3tZCaQ900L81" data-pm="default" data-sstype="content" data-hasbackground="0"><div class="n2-ss-section-main-content n2-ss-layer-with-background n2-ss-layer-content n2-ow n-uc-3tZCaQ900L81-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-fwhjKFDaQmR8" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-fwhjKFDaQmR8-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-tgHa7ZpGRmvu" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-tgHa7ZpGRmvu-inner"><div class="n2-ss-layer n2-ow n-uc-R0383iy2kRBo" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item78" class="n2-font-bb8a8ebbef82965b045c7cc66415e973-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Michael Pitiot</div></div><div class="n2-ss-layer n2-ow n-uc-nLTZsZlainbS" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.05,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item79" class="n2-font-53800138ef911fbb422d999cedf39f67-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Vivre mille vies en une</div></div><div class="n2-ss-layer n2-ow n-uc-IY9mLSlOjRyz" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-hidemobileportrait="1" data-sstype="layer"><div class="n2-ss-item-content n2-ss-text n2-ow-all"><div class=""><p class="n2-font-d90a9b84626b12a176d70e24355b0ebb-paragraph   ">Michael Pitiot n’a jamais été ingénieur. Pourtant, ce diplômé en génie informatique, devenu réalisateur de films documentaires, n’a jamais oublié les leçons apprises à l’UTC. Le 27 aout dernier, il est venu a l’UTC pour donner une leçon inaugurale aux étudiantes et étudiants. Son mot d’ordre pour cette future génération d’ingénieurs ? « Rêvez ! » </p>
</div></div></div><div class="n2-ss-layer n2-ow n-uc-5cd3ebd8EO58 n2-ss-layer--auto" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bas&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div class="n2-ss-button-container n2-ss-item-content n2-ow n2-font-beb2df7d76a016c9d6eab777c4c577a1-link  n2-ss-nowrap n2-ss-button-container--non-full-width"><a class="n2-style-cdb60a339019064a62b500c95f67f4e3-heading  n2-ow " target="_blank" href="https://interactions.utc.fr/thematiques/regards-sur-le-monde/vivre-mille-vies-en-une/"><div><div>Lire</div></div></a></div></div><div class="n2-ss-layer n2-ow n2-ss-layer--auto n2-ss-has-self-align n-uc-VrSaXQwI0U5Z" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.25,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-VrSaXQwI0U5Z-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-Q8LuA6JWMwGq" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'previous');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-Q8LuA6JWMwGq-inner"><div class="n2-ss-layer n2-ow n-uc-OnKu74C5I7S7 n2-ss-layer--auto" data-pm="normal" data-sstype="layer"><span class="n2i  n2-ss-859item82 nicomoon nicomoon-arrow-left2 n2-ss-item-content" style="font-size:125%;"></span></div></div></div><div class="n2-ss-layer n2-ow n-uc-9ULn3qYG17YO" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'next');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-la