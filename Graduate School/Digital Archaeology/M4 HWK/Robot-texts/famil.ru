LIOPE-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:42:17.989Z\",\"updatedAt\":\"2025-08-29T10:51:16.419Z\",\"url\":\"/cms/media/CALLIOPE.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d6e87929e66c401c74fd\",\"name\":\"DEFACTO\",\"description\":\"DeFacto турецкий бренд мужской и женской одежда, обуви, аксессуаров и украшений. Амбициозный турецкий бренд совершил взлет буквально за 15 лет работы. Дизайнерское бюро находится в Барселоне, модельеры которого сделали ставку на изделия повседневной одежды по доступным ценам.\",\"category\":[\"men\",\"women\",\"accessories\",\"children\",\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:55:52.964Z\",\"updatedAt\":\"2025-03-04T03:11:44.144Z\",\"logo\":{\"id\":\"65802fd7e2f304ddab7c29a8\",\"alt\":\"logo\",\"filename\":\"DEFACTO.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":10659,\"width\":450,\"height\":135,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/jpeg\",\"filesize\":424,\"filename\":\"DEFACTO-32x9.jpg\",\"url\":\"/cms/media/DEFACTO-32x9.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":742,\"filename\":\"DEFACTO-64x19.jpg\",\"url\":\"/cms/media/DEFACTO-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":38,\"mimeType\":\"image/jpeg\",\"filesize\":1606,\"filename\":\"DEFACTO-128x38.jpg\",\"url\":\"/cms/media/DEFACTO-128x38.jpg\"},\"w384\":{\"width\":384,\"height\":115,\"mimeType\":\"image/jpeg\",\"filesize\":5928,\"filename\":\"DEFACTO-384x115.jpg\",\"url\":\"/cms/media/DEFACTO-384x115.jpg\"},\"w640\":{\"width\":640,\"height\":192,\"mimeType\":\"image/jpeg\",\"filesize\":10629,\"filename\":\"DEFACTO-640x192.jpg\",\"url\":\"/cms/media/DEFACTO-640x192.jpg\"},\"w1080\":{\"width\":1080,\"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":20399,\"filename\":\"DEFACTO-1080x324.jpg\",\"url\":\"/cms/media/DEFACTO-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":43947,\"filename\":\"DEFACTO-1920x576.jpg\",\"url\":\"/cms/media/DEFACTO-1920x576.jpg\"},\"w3840\":{\"width\":3840,\"height\":1152,\"mimeType\":\"image/jpeg\",\"filesize\":117857,\"filename\":\"DEFACTO-3840x1152.jpg\",\"url\":\"/cms/media/DEFACTO-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:41:11.598Z\",\"updatedAt\":\"2025-08-29T10:51:20.165Z\",\"url\":\"/cms/media/DEFACTO.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d6d87929e66c401c74a9\",\"name\":\"FACKELMANN\",\"description\":\"Fackelman – компания, выпускающая продукцию для выпечки и приготовления пищи, которая соответствует международным экологическим стандартам качества. Инженеры бренда уделяют большое внимание соответствию выпускаемых товаров определенным характеристикам.\",\"category\":[\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:55:36.252Z\",\"updatedAt\":\"2025-03-04T03:11:41.338Z\",\"logo\":{\"id\":\"65803038e2f304ddab7c2a23\",\"alt\":\"logo\",\"filename\":\"FACKELMANN.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":11027,\"width\":450,\"height\":135,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/jpeg\",\"filesize\":427,\"filename\":\"FACKELMANN-32x9.jpg\",\"url\":\"/cms/media/FACKELMANN-32x9.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":884,\"filename\":\"FACKELMANN-64x19.jpg\",\"url\":\"/cms/media/FACKELMANN-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":38,\"mimeType\":\"image/jpeg\",\"filesize\":1669,\"filename\":\"FACKELMANN-128x38.jpg\",\"url\":\"/cms/media/FACKELMANN-128x38.jpg\"},\"w384\":{\"width\":384,\"height\":115,\"mimeType\":\"image/jpeg\",\"filesize\":7068,\"filename\":\"FACKELMANN-384x115.jpg\",\"url\":\"/cms/media/FACKELMANN-384x115.jpg\"},\"w640\":{\"width\":640,\"height\":192,\"mimeType\":\"image/jpeg\",\"filesize\":11395,\"filename\":\"FACKELMANN-640x192.jpg\",\"url\":\"/cms/media/FACKELMANN-640x192.jpg\"},\"w1080\":{\"width\":1080,\"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":20719,\"filename\":\"FACKELMANN-1080x324.jpg\",\"url\":\"/cms/media/FACKELMANN-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":45918,\"filename\":\"FACKELMANN-1920x576.jpg\",\"url\":\"/cms/media/FACKELMANN-1920x576.jpg\"},\"w3840\":{\"width\":3840,\"height\":1152,\"mimeType\":\"image/jpeg\",\"filesize\":125219,\"filename\":\"FACKELMANN-3840x1152.jpg\",\"url\":\"/cms/media/FACKELMANN-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:42:48.442Z\",\"updatedAt\":\"2025-08-29T10:51:16.276Z\",\"url\":\"/cms/media/FACKELMANN.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d6d17929e66c401c7485\",\"name\":\"FRENCH CONNECTION\",\"description\":\"Бренд French Connection создан в 1972 году. Это производитель модной одежды от дизайнера Стивена Маркса. Фирма Маркса стала одной из самых первых в Великобритании, предлагающей модную, качественную и в то же время доступную мужскую, женскую и детскую одежду в стиле casual. Одежда рассчитана на потребительскую аудиторию от 18 до 35 лет. French Connection предлагает коллекцию женской одежды, которая сочетает в себе дерзкую сексуальность и юношескую невинность. Также компания выпускает мужскую и детскую одежду. Современный бренд выпускает все, что необходимо для создания завершенного женского образа. Платья, юбки, брюки, кардиганы, блузы и рубашки, топы и майки, сумки, а также различные аксессуары. Сформируйте свой собственный стиль, сделайте акцент на своей смелости, молодости и красоте. Сочетание наивности и дерзости, приверженности к традициям и новаторства выделяет марку French Connection среди других и делает ее стиль желанным и востребованным.\",\"category\":[\"men\",\"women\",\"accessories\",\"children\",\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":true,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:55:29.083Z\",\"updatedAt\":\"2025-03-04T03:11:40.141Z\",\"logo\":{\"id\":\"6581ee551766398cf584e65f\",\"alt\":\"logo\",\"filename\":\"French-Connection-logo-1.png\",\"mimeType\":\"image/png\",\"filesize\":6996,\"width\":615,\"height\":132,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/French-Connection-logo-1-480x320.png\",\"width\":480,\"height\":320,\"mimeType\":\"image/png\",\"filesize\":12719,\"filename\":\"French-Connection-logo-1-480x320.png\"},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":7,\"mimeType\":\"image/png\",\"filesize\":343,\"filename\":\"French-Connection-logo-1-32x7.png\",\"url\":\"/cms/media/French-Connection-logo-1-32x7.png\"},\"w64\":{\"width\":64,\"height\":14,\"mimeType\":\"image/png\",\"filesize\":802,\"filename\":\"French-Connection-logo-1-64x14.png\",\"url\":\