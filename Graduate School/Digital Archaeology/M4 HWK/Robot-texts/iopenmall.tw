<script>
$(function(){
    $("ul.footer_menutext_mob").hide();
    $(".footer_menutitle_mob").click(function(){
        $(this).children('span').toggleClass("inner_arrow-up");
        $("ul.footer_menutext_mob").slideUp();
        $(".footer_menutitle_mob").removeClass("open");
        if($("+ul",this).css("display")=="none"){
            $("+ul",this).slideDown();
            $(this).parents('li').siblings().find('span').removeClass("inner_arrow-up").addClass("inner_arrow-down");
        }
    });
});
</script>

