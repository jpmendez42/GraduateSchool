value="296" data-field-left-res-640-value="60" data-field-width-res-640-value="150" data-field-left-res-960-value="64"> <div class='tn-atom'field='tn_text_1716561696647'>Запустила работу системы SQNS в&nbsp; 115 медицинских центрах. Ответит на все ваши вопросы.</div> </div> <div class='t396__elem tn-elem tn-elem__10519013611716998220075' data-elem-id='1716998220075' data-elem-type='text' data-field-top-value="140" data-field-left-value="72" data-field-height-value="42" data-field-width-value="459" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-top-res-320-value="119" data-field-left-res-320-value="20" data-field-height-res-320-value="48" data-field-width-res-320-value="226" data-field-container-res-320-value="grid" data-field-heightunits-res-320-value="px" data-field-textfit-res-320-value="autoheight" data-field-left-res-480-value="40" data-field-top-res-640-value="106" data-field-left-res-640-value="40" data-field-top-res-960-value="149" data-field-left-res-960-value="30" data-field-width-res-960-value="380"> <div class='tn-atom'field='tn_text_1716998220075'>Заполните форму и получите бесплатный демо-доступ прямо сейчас.</div> </div> <div class='t396__elem tn-elem tn-elem__10519013611716561607667' data-elem-id='1716561607667' data-elem-type='text' data-field-top-value="247" data-field-left-value="191" data-field-height-value="21" data-field-width-value="62" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-top-res-320-value="595" data-field-left-res-320-value="110" data-field-top-res-480-value="562" data-field-left-res-480-value="130" data-field-top-res-640-value="208" data-field-left-res-640-value="123" data-field-top-res-960-value="244" data-field-left-res-960-value="150"> <div class='tn-atom'field='tn_text_1716561607667'>Полина</div> </div> <div class='t396__elem tn-elem tn-elem__10519013611716561645012' data-elem-id='1716561645012' data-elem-type='text' data-field-top-value="268" data-field-left-value="191" data-field-height-value="19" data-field-width-value="192" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight" data-field-top-res-320-value="616" data-field-left-res-320-value="110" data-field-top-res-480-value="583" data-field-left-res-480-value="130" data-field-top-res-640-value="229" data-field-left-res-640-value="123" data-field-width-res-640-value="121" data-field-top-res-960-value="265" data-field-left-res-960-value="150"> <div class='tn-atom'field='tn_text_1716561645012'>Эксперт отдела внедрения </div> </div> </div> </div> <script>t_onFuncLoad('t396_initialScale',function() {t396_initialScale('1051901361');});t_onReady(function() {t_onFuncLoad('t396_init',function() {t396_init('1051901361');});});</script> <!-- /T396 --> </div> <div id="rec915193231" class="r t-rec t-rec_pt_90 t-rec_pb_90" style="padding-top:90px;padding-bottom:90px;background-color:#f5f5f5; " data-record-type="668" data-bg-color="#f5f5f5"> <!-- T668 --> <div class="t668"> <div class="t-section__container t-container t-container_flex"> <div class="t-col t-col_12 "> <div
class="t-section__title t-title t-title_xs t-align_center t-margin_auto"
field="btitle">
Подробнее о системах SQNS — CRM для медицинских учреждений
</div> </div> </div> <style>.t-section__descr {max-width:560px;}#rec915193231 .t-section__title {margin-bottom:80px;}#rec915193231 .t-section__descr {}@media screen and (max-width:960px) {#rec915193231 .t-section__title {margin-bottom:45px;}}</style> <div class="t-container"> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
aria-controls="accordion1_915193231"
aria-expanded="false"> <span class="t668__title t-name t-name_xl" field="li_title__8478223929570" style="">Как управлять клиникой эффективнее: CRM системы управления деятельностью медицинских организаций </span> <span class="t668__icon"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: transparent;"></span> </span> <span class="t668__icon t668__icon-hover"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: #eee;"></span> </span> </button> </div> <div class="t668__content"
id="accordion1_915193231"
hidden > <div class="t668__textwrapper"> <div class="t668__text t-descr t-descr_xs" field="li_descr__8478223929570" style="">В здравоохранении важно не только качество лечения, но и удобство для пациентов. Чтобы контролировать работу врачей, управлять потоком пациентов и следить за бухгалтерией, клинике нужна надежная CRM-система. Она помогает вести электронные медицинские карты, организовывать онлайн-запись, координировать работу врачей и лабораторий, а также автоматизировать все бизнес процессы.<br />CRM выстраивает четкую и удобную работу медицинского учреждения. Она снижает нагрузку на администраторов, сводит к минимуму ошибки в расписании, а также улучшает уровень обслуживания. Современная медицина – это не только технологии в лечении, но и эффективный менеджмент.</div> </div> </div> </div> </div> </div> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
aria-controls="accordion2_915193231"
aria-expanded="false"> <span class="t668__title t-name t-name_xl" field="li_title__4718223929571" style="">Управляйте мед центром или клиникой онлайн с помощью СРМ программы</span> <span class="t668__icon"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: transparent;"></span> </span> <span class="t668__icon t668__icon-hover"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: #eee;"></span> </span> </button> </div> <div class="t668__content"
id="accordion2_915193231"
hidden > <div class="t668__textwrapper"> <div class="t668__text t-descr t-descr_xs" field="li_descr__4718223929571" style="">Управление медицинским центром, клиникой или стоматологией требует четкой организации процессов. Но внедрение чего-то нового часто связано с длительным обучением, сложными настройками и дополнительными расходами. С нашим сервисом вы сможете начать работать с программой уже на следующий день.<br />В частной клинике каждый процесс важен: от записи пациента до оформления лечения. Если данные разрознены, а расписание ведется вручную, растет нагрузка на персонал, увеличивается риск ошибок, пациенты дольше ждут приема. CRM-сервис решает эти проблемы, объединяя работу врачей, администраторов и бухгалтерии в одном сервисе.</div> </div> </div> </div> </div> </div> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
aria-controls="accordion3_915193231"
aria-expanded="false"> <span class="t668__title t-name t-name_xl" field="li_title__4718223929572" style="">Автоматизированные CRM программы управления в медицинской организации</span> <span class="t668__icon"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: transparent;"></span> </span> <span class="t668__icon t668__icon-hover"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: #eee;"></span> </span> </button> </div> <div class="t668__content"
id="accordion3_915193231"
hidden > <div class="t668__textwrapper"> <div class="t668__text t-descr t-descr_xs" field="li_descr__4718223929572" style="">Без CRM администраторы вручную сверяют записи, ищут карты пациентов, напоминают о визитах. Это отнимает время или приводит к ошибкам. CRM упрощает эти задачи.</div> </div> </div> </div> </div> </div> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
aria-controls="accordion4_915193231"
aria-expanded="false"> <span class="t668__title t-name t-name_xl" field="li_title__1743065436611" style="">Интеграция с медицинскими сервисами и системами</span> <span class="t668__icon"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: transparent;"></span> </span> <span class="t668__icon t668__icon-hover"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: #eee;"></span> </span> </button> </div> <div class="t668__content"
id="accordion4_915193231"
hidden > <div class="t668__textwrapper"> <div class="t668__text t-descr t-descr_xs" field="li_descr__1743065436611" style="">Наша CRM совместима с популярными медицинскими системами (МИС) и единой государственной информационной системой в сфере здравоохранения (ЕГИСЗ) сервисами здравоохранения. Возможности интеграции:<br /><ul><li data-list="bullet">Обмен данными с лабораториями или диагностическими центрами.</li><li data-list="bullet">Подключение к медицинским справочникам.</li><li data-list="bullet">Интеграция с программами электронного документооборота.</li><li data-list="bullet">Связь с медицинскими онлайн-сервисами для удобства пациентов.</li></ul></div> </div> </div> </div> </div> </div> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
aria-controls="accordion5_915193231"
aria-expanded="false"> <span class="t668__title t-name t-name_xl" field="li_title__1743065464576" style="">Сколько стоит CRM для медицинского бизнеса</span> <span class="t668__icon"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: transparent;"></span> </span> <span class="t668__icon t668__icon-hover"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: #eee;"></span> </span> </button> </div> <div class="t668__content"
id="accordion5_915193231"
hidden > <div class="t668__textwrapper"> <div class="t668__text t-descr t-descr_xs" field="li_descr__1743065464576" style="">Стоимость CRM зависит от масштаба клиники, количества пользователей, а также функций. Мы предлагаем гибкие тарифы, которые подходят как для небольшого частного центра, так и для сети клиник. Узнать цену и выбрать нужный вариант вы можете оставив заявку на сайте или позвонив нам по телефону 8 (800) 777 65 87</div> </div> </div> </div> </div> </div> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
aria-controls="accordion6_915193231"
aria-expanded="false"> <span class="t668__title t-name t-name_xl" field="li_title__1743065485918" style="">Почему выбирают SQNS?</span> <span class="t668__icon"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: transparent;"></span> </span> <span class="t668__icon t668__icon-hover"> <span class="t668__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#222222"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t668__circle" style="background-color: #eee;"></span> </span> </button> </div> <div class="t668__content"
id="accordion6_915193231"
hidden > <div class="t668__textwrapper"> <div class="t668__text t-descr t-descr_xs" field="li_descr__1743065485918" style="">Мы — российский разработчик SaaS - решений для сферы услуг: медицинские учреждения, стоматологии, косметологии, офтальмологии, детские, а также многопрофильные клиники. Уже 13 лет мы помогаем бизнесу автоматизировать процессы, находить новые точки роста, а также освобождать сотрудников от рутины. Наши решения созданы для того, чтобы сделать вашу работу проще, а бизнес — эффективнее. В результате нашей совместной работы пациенты получают качественный сервис, а руководство видит реальную картину бизнеса.<br /><strong><u>Что мы предлагаем:</u></strong><br /><ol><li data-list="ordered"><strong>Персональные доработки.</strong> Мы адаптируем программу управление клиникой под ваши цели: внедряем документы вашей компании, отчеты, схемы расчета зарплаты, KPI и другие требования.</li><li data-list="ordered"><strong>Гибкую система оплаты. </strong>Вы платите только за те функции, которыми пользуетесь. Никаких скрытых платежей или навязанных услуг.</li><li data-list="ordered"><strong>Опыт с 2012 года. </strong>Более 3800 медицинских организаций уже используют наши решения. Мы знаем, как помочь вашему бизнесу расти.</li><li data-list="ordered"><strong>Адаптированный подход. </strong>Уникальная система внедрения вместе с обучением. Мы учитываем особенности вашего бизнеса, помогаем вашим сотрудникам быстро освоить программу.</li><li data-list="ordered"><strong>Реализация любых пожеланий. </strong>Нужен особый отчет, функция, сервис или интеграция? Мы готовы воплотить ваши идеи в жизнь.</li><li data-list="ordered"><strong>Работа нескольких филиалов в одной системе. </strong>Управляйте несколькими филиалами или организациями в единой базе данных. Это удобно и экономит время.</li><li data-list="ordered"><strong>Без ограничений по пользователям. </strong>В нашей системе нет лимитов на количество сотрудников или пользователей. Наша платформа позволяет масштабировать ваш бизнес без ограничений, обеспечивая гибкость и адаптацию под любые объемы или задачи.</li><li data-list="ordered"><strong>Прозрачная система оплаты. </strong>Мы не повышаем цены после подключения. Все условия сотрудничества четко прописаны в договоре.</li><li data-list="ordered"><strong>Доступ из любой точки мира. </strong>Облачные решения для доступа из любой точки мира.</li><li data-list="ordered"><strong>Простой и понятный интерфейс. </strong>Наш сервис для клиник сделан для врачей и администраторов. При разработке мы учитывали их повседневные задачи, реальные рабочие ситуации и особенности медицинской практики. Интуитивно понятный интерфейс позволяет начать работу сразу, без долгого обучения, это позволяет быстро освоить программу без долгого обучения.</li><li data-list="ordered"><strong>Создана для врачей. </strong>Мы разрабатываем решения вместе с практикующими врачами. Это значит, что система учитывает реальные задачи мед. центров: от записи пациентов до ведения электронных карт или управления расписанием. Все функции направлены на то, чтобы облегчить работу врачей и улучшить качество обслуживания пациентов.</li><li data-list="ordered"><strong>Быстрый запуск:</strong> Система готова к работе уже через 1 день.</li><li data-list="ordered"><strong>Поддержка 24/7:</strong> Мы всегда на связи по телефону, email или в мессенджерах.</li><li data-list="ordered"><strong>Обучение сотрудников:</strong> Проводим обучение и предоставляем инструкции для комфортной работы.</li></ol></div> </div> </div> </div> </div> </div> <div class="t668__col t-col t-col_12 " style="margin-bottom:2px;"> <div class="t668__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t668__wrapper" style="background-color: #f5f5f5;"> <div class="t668__header "> <button type="button"
class="t668__trigger-button"
