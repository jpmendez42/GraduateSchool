  list-style: square;
  margin-top: 4px;
}

.numberList {
  padding-left: 15px;
}

.numberList > li {
  list-style: decimal;
  margin-top: 10px;
}

.subList_item {
  margin-left: 1.5em;
  margin-top: .5em;
  counter-increment: cnt;
}

.subList_item::before {
  margin-left: -1.5em;
  content: "(" counter(cnt) ") ";
}

