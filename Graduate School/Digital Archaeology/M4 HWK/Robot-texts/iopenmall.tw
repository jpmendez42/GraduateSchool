<script src="/website/javascripts/socket.io.min.js"></script>
<script src="/website/javascripts/imkit-ws-sdk-v2.js"></script>
<script>
$(document).ready(function() {
    
    // 設置未讀消息變化監聽器
    IMKitWsSDKV2.on(IMKitWsSDKV2.EventNames.UNREAD_CHANGE, function(count) {
        updateUnreadBadge(count, 'unreadChange');
    });
    
    // 設置連接狀態監聽器
    IMKitWsSDKV2.on(IMKitWsSDKV2.EventNames.CONNECT, function() {
        // 初始化未讀計數
        IMKitWsSDKV2.getTotalBadgeCount().then(function(count) {
            updateUnreadBadge(count, 'totalBadgeCount');
        });
    });
    
    // 初始化 WebSocket SDK
    IMKitWsSDKV2.init({
        apiUrl: '/iopen/api/api.bbc_instant_messaging.php',
    }).then(function(socket) {
        console.log('WebSocket connected successfully:', socket.id);
    }).catch(function(error) {
        console.error('Failed to initialize WebSocket SDK:', error);
    });
    
    // 更新未讀標記的輔助函數
    function updateUnreadBadge(count, from) {
        const chatButton = document.querySelector('#chatButton');
        const chatButton2 = document.querySelector('.chat-widget__button');
        const badge = document.querySelector('.chat-widget__badge');
        const badgeAdmweb = document.querySelector('.admweb-v2-list-chat-num');

        if (count > 0) {
            chatButton.classList.add('chat-widget__button--has-unread');
            chatButton2.classList.add('chat-widget__button--has-unread');
            if (badgeAdmweb) badgeAdmweb.style.display = 'block';
        } else {
            chatButton.classList.remove('chat-widget__button--has-unread');
            chatButton2.classList.remove('chat-widget__button--has-unread');
            if (badgeAdmweb) badgeAdmweb.style.display = 'none';
        }

        // if (badge) badge.textContent = (count > 99 ? '99+' : (count > 0 ? count : ''));
        if (badgeAdmweb) badgeAdmweb.textContent = (count > 99 ? '99+' : (count > 0 ? count : ''));
    }
});
</script>
