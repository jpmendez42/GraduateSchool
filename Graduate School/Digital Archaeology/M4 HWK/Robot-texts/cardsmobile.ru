ext/static/css/19343ddeed311109.css" as="style"/><link rel="stylesheet" href="/_next/static/css/19343ddeed311109.css"/><link rel="preload" href="/_next/static/css/1d6cca3779d78576.css" as="style"/><link rel="stylesheet" href="/_next/static/css/1d6cca3779d78576.css"/><link rel="preload" href="/_next/static/css/c57ac27df1ef76aa.css" as="style"/><link rel="stylesheet" href="/_next/static/css/c57ac27df1ef76aa.css"/><link rel="preload" href="/_next/static/css/47c61d0dd4bf0fc2.css" as="style"/><link rel="stylesheet" href="/_next/static/css/47c61d0dd4bf0fc2.css"/><link rel="preload" href="/_next/static/css/8b881a69766c36da.css" as="style"/><link rel="stylesheet" href="/_next/static/css/8b881a69766c36da.css"/><link rel="preload" href="/_next/static/css/e1b036a13450ba22.css" as="style"/><link rel="stylesheet" href="/_next/static/css/e1b036a13450ba22.css"/><noscript data-n-css=""></noscript><script defer="" nomodule="" src="/_next/static/chunks/polyfills-42372ed130431b0a.js"></script><script defer="" src="/_next/static/chunks/423.06cc0f3a7c70058b.js"></script><script defer="" src="/_next/static/chunks/2739-05443483c8400d45.js"></script><script defer="" src="/_next/static/chunks/121-1b9b1a0411ef746c.js"></script><script defer="" src="/_next/static/chunks/7007.44c237926ea3b9cb.js"></script><script defer="" src="/_next/static/chunks/5625.0fe9d94ae3386d27.js"></script><script defer="" src="/_next/static/chunks/8278.9536e0b0983913bf.js"></script><script defer="" src="/_next/static/chunks/7172.69775749bfaa32ce.js"></script><script defer="" src="/_next/static/chunks/5637.e716a3ffbaddc1c4.js"></script><script defer="" src="/_next/static/chunks/1946.c747055a5a91930e.js"></script><script defer="" src="/_next/static/chunks/7957-032f58f14e214fbb.js"></script><script src="/_next/static/chunks/webpack-64fc83d33228c98d.js" defer=""></script><script src="/_next/static/chunks/framework-978a6051e6d0c57a.js" defer=""></script><script src="/_next/static/chunks/main-487a69c9efd9aa33.js" defer=""></script><script src="/_next/static/chunks/pages/_app-80500d525f4b3c50.js" defer=""></script><script src="/_next/static/chunks/5354-7ee3e8dff0373659.js" defer=""></script><script src="/_next/static/chunks/7176-7d4ea4256b0013e4.js" defer=""></script><script src="/_next/static/chunks/401-f15c9ed47a6f2043.js" defer=""></script><script src="/_next/static/chunks/1916-f027e6153a2e80f3.js" defer=""></script><script src="/_next/static/chunks/pages/index-1071bcbc57ce5994.js" defer=""></script><script src="/_next/static/mnQlg_q7hRRSEIFKbY6-v/_buildManifest.js" defer=""></script><script src="/_next/static/mnQlg_q7hRRSEIFKbY6-v/_ssgManifest.js" defer=""></script></head><body><div id="__next"><div class="root_container__XZzo7"><div id="top"></div><div></div><header class="header_container__XSEN0"></header><section><div id="mouse-parallax-container" style="overflow:hidden;position:relative"><div class="hero_container__VlgB6"><div class="hero_content__HM_5s"><div class="hero_content_left__F_hzl"><h1 class="hero_slogan__rj59E">Открывать <br class="br_mobile_to_xl_only__M6Jv0"/>Кошелёк —<br/>это к покупкам</h1><img class="hero_image__SMOkZ" alt=""/><button class="button_container__NrxUv hero_download__A5A2c hero_download_mobile__XRz6K" aria-label="Скачать приложение Кошелёк" type="button">Скачать приложение</button></div></div></div></div></section><section class="benefits_container__b7RBQ"><div class="benefits_content___w2Mw"><h2 class="benefits_title__nepNq">Всегда выгодные и удобные покупки</h2><div class="benefits_benefits__oheOK"><div class="benefits_benefit__Vt8bf"><h3 class="benefits_benefit_title__WPNOS">Карты в вашем телефоне</h3><div class="benefits_benefit_description__BzUBr">Легко переносите существующие дисконтные и бонусные карты в телефон или выпускайте новые прямо в приложении</div><img src="/_next/static/media/benefit-image-1.ae47265f.webp" width="224" height="162" loading="lazy" alt=""/></div><div class="benefits_benefit__Vt8bf"><h3 class="benefits_benefit_title__WPNOS">Что выгодно — то в Выгоде</h3><div class="benefits_benefit_description__BzUBr">Следите за лучшими предложениями в разделе «Выгода». Акции, бонусы и промокоды уже ждут вас там</div><img src="/_next/static/media/benefit-image-2.6c944280.webp" width="224" height="162" loading="lazy" alt=""/></div><div class="benefits_benefit__Vt8bf"><h3 class="benefits_benefit_title__WPNOS">Промокоды везде</h3><div class="benefits_benefit_description__BzUBr">Чтобы вы не забывали делать свои покупки выгодными в онлайне и офлайне, мы разместили промокоды на Главной, в Выгоде и под картами</div><img src="/_next/static/media/benefit-image-3.a9cbd79a.webp" width="224" height="162" loading="lazy" alt=""/></div></div><div class="benefits_banner__9j7AX"><h2 class="benefits_banner_title__1pwjU">Покупайте со скидкой</h2><div class="benefits_banner_description__sOgt9">Выпускайте новые бонусные и дисконтные карты онлайн- и офлайн- магазинов прямо в приложении. Добавляйте карты, которые у вас уже есть, чтобы они всегда были под рукой. А мы напомним об актуальных акциях и скидках ваших любимых магазинов</div><a class="benefits_banner_link__xaAuo" aria-label="Перейти в Каталог" href="/karty"><span>УЗНАТЬ БОЛЬШЕ</span><svg><use href="/_next/static/media/arrow-right.icon.dd92111b.svg#id"></use></svg></a><svg class="benefits_banner_background__46csK"><use href="/_next/static/media/background.3c6177db.svg#id"></use></svg></div></div></section><section class="cards_container__8DiQq"><div class="cards_content__bP1B8"><div class="double-slider_container__yQ692"><div class="cards_top__cXsNW"><div><h2 class="cards_title__jYCNB">Дисконтные карты</h2><div class="cards_description__KCzSG">В приложении уже выпущено больше 105 млн карт.<br class="br_sm_only__o2Blp"/><br class="br_desktop__PUYio"/> А эти карты вы можете выпустить в Кошельке прямо сейчас:</div></div></div><div class="double-slider_content__TPxhX cards_double_slider_content__guRMr"><div class="slider_wrapper__sCEWk"><div class="slider_container