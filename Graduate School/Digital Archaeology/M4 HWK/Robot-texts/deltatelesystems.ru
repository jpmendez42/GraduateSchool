<script type="text/javascript">
document.addEventListener('DOMContentLoaded', () => {
  <!-- PUM fast-order -->
  if (window.location.search.indexOf("?fast-order") !== -1) {
	  PUM.open(4367);
      window.history.replaceState({}, document.title, window.location.href.split('?')[0]);
  }
  <!-- /PUM fast-order -->

  <!-- ym goal -->
  if (!getCookie('_ym_goal_reached')) {
    let isPageScrolled = 0;
    let isTimeReached = 0;
	const pageMinTime = window.location.pathname === '/business/' ? 25 : 35;
	const scrollPercentTreshold = window.location.pathname === '/business/' ? 70 : 65;

    function scrollHandler () {
      const scrollPercent = (window.pageYOffset / (document.documentElement.scrollHeight - document.documentElement.clientHeight)) * 100;
      if (scrollPercent < scrollPercentTreshold) return;
      isPageScrolled = 1;
//	  console.log("scroll treshold reached");
      window.removeEventListener('scroll', scrollHandler);
      goalReached();
    }
    window.addEventListener('scroll', scrollHandler);
	function wrapper (name, value) {
		   ym('9257'+'8371', name, value);
	}
    function goalReached() {
      if ((isPageScrolled) && (isTimeReached)) {
        wrapper('rea'+'chGo'+'al', 'go'+'al-1');
        setCookie('_ym_goal_reached', true, 30);
//		console.log('ym sent');
      }
    }
    setTimeout(() => {
      isTimeReached = 1;
      goalReached();
    }, pageMinTime * 1000);
  }
  
  function setCookie(name, value, days) {
  	document.cookie = `${name}=${value || ""}; expires=${days ? new Date(new Date().getTime() + (days * 24 * 60 * 60 * 1000)).toUTCString() : ""}; path=/; secure`;
  }

  function getCookie(name) {
  	return document.cookie.split(';').reduce((found, c) => {
    	c = c.trim();
    	return found || (c.indexOf(name + "=") === 0) && c.substr(name.length + 1);
  	}, null);
  }
  <!-- /ym goal -->
});
</script>
