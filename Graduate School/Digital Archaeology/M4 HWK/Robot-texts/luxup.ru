    .v-header-desktop-menu { position: absolute; display: flex; height: 64px; left: 163px; top: 0; color: #bbb; }
    .v-header-desktop-menu-item { position: relative; height: 100%; height: 40px; top: 12px; border-radius: 10px; cursor: pointer; }
        .v-header-desktop-menu-item2:hover { background: #373833; cursor: pointer; }
        .v-header-desktop-menu-item:hover .v-header-desktop-menu-item-text { color: rgba(187, 187, 187, 0.3); cursor: default; }
        .v-header-desktop-menu-item:hover .v-header-desktop-menu-item-inner { display: block; }
    .v-header-desktop-menu-item-text { position: relative; height: 100%; padding: 0 12px; font-size: 16px; font-weight: 600; display: flex; align-items: center; color: #bbbbbb; }
    
    .v-header-desktop-menu-round { position: absolute; display: none; background: #373833; width: 10px; height: 10px; right: -10px; bottom: 0px; }
    .v-header-desktop-menu-round2 { background: #373833; width: 100%; height: 100%; background-color: rgba(14,11,4, 0.95); border-radius: 0 0 0 30px; }
    
    .v-header-desktop-menu-item-inner { position: absolute; display: none; left: 0; cursor: pointer;  }
    .v-header-desktop-menu-item-submenu { position: relative; width: 185px; background: #373833; margin-top: 13px; border-radius: 0 0 10px 10px; padding: 10px 0 10px 0; box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.2); -webkit-box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.2); -moz-box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.2);}
    .v-header-desktop-menu-item-inner-text { position: relative; padding: 10px 20px; color: #ffffff; font-size: 14px; font-weight: 450; cursor: pointer; }
    .v-header-desktop-menu-item-inner-text:hover { color: #E2B400; cursor: pointer; }
    .v-header-desktop-menu-item-inner-req { position: relative; padding: 10px 20px; color: #E2B400; font-size: 14px; font-weight: 450; }
    
    .v-header-login { position: absolute; width: 180px; height: 40px; color: #fff; right: 110px; top: 12px; font-size: 16px; border-radius: 10px; }
        .v-header-login:hover { background: #373833; cursor: default; }
        .v-header-login:hover .v-header-login-text { opacity: 0.3; }
        .v-header-login:hover .v-header-login-icon { opacity: 0.3; }
    .v-header-login:hover .v-header-login-menu { display: block; }
    .v-header-login-text { position: absolute; left: 5px; height: 40px; width: 140px; font-weight: 550; color: #E2B400; display: flex; align-items: center; justify-content: center; }
    .v-header-login-icon { position: absolute; width: 18px; height: 18px; top: 11px; right: 11px; background: url('https://luxupnetwork.com/img/user.png') no-repeat; background-size: cover; }
 
    .v-header-login-menu { position: absolute; display: none; width: 180px; height: 88px; top: 32px; background: #373833; border-radius: 0 0 10px 10px; color: #fff; box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.2); -webkit-box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.2); -moz-box-shadow: 0px 10px 10px 0px rgba(0, 0, 0, 0.2); }
    .v-header-login-menu-signup { position: absolute; width: 100%; height: 40px; top: 8px; }
