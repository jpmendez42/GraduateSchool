slug\":\"technik-prozradil-u-jakych-spotrebicu-v-domacnosti-je-nejvetsi-riziko-odposlechu-doma-je-ma-skoro-kazdy-d5eb9d02-c702-5975-b737-2deb2c83f82c\",\"categories\":[\"Další\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/576c9eb0-e9f8-4185-33a7-292bde363200/public\",\"type\":\"image\",\"credit\":\"Zodpovime.cz\",\"title\":\"Technik prozradil, u jakých spotřebičů v domácnosti je největší riziko odposlechu. Doma je má skoro každý\",\"text\":\"Foto: Freepik.com\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-12T03:50:00.000Z\"}],\"count\":128},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393075970,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"detailRelated\",\"diAKT57PYiLrW0EWR0cMB\",5,0],\"queryHash\":\"[\\\"detailRelated\\\",\\\"diAKT57PYiLrW0EWR0cMB\\\",5,0]\"},{\"state\":{\"data\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"partnerName\":\"VIP show\",\"description\":\"Magazín, který bere čtenáře přímo do centra dění – ať už jde o červený koberec, zákulisí televizních show, hudební scény nebo nečekané momenty ze života známých osobností. Články přinášejí aktuální novinky, drby, rozhovory i zajímavosti, které se k fanouškům běžně nedostanou.\\n\\nObsah se nebojí být odlehčený a zábavný, ale nechybí ani informace o kariérních posunech, osobních výhrách a prohrách či společenských trendech. Od hollywoodských hvězd po domácí celebrity – VIPshow.cz míchá světovou i českou scénu do čtivé kombinace, která baví i překvapuje.\\n\\nPro každého, kdo má rád lesk reflektorů a chce vědět, co se děje za nimi, je tohle místo, kde show nikdy nekončí.\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\",\"partnerUrl\":\"https://vipshow.cz/\",\"slug\":\"vip-show-Rs4O0DPiSLtIGvMWrwcu8\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393077975,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"feedDetail\",\"Rs4O0DPiSLtIGvMWrwcu8\"],\"queryHash\":\"[\\\"feedDetail\\\",\\\"Rs4O0DPiSLtIGvMWrwcu8\\\"]\"},{\"state\":{\"data\":{\"id\":97605,\"guid\":\"7be7cd66-37e6-5104-8244-daab80a98973\",\"feed\":{\"id\":98,\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"companyId\":25,\"contactId\":null,\"type\":\"rss\",\"partnerName\":\"VIP show\",\"partnerUrl\":\"https://vipshow.cz/\",\"description\":\"Magazín, který bere čtenáře přímo do centra dění – ať už jde o červený koberec, zákulisí televizních show, hudební scény nebo nečekané momenty ze života známých osobností. Články přinášejí aktuální novinky, drby, rozhovory i zajímavosti, které se k fanouškům běžně nedostanou.\\n\\nObsah se nebojí být odlehčený a zábavný, ale nechybí ani informace o kariérních posunech, osobních výhrách a prohrách či společenských trendech. Od hollywoodských hvězd po domácí celebrity – VIPshow.cz míchá světovou i českou scénu do čtivé kombinace, která baví i překvapuje.\\n\\nPro každého, kdo má rád lesk reflektorů a chce vědět, co se děje za nimi, je tohle místo, kde show nikdy nekončí.\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\",\"sourceUrl\":\"https://vipshow.cz/rss-centrum.xml?refresh=2\",\"slug\":\"vip-show-Rs4O0DPiSLtIGvMWrwcu8\",\"note\":null,\"active\":true,\"economiaFeed\":false,\"downloadPeriod\":1800,\"paywall\":false,\"skipImages\":false,\"autoPublishing\":true,\"canonical\":true,\"companySwitchedFrom\":null,\"createdAt\":\"2025-08-13T10:53:43.000Z\",\"updatedAt\":\"2025-08-15T11:54:49.000Z\"},\"feedId\":98,\"block\":null,\"blockId\":null,\"title\":\"Zeptali jsme se AI na nejkrásnějšího českého herce. Na celé čáře vyhrála vycházející filmová hvězda\",\"description\":\"Když systém umělé inteligence zpracoval stovky portrétů a veřejných fotografií českých herců, výsledek překvapil. Na první místo se dostal teprve jedenadvacetiletý Tomas Sean Pšenička, mladý talent, který spojuje svěží vzhled s hereckým citem a čím dál častěji se objevuje na obrazovkách, v seriálech, filmech i divadelních jevištích po celé republice.\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/nejkrasnejsi-filmova-hvezda-ai/alexandrakrizova/\",\"slug\":\"zeptali-jsme-se-ai-na-nejkrasnejsiho-ceskeho-herce-na-cele-care-vyhrala-vychazejici-filmova-hvezda-7be7cd66-37e6-5104-8244-daab80a98973\",\"categories\":[\"Česko\",\"Film a seriál\",\"Nejnovější zprávy\"],\"type\":\"article\",\"source\":null,\"label\":null,\"order\":0,\"verified\":false,\"canonical\":true,\"seoTitle\":null,\"hash\":\"95fa1ae8b4d92cfbf35cc2a9624f73a5\",\"discussionId\":null,\"redirectOnly\":false,\"content\":\"$7e\",\"readingTime\":3,\"note\":null,\"reviewRemovedImages\":false,\"reviewProcessedImages\":true,\"paywall\":false,\"alternativeTitle\":null,\"alternativeImage\":null,\"imagesChecked\":false,\"keywords\":null,\"recombee\":false,\"audio\":false,\"blockAddedAt\":null,\"originalPublishedAt\":\"2025-10-13T12:43:41.000Z\",\"publishedAt\":\"2025-10-13T12:43:41.000Z\",\"createdAt\":\"2025-10-13T13:01:32.000Z\",\"updatedAt\":\"2025-10-13T13:01:34.000Z\",\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/3074145f-a048-46f1-acf1-73b75d55d000/public\",\"type\":\"image\",\"title\":\"Přirozený talent nové generace: charizma, které nepotřebuje efekty\",\"text\":\"Přirozený talent nové generace: charizma, které nepotřebuje efekty\",\"credit\":\"VIPshow\"}],\"processedContent\":\"$7f\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393077993,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"article\",\"7be7cd66-37e6-5104-8244-daab80a98973\"],\"queryHash\":\"[\\\"article\\\",\\\"7be7cd66-37e6-5104-8244-daab80a98973\\\"]\"},{\"state\":{\"data\":{\"items\":[{\"guid\":\"f4c82972-781b-5b52-9fe4-a9a0271663d1\",\"feed\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"name\":\"VIP show\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\"},\"title\":\"Podívejte, jak roztomilé děti má Rey Koranteng. Jeho manželka pochází z Česka a je nádherná\",\"description\":\"Reye Korantenga zná celý národ jako klidnou a profesionální tvář Televizních novin, kde po boku Lucie Borhyové působí už od roku 1997. Jeho kariéra na Nově ale začala ještě dříve, v roce 1994, jako usměvavého moderátora počasí.\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/rey-koranteng-rodina/michaelapisanova/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipshow.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"podivejte-jak-roztomile-deti-ma-rey-koranteng-jeho-manzelka-pochazi-z-ceska-a-je-nadherna-f4c82972-781b-5b52-9fe4-a9a0271663d1\",\"categories\":[\"Česko\",\"Film a seriál\",\"Nejnovější zprávy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/a580156b-ba48-480a-7036-454a977b9200/public\",\"type\":\"image\",\"credit\":\"VIPshow\",\"title\":\"Rey s mladšími dcerami v roce 2016.\",\"text\":\"Rey s mladšími dcerami v roce 2016.\"}],\"blockGuid\":\"OxCq-Bs8zLe9kqK6FlqQw\",\"order\":1,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":3,\"publishedAt\":\"2025-10-13T16:49:20.000Z\"},{\"guid\":\"b567b696-638d-51c8-89a7-4f0a2c9c0c78\",\"feed\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"name\":\"VIP show\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\"},\"title\":\"Jak dnes vypadá Zlatovláska Jorga Kotrbová. Už ji neznáte, ale bohatá je tak, že se vám zatají dech\",\"description\":\"Kdysi ji miloval celý národ. Princezna se zlatými vlasy okouzlila krále i srdce diváků. Dnes už o Jorze Kotrbové téměř neslyšíme, přesto žije život. Vyměnila svět kamer za klid u koní, reflektory za ticho hor a pozornost publika za svobodu, kterou si vybudovala sama.\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/jorga-kotrbova-zlatovlaska/alexandrakrizova/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipshow.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"jak-dnes-vypada-zlatovlaska-jorga-kotrbova-uz-ji-neznate-ale-bohata-je-tak-ze-se-vam-zataji-dech-b567b696-638d-51c8-89a7-4f0a2c9c0c78\",\"categories\":[\"Česko\",\"Film a seriál\",\"Nejnovější zprávy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/67861dc0-040e-40bc-5918-a8403d27e100/public\",\"type\":\"image\",\"credit\":\"VIPshow\",\"title\":\"Princezna, která učarovala divákům\",\"text\":\"Princezna, která učarovala divákům\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":3,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":4,\"publishedAt\":\"2025-10-13T15:48:19.000Z\"},{\"guid\":\"7be7cd66-37e6-5104-8244-daab80a98973\",\"feed\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"name\":\"VIP show\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\"},\"title\":\"Zeptali jsme se AI na nejkrásnějšího českého herce. Na celé čáře vyhrála vycházející filmová hvězda\",\"description\":\"Když systém umělé inteligence zpracoval stovky portrétů a veřejných fotografií českých herců, výsledek překvapil. Na první místo se dostal teprve jedenadvacetiletý Tomas Sean Pšenička, mladý talent, který spojuje svěží vzhled s hereckým citem a čím dál častěji se objevuje na obrazovkách, v seriálech, filmech i divadelních jevištích po celé republice.\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/nejkrasnejsi-filmova-hvezda-ai/alexandrakrizova/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipshow.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"zeptali-jsme-se-ai-na-nejkrasnejsiho-ceskeho-herce-na-cele-care-vyhrala-vychazejici-filmova-hvezda-7be7cd66-37e6-5104-8244-daab80a98973\",\"categories\":[\"Česko\",\"Film a seriál\",\"Nejnovější zprávy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/3074145f-a048-46f1-acf1-73b75d55d000/public\",\"type\":\"image\",\"credit\":\"VIPshow\",\"title\":\"Přirozený talent nové generace: charizma, které nepotřebuje efekty\",\"text\":\"Přirozený talent nové generace: charizma, které nepotřebuje efekty\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":3,\"publishedAt\":\"2025-10-13T12:43:41.000Z\"},{\"guid\":\"0e99fa81-7c35-5e26-8044-f4a973e28a96\",\"feed\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"name\":\"VIP show\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\"},\"title\":\"Pět slavných herců, co působí jako tykve, ale tvrdí, že mají IQ nad 140. Věříte jim to?\",\"description\":\"Někdy to vypadá, že filmové hvězdy žijí hlavně z lesku a popularity. Jenže právě ti, kteří hrají největší smolaře, se často chlubí mimořádnou inteligencí. Někteří herci o sobě tvrdí, že patří mezi skutečné génie, a i když to může znít přehnaně, jejich životy dokazují, že za úsměvem kamery se skrývá víc, než čekáme.\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/herci-iq-140-zajimavosti/zuzanasalah/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipshow.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"pet-slavnych-hercu-co-pusobi-jako-tykve-ale-tvrdi-ze-maji-iq-nad-140-verite-jim-to-0e99fa81-7c35-5e26-8044-f4a973e28a96\",\"categories\":[\"Nejnovější zprávy\",\"Svět\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/728f5bcc-affc-4e1e-28b1-397540d76600/public\",\"type\":\"image\",\"credit\":\"VIPshow\",\"title\":\"James Woods patří mezi hollywoodské herce, o nichž se říká, že mají mimořádně vysoké IQ\",\"text\":\"James Woods patří mezi hollywoodské herce, o nichž se říká, že mají mimořádně vysoké IQ\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":4,\"publishedAt\":\"2025-10-13T10:00:45.000Z\"},{\"guid\":\"bc15c2ce-ca60-5e88-90e7-1efde6c60be4\",\"feed\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"name\":\"VIP show\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\"},\"title\":\"Baarová nebo Mandlová: Jedna byla zlá a druhá hloupá, tvrdil Werich\",\"description\":\"Když Jan Werich hodnotil lidi, málokdy se držel zpátky. A když došla řeč na dvě nejslavnější herečky první republiky, Lídu Baarovou a Adinu Mandlovou, pronesl údajně výrok, který se cituje dodnes. Jedna prý byla hloupá, druhá zlá. Na první pohled bonmot, na druhý stručné shrnutí složitých osudů a povah. A jak to tedy vlastně bylo?\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/baarova-mandlova-werich-zajimavosti/martinaweber/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipshow.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"baarova-nebo-mandlova-jedna-byla-zla-a-druha-hloupa-tvrdil-werich-bc15c2ce-ca60-5e88-90e7-1efde6c60be4\",\"categories\":[\"Česko\",\"Film a seriál\",\"Nejnovější zprávy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/ce272d90-cfa2-4842-3fda-1797234f7600/public\",\"type\":\"image\",\"credit\":\"VIPshow\",\"title\":\"Baarová nebo Mandlová: Jedna byla zlá a druhá hloupá, tvrdil Werich\",\"text\":\"Baarová nebo Mandlová: Jedna byla zlá a druhá hloupá, tvrdil Werich\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":20,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":4,\"publishedAt\":\"2025-10-13T09:41:51.000Z\"}],\"count\":165},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393078025,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"detailRelated\",\"Rs4O0DPiSLtIGvMWrwcu8\",5,0],\"queryHash\":\"[\\\"detailRelated\\\",\\\"Rs4O0DPiSLtIGvMWrwcu8\\\",5,0]\"},{\"state\":{\"data\":{\"guid\":\"np7A464rbojBeZki5YlSY\",\"partnerName\":\"VIPživot.cz\",\"description\":\"$80\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\",\"partnerUrl\":\"https://vipzivot.cz\",\"slug\":\"vipzivotcz-np7A464rbojBeZki5YlSY\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393078418,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"feedDetail\",\"np7A464rbojBeZki5YlSY\"],\"queryHash\":\"[\\\"feedDetail\\\",\\\"np7A464rbojBeZki5YlSY\\\"]\"},{\"state\":{\"data\":{\"id\":95317,\"guid\":\"ba56b099-9c9a-5c14-9093-33c4cc7e9b1a\",\"feed\":{\"id\":75,\"guid\":\"np7A464rbojBeZki5YlSY\",\"companyId\":10,\"contactId\":null,\"type\":\"rss\",\"partnerName\":\"VIPživot.cz\",\"partnerUrl\":\"https://vipzivot.cz\",\"description\":\"$81\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\",\"sourceUrl\":\"https://vipzivot.cz/wp-json/abc-media/v1/feed/centrum\",\"slug\":\"vipzivotcz-np7A464rbojBeZki5YlSY\",\"note\":\"slavna poznamka\",\"active\":true,\"economiaFeed\":false,\"downloadPeriod\":600,\"paywall\":false,\"skipImages\":false,\"autoPublishing\":true,\"canonical\":true,\"companySwitchedFrom\":null,\"createdAt\":\"2025-07-03T13:39:20.000Z\",\"updatedAt\":\"2025-07-30T19:34:12.000Z\"},\"feedId\":75,\"block\":null,\"blockId\":null,\"title\":\"Před manželkou Igora Chmely rodiče dlouho skrývali pravdu. Až ve 12 letech se dozvěděla, že je dcerou Petra Svojtky\",\"description\":\"Janěková vždy tušila, že je adoptovaná. Herectví v krvi ale nezapře, svou kariéru nastartovala skvěle, stejně jako manželství s Igorem Chmelou.\",\"url\":\"https://vipzivot.cz/p/jana-janekova-otec-herec-manzel-chmela/\",\"slug\":\"pred-manzelkou-igora-chmely-rodice-dlouho-skryvali-pravdu-az-ve-12-letech-se-dozvedela-ze-je-dcerou-petra-svojtky-ba56b099-9c9a-5c14-9093-33c4cc7e9b1a\",\"categories\":[\"Celebrity\"],\"type\":\"article\",\"source\":null,\"label\":null,\"order\":0,\"verified\":false,\"canonical\":true,\"seoTitle\":null,\"hash\":\"bd3d670740058e1ca398ea0e5aabfd34\",\"discussionId\":null,\"redirectOnly\":false,\"content\":\"$82\",\"readingTime\":3,\"note\":null,\"reviewRemovedImages\":false,\"reviewProcessedImages\":true,\"paywall\":false,\"alternativeTitle\":null,\"alternativeImage\":null,\"imagesChecked\":false,\"keywords\":null,\"recombee\":false,\"audio\":false,\"blockAddedAt\":null,\"originalPublishedAt\":\"2025-10-09T05:00:00.000Z\",\"publishedAt\":\"2025-10-09T05:00:00.000Z\",\"createdAt\":\"2025-10-09T03:00:24.000Z\",\"updatedAt\":\"2025-10-09T03:00:27.000Z\",\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/9f57d935-2f3b-4146-7bd6-393c0378b500/public\",\"type\":\"image\",\"title\":\"Před manželkou Igora Chmely rodiče dlouho skrývali pravdu. Až ve 12 letech se dozvěděla, že je dcerou Petra Svojtky\",\"text\":\"Zdroj fotografie: Nextfoto\",\"credit\":\"Zdroj fotografie: Nextfoto\"}],\"processedContent\":\"$83\"},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393078449,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"article\",\"ba56b099-9c9a-5c14-9093-33c4cc7e9b1a\"],\"queryHash\":\"[\\\"article\\\",\\\"ba56b099-9c9a-5c14-9093-33c4cc7e9b1a\\\"]\"},{\"state\":{\"data\":{\"items\":[{\"guid\":\"145b3414-e5b2-53cf-97e4-565bab93a821\",\"feed\":{\"guid\":\"np7A464rbojBeZki5YlSY\",\"name\":\"VIPživot.cz\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\"},\"title\":\"Jana Paulová si po letech užije přítomnost dcery a vnoučat: Anežka po letech v zahraničí porodila v Česku\",\"description\":\"Sedmdesátiletá herečka, která zářila na parketu populární taneční soutěže StarDance, se už nemusí za vnoučaty trmácet tisíc kilometrů daleko. Má je za rohem.\",\"url\":\"https://vipzivot.cz/p/jana-paulova-dcera-vnouce/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipzivot.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"jana-paulova-si-po-letech-uzije-pritomnost-dcery-a-vnoucat-anezka-po-letech-v-zahranici-porodila-v-cesku-145b3414-e5b2-53cf-97e4-565bab93a821\",\"categories\":[\"Celebrity\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/2763a22b-f0a6-4422-1b45-43acbeca0400/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: Nextfoto\",\"title\":\"Jana Paulová\",\"text\":\"Zdroj fotografie: Nextfoto\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T12:23:05.000Z\"},{\"guid\":\"3f9bf3aa-78f3-589d-84a8-269fba03bffc\",\"feed\":{\"guid\":\"np7A464rbojBeZki5YlSY\",\"name\":\"VIPživot.cz\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\"},\"title\":\"„Jsem sice chudá, ale hrdá,“ stěžuje si Jaroslava Obermaierová. Herečka odmítla honorář z Ulice\",\"description\":\"Seriál Ulice, který se vysílá už přes dvacet let, má na svém kontě přes 4500 epizod. Ve většině z nich se objevila i drbna Vilma Nyklová. Teď ale bude upozaděná.\",\"url\":\"https://vipzivot.cz/p/nekonecny-serial-ulice-jaroslava-obermaierova/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipzivot.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"jsem-sice-chuda-ale-hrda-stezuje-si-jaroslava-obermaierova-herecka-odmitla-honorar-z-ulice-3f9bf3aa-78f3-589d-84a8-269fba03bffc\",\"categories\":[\"Celebrity\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/ef4f7444-7418-4039-2ccd-23fcdf206e00/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: Nextfoto\",\"title\":\"Jaroslava Obermaierová\",\"text\":\"Zdroj fotografie: Nextfoto\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"alternativeTitle\":\"„Jsem sice chudá, ale hrdá,“ stěžuje si Obermaierová. Herečka odmítla honorář z Ulice\",\"readingTime\":2,\"publishedAt\":\"2025-10-13T05:00:00.000Z\"},{\"guid\":\"5faf75ab-8132-5b02-b2e8-66c1c57d3db6\",\"feed\":{\"guid\":\"np7A464rbojBeZki5YlSY\",\"name\":\"VIPživot.cz\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\"},\"title\":\"Tatiana Dyková: Její zdravotní stav jí nedovolil vystupovat. Prý ale nezkolabovala, jak se tvrdilo\",\"description\":\"Televizní diváci se letos na obrazovkách nedočkají nového ročníku oblíbené taneční show. Namísto toho vyrazila karavana StarDance na turné po republice.\",\"url\":\"https://vipzivot.cz/p/stardance-tour-tatiana-dykova-zdravi/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipzivot.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"tatiana-dykova-jeji-zdravotni-stav-ji-nedovolil-vystupovat-pry-ale-nezkolabovala-jak-se-tvrdilo-5faf75ab-8132-5b02-b2e8-66c1c57d3db6\",\"categories\":[\"Celebrity\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/6b65556d-2034-4af3-7df8-abb3a2377700/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: Nextfoto\",\"title\":\"Herečka Tatiana Dyková\",\"text\":\"Zdroj fotografie: Nextfoto\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T04:45:00.000Z\"},{\"guid\":\"dd2022e0-42aa-5f00-a0dc-24ecd8e76221\",\"feed\":{\"guid\":\"np7A464rbojBeZki5YlSY\",\"name\":\"VIPživot.cz\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\"},\"title\":\"Princezna Diana nenosila vlasy nakrátko dobrovolně. Královna totiž pukala zlostí při myšlence, že by ji měla zastínit\",\"description\":\"Populární Lady Di byla módní ikonou, která udávala trendy. Její život ale předčasně vyhasl v šestatřiceti letech při dopravní nehodě v Paříži v roce 1997.\",\"url\":\"https://vipzivot.cz/p/kadernik-princezna-diana-kratke-vlasy/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipzivot.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"princezna-diana-nenosila-vlasy-nakratko-dobrovolne-kralovna-totiz-pukala-zlosti-pri-myslence-ze-by-ji-mela-zastinit-dd2022e0-42aa-5f00-a0dc-24ecd8e76221\",\"categories\":[\"Celebrity\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/b67197ce-4db9-4d90-c870-7a7009514f00/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: John Mathew Smith / Creative Commons / CC-BY-SA\",\"title\":\"Princezna Diana\",\"text\":\"Zdroj fotografie: John Mathew Smith / Creative Commons / CC-BY-SA\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":2,\"publishedAt\":\"2025-10-13T04:30:00.000Z\"},{\"guid\":\"49e4edd8-09b3-5122-8116-6f1f9593c2be\",\"feed\":{\"guid\":\"np7A464rbojBeZki5YlSY\",\"name\":\"VIPživot.cz\",\"logo\":\"https://vipzivot.cz/wp-content/uploads/2025/02/group-615.png\"},\"title\":\"Jak žije dnes: Jaroslava Kretschmerová alias Dorota Máchalová zůstala bez muže i dětí. Na samotu si prý zvykla\",\"description\":\"Herečka, která má za sebou hvězdnou kariéru. Osobní život však nesdílí s nikým. Nikdy se nevdala ani neměla děti.\",\"url\":\"https://vipzivot.cz/p/jaroslava-kretschmerova-herecka-energie-sekta/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=vipzivot.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"jak-zije-dnes-jaroslava-kretschmerova-alias-dorota-machalova-zustala-bez-muze-i-deti-na-samotu-si-pry-zvykla-49e4edd8-09b3-5122-8116-6f1f9593c2be\",\"categories\":[\"Celebrity\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/6c0fd801-45b3-41dd-b712-c8b909362700/public\",\"type\":\"image\",\"credit\":\"Zdroj fotografie: Nextfoto\",\"title\":\"Jaroslava Kretschmerová\",\"text\":\"Zdroj fotografie: Nextfoto\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":15,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"alternativeTitle\":\"Jaroslava Kretschmerová alias Dorota Máchalová zůstala bez muže i dětí\",\"readingTime\":2,\"publishedAt\":\"2025-10-13T04:15:00.000Z\"}],\"count\":400},\"dataUpdateCount\":1,\"dataUpdatedAt\":1760393078462,\"error\":null,\"errorUpdateCount\":0,\"errorUpdatedAt\":0,\"fetchFailureCount\":0,\"fetchFailureReason\":null,\"fetchMeta\":null,\"isInvalidated\":false,\"status\":\"success\",\"fetchStatus\":\"idle\"},\"queryKey\":[\"detailRelated\",\"np7A464rbojBeZki5YlSY\",5,0],\"queryHash\":\"[\\\"detailRelated\\\",\\\"np7A464rbojBeZki5YlSY\\\",5,0]\"},{\"state\":{\"data\":{\"items\":[{\"guid\":\"3b558074-4d8a-50f5-a6a2-00da232fc243\",\"feed\":{\"guid\":\"eiTTjTgz8N9tSCOWJmP5j\",\"name\":\"Sport - Aktuálně.cz\",\"logo\":\"https://asset.stdout.cz/fe/aktualne/img/acz-desktop-logo-dark.png\"},\"title\":\"Slováci se hodinu trápili s Lucemburskem, ale MS mají zase blíž. Trefil se i Schranz\",\"description\":\"Slováci se hodinu trápili s Lucemburskem, ale MS mají zase blíž. Trefil se i Schranz\",\"url\":\"https://sport.aktualne.cz/fotbal/slovaci-se-hodinu-trapili-s-lucemburskem-ale-ms-maji-zase-bl/r~ca5a8662a87a11f0801c0cc47ab5f122/?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=sport.aktualne.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"slovaci-se-hodinu-trapili-s-lucemburskem-ale-ms-maji-zase-bliz-trefil-se-i-schranz-3b558074-4d8a-50f5-a6a2-00da232fc243\",\"categories\":[\"Fotbal\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/c978fcb6-af01-464d-7986-c6ca0d529300/public\",\"type\":\"image\",\"credit\":\"Sport - Aktuálně.cz\",\"title\":\"Slováci se hodinu trápili s Lucemburskem, ale MS mají zase blíž. Trefil se i Schranz\",\"text\":\"Slováci se hodinu trápili s Lucemburskem, ale MS mají zase blíž. Trefil se i Schranz\"}],\"order\":0,\"verified\":false,\"canonical\":true,\"redirectOnly\":true,\"paywall\":false,\"readingTime\":null,\"publishedAt\":\"2025-10-13T21:27:51.000Z\"},{\"guid\":\"6cd36032-a6a7-567b-8a28-a99ed59a304f\",\"feed\":{\"guid\":\"V3FHCvIMlehRMrn-Gev_o\",\"name\":\"KINOTIP2.cz\",\"logo\":\"https://www.kinotip2.cz/kinotip-logo-32-32.png\"},\"title\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\",\"description\":\"Jako tichý stín se plazí detektivní hrou Zrádci spánková deprivace jejích účastníků. A to nejen hráčů, ale i štábu. Natáčení šestého dílu, který uvedla prima+, se podepsalo na všech, bez spánku totiž točili dva dny v kuse. Mohla za to náročná noční mise a zrádkyně Mia, která zkomplikovala natáčecí den.\",\"url\":\"https://www.kinotip2.cz/clanky/zradci-mia-neomylne-miri-do-finale-soutezici-ji-veri-stab-ji-proklina-kvuli-ni-jeli-bez-spanku-dva-dny-v-kuse-20251013-14625.html?utm_source=centrumHP\u0026utm_medium=feed_detail\u0026utm_campaign=www.kinotip2.cz\u0026utm_content=articleOnFeedDetail\",\"slug\":\"zradci-mia-neomylne-miri-do-finale-soutezici-ji-veri-stab-ji-proklina-kvuli-ni-jeli-bez-spanku-dva-dny-v-kuse-6cd36032-a6a7-567b-8a28-a99ed59a304f\",\"categories\":[\"Reality show\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/096226f1-85d3-4a77-0bb8-019234914a00/public\",\"type\":\"image\",\"credit\":\"FTV Prima\",\"title\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\",\"text\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spánku dva dny v kuse\"},{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/eb45eec7-7b7f-4715-77cd-098fc7a4bb00/public\",\"type\":\"image\",\"credit\":\"FTV Prima\",\"title\":\"Zrádci: Mia neomylně míří do finále, soutěžící jí věří, štáb ji proklíná. Kvůli ní jeli bez spán