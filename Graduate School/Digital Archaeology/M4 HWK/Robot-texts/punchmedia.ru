<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <meta name="description" content="Профессиональная рекламная платформа. 52 миллиона уникальных пользователей в России. 12 миллионов показов рекламы в сутки. Рекламная сеть на всех устройствах.">
    <meta name="keywords" content="реклама, заказать показ рекламы, купить показы рекламы, сколько стоит реклама, где заказать показ рекламы">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css" integrity="sha384-B0vP5xmATw1+K9KRQjQERJvTumQW0nPEzvF6L/Z6nronJ3oUOFUFpCjEUQouq2+l" crossorigin="anonymous">
    <link rel="stylesheet" href="css/fonts.css">
    <link rel="stylesheet" href="css/main.css">
    <link rel="stylesheet" href="css/media.css">

    <link rel="apple-touch-icon" sizes="57x57" href="favicon/apple-icon-57x57.png">
    <link rel="apple-touch-icon" sizes="60x60" href="favicon/apple-icon-60x60.png">
    <link rel="apple-touch-icon" sizes="72x72" href="favicon/apple-icon-72x72.png">
    <link rel="apple-touch-icon" sizes="76x76" href="favicon/apple-icon-76x76.png">
    <link rel="apple-touch-icon" sizes="114x114" href="favicon/apple-icon-114x114.png">
    <link rel="apple-touch-icon" sizes="120x120" href="favicon/apple-icon-120x120.png">
    <link rel="apple-touch-icon" sizes="144x144" href="favicon/apple-icon-144x144.png">
    <link rel="apple-touch-icon" sizes="152x152" href="favicon/apple-icon-152x152.png">
    <link rel="apple-touch-icon" sizes="180x180" href="favicon/apple-icon-180x180.png">
    <link rel="icon" type="image/png" sizes="192x192"  href="favicon/android-icon-192x192.png">
    <link rel="icon" type="image/png" sizes="32x32" href="favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="favicon/favicon-96x96.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicon/favicon-16x16.png">
    <link rel="manifest" href="favicon/manifest.json">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="favicon/ms-icon-144x144.png">
    <meta name="theme-color" content="#ffffff">
    <title>Профессиональная рекламная платформа</title>

    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  </head>
  <body>
    <div class="bg d-sm-none"></div>
    <header>
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
          <a class="navbar-brand" href="">
            <img src="img/header/logo.png" alt="">
          </a>
          <button class="navbar-toggler d-none" type="button" data-toggle="collapse" data-target="#navbarMenu" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <!-- <span class="navbar-toggler-icon"></span> -->
            <i class="bi bi-list"></i>
            <i class="bi bi-x" style="display: none;"></i>
          </button>

          <div class="collapse navbar-collapse" id="navbarMenu">
            <ul class="navbar-nav mr-auto d-none">
              <li class="nav-item active">
                <a class="nav-link" href="#">Рекламодателям</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Площадкам</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Форматы</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Кейсы</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Контакты</a>
              </li>
            </ul>
          </div>
      </div>
      </nav>
    </header>
    <main>
      <section class="jumbotron">
        <div class="container">
          <div class="row">
            <div class="col-12 col-sm-4 col-md-4">
              <div class="jumbotron__image__box">
                <img src="img/jumbotron/jumbo__logo.png" alt="Профессиональная рекламная платформа" class="img-fluid">
              </div>
            </div>
            <div class="col-12 col-sm-8 col-md-8">
              <div class="jumbotron__text__box">
                <h1>ПРОФЕССИОНАЛЬНАЯ РЕКЛАМНАЯ ПЛАТФОРМА</h1>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="integrated__approach">
        <div class="container">
          <div class="row">
              <div class="col-12 col-md-4">
                <div class="integrated__approach__master__box">
                  <h2 class="title">Интегрированный подход</h2>
                  <p class="clear__text">НЕЗАВИСИМАЯ МУЛЬТИКАНАЛЬНАЯ РЕКЛАМНАЯ ПЛАТФОРМА</p>
                  <div class="color__box">
                    <p>Быстрое достижение KPI при постоянном снижении затрат</p>
                  </div>
                  <small>гарантированное снижение затрат при сотрудничестве от 3-х месяцев</small>
                </div>
              </div>
              <div class="col-6 col-md-4">
                <div class="integrated__approach__slave__box">
                  <span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-02.svg');"></span>
                  <h3 class="title">Команда</h3>
                  <ul class="list-unstyled">
                    <li>10+ лет экспертиза в digital</li>
                    <li>100+ клиентов</li>
                    <li>1000+ рекламных кампаний</li>
                  </ul>
                </div>
                <div class="integrated__approach__slave__box">
                  <span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-03.svg');"></span>
                  <h3 class="title">РАЗРАБОТКИ</h3>
                  <ul class="list-unstyled">
                    <li>Adserver</li>
                    <li>Трекинг</li>
                    <li>Trading Desk</li>
                    <li>Video Player</li>
                    <li>Любые форматы</li>
                    <li>Open RTB</li>
                  </ul>
                </div>
              </div>
              <div class="col-6 col-md-4">
                <div class="integrated__approach__slave__box">
                  <span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-05.svg');"></span>
                  <h3 class="title">Данные</h3>
                  <ul class="list-unstyled">
                    <li>1st Party DATA</li>
                    <li>2nd PARTY DATA</li>
                    <li>3rd PARTY DATA</li>
                  </ul>
                </div>
                <div class="integrated__approach__slave__box">
                  <span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-04.svg');"></span>
                  <h3 class="title">Каналы</h3>
                  <ul class="list-unstyled">
                    <li>Display</li>
                    <li>Mobile</li>
                    <li>Video</li>
                    <li>Instream & Out stream</li>
                    <li>Applications</li>
                    <li>Smart TV</li>
                  </ul>
                </div>
              </div>
          </div>
        </div>
      </section>
      <section class="our__capabilities">
        <div class="container">
          <div class="row">
            <div class="col-12 col-md-4">
              <div class="our__capabilities__master__box">
                <h2 class="title">Наши возможности</h2>
                <div class="color__box">
                  <p>РЕКЛАМНАЯ СЕТЬ НА ВСЕХ ЭКРАНАХ</p>
                </div>
              </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <div class="our__capabilities__slave__box"><span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-05.svg');"></span>
                <h3 class="title">ОХВАТ</h3>
                <ul class="list-unstyled">
                  <li><strong>52 миллиона</strong> уникальных
                    пользователей в России<sup>*</sup></li>
                  <li><strong>12 миллионов</strong> показов
                    рекламы в сутки <small><sup>*</sup> зарубежный трафик по запросу</small></li>
                </ul>
              </div>
              <div class="our__capabilities__slave__box"><span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-05.svg');"></span>
                <h3 class="title">ТРАФИК</h3>
                <ul class="list-unstyled">
                  <li>Партнерская сеть из прямых медиа-площадок Медийная сеть RTB</li>
                </ul>
              </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <div class="our__capabilities__slave__box"><span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-05.svg');"></span>
                <h3 class="title">СТАТИСТИКА</h3>
                <ul class="list-unstyled">
                  <li>24/7 доступ в личный кабинет</li>
                  <li>Актуальные данные моментально обновляются в онлайн-режиме</li>
                </ul>
              </div>
              <div class="our__capabilities__slave__box"><span class="punch__icon" style="background-image: url('img/integrated__approach/PUNCH_Icons-05.svg');"></span>
                <h3 class="title">АУДИТ</h3>
                <ul class="list-unstyled">
                  <li>24 часа до запуска РК проверка трафика</li>
                  <li>Аудит Antifraud: Moat, Adloox, Forensiq</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="device__box">
        <div class="container">
          <div class="row">
            <div class="col-6 col-sm-3 col-md-3">
              <div class="device__item" style="margin-right: 65px;">
                <div class="image">
                  <img src="img/device__box/PUNCH_Icons-14.svg" alt="DESKTOP">
                </div>
                <div class="name">DESKTOP</div>
              </div>
            </div>
            <div class="col-6 col-sm-3 col-md-3">
              <div class="device__item">
                <div class="image">
                  <img src="img/device__box/PUNCH_Icons-12.svg" alt="Mobile" style="width:101px;">
                </div>
                <div class="name">Mobile</div>
              </div>
            </div>
            <div class="col-6 col-sm-3 col-md-3">
              <div class="device__item">
                <div class="image">
                  <img src="img/device__box/PUNCH_Icons-13.svg" alt="Tablet" style="width:121px;">
                </div>
                <div class="name">Tablet</div>
              </div>
            </div>
            <div class="col-6 col-sm-3 col-md-3">
              <div class="device__item" style="margin-left: 53px;">
                <div class="image">
                  <img src="img/device__box/PUNCH_Icons-15.svg" alt="Smart TV" style="width:200px;">
                </div>
                <div class="name">Smart TV</div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="with__us__more">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <h2 class="title">C нами вы сможете больше</h2>
              <div class="txt">
                <p>Наша цель - стать вашим партнером. <br>Нам интересно долгосрочное сотрудничество, чтобы каждый день давать вам лучший результат и повышать вашу скидку.</p>
                <p>Мы всегда на связи, оперативно ищем решения и реагируем на ваши запросы.</p>
                <p>Мы за понятное и прозрачное ценообразование. У нас нет дополнительных и скрытых наценок. Для каждого брифа мы предложим подход и порекомендуем модель закупки. </p>
                <p>Мы будем рады обеспечить любые охваты, решить нестандартные задачи и достичь performance-цели.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="work__form">
        <div class="container">
          <div class="row">
            <div class="col-12">
              <h2 class="title">Давайте начнем работать прямо сейчас</h2>
              <div class="form__box">
                <form id="frm" method="POST">
                  <div class="form-row">
                    <div class="form-group input-group col-md-6 mr-15">
                      <input id="name" type="text" class="form-control" name="name" placeholder="Имя">
                      <div class="input-group-append">
                        <span class="input-group-text">*</span>
                      </div>
                    </div>
                    <div class="form-group input-group col-md-6 ml-15">
                      <input id="email" type="email" class="form-control" name="email" placeholder="Эл. почта">
                      <div class="input-group-append">
                        <span class="input-group-text">*</span>
                      </div>
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group col-md-6 mr-15">
                      <input id="phone" type="text" class="form-control" name="phone" placeholder="Телефон">
                    </div>
                    <div class="form-group col-md-6 ml-15">
                      <input type="text" class="form-control" name="site" placeholder="Сайт">
                    </div>
                  </div>
                  <div class="form-group">
                    <textarea class="form-control" rows="5" name="mes" placeholder="Сообщение"></textarea>
                  </div>
                  <div class="form-row mb-5">
                    <div class="col-12">
                      <div class="g-recaptcha" data-sitekey="6LdlDHUkAAAAAGE4OT_9mYhklomjjPcrxo1UqBr2" data-theme="dark" data-callback="gResponceTrue"></div>
                      <div class="text-danger" id="recaptchaError"></div>
                      <input type="hidden" name="seyGoodBy" id="seyGoodBy" value="1">
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group col-sm-7 col-md-7 col-lg-8 col-xl-9">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="" id="check">
                        <label class="form-check-label" for="check">
                          Я подтверждаю свое согласие с <a href="privacy.html" target="_blank">Политикой обработки персональных данных</a>
                        </label>
                      </div>
                    </div>
                    <div class="form-group col-sm-5 col-md-5 col-lg-4 col-xl-3">
                      <div class="form-group">
                        <button type="submit" class="btn btn-primary send__button">Отправить</button>
                      </div>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-12">
              <div class="write_to_email">
                <p>Вы можете написать нам также и на электронную почту <strong><a href="" class="link__to__email"></a></strong></p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        <div class="row">
        <div class="col-12 col-sm-6 col-md-8 col-lg-6">
          <div class="copyright">
            <img src="img/header/logo.png" alt="Профессиональная рекламная платформа">
            <p>© 2018-2025 Punch Media Group</p>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-md-4 col-lg-6">
          <div class="contact">
            <ul class="list-inline">
              <li class="list-inline-item"><a href="" class="link__to__phone"></a></li>
              <li class="list-inline-item"><a href="" class="link__to__email"></a></li>
            </ul>
          </div>
        </div>
        </div>
      </div>
    </footer>

    <div class="position-fixed bottom-0 right-0 p-3" style="z-index: 5; right: 0; bottom: 0;">
      <div id="liveToast" class="toast hide" role="alert" aria-live="assertive" aria-atomic="true" data-delay="7000">
        <div class="toast-header">
          Ваше сообщение отправлено
          <button type="button" class="ml-4 mb-1 close" data-dismiss="toast" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
      </div>
    </div>
    <div class="position-fixed bottom-0 right-0 p-3" style="z-index: 5; right: 0; bottom: 0;">
      <div id="errorToast" class="toast hide" role="alert" aria-live="assertive" aria-atomic="true" data-delay="7000">
        <div class="toast-header">
          Ошибка! Данные не отправлены.
          <button type="button" class="ml-4 mb-1 close" data-dismiss="toast" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
      </div>
    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-Piv4xVNRyMGpqkS2by6br4gNJ7DXjqk09RmUpJ8jgGtD7zP9yug3goQfGII0yAns" crossorigin="anonymous"></script>
    <script src="js/jquery.maskedinput.min.js"></script>
    <script src="js/main.js"></script>
  </body>
</html>
