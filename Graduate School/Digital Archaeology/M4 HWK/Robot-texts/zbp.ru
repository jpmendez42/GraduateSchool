g#icon-eye_24-153cb3"></use></svg><span class="text_eiDCU">3 064</span></div><!----><button aria-label="Добавить в закладки" class="btn_eiDCU cell_eiDCU"><!--[--><svg width="24" height="24" class="size-6 bookmarkIcon_eiDCU"><use xlink:href="/svg/sprite-d488f5.svg#icon-bookmark_24-55b381"></use></svg><svg width="24" height="24" class="size-6 bookmarkIcon_eiDCU"><use xlink:href="/svg/sprite-d488f5.svg#icon-bookmark_added_24-d47d31"></use></svg><!--]--></button></div></div></div><!----></article><!----><!----><!----><!----><!----><!----><!----><!----></div><!--]--><!--]--><!--]--><!--[--><!----><!--[--><section class="baseBlock_Gymb4 grey_Gymb4 d-flex align-items-c flex-column w-100 large_seP2T gridFullMobile gridTwoThirdLaptop"><!--[--><a href="/text/theme/25415/" target="_self" class="header_Gymb4 text-style-title-5 mb-4">Спецоперация на Украине</a><!--]--><!--[--><div class="wrapper_0MwyC grey_0MwyC large_0MwyC"><div class="mainItemWrapper_0MwyC"><article class="wrapper_tmGRm primary_tmGRm grey_tmGRm large_tmGRm item_0MwyC"><a class="link_tmGRm" href="https://www.chita.ru/text/world/2025/10/13/76071964/" target="_blank"><div class="image_8k3Lo imgWrap_tmGRm"><picture class="imageWrap_8k3Lo" style="width:100%;"><!--[--><source media="all" type srcset="https://n1s1.hsmedia.ru/94/b1/4c/94b14c2e6bfb766a3508a7d70f41a9c3/600x400_0_0fff555a3455fd98470e070592fc0172@1920x1281_0xhYDN7Atb_6589458303200958963.jpg.webp 1x, https://n1s1.hsmedia.ru/94/b1/4c/94b14c2e6bfb766a3508a7d70f41a9c3/1200x800_0_de2f4578163c664e0858dd9d64deb4dd@1920x1281_0xhYDN7Atb_6589458303200958963.jpg.webp 2x"><!--]--><img src="https://n1s1.hsmedia.ru/94/b1/4c/94b14c2e6bfb766a3508a7d70f41a9c3/1920x1281_0xhYDN7Atb_6589458303200958963.jpg" class="" alt width="100%" loading="lazy"></picture><div class="label_8k3Lo"><!--[--><!--]--></div></div><div class="header_tmGRm maxLength_tmGRm">Был ранен, но продолжил выполнять задачи. Подполковник из Забайкалья получил сразу три госнаграды</div></a><div class="wrap_eiDCU light_eiDCU info_tmGRm"><div class="cell_eiDCU"><span class="text_eiDCU">8 часов</span></div><div class="btnBox_eiDCU"><div class="cell_eiDCU"><svg width="24" height="24" class="size-6 icon_eiDCU"><use xlink:href="/svg/sprite-d488f5.svg#icon-eye_24-153cb3"></use></svg><span class="text_eiDCU">1 551</span></div><a href="https://www.chita.ru/text/world/2025/10/13/76071964/comments/" class="cell_eiDCU comments_eiDCU" target="_self"><svg width="24" height="24" class="size-6 icon_eiDCU"><use xlink:href="/svg/sprite-d488f5.svg#icon-comments_24-6b332f"></use></svg><span class="text_eiDCU">7</span></a><!----></div></div></article></div><div class="tailItemsWrapper_0MwyC"><!--[--><article class="wrapper_tmGRm secondary_tmGRm grey_tmGRm large_tmGRm item_0MwyC"><a class="link_tmGRm" href="https://www.chita.ru/text/world/2025/10/12/76071012/" target="_blank"><!----><div class="header_tmGRm">Забайкалец из группировки «Восток» получил две госнаграды на СВО</div></a><!----></article><article class="wrapper_tmGRm secondary_tmGRm grey_tmGRm large_tmGRm item_0MwyC"><a class="link_tmGRm" href="https://www.chita.ru/text/world/2025/10/12/76070993/" target="_blank"><!----><div class="header_tmGRm">Брат-близнец из многодетной семьи Забайкалья погиб на СВО</div></a><!----></article><article class="wrapper_tmGRm secondary_tmGRm grey_tmGRm large_tmGRm item_0MwyC"><a class="link_tmGRm" href="https://www.chita.ru/text/world/2025/10/11/76070421/" target="_blank"><!----><div class="header_tmGRm">Забайкалец во время атаки украинских БПЛА наладил связь и смог вызвать подкрепление — за это получил медаль</div></a><!----></article><article class="wrapper_tmGRm secondary_tmGRm grey_tmGRm large_tmGRm item_0MwyC"><a class="link_tmGRm" href="https://www.chita.ru/text/world/2025/10/11/76070437/" target="_blank"><!----><div class="header_tmGRm">Замминистра обороны вручила медаль отцу Героя России из Забайкалья</div></a><!----></article><!--]--></div></div><!--]--></section><!--]--><!--]--><!--[--><!--