	var check_ready=function()
	{
		if (!isready)
		{
			do_ready();
		}
		
		if (document.readyState=="complete")
		{
			$(window).trigger("resize");
		}
		else
		{
			setTimeout(check_ready,500);
		}
	};

	$(document).ready(function()
	{
		check_ready();
	});
	


