.gform_wrapper {
    margin: 0;
    max-width: 100%;
}
.gform_wrapper .gf_page_steps {
    z-index: 9;
    width: 100%;
    margin: 0;
    border-bottom: 0;
    position: fixed;
    background-color: #1e242c;
    color: white;
    left: 0;
    top: 0;
    text-align: center;
    padding: 18px 0;
    background-repeat: no-repeat;
