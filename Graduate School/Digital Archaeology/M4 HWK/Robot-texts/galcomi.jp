}
*/
.contents_ttl_txt {
  color: #555;
  display: inline-block;
  font-weight: bold;
  margin-top: 4px;
  overflow: hidden;
  width: 100%;
  -webkit-box-orient: vertical;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-height: 1.1;
}




