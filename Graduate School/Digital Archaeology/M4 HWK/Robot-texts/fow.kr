           </div>            
            <input type="hidden" name="act" id="act" value="find"/>
            <input type="hidden" name="region" id="region" value="NA"/>
            <input type="text" name="field" id="field" autocomplete="off" placeholder="Player Search( PLAYER#KR1 )"/>
            <input type="submit" name="submit" id="submit" value=""/>
        </div>
        </FORM>
        <div class="toggle_lang"><div class="fbtn"></div></div>
        <div class="toggle_lang_select_container hidden">
