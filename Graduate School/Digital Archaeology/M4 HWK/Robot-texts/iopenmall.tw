            <!-- Aotter Trek -->
<script>
(function (w, d, s, src, n, pld) {
var js, ajs = d.getElementsByTagName(s)[0];
if (d.getElementById(n)) return;
js = d.createElement(s); js.id = n;
w[n] = w[n] || function () { (w[n].q = w[n].q || []).push(arguments) }; w[n].l = 1 * new Date();
w[n]('setEndPoint', pld && pld.endPoint, pld && pld.eventPoint);
js.async = 1; js.src = src; ajs.parentNode.insertBefore(js, ajs)
})(window, document, 'script', '/website/assets/js/iopen-sdk-1.0.1.min.js', 'AotterTrek', { endPoint: 'api/api.aottertrek_auctions.php', eventPoint: 'api/api.aottertrek_events.php' });

// 設定使用者
window.addEventListener("set_user", (e) => {
    if (e.detail?.user_id) {
        AotterTrek('setUser', e.detail?.user_id);
    }
});

// 加入購物車
window.addEventListener("add_to_cart", (e) => {
    if (e.detail?.items) {
        e.detail.items.forEach((item) => {
            AotterTrek('track', 'add_to_cart', {
                items: [{
                    attribution_id: item.attribution_id,
                    canonical_url: item.canonical_url,
                    content_name: item.content_name,
                    category: item.category_no,
                    keywords: item.keywords.split(','),
                    price: item.price,
                    quantity: e.detail?.quantity || 1,
                    currency: e.detail?.currency || 'TWD',
                }]
            });
        });
    }
});

// 結帳完成
window.addEventListener("purchase", (e) => {
    if (!e.detail.items || !Array.isArray(e.detail.items)) return;
    AotterTrek('track', 'purchase', {
        items: e.detail.items.reduce((arr, item) => {
            arr.push({
                order_id: item.order_id,
                attribution_id: item.attribution_id,
                canonical_url: item.canonical_url,
                content_name: item.content_name,
                category: item.category_no,
                keywords: item.keywords.split(','),
                price: item.price,
                quantity: item.quantity,
                currency: item.currency || 'TWD',
            });
            return arr;
        }, [])
    });
});


// 加載完成執行初始化
document.addEventListener("DOMContentLoaded", () => {
    AotterTrek('init', 'MwDOOz6QAjXOEyOtrry6');
});
</script>
<!-- End Aotter Trek -->                                    <!-----------------  Insider Code  ----------------->
