        var app = new Vue({
            el: '#app',
            data: {
                galleries: elements,
                cached_galleries: [],
                more_data: true,
                processing: false,
                elements_per_click: 36,
            },
	        updated: function () {
		        this.$nextTick(function () {
			        this.initThumbnails();
		        })
	        },
            methods: {
                appendElements: function () {
                    var counter = 0;
                    for (var f in this.cached_galleries) {
                        this.galleries.push({
                            media_format: this.cached_galleries[f].media_format,
                            url: this.cached_galleries[f].url,
                            thumbnail: this.cached_galleries[f].thumbnail,
                            video_thumbnail: this.cached_galleries[f].video_thumbnail,
                            duration: this.cached_galleries[f].duration,
                            title: this.cached_galleries[f].title,
                        });
                        counter++
                        if(counter >= this.elements_per_click){
                            break;
                        }
                    }
                    this.cached_galleries.splice(0, this.elements_per_click);
                    this.processing = false;
                },
                initThumbnails: function(){
                    $.videoThumbnail.init('.video-preview:not(.video_thumbnail_init) .video__container');
                    $('.video-preview:not(.video_thumbnail_init)').addClass('video_thumbnail_init');
                },
                buildMasonry: function(){

                },
                addGallery: function () {
                    this.processing = true;
                    if(this.cached_galleries.length >= this.elements_per_click){
                        this.appendElements()
                    }else {
                        $.ajax({
                            url: "/paysites/api/stranka.json"
                        })
                            .done(function (data) {
                                this.cached_galleries = this.cached_galleries.concat(data['results']);
                                this.appendElements();
                                this.api = "/paysites/api/stranka.json";
                            }.bind(this)).then(function () {
                                app.initThumbnails();
                        })
                    }
                },
	            getVideoQualityTag(media_format){
                	let tag;

                	if(media_format === 3 || media_format === 2){
                		tag = "HD";
	                }else if(media_format === 5){
                		tag = "5K";
	                }else{
                		tag = "4K";
	                }

		            return tag;
	            },
            },
            delimiters: ["[[", "]]"]
        })
