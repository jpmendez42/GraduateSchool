oft 365, téléphonie/VoIP, réseaux et support utilisateur. En tant que membre du groupe Sequotech, nous combinons expertise locale, infrastructures souveraines et engagements de service mesurables (SLA). Notre approche est pragmatique: architecture simple, coûts lisibles, et un point de contact unique pour votre IT au quotidien.","email":"info@evok.com","telephone":"+41 26 309 27 27","legalName":"Altern8 SA","foundingDate":"1998-01-01","vatID":"CHE-105.467.972 TVA","taxID":"CHE-105.467.972","numberOfEmployees":{"@type":"QuantitativeValue","minValue":"11","maxValue":"50"}}]}</script>
