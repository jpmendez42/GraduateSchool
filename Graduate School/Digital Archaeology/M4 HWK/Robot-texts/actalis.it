        var hosactalisservices = {"certificate_ajax_url":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/certificateajax","unknown_error":"Errore sconosciuto. Riprova.","certificate_reissue_url":"https:\/\/www.actalis.com\/it\/activate-certificate?c=certificate_placeholder_id&reissue=1","valid_domain_regex":"\/^(((?!-)[a-zA-Z0-9-]{1,63})\\.)+([a-zA-Z0-9-]{2,})$\/","valid_2_level_domain_regex":"\/^((?!-)[a-zA-Z0-9-]{1,63})\\.([a-zA-Z]{2,})$\/","valid_domain_regex_error_msg":"<span class=\"error-msg\"><b> Attenzione: <\/b> il dominio indicato non risulta corretto. Verifica e riprova.<\/span>","renew_certificate_url":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/renewcertificate","revoke_certificate_url":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/revokecertificate","cancel_certificate_url":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/cancelcertificate","render_certificate_url":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/rendercertificate","certificate_widgets_url":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/elementorcertificatewidgetsajax","cart_warranty_switcher":"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/cartwarranty","cart_qty_taylor_made_proposal_lowerbound":30,"cart_qty_taylor_made_proposal_title":"Hai bisogno di una proposta su misura? Contattaci.","cart_qty_taylor_made_proposal_description":"Hai aggiunto %qty% certificati al tuo carrello. Se lo desideri, possiamo trovare una soluzione personalizzata e in linea con le tue esigenze. In alternativa, procedi con l'acquisto.","cart_qty_taylor_made_proposal_confirm_label":"Continua","cart_qty_taylor_made_proposal_cancel_label":"Contattaci","copied_to_clipboard":"Copiato negli appunti","domains_cannot_be_changed_during_renew":"I domini non possono essere modificati durante il rinnovo del certificato","reissue_certificate_modal_title":"Riemissione del certificato","reissue_certificate_modal_content":"<div class=\"reissue-certificate-model-content\">\n    <div class=\"reissue-certificate-model-content-description\">\n        <div>\n            Il nuovo certificato avr\u00e0 la stessa data di scadenza di quello attuale e manterr\u00e0 i medesimi parametri di configurazione. Ti verr\u00e0 richiesta una nuova chiave CSR, diversa da quella del certificato precedente.\n        <\/div>\n    <\/div>\n<\/div>","reissue_certificate_modal_content_smime":"<div class=\"reissue-certificate-model-content\">\n    <div class=\"reissue-certificate-model-content-description\">\n        <div>\n            Il nuovo certificato avr\u00e0 la stessa data di scadenza di quello attuale e manterr\u00e0 i medesimi parametri di configurazione.\n        <\/div>\n    <\/div>\n<\/div>","revoke_certificate_modal_title":"Revoca certificato","revoke_certificate_modal_content":"<div class=\"revoke-certificate-model-content\">\n    <div class=\"revoke-certificate-model-content-description\">\n        <p>\n            La revoca del certificato causer\u00e0 la sua definitiva cancellazione. Non potrai pi\u00f9 recuperarlo ma sar\u00e0 necessaria una nuova emissione.\n        <\/p>\n        <p>\n            Confermando la revoca entro 14 giorni dalla data dell'acquisto, riceverai automaticamente un rimborso pari al costo del servizio sullo stesso metodo di pagamento utilizzato per l'acquisto.\n                    <\/p>\n    <\/div>\n\n    <div class=\"revoke-reason\">\n        <span class=\"revoke-reason-title\">\n            Perch\u00e9 vuoi cancellare il certificato?\n        <\/span>\n        <div class=\"revoke-reason-options\">\n            <div class=\"form-group\">\n                <div class=\"custom-select2\">\n                    <select class=\"form-control form-control-select\" name=\"revoke_reason\">\n                        <option value=\"none\">Scegli tra le opzioni disponibili<\/option>\n                                                    <option value=\"R0\">Preferisco non dirlo<\/option>\n                                                    <option value=\"R1\">Ho problemi con la chiave privata (persa, compromessa, rubata, ecc)<\/option>\n                                                    <option value=\"R3\">Alcune informazioni nel certificato non sono pi\u00f9 valide<\/option>\n                                                    <option value=\"R4\">La richiesta del certificato non \u00e8 andata a buon fine (errore o non autorizzata)<\/option>\n                                                    <option value=\"R5\">Il certificato non \u00e8 pi\u00f9 necessario o contiene informazioni errate<\/option>\n                                            <\/select>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <div class=\"other-reason\">\n            <span class=\"revoke-reason-title\">\n                Altro:\n            <\/span>\n            <div class=\"form-group\">\n                <input type=\"text\" class=\"form-control\" placeholder=\"Spiegare la motivazione\">\n            <\/div>\n        <\/div>\n    <\/div>\n\n    <span class=\"confirm-title\">\n        Confermi di voler revocare questo certificato?\n    <\/span>\n<\/div>","revoke_certificate_modal_content_plan":"<div class=\"revoke-certificate-model-content\">\n    <div class=\"revoke-certificate-model-content-description\">\n        <p>\n            Se revochi il certificato non potrai pi\u00f9 usarlo e continuer\u00e0 ad occupare spazio all'interno del piano.\n        <\/p>\n    <\/div>\n    <div class=\"revoke-reason\">\n        <span class=\"revoke-reason-title\">\n            Perch\u00e9 vuoi cancellare il certificato?\n        <\/span>\n        <div class=\"revoke-reason-options\">\n            <div class=\"form-group\">\n                <div class=\"custom-select2\">\n                    <select class=\"form-control form-control-select\" name=\"revoke_reason\">\n                        <option value=\"none\">Scegli tra le opzioni disponibili<\/option>\n                                                    <option value=\"R0\">Preferisco non dirlo<\/option>\n                                                    <option value=\"R1\">Ho problemi con la chiave privata (persa, compromessa, rubata, ecc)<\/option>\n                                                    <option value=\"R3\">Alcune informazioni nel certificato non sono pi\u00f9 valide<\/option>\n                                                    <option value=\"R4\">La richiesta del certificato non \u00e8 andata a buon fine (errore o non autorizzata)<\/option>\n                                                    <option value=\"R5\">Il certificato non \u00e8 pi\u00f9 necessario o contiene informazioni errate<\/option>\n                                            <\/select>\n                <\/div>\n            <\/div>\n        <\/div>\n\n        <div class=\"other-reason\">\n            <span class=\"revoke-reason-title\">\n                Altro:\n            <\/span>\n            <div class=\"form-group\">\n                <input type=\"text\" class=\"form-control\" placeholder=\"Spiegare la motivazione\">\n            <\/div>\n        <\/div>\n    <\/div>\n\n    <span class=\"confirm-title\">\n        Confermi di voler revocare questo certificato?\n    <\/span>\n<\/div>","cancel_certificate_modal_content":"<div class=\"cancel-certificate-model-content\">\n    <div class=\"cancel-certificate-model-content-description\">\n        <p>\n            Confermando la cancellazione, riceverai automaticamente un rimborso pari al costo del servizio sullo stesso metodo di pagamento utilizzato per l'acquisto, solo se questo \u00e8 stato effettuato negli ultimi 12 mesi.\n        <\/p>\n    <\/div>\n\n    <span class=\"confirm-title\">\n        Confermi di voler cancellare questo servizio?\n    <\/span>\n<\/div>","cancel_certificate_modal_content_plan":"<div class=\"cancel-certificate-model-content\">\n    <div class=\"cancel-certificate-model-content-description\">\n        <p>\n            Se confermi, la richiesta di attivazione del certificato verr\u00e0 annullata e lasci lo spazio per la richiesta di nuovi certificati.\n        <\/p>\n    <\/div>\n\n    <span class=\"confirm-title\">\n        Confermi di voler cancellare?\n    <\/span>\n<\/div>","error_during_revoke_request_title":"Si \u00e8 verificato un errore nell'invio della tua richiesta.","error_during_revoke_request_description":"Riprova pi\u00f9 tardi.","error_during_cancel_request_title":"Si \u00e8 verificato un errore nell'invio della tua richiesta.","error_during_cancel_request_description":"Riprova pi\u00f9 tardi.","success_during_cancel_request_title":"Il servizio \u00e8 stato cancellato","success_during_cancel_request_url":"https:\/\/www.actalis.com\/it\/termini-e-condizioni","success_during_cancel_request_url_title":"Termini e condizioni","revoke_request_sent_title":"Richiesta inviata","cancel_request_title":"Cancellazione del servizio","cancel_request_title_plan":"Annulla la richiesta di certificato","revoke_request_sent_description":"La richiesta di revoca del servizio \u00e8 avvenuta correttamente.","confirm_reissue_btn_label":"Procedi con la riemissione","confirm_btn_label":"Conferma","cancel_btn_label":"Annulla","add_new_certificate_modal_title":"Aggiungi nuovo certificato","add_new_certificate_modal_button_1":"Annulla","add_new_certificate_modal_button_2":"Conferma","add_standalone_certificate_to_plan_modal_title":"Vuoi aggiungere un certificato al tuo piano?","add_standalone_certificate_to_plan_modal_description":"Hai ancora spazio per aggiungere altri certificati al tuo piano.","add_standalone_certificate_to_plan_modal_button_1":"Aggiungi certificato","add_standalone_certificate_to_plan_modal_button_2":"Continua senza aggiungere","wizard_content":"\n    <div class=\"wizard-step\">\n        \n        <div class=\"wizard-step-content\">\n            \n                <div class=\"wizard-step-content-info\">\n                    \n    <div class=\"wizard-step-content-info-icons\">\n        <span class=\"wizard-step-content-info-icon wizard-step-content-info-icon-personal\"><\/span>\n        <span class=\"wizard-step-content-info-icon wizard-step-content-info-icon-small-business\"><\/span>\n        <span class=\"wizard-step-content-info-icon wizard-step-content-info-icon-large-business\"><\/span>\n    <\/div>\n    <div class=\"wizard-step-content-info-title\">\n        Trova il certificato SSL adatto alle tue esigenze\n    <\/div>\n    <div class=\"wizard-step-content-info-content\">\n        Rispondi a poche domande e ti aiutiamo a scegliere la soluzione pi\u00f9 in linea con i tuoi bisogni.\n    <\/div>\n\n                <\/div>\n                <div class=\"wizard-step-content-options\">\n                    \n            <span class=\"step_content_options_title\">Per quale tipo di sito web ti serve il certificato SSL?<\/span>\n        <div class=\"step_content_options_form\">\n            \n    \n            \n    <form action=\"https:\/\/www.actalis.com\/it\/module\/hosactalisservices\/wizard\" id=\"wizard-form\" class=\"js-ca-form vertical-form\" method=\"post\">\n        \n            <div>\n                \n                                            \n                            \n    \n        <input type=\"hidden\" name=\"wizard_data\" value=\"[]\">\n    \n\n\n                        \n                                            \n                            \n    \n        <input type=\"hidden\" name=\"active_step\" value=\"site_type\">\n    \n\n\n                        \n                                            \n                                    \n    <div  class=\"form-group row align-items-center  \">\n                                    <label class=\"col-md-2 col-form-label required\" for=\"field-site_type\">\n                                            \n                                                        <\/label>\n                    \n        <div class=\"col-md-8 js-input-column form-control-valign form-control-valign\">\n\n            \n                \n                                            <label class=\"radio-inline\">\n                            <span class=\"custom-radio\">\n                                <input\n                                        name=\"site_type\"\n                                        type=\"radio\"\n                                        value=\"personal\"\n                                        required                                         checked                                 >\n                                <span><\/span>\n                            <\/span>\n                            <span class=\"custom-radio-label\">Blog e piccoli siti web personali<\/span>\n                        <\/label>\n                                            <label class=\"radio-inline\">\n                            <span class=\"custom-radio\">\n                                <input\n                                        name=\"site_type\"\n                                        type=\"radio\"\n                                        value=\"small_business\"\n                                        required                                                                        >\n                                <span><\/span>\n                            <\/span>\n                            <span class=\"custom-radio-label\">E-commerce piccoli e medi<\/span>\n                        <\/label>\n                                            <label class=\"radio-inline\">\n                            <span class=\"custom-radio\">\n                                <input\n                                        name=\"site_type\"\n                                        type=\"radio\"\n                                        value=\"large_business\"\n                                        required                                                                        >\n                                <span><\/span>\n                            <\/span>\n                            <span class=\"custom-radio-label\">Top e-commerce e siti web di gradi aziende<\/span>\n                        <\/label>\n                                    \n\n            \n            \n                            \n\n            \n            \n            \n            \n        <\/div>\n\n        <div class=\"col-md-2 form-control-comment\">\n            \n                            \n        <\/div>\n    <\/div>\n\n    \n\n                        \n                                    \n            <\/div>\n        \n        \n    <\/form>\n\n        <\/div>\n    \n                <\/div>\n            \n        <\/div>\n        \n        <div class=\"navigation-block\">\n            <div class=\"navigation-block-prev\">\n                            <\/div>\n                            <div class=\"wizard-step-timeline few-steps-mode  \">\n                                                                <span class=\"active-step current-step\">\n                        <span><span>Tipologia sito<\/span><\/span>\n                         <span class=\"timeline-progress\"><\/span>                    <\/span>\n                                                                    <span class=\"not-active-step\">\n                        <span><span>Quantit\u00e0 siti<\/span><\/span>\n                         <span class=\"timeline-progress\"><\/span>                    <\/span>\n                                                                    <span class=\"not-active-step\">\n                        <span><span>Garanzia<\/span><\/span>\n                         <span class=\"timeline-progress\"><\/span>                    <\/span>\n                                                                    <span class=\"not-active-step\">\n                        <span><span>Esito<\/span><\/span>\n                         <span class=\"timeline-progress\"><\/span>                    <\/span>\n                                                            <\/div>\n                        <div class=\"navigation-block-next\">\n                                    <button class=\"btn btn-primary\">Avanti<\/button>\n                            <\/div>\n        <\/div>\n    <\/div>\n"};
