T22:00:00.000Z\",\"title\":\"World Sport\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"world-sport-97579479\",\"channelId\":\"23\"},{\"id\":\"97579480\",\"start\":\"2025-10-13T22:00:00.000Z\",\"stop\":\"2025-10-13T23:00:00.000Z\",\"title\":\"The Brief with Jim Sciutto\",\"description\":\"\",\"durationMin\":60,\"genre\":null,\"slug\":\"the-brief-with-jim-sciutto-97579480\",\"channelId\":\"23\"},{\"id\":\"97579481\",\"start\":\"2025-10-13T23:00:00.000Z\",\"stop\":\"2025-10-14T00:00:00.000Z\",\"title\":\"Erin Burnett OutFront\",\"description\":\"\",\"durationMin\":60,\"genre\":null,\"slug\":\"erin-burnett-outfront-97579481\",\"channelId\":\"23\"}],\"24\":[{\"id\":\"97326974\",\"start\":\"2025-10-13T00:00:00.000Z\",\"stop\":\"2025-10-13T00:10:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":10,\"genre\":9,\"slug\":\"zpravy-97326974\",\"channelId\":\"24\"},{\"id\":\"97326975\",\"start\":\"2025-10-13T00:10:00.000Z\",\"stop\":\"2025-10-13T00:34:00.000Z\",\"title\":\"Studio ČT24\",\"description\":\"\",\"durationMin\":24,\"genre\":9,\"slug\":\"studio-ct24-97326975\",\"channelId\":\"24\"},{\"id\":\"97326976\",\"start\":\"2025-10-13T00:34:00.000Z\",\"stop\":\"2025-10-13T01:00:00.000Z\",\"title\":\"Zajímavosti z regionů\",\"description\":\"\",\"durationMin\":26,\"genre\":9,\"slug\":\"zajimavosti-z-regionu-97326976\",\"channelId\":\"24\"},{\"id\":\"97326977\",\"start\":\"2025-10-13T01:00:00.000Z\",\"stop\":\"2025-10-13T01:10:00.000Z\",\"title\":\"Zprávy\",\"description\":\"\",\"durationMin\":10,\"genre\":9,\"slug\":\"zpravy-97326977\",\"channelId\":\"24\"},{\"id\":\"97326978\",\"start\":\"2025-10-13T01:10:00.000Z\",\"stop\":\"2025-10-13T01:34:00.000Z\",\"title\":\"Studio ČT24\",\"description\":\"\",\"durationMin\":24,\"genre\":9,\"slug\":\"studio-ct24-97326978\",\"channelId\":\"24\"},{\"id\":\"97326979\",\"start\":\"2025-10-13T01:34:00.000Z\",\"stop\":\"2025-10-13T02:00:00.000Z\",\"title\":\"Zajímavosti z regionů\",\"description\":\"\",\"