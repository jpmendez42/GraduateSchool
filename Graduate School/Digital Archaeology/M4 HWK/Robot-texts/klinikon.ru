1365811718865508517' data-elem-id='1718865508517' data-elem-type='text' data-field-top-value="89" data-field-left-value="605" data-field-height-value="17" data-field-width-value="99" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-textfit-value="autoheight"> <div class='tn-atom'><a href="/blog"style="color: inherit">Блог</a></div> </div> <div class='t396__elem tn-elem tn-elem__13001365811722870927829' data-elem-id='1722870927829' data-elem-type='image' data-field-top-value="5" data-field-left-value="630" data-field-height-value="15" data-field-width-value="35" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-field-filewidth-value="52" data-field-fileheight-value="23" data-field-heightmode-value="hug"> <div class='tn-atom'> <img class='tn-atom__img t-img' data-original='https://static.tildacdn.com/tild3730-6138-4230-b132-346337643132/Polygon-menu.svg'
src='https://static.tildacdn.com/tild3730-6138-4230-b132-346337643132/Polygon-menu.svg'
alt='' imgfield='tn_img_1722870927829'
/> </div> </div> </div> </div> <script>t_onFuncLoad('t396_initialScale',function() {t396_initialScale('1300136581');});t_onReady(function() {t_onFuncLoad('t396_init',function() {t396_init('1300136581');});});</script> <!-- /T396 --> </div> <div id="rec1300762971" class="r t-rec" style=" " data-animationappear="off" data-record-type="131"> <!-- T123 --> <div class="t123"> <div class="t-container_100 "> <div class="t-width t-width_100 "> <!-- nominify begin --> <!-- ВСПЛЫВАЮЩЕЕ МЕНЮ "БЛОГ" для #menu7 (независимое) --> <style>
  :root {
    --blog-z: 999998;
    --blog-top: 80px; /* скрипт обновит по высоте .uc-menu */
    --blog-bg: #fff;
    --blog-border: #e9ecf1;
    --blog-shadow: 0 12px 30px rgba(0,0,0,.08);
    --blog-radius: 14px;
    --blog-pad: 20px;
  }

  /* Контейнер всплывающего меню */
  #blog-sub {
    position: fixed;
    left: 0;
    top: var(--blog-top);
    width: 100%;
    z-index: var(--blog-z);
    pointer-events: none;
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity .2s ease, transform .2s ease;
  }
  #blog-sub.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Внутренняя панель (минимальные стили, не ломают твой HTML) */
  #blog-sub .blog-panel {
    margin: 0 auto;
    max-width: 1200px; /* при необходимости подгони */
    background: var(--blog-bg);
    border: 1px solid var(--blog-border);
    border-radius: var(--blog-radius);
    box-shadow: var(--blog-shadow);
    padding: var(--blog-pad);
  }
</style> <!-- ВСПЛЫВАЮЩЕЕ МЕНЮ: контейнер --> <div id="blog-sub" aria-hidden="true"> <div class="blog-panel"> <!-- ВСТАВЬ СВОЙ ГОТОВЫЙ HTML ПОДПУНКТОВ НИЖЕ (без примеров) --> <!-- ↓↓↓ --> <!-- ↑↑↑ --> </div> </div> <script>
(function($){
  const BLOG_HREF = '#menu7';        // пункт меню «Блог»
  const MENU_CONTAINER = '.uc-menu'; // контейнер шапки

  const $doc = $(document);
  const $panel = $('#blog-sub');

  let $trigger = null;

  function getHeaderHeight() {
    const $menu = $(MENU_CONTAINER);
    const h = $menu.length ? $menu.outerHeight() : 80;
    return h || 80;
  }

  function positionPanel() {
    $panel.css('top', getHeaderHeight() + 'px');
  }

  function openPanel() {
    positionPanel();
    if ($trigger && $trigger.length) $trigger.addClass('active');
    $panel.addClass('active').attr('aria-hidden', 'false');
    if (typeof window.t_lazyload_update === 'function') window.t_lazyload_update();
  }

  function closePanel() {
    if ($trigger && $trigger.length) $trigger.removeClass('active');
    $panel.removeClass('active').attr('aria-hidden', 'true');
  }

  // Снять старый hover-обработчик, чтобы не конфликтовал с этим блоком
  function detachOldHover() {
    const $item = $(MENU_CONTAINER + ' .menu-btn[href="' + BLOG_HREF + '"]');
    $item.off('mouseenter mouseleave'); // снимаем любые навешанные hover-события
  }

  // Открытие по ховеру
  $doc.on('mouseenter', MENU_CONTAINER + ' .menu-btn[href="' + BLOG_HREF + '"]', function(){
    $trigger = $(this);
    openPanel();
  });

  // Тап/клик — переключатель (на мобилке)
  $doc.on('click', MENU_CONTAINER + ' .menu-btn[href="' + BLOG_HREF + '"]', function(e){
    e.preventDefault(); // убери, если нужен переход по ссылке
    $trigger = $(this);
    if ($panel.hasClass('active')) closePanel(); else openPanel();
  });

  // Закрытие: уход курсора с панели
  $panel.on('mouseleave', closePanel);

  // Клик вне панели — закрыть
  $doc.on('click', function(e){
    const $t = $(e.target);
    if ( !$t.closest('#blog-sub').length &&
         !$t.closest(MENU_CONTAINER + ' .menu-btn[href="' + BLOG_HREF + '"]').length ) {
      closePanel();
    }
  });

  // Скролл/resize/ESC — закрыть (и обновить позицию)
  $(window).on('scroll resize', function(){
    positionPanel();
    closePanel();
  });
  $doc.on('keyup', function(e){
    if (e.key === 'Escape') closePanel();
  });

  // Инициализация
  $(function(){
    detachOldHover();
    positionPanel();
  });
})(jQuery);
</script> <!-- nominify end --> </div> </div> </div> </div> <div id="rec843823817" class="r t-rec" style=" " data-animationappear="off" data-record-type="396"> <!-- T396 --> <style>#rec843823817 .t396__artboard {min-height:330px;height:100vh;}#rec843823817 .t396__filter {min-height:330px;height:100vh;}#rec843823817 .t396__carrier{min-height:330px;height:100vh;background-position:center center;background-attachment:scroll;background-size:cover;background-repeat:no-repeat;}@media screen and (max-width:1199px) {#rec843823817 .t396__artboard,#rec843823817 .t396__filter,#rec843823817 .t396__carrier {}#rec843823817 .t396__filter {}#rec843823817 .t396__carrier {background-attachment:scroll;}}@media screen and (max-width:959px) {#rec843823817 .t396__artboard,#rec843823817 .t396__filter,#rec843823817 .t396__carrier {min-height:290px;}#rec843823817 .t396__filter {}#rec843823817 .t396__carrier {background-attachment:scroll;}}@media screen and (max-width:639px) {#rec843823817 .t396__artboard,#rec843823817 .t396__filter,#rec843823817 .t396__carrier {min-height:270px;}#rec843823817 .t396__filter {}#rec843823817 .t396__carrier {background-attachment:scroll;}}@media screen and (max-width:479px) {#rec843823817 .t396__artboard,#rec843823817 .t396__filter,#rec843823817 .t396__carrier {min-height:340px;}#rec843823817 .t396__filter {}#rec843823817 .t396__carrier {background-attachment:scroll;}}#rec843823817 .tn-elem[data-elem-id="1734877244229"] {z-index:3;top:calc(50vh - 165px + 10px);left:calc(50% - 600px + 330px);width:540px;height:306px;}#rec843823817 .tn-elem[data-elem-id="1734877244229"] .tn-atom {border-radius:30px 30px 30px 30px;background-color:#333333;background-position:center center;border-color:transparent ;border-style:solid;}@media screen and (max-width:1199px) {#rec843823817 .tn-elem[data-elem-id="1734877244229"] {display:table;top:10px;left:calc(50% - 480px + 210px);width:540px;height:306px;}}@media screen and (max-width:959px) {#rec843823817 .tn-elem[data-elem-id="1734