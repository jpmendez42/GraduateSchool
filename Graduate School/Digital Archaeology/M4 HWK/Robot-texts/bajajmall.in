  <!-- JS to handle fade -->
  <script>
    const pageTypeSkel = document.querySelector('.global-dataset-wrapper')?.getAttribute('data-pageType');
    let skelPageTimeout = 0;
    if (pageTypeSkel && (pageTypeSkel.includes('emi') || pageTypeSkel.includes('brand') || pageTypeSkel.includes('dsf'))) {
      skelPageTimeout = 2000;
    }
    function fadeOutSkeleton(skeletonEl, contentEl) {
      if (!skeletonEl || !contentEl) return;
      skeletonEl.style.transition = `opacity 50ms ease`;
      setTimeout(() => {
        skeletonEl.style.opacity = '0';
      }, skelPageTimeout)
      skeletonEl.addEventListener('transitionend', () => {
        skeletonEl.style.display = 'none';
        contentEl.style.visibility = 'visible';
        contentEl.style.opacity = '1';
      }, { once: true });
    }

    document.addEventListener('DOMContentLoaded', () => {
      fadeOutSkeleton(
        document.getElementById('outer-parsys-skeleton'),
        document.getElementById('outer-parsys-content')
      );

      fadeOutSkeleton(
        document.getElementById('mainFludeContent-skeleton'),
        document.getElementById('mainFludeContent-real')
      );

      document.getElementById("mainFludeContent-real")?.classList.remove('hidden');
      setTimeout(() => {
        document.querySelector(".footer-exp")?.classList.remove('hidden');
      }, 2000);
    });
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        document.querySelectorAll('.skeleton-comp').forEach(wrapper => {
          const skeleton = wrapper.querySelector('.common-skeleton');
          const content = wrapper.querySelector('.common-content');
          if (skeleton && content) {
            if (content.classList.contains('hero-banner-skeleton')) {
              setTimeout(() => {
                skeleton.style.display = 'none';
                content.style.visibility = 'visible';
                content.style.opacity = '1';
              }, 3000);
              setTimeout(() => {
                content.classList.remove('hero-banner-skeleton');
              }, 4000);
            } else {
              skeleton.style.display = 'none';
              content.style.visibility = 'visible';
              content.style.opacity = '1';
            }
            setTimeout(() => {
              content.style.height = '';
              content.classList.remove('offer-banner-skeleton');
              content.classList.remove('mi-height');
              content.classList.remove('top-offer-banner-plp-skeleton');
              content.classList.remove('total-savings-skeleton');
              content.classList.remove('dealer-title-desc-skeleton');
            }, 2000);
            setTimeout(() => {
              content.classList.remove('dsf-dealer-title-desc-skeleton');
            }, 500);
          }
        });
      }, 200);
    });
  </script>


    
  


