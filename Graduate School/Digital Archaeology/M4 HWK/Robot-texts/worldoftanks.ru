                countdownSelector: '.js-card-time-end',
                countdownFinishedClass: 'card_tag__bordered',
                countdownHiddenClass: 'card_tag__hidden',
                countdownFinishedText: "Завершено",
                countdownText: "Осталось: %(time)s"
            });
        }

        if (typeof SpecialOffersWidget === 'function' && typeof CardBanner === 'function') {
            initWidget();
        } else {
            $.getScript('//eu-wotp.wgcdn.co/static/6.11.0_9b6f5a/portal/js/card_banner.js', function() {
                $.getScript('//eu-wotp.wgcdn.co/static/6.11.0_9b6f5a/specials/js/special_offers_widget.js', function() {
                    initWidget();
                });
            });
        }
    })();
</script>
        

