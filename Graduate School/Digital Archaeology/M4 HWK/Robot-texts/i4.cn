  <script>
    $('.download-modal-close').on('click', (e) => {
      e.preventDefault();
      $('.download-modal').removeClass('show');
      $('body').css('overflow', 'auto');
    });
	$(document).ready(function() {
		$('.iapp-download-modal-yk .download-pro-item').on('mouseenter', function() {
		  var index = $(this).index();
		  console.log(index)
		  $(this).addClass('active').siblings().removeClass('active');
		  $('.iapp-download-desic-yk .iapp-desic-item').eq(index).addClass('active').siblings().removeClass('active');
		  $('.iapp-download-desic-yk .sj').css({
		    'left': (((120+24) * index) + 60 )  + 'px'
		  });
		});
	});

    // 适用状态
    var ua = window.navigator.userAgent.toLowerCase();
    // 系统位数
    var x86_x64 = ua.match(/x86_64|win64|wow64/) || navigator.cpuClass === 'x64' ? 'x64' : 'x86';
    // 系统
    var winMac = /Macintosh|Mac OS X/.test(navigator.userAgent) ? 'mac' : 'win';

    if(winMac == 'win') {
		if(x86_x64==='x32'){
			$('.iapp-item-btn-yk .link-btn .tips32').show()
		}else{
			$('.iapp-item-btn-yk .link-btn .tips64').show()
		}
    } else {
			$('.iapp-download-desic-yk .tips-remote-label').show()
    }
  </script>

  
  <script>
    $(document).ready(() => {
      // ********** Swiper Banner **********
      function updateActiveOverlay(swiper) {
        const currentIndex = swiper.realIndex;
        document.querySelectorAll('.swiper-banner .banner-down-wrap').forEach(overlay => {
          overlay.classList.remove('active');
          if (parseInt(overlay.dataset.index) === currentIndex) {
            overlay.classList.add('active');
          }
        });
      }
      const mySwiper = new Swiper('.swiper-banner', {
        loop: true, // 循环模式选项
        effect: 'fade',
        speed: 1000,
        autoplay: {
          delay: 3000,
          pauseOnMouseEnter: true
        },
        
        // 分页器
        pagination: {
          el: '.swiper-pagination',
          clickable: true
        },
        on: {
          // 初始化和滑动时更新覆盖元素显示状态
          init: function() {
            updateActiveOverlay(this);
          },
          slideChange: function() {
            updateActiveOverlay(this);
          },
          slideChangeTransitionStart: function() {
            if (this.realIndex === 1) {
              $('.head-content').addClass('head-light');
            } else {
              $('.head-content').removeClass('head-light');
            }
          }
        }
      });

      // banner 下载适用状态
      var ua = window.navigator.userAgent.toLowerCase();
      // 系统位数
      var x86_x64 = ua.match(/x86_64|win64|wow64/) || navigator.cpuClass === 'x64' ? 'x64' : 'x86';
      // 系统
      var winMac = /Macintosh|Mac OS X/.test(navigator.userAgent) ? 'mac' : 'win';

      if(winMac == 'win') {
        $('.swiper-banner-content .banner-down-wrap .item.'+winMac+'.'+x86_x64 + ' .item-title .tag').addClass('tag-local').find('i').html('(适用于本机)')
      } else {
        // $('#downloadByAideModal .download-pro-list').find('.item.'+winMac+' .item-title .tag').addClass('tag-local').find('i').html('(适用于本机)')
      }
    });
  </script>
