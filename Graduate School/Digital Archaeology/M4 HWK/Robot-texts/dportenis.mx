    border-color: #333;
  }

  .botones {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
  }

    @media (max-width: 768px) {
        .texto-botones{
            margin-top: 0%;
            display:block;
        }
    }
