    ">
        <span>How We Help</span>
        <svg width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            class="group-open:rotate-180 transition-transform duration-300"
