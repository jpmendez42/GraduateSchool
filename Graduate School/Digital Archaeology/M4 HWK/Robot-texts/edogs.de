<script src="/bundles/scripts/fulltextsearchsuggestions?v=IRx39zo-rMq_vRGprCSvwivRXWGsz08dCyA9jrDIGzg1"></script>

<script>
	$(document).ready(function () {
		var fulltext = $('#FulltextSB');
		var categorie = $('#KategorieSB');
		var zip = $('#PlzSB');
		var area = $('#UmkreisSB');

		fulltext.keypress(function (e) {
			if (e.which == 13) {
				SubmitForm();
			}
		});

		if (fulltext.val().length > 0 || categorie.val() !== "" || zip.val() > 0 || area.val() != 9999) {
			GetSearchCount();
		}

		$('#sb-btn-text, #sb-btn-text-mobile').click(function() {
			SubmitForm();
		});

		$('#FulltextSB, #PlzSB').on("paste keyup", function () {
			GetSearchCount();
		});

		$('#KategorieSB, #UmkreisSB').change(function () {
			GetSearchCount();
		});
	});

	function selectFTsuggestion(obj) {
		$("#FulltextSB").val($(obj).text());
		GetSearchCount();
		$(".ft_suggest").hide();
	}

	function SubmitForm() {
		if ($(window).width() >= 988) {
			$('#sb-btn-text').html("Bitte warten ...");
		}

		$('#searchBar').submit();
	}

	function GetSearchCount() {
		var query = "";

		$('#searchBar input, #searchBar select').each(function (i, e) {
			query = query + '&' + $(e).attr('name') + '=' + $(e).val();
		});

		GetSearchCountCall(query);
	}

	function GetSearchCountCall(query) {
		if ($(window).width() >= 988) {
			$('#sb-btn-text').html("Bitte warten ...");
		}

		$.ajax({
			url: "/search/getsearchcount?dum=dum" + query,
			success: function (response) {
				$('#sb-btn-text, #sb-btn-text-mobile').html(response + " Treffer");
			}
		});
	}
</script>
