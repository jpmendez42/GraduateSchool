    $('.js-share-btn').on('click', (e) => {
        e.preventDefault();

        let socialShareDiv = $('.social-share-wrapper');

        if (socialShareDiv.hasClass('d-none'))
            socialShareDiv.removeClass('d-none');
        else
            socialShareDiv.addClass('d-none');
