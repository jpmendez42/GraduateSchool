    <!-- Styles -->
    <link href="https://visicomdata.com/css/main.css" rel="stylesheet">
        <style>
            /* звичайний клас зображення з фоном, що можна змінити */
            .lazy {
                #background-color: #eee;
                transition: opacity 0.3s ease-in-out;
            }

            /* клас-модифікатор, що встановлює прозорість на 0 для елементів, що не знаходяться у видимому полі зору */
            .lazy.loaded {
                opacity: 1;
            }
        </style>

    <!-- Scripts -->
    <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script defer id="js-global" src="https://visicomdata.com/js/global.js"></script>
    <script defer src="https://visicomdata.com/vendor/alpinejs/dist/cdn.min.js"></script>
    <script defer src="https://visicomdata.com/js/main.js"></script>
        <script>
            // вибрати всі елементи з класом "lazy"
            const lazyImages = document.querySelectorAll('.lazy');

            // опції Intersection Observer API
            const options = {
                rootMargin: '0px',
                threshold: 0.1
            };

            // функція завантаження зображення
            function loadImage(image) {
                image.src = image.dataset.src;
                image.classList.add('loaded');
            }

            // створюємо новий observer
            const observer = new IntersectionObserver(function (entries, self) {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        // застосовуємо функцію завантаження для вхідного елемента
                        loadImage(entry.target);
                        // видаляємо спостереження для даного елементу
                        self.unobserve(entry.target);
                    }
                });
            }, options);

            // проходимо крізь кожен елемент
            lazyImages.forEach(image => {
                observer.observe(image);
            });

        </script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('noty', () => ({
                show: false,
                message: '',

                init () {
                    window.addEventListener('notify', (e) => {
                        this.show = true
                        this.message = e.detail.message
                    })

                    this.$watch('show', () => {
                        let _self = this

                        setTimeout(function () {
                            _self.show = false
                        }, 3500)
                    })
                },
            }))

            Alpine.data('subscribe', () => ({
                email: '',
                errors: {},
                loading: false,

                init() {
                    this.$watch('email', () => delete this.errors.email)
                },

                submit() {
                    this.loading = true

                    let data = new FormData()

                    data.append('email', this.email)
                    data.append('locale', 'en')

                    fetch('/subscribe', {
                            method: 'POST',
                            headers: {
                                'Accept': 'application/json',
                                'X-CSRF-TOKEN': 'zCoIxKwzFra9yOwnujZ0QEfERAx192Cm9YJLnIYU'
                            },
                            body: data
                        })
                        .then((response) => response.json())
                        .then((data) => {
                            this.errors = data.errors || {}

                            if (data.success) {
                                this.email = null
                                this.$dispatch('notify', { message: data.message })
                            }
                        })
                        .catch((error) => console.log(error))
                        .then(() => this.loading = false)
                }
            }))

            Alpine.data('contact', () => ({
                name: '',
                company: '',
                email: '',
                message: '',
                errors: {},
                loading: false,

                init() {
                    this.$watch('name', () => delete this.errors.name)
                    this.$watch('company', () => delete this.errors.company)
                    this.$watch('email', () => delete this.errors.email)
                },

                submit() {
                    this.loading = true

                    let data = new FormData()

                    data.append('name', this.name)
                    data.append('company', this.company)
                    data.append('email', this.email)
                    data.append('message', this.message)
                    data.append('url', window.location)

                    fetch('/contact-us', {
                            method: 'POST',
                            headers: {
                                'Accept': 'application/json',
                                'X-CSRF-TOKEN': 'zCoIxKwzFra9yOwnujZ0QEfERAx192Cm9YJLnIYU'
                            },
                            body: data
                        })
                        .then((response) => response.json())
                        .then((data) => {
                            let _self = this

                            this.errors = data.errors || {}

                            if (data.success) {
                                this.name = this.company = this.email = this.message = ''

                                document.getElementById('contact-popup').classList.remove('active')

                                setTimeout(function () {
                                    _self.$dispatch('notify', { message: data.message })
                                }, 1000)
                            }
                        })
                        .catch((error) => console.log(error))
                        .then(() => this.loading = false)
                }
            }))

            Alpine.data('order', () => ({
                name: '',
                company: '',
                email: '',
                message: '',
                errors: {},
                loading: false,

                init() {
                    this.$watch('name', () => delete this.errors.name)
                    this.$watch('company', () => delete this.errors.company)
                    this.$watch('email', () => delete this.errors.email)
                },

                submit() {
                    this.loading = true

                    let data = new FormData()

                    data.append('name', this.name)
                    data.append('company', this.company)
                    data.append('email', this.email)
                    data.append('message', this.message)
                    data.append('url', window.location)
                    data.append('locale', 'en')

                    fetch('/order', {
                            method: 'POST',
                            headers: {
                                'Accept': 'application/json',
                                'X-CSRF-TOKEN': 'zCoIxKwzFra9yOwnujZ0QEfERAx192Cm9YJLnIYU'
                            },
                            body: data
                        })
                        .then((response) => response.json())
                        .then((data) => {
                            this.errors = data.errors || {}

                            if (data.success) {
                                this.name = this.company = this.email = this.message = ''
                                this.$dispatch('notify', { message: data.message })
                            }
                        })
                        .catch((error) => console.log(error))
                        .then(() => this.loading = false)
                }
            }))
        })
    </script>
</body>
</html>
