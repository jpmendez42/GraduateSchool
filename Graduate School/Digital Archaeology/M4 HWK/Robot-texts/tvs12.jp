			<!-- InstanceEndEditable -->
			<!-- ↑最上部配置：ページ固有 リソース・要素等：footer-->
		</div>

		<script>
			////Splide：スライドショー >  トップページ：ピックアップニュース
			let splideNewsPicup;
			const splideNewsPicupStart = function () {
				let slideClass = ".js-top-newsPickup";

				//対象要素が無い時はエスケープ
				if (!document.querySelector(".js-top-newsPickup")) { return; }

				let timer;
				let option = {
					type: 'loop',
					direction: 'ttb',//上から下
					height: document.querySelector(slideClass).clientHeight + "px",//縦スライドは高さ指定がいる
					perPage: 1,
					perMove: 1,
					focus: 'center',
					autoplay: {
						interval: 3000
					},
					pagination: false,//ページネーション
					arrows: false,//左右矢印 -- 無効化
				}

				let start = () => {
					splideNewsPicup = new Splide(slideClass, option);
					splideNewsPicup.mount();
				}

				//resize処理
				let reset = () => {
					clearTimeout(timer);
					// 指定時間後、一度だけ処理を実行
					timer = setTimeout(function () {
						if (splideNewsPicup) { splideNewsPicup.destroy() };
						start();
					}, 300);
				}


				//処理開始
				start();
			}
			splideNewsPicupStart(); //スライドの処理開始

			/*splide：キービジュアル*/
			let splideTopKeyVisual;
			const splideTopKeyVisualStart = function () {

				//対象要素が無い時はエスケープ
				if (!document.querySelector(".js-top-keyVisual")) { return; }

				let timer;
				let option = {
					type: 'loop',
					padding: `${(window.innerWidth - 1400) / 2 - 8}px`, // スライダーの左右の余白
					perMove: 1,
					focus: 'center',
					autoplay: {
						interval: 3000
					},
					pagination: true,//ページネーション
					arrows: false,//左右矢印 -- 無効化
					classes: {
						pagination: "splide__pagination p-top-keyVisual-pager js-top-keyVisual-pager",
					},
					breakpoints: {
						1400: {
							padding: 0,
						},
					}
				}

				//resize処理
				let reset = () => {
					clearTimeout(timer);
					// 指定時間後、一度だけ処理を実行
					timer = setTimeout(function () {
						if (splideTopKeyVisual) { splideTopKeyVisual.destroy() };
						option.padding = `${(window.innerWidth - 1400) / 2 - 8}px`, // スライダーの左右の余白
							splideTopKeyVisual = new Splide('.js-top-keyVisual', option);
						splideTopKeyVisual.mount();
					}, 300);
				}



				//処理開始
				let splideTopKeyVisual = new Splide('.js-top-keyVisual', option);
				splideTopKeyVisual.mount();
				window.addEventListener('resize', reset);

			};
			splideTopKeyVisualStart();


				/*splide：おすすめ情報*/
				let splideTopRecommend;
				const splideTopRecommendStart = function () {
					let slideClass = ".js-top-recommend";

					//対象要素が無い時はエスケープ
					if (
						!document.querySelector(slideClass) ||
						!document.querySelector(".js-top-recommend-pager__prev") ||
						!document.querySelector(".js-top-recommend-pager__next")
					) { return; }

					let itemLength = document.querySelector(`${slideClass} .splide__slide`).clientWidth;
					let gap = 20;
					let timer;
					let option = {
						type: 'loop',
						drag: 'free',
						focus: 'center',
						arrows: false, //左右矢印 -- 無効化
						pagination: false, //ページネーション -- 無効化
						gap: 36,
						perPage: 1,
						perMove: 1,
						flickMaxPages: 1,//フリック入力での移動量設定
						fixedWidth: `${window.innerWidth}px`,
						autoplay: {
							interval: 3000
						},
						breakpoints: {
							812: {
								gap: 0,
								fixedWidth: "100%",
								drag: true,
							},
						},
						arrowPath: "none"
					}

					//resize処理
					let reset = () => {
						clearTimeout(timer);
						// 指定時間後、一度だけ処理を実行
						timer = setTimeout(function () {
							if (splideTopRecommend) { splideTopRecommend.destroy() };
							splideTopRecommend = new Splide(slideClass, option);
							splideTopRecommend.mount();
						}, 300);
					}

					document.querySelector(".js-top-recommend-pager__prev").addEventListener("click", () => {
						splideTopRecommend.go('-${1}');
					})

					document.querySelector(".js-top-recommend-pager__next").addEventListener("click", () => {
						splideTopRecommend.go('+${1}');
					})



					//処理開始
					let splideTopRecommend = new Splide(slideClass, option);
					splideTopRecommend.mount();
					window.addEventListener('resize', reset);

				};
				splideTopRecommendStart();


				/*swiper：イベント情報*/
				let splideTopEvent;
				const splideTopEventStart = function () {

					//対象要素が無い時はエスケープ
					if (!document.querySelector('.js-top-event')) { return; }

					let timer;
					let option = {
						type: 'loop',
						fixedWidth: "100%",
						focus: 'center',
						autoplay: {
							interval: 3000
						},
						pagination: true,//ページネーション
						arrows: false,//左右矢印 -- 無効化
						classes: {
							pagination: "splide__pagination p-top-event-pager js-top-event-pager",
						},
						breakpoints: {
							1400: {
								padding: 0,
							},
						}
					}

					//resize処理
					let reset = () => {
						clearTimeout(timer);
						// 指定時間後、一度だけ処理を実行
						timer = setTimeout(function () {
							if (splideTopEvent) { splideTopEvent.destroy() };
							splideTopEvent = new Splide('.js-top-event', option);
							splideTopEvent.mount();
						}, 300);
					}


					//処理開始
					let splideTopEvent = new Splide('.js-top-event', option);
					splideTopEvent.mount();
					window.addEventListener('resize', reset);
				}
				splideTopEventStart();


				/*swiper：フッタバナー*/
				let splideTopSandard;
				const splideTopSandardStart = function () {
					let slideClass = ".js-top-standard";
					let gap = 20;
					let timer;

					//対象要素が無い時はエスケープ
					if (
						!document.querySelector(slideClass) ||
						!document.querySelector(".js-top-standard-pager__prev") ||
						!document.querySelector(".js-top-standard-pager__next")
					) { return; }


					let option = {
						type: 'loop',
						drag: true,
						focus: 'center',
						//fixedWidth: "100%",
						arrows: false,//左右矢印 -- 無効化
						pagination: false,
						classes: {
							arrows: "p-top-standard-pager",
						},
						gap: 36,
						perPage: 1,
						perMove: 1,
						autoplay: {
							interval: 1000
						},
						arrowPath: "none"
					}

					//resize処理
					let reset = () => {
						clearTimeout(timer);
						// 指定時間後、一度だけ処理を実行
						timer = setTimeout(function () {
							if (splideTopSandard) {
								splideTopSandard.destroy('completely')
								document.querySelector(slideClass).classList.remove("is-initialized")
							};
							start();
						}, 300);
					}

					let start = () => {
						if (window.innerWidth <= _breakpointSP) {
							splideTopSandard = new Splide(".js-top-standard", option);
							splideTopSandard.mount();
						}

					}

					document.querySelector(".js-top-standard-pager__next").addEventListener("click", () => {
						if (!splideTopSandard) { return }
						splideTopSandard.go('-${1}');
					})

					document.querySelector(".js-top-standard-pager__prev").addEventListener("click", () => {
						if (!splideTopSandard) { return }
						splideTopSandard.go('+${1}');
					})


					//処理開始
					start();
					window.addEventListener('resize', reset);
				}
				splideTopSandardStart();

			//タブ切り替え機能：お知らせ
			tabChange("all")
		</script><!-- InstanceEndEditable -->




		<!-- InstanceEndEditable -->
		<!--↓ページ固有リソース：foot-->
	</body>
<!-- InstanceEnd --></html>