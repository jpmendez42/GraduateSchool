        border-radius: 20px;
        border: 1px solid #ccc;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .botones a:hover {
    background-color: #333;
    color: white;
    border-color: #333;
    }

      .botones label {
    background-color: white;
    color: #666;
    padding: 8px 16px;
    border-radius: 20px;
    border: 1px solid #ccc;
