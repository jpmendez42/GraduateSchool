<div id="login-side-panel" class="side-panel d-flex flex-column">
  <div class="close-container d-flex justify-content-end align-items-center py-3 pr-3">
    <button type="button" id="closePanelBtn" class="close">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
  <div class="side-panel-content">
    <div class="mb-4">
      <h1 class="login-panel-title">Area clienti</h1>
      <h2>Inserisci le tue credenziali per accedere.</h2>
    </div>
    <div class="alerts-container"></div>
    <form id="loginForm" class="form-group" action="https://www.actalis.com/it/module/hoslogindrawer/logindrawer">
      <input type="hidden" name="back" value="https://www.actalis.com/it/">
      <div class="form-group mb-4">
        <label for="email" class="font-weight-bold">Email</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="Inserisci indirizzo email" value required autocomplete="email">
      </div>
      <div class="form-group mb-4">
        <div class="d-flex justify-content-between">
          <label for="password" class="font-weight-bold">Password</label>
          <u><a href="https://www.actalis.com/it/recupero-password" rel="nofollow" class="text-dark">Hai dimenticato la password?</a></u>
        </div>
        <div class="input-group js-parent-focus">
          <input type="password" id="password" name="password" class="form-control js-child-focus js-visible-password" placeholder="Inserisci password" aria-label="Inserimento password" title="At least 5 characters long" data-minlength="8" data-maxlength="72" data-minscore="3" autocomplete="current-password" value required>
          <span class="input-group-append">
            <button class="btn btn-outline-secondary bg-transparent border-0 shadow-none" type="button" data-action="show-password">
              <i class="fa fa-eye-slash" aria-hidden="true"></i>
            </button>
          </span>
        </div>
      </div>
      <div id="hi_recaptcha_login" style="display:none;"></div>

      <input type="hidden" name="submitLogin" value="1">
      <button type="submit" class="btn btn-primary mt-3">Accedi</button>
    </form>

    <div class="my-4 no-account">
      <h3>Sei un nuovo cliente?</h3>
      <a href="https://www.actalis.com/it/registrazione" class="btn btn-outline-primary" data-link-action="display-register-form">Crea il tuo account Actalis</a>
