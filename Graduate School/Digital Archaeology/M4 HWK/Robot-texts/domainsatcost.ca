/cms-assets/static/ba4b9a6a15a64d67eb9b01bad410073c/55b5e/business-pro.jpg 867w" src="/cms-assets/static/ba4b9a6a15a64d67eb9b01bad410073c/55b5e/business-pro.jpg" alt="Woman sitting with a laptop composing an email." style="position:absolute;top:0;left:0;opacity:1;width:100%;height:100%;object-fit:cover;object-position:center"/></picture></noscript></div></div></div></div></div></section><section width="1" color="greys.1" id="dream-website" display="flex" class="box__Box-sc-1195mmx-0 bAJIKA"><div width="1" display="flex" class="box__Box-sc-1195mmx-0 fFkUTz"><div width="100%" display="flex" class="box__Box-sc-1195mmx-0 eHVtP"><div display="flex" class="box__Box-sc-1195mmx-0 DfatU"><div display="flex" class="box__Box-sc-1195mmx-0 eMkPQM"><div color="greys.1" display="flex" class="box__Box-sc-1195mmx-0 bJLtKU"><div font-family="body" class="text__Text-sc-78yxcw-0 GBFRo">Free SSL Security</div><h2 class="text__Text-sc-78yxcw-0 heading__Heading-sc-8y1gmp-0 cqisOR llvEqk"><div display="flex" class="style-reset__StyleReset-sc-19u980z-0 gFcQco"><div color="greys.1" font-family="title" class="text__Text-sc-78yxcw-0 ituCVP"><div class="html-block__Block-sc-1dm9fyv-0 hHzCMM content___StyledHtmlBlock-sc-1lhrlny-0">Keep your site safe and secure.</div></div></div></h2></div><div display="flex" class="box__Box-sc-1195mmx-0 fRhjKs"><div display="flex" class="style-reset__StyleReset-sc-19u980z-0 gFcQco"><div color="greys.1" font-family="body" class="text__Text-sc-78yxcw-0 kGLXQD"><div class="html-block__Block-sc-1dm9fyv-0 hCYXFy content___StyledHtmlBlock-sc-1lhrlny-0 jSOgSc">Managed WordPress and Plesk Web Hosting users get a free SSL certificate to ensure that communication with your visitors is secure. It keeps personal and credit card information out of hackers hands and also improves your search engine rankings.</div></div></div><div display="flex" class="box__Box-sc-1195mmx-0 gXpWHp"><a aria-label="View Security Options" target="" title="View Security Options" color="deepKoamaru" id="learn-more-security" href="/security/security-overview" class="link__StyledLink-sc-sk2fkb-0 iVGvtZ link__StyledLink-sc-sk2fkb-0 iVGvtZ"><div class="text__Text-sc-78yxcw-0 lnSPAF">View Security Options</div></a></div></div></div><div height="25rem,40rem" width="100%,100%,50%" display="flex" class="box__Box-sc-1195mmx-0 cvVveD"><div class="image__Img-es1yyv-0 kogOJO gatsby-image-wrapper" style="position:absolute;overflow:hidden"><div aria-hidden="true" style="width:100%;padding-bottom:66.66666666666667%"></div><img aria-hidden="true" src="data:image/jpeg;base64," alt="Woman holding phone ensuring her site is secure." style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:contain;object-position:50% 50%;opacity:1;transition-delay:500ms;font-family:&quot;object-fit: contain; object-position: 50% 50%&quot;"/><noscript><picture><source type='image/webp' srcset="/cms-assets/static/ad7cede2b24093f02ec67ec2ac40b8ad/8ca88/securelaptop.webp 360w,
