:\"465\"},{\"id\":\"97519385\",\"start\":\"2025-10-13T11:30:00.000Z\",\"stop\":\"2025-10-13T13:00:00.000Z\",\"title\":\"Házená: SG Flensburg - Handewitt - THW Kiel\",\"description\":\"\",\"durationMin\":90,\"genre\":2,\"slug\":\"hazena-sg-flensburg-handewitt-thw-kiel-97519385\",\"channelId\":\"465\"},{\"id\":\"97519386\",\"start\":\"2025-10-13T13:00:00.000Z\",\"stop\":\"2025-10-13T14:45:00.000Z\",\"title\":\"Ragby: Bath Rugby - Gloucester Rugby\",\"description\":\"\",\"durationMin\":105,\"genre\":2,\"slug\":\"ragby-bath-rugby-gloucester-rugby-97519386\",\"channelId\":\"465\"},{\"id\":\"97519387\",\"start\":\"2025-10-13T14:45:00.000Z\",\"stop\":\"2025-10-13T16:25:00.000Z\",\"title\":\"NHL: New York Rangers - Washington Capitals\",\"description\":\"\",\"durationMin\":100,\"genre\":2,\"slug\":\"nhl-new-york-rangers-washington-capitals-97519387\",\"channelId\":\"465\"},{\"id\":\"97519388\",\"start\":\"2025-10-13T16:25:00.000Z\",\"stop\":\"2025-10-13T17:00:00.000Z\",\"title\":\"Defender GKA Kite - Surf World Cup Sylt\",\"description\":\"\",\"durationMin\":35,\"genre\":2,\"slug\":\"defender-gka-kite-surf-world-cup-sylt-97519388\",\"channelId\":\"465\"},{\"id\":\"97673017\",\"start\":\"2025-10-13T17:00:00.000Z\",\"stop\":\"2025-10-13T19:30:00.000Z\",\"title\":\"Longines Global Champions Tour 2025 - Řím\",\"description\":\"\",\"durationMin\":150,\"genre\":2,\"slug\":\"longines-global-champions-tour-2025-rim-97673017\",\"channelId\":\"465\"},{\"id\":\"97673018\",\"start\":\"2025-10-13T19:30:00.000Z\",\"stop\":\"2025-10-13T22:30:00.000Z\",\"title\":\"NFL: Kansas City Chiefs - Detroit Lions\",\"description\":\"\",\"durationMin\":180,\"genre\":2,\"slug\":\"nfl-kansas-city-chiefs-detroit-lions-97673018\",\"channelId\":\"465\"},{\"id\":\"97673019\",\"start\":\"2025-10-13T22:30:00.000Z\",\"stop\":\"2025-10-14T00:15:00.000Z\",\"title\":\"Basketbal: Basket Ostrava - SBŠ Ostrava\",\"description\":\"\",\"durationMin\":105,\"genre\":2,\"slug\":\"basketbal-basket-ostrava-sbs-ostrava-97673019\",\"channelId\":\"465\"}],\"474\":[{\"id\":\"97317855\",\"start\":\"2025-10-13T00:20:00.000Z\",\"stop\":\"2025-10-13T02:15:00.000Z\",\"title\":\"Útok megažraloka\",\"description\":\"$59\",\"durationMin\":82,\"genre\":3,\"slug\":\"utok-megazraloka-97317855\",\"channelId\":\"474\"},{\"id\":\"97317856\",\"start\":\"2025-10-13T02:15:00.000Z\",\"stop\":\"2025-10-13T03:10:00.000Z\",\"title\":\"Námořní vyšetřovací služba VIII (2)\",\"description\":\"Nejhorší noční můra. Krimiseriál USA (2010). Tým zvláštních agentů, kteří operují mimo vojenské velení, musí vyšetřit každý zločin, který má něco společného s námořními silami, bez ohledu na to, jakou hodnost mají podezřelí. Vede je zvláštní agent Leroy Jethro Gibbs, který vedle racionálních úvah vždy dá i na své instinkty.\",\"durationMin\":41,\"genre\":4,\"slug\":\"namorni-vysetrovaci-sluzba-viii-97317856\",\"channelId\":\"474\"},{\"id\":\"97317857\",\"start\":\"2025-10-13T03:15:00.000Z\",\"stop\":\"2025-10-13T04:00:00.000Z\",\"title\":\"M.A.S.H\",\"description\":\"\",\"durationMin\":23,\"genre\":4,\"slug\":\"ma-s-h-97317857\",\"channelId\":\"474\"},{\"id\":\"97515152\",\"start\":\"2025-10-13T04:00:00.000Z\",\"stop\":\"2025-10-13T04:20:00.000Z\",\"title\":\"M.A.S.H\",\"description\":\"\",\"durationMin\":23,\"genre\":4,\"slug\":\"ma-s-h-97515152\",\"channelId\":\"474\"},{\"id\":\"97515153\",\"start\":\"2025-10-13T04:20:00.000Z\",\"stop\":\"2025-10-13T04:45:00.000Z\",\"title\":\"M.A.S.H\",\"description\":\"\",\"durationMin\":23,\"genre\":4,\"slug\":\"ma-s-h-97515153\",\"channelId\":\"474\"},{\"id\":\"97515154\",\"start\":\"2025-10-13T04:45:00.000Z\",\"stop\":\"2025-10-13T05:35:00.000Z\",\"title\":\"Námořní vyšetřovací služba VIII (2)\",\"description\":\"Nejhorší noční můra. Krimiseriál USA (2010). Tým zvláštních agentů, kteří operují mimo vojenské velení, musí vyšetřit každý zločin, který má něco společného s námořními silami, bez ohledu na to, jakou hodnost mají podezřelí. Vede je zvláštní agent Leroy Jethro Gibbs, který vedle racionálních úvah vždy dá i na své instinkty.\",\"durationMin\":41,\"genre\":4,\"slug\":\"namorni-vysetrovaci-sluzba-viii-97515154\",\"channelId\":\"474\"},{\"id\":\"97515155\",\"start\":\"2025-10-13T05:35:00.000Z\",\"stop\":\"2025-10-13T06:30:00.000Z\",\"title\":\"Námořní vyšetřovací služba VIII (3)\",\"description\":\"Zkrat. Krimiseriál USA (2010). Tým zvláštních agentů, kteří operují mimo vojenské velení, musí vyšetřit každý zločin, který má něco společného s námořními silami, bez ohledu na to, jakou hodnost mají podezřelí. Vede je zvláštní agent Leroy Jethro Gibbs, který vedle racionálních úvah vždy dá i na své instinkty.\",\"durationMin\":40,\"genre\":4,\"slug\":\"namorni-vysetrovaci-sluzba-viii-97515155\",\"channelId\":\"474\"},{\"id\":\"97515156\",\"start\":\"2025-10-13T06:30:00.000Z\",\"stop\":\"2025-10-13T09:30:00.000Z\",\"title\":\"Kontakt\",\"description\":\"Sci-fi film USA (1997). Ellie zasvětila celý svůj život hledání života na jiných planetách. Jednoho dne se jí podaří zachytit signál z vesmíru. Svůj projekt a kontakt se vzdálenou civilizací si bude ale muset tvrdě vybojovat.\",\"durationMin\":136,\"genre\":3,\"slug\":\"kontakt-97515156\",\"channelId\":\"474\"},{\"id\":\"97515157\",\"start\":\"2025-10-13T09:30:00.000Z\",\"stop\":\"2025-10-13T11:15:00.000Z\",\"title\":\"Dámská jízda\",\"description\":\"Komedie USA (2017). Když si Emily vyrazila se svou zhýčkanou matkou na dovolenou do Ekvádoru, určitě nečekala, že se stanou oběťmi únosu. A tak jim teď nezbývá než se z této nemilé šlamastiky nějak dostat. V útěku jim brání nejen jejich únosci, ale také hustá džungle.\",\"durationMin\":82,\"genre\":3,\"slug\":\"damska-jizda-97515157\",\"channelId\":\"474\"},{\"id\":\"97515158\",\"start\":\"2025-10-13T11:15:00.000Z\",\"stop\":\"2025-10-13T13:30:00.000Z\",\"title\":\"Angelika\",\"description\":\"Romantický film Fr./Belg./ČR/Rak. (2013). Mladičká Angelika se má provdat za hraběte de Peyrac, kterého předchází pověst ošklivého a zlého muže. Podaří se jí překonat nelibost a následně i nástrahy osudu?\",\"durationMin\":103,\"genre\":3,\"slug\":\"angelika-97515158\",\"channelId\":\"474\"},{\"id\":\"97515159\",\"start\":\"2025-10-13T13:30:00.000Z\",\"stop\":\"2025-10-13T15:40:00.000Z\",\"title\":\"Nadějný rok\",\"description\":\"Komedie USA (2011). Tři vášniví ornitologové se chystají utkat v soutěži o titul nejlepšího ptačího pozorovatele. Vyhraje ten, kdo během jednoho roku uvidí nejvíce ptáků. Přátelské soupeření se ale brzy změní v bláznivé dobrodružství, během kterého si všichni tři uvědomí, že úspěch bude něco stát.\",\"durationMin\":91,\"genre\":3,\"slug\":\"nadejny-rok-97515159\",\"channelId\":\"474\"},{\"id\":\"97515160\",\"start\":\"2025-10-13T15:40:00.000Z\",\"stop\":\"2025-10-13T18:00:00.000Z\",\"title\":\"Robin Hood\",\"description\":\"Dobrodružný film USA (2018). Lord Robin z Loxley se vrací z křižáckých výprav. V rodné Anglii zjistí, že mu zlotřilý šerif z Nottinghamu zabavil majetek a jeho milá si našla jiného. Robin musí za pomoci maurského přítele vypilovat své bojové umění a postavit se do čela lidového povstání proti zvůli vlády.\",\"durationMin\":103,\"genre\":3,\"slug\":\"robin-hood-97515160\",\"channelId\":\"474\"},{\"id\":\"97515161\",\"start\":\"2025-10-13T18:00:00.000Z\",\"stop\":\"2025-10-13T20:00:00.000Z\",\"title\":\"Ledově ostří\",\"description\":\"Komedie USA (2007). Dva největší rivalové, krasobruslaři Jimmy a Chazz, dostanou doživotní zákaz krasobruslení v mužské kategorii. Několik let se věnují jiné práci, než za Jimmym přijde jeho největší fanoušek a oznámí mu, že může znovu soutěžit, ale v kategorii párů. Protože se mu ale nedaří sehnat partnerku, napadne jeho trenéra, že by mohl soutěžit s Chazzem.\",\"durationMin\":84,\"genre\":3,\"slug\":\"ledove-ostri-97515161\",\"channelId\":\"474\"},{\"id\":\"97515162\",\"start\":\"2025-10-13T20:00:00.000Z\",\"stop\":\"2025-10-13T22:20:00.000Z\",\"title\":\"Tahle země není pro starý\",\"description\":\"Thriller USA (2007). V roce 1980 v Texasu vzrůstá kriminalita a obchod s drogami. Na jeden takový nepovedený obchod narazí Llewenyl Moss, který díky tomu přijde k pěknému balíku peněz. O tyto peníze má však zájem i někdo další.\",\"durationMin\":111,\"genre\":3,\"slug\":\"tahle-zeme-neni-pro-stary-97515162\",\"channelId\":\"474\"},{\"id\":\"97515163\",\"start\":\"2025-10-13T22:20:00.000Z\",\"stop\":\"2025-10-14T00:35:00.000Z\",\"title\":\"Kletba bratří Grimmů\",\"description\":\"$5a\",\"durationMin\":107,\"genre\":3,\"slug\":\"kletba-bratri-grimmu-97515163\",\"channelId\":\"474\"}],\"475\":[{\"id\":\"97119984\",\"start\":\"2025-10-13T01:30:00.000Z\",\"stop\":\"2025-10-13T02:00:00.000Z\",\"title\":\"Comedy Club IV (22)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"comedy-club-iv-97119984\",\"channelId\":\"475\"},{\"id\":\"97119985\",\"start\":\"2025-10-13T02:00:00.000Z\",\"stop\":\"2025-10-13T02:25:00.000Z\",\"title\":\"Comedy Club IV (23)\",\"description\":\"\",\"durationMin\":25,\"genre\":1,\"slug\":\"comedy-club-iv-97119985\",\"channelId\":\"475\"},{\"id\":\"97119986\",\"start\":\"2025-10-13T02:25:00.000Z\",\"stop\":\"2025-10-13T02:55:00.000Z\",\"title\":\"Comedy Club IV (24)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"comedy-club-iv-97119986\",\"channelId\":\"475\"},{\"id\":\"97119987\",\"start\":\"2025-10-13T02:55:00.000Z\",\"stop\":\"2025-10-13T03:25:00.000Z\",\"title\":\"Comedy Club IV (25)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"comedy-club-iv-97119987\",\"channelId\":\"475\"},{\"id\":\"97119988\",\"start\":\"2025-10-13T03:25:00.000Z\",\"stop\":\"2025-10-13T04:00:00.000Z\",\"title\":\"Comedy Club IV (26)\",\"description\":\"\",\"durationMin\":35,\"genre\":1,\"slug\":\"comedy-club-iv-97119988\",\"channelId\":\"475\"},{\"id\":\"97119989\",\"start\":\"2025-10-13T04:00:00.000Z\",\"stop\":\"2025-10-13T04:30:00.000Z\",\"title\":\"Kung Fu Panda: Legendy o mazáctví (21)\",\"description\":\"Z dračího bojovníka, obtloustlého a líného pandy Poa, se pod vedením jeho učitele Shifua stal mazák, který je připraven bojovat po boku svých přátel proti zlu.\",\"durationMin\":30,\"genre\":4,\"slug\":\"kung-fu-panda-legendy-o-mazactvi-97119989\",\"channelId\":\"475\"},{\"id\":\"97119990\",\"start\":\"2025-10-13T04:30:00.000Z\",\"stop\":\"2025-10-13T05:00:00.000Z\",\"title\":\"Kung Fu Panda: Legendy o mazáctví (22)\",\"description\":\"Z dračího bojovníka, obtloustlého a líného pandy Poa, se pod vedením jeho učitele Shifua stal mazák, který je připraven bojovat po boku svých přátel proti zlu.\",\"durationMin\":30,\"genre\":4,\"slug\":\"kung-fu-panda-legendy-o-mazactvi-97119990\",\"channelId\":\"475\"},{\"id\":\"97119991\",\"start\":\"2025-10-13T05:00:00.000Z\",\"stop\":\"2025-10-13T05:30:00.000Z\",\"title\":\"Tučňáci z Madagaskaru II (34)\",\"description\":\"Animovaný seriál USA (2008). Doktor Blowhole, úhlavní nepřítel tučňáků, se vrací do New Yorku. A s ním i jeho ďáblský plán.\",\"durationMin\":30,\"genre\":4,\"slug\":\"tucnaci-z-madagaskaru-ii-97119991\",\"channelId\":\"475\"},{\"id\":\"97119992\",\"start\":\"2025-10-13T05:30:00.000Z\",\"stop\":\"2025-10-13T06:00:00.000Z\",\"title\":\"Tučňáci z Madagaskaru II (35)\",\"description\":\"Animovaný seriál USA (2008). Doktor Blowhole, úhlavní nepřítel tučňáků, se vrací do New Yorku. A s ním i jeho ďáblský plán.\",\"durationMin\":30,\"genre\":4,\"slug\":\"tucnaci-z-madagaskaru-ii-97119992\",\"channelId\":\"475\"},{\"id\":\"97119993\",\"start\":\"2025-10-13T06:00:00.000Z\",\"stop\":\"2025-10-13T06:30:00.000Z\",\"title\":\"Spongebob v kalhotách VI (117)\",\"description\":\"Animovaný seriál USA (1999). Supermořec a Ploutvokluk se mají zúčastnit turnaje ve stolním fotbalu, ale nemůžou jít. // Když si Sépiáka spletou s jeho slavným rivalem Squilliamem Fancysonem, pozvou ho učit v jedné z nejprestižnějších hudebních škol v Zátiší Bikin.\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119993\",\"channelId\":\"475\"},{\"id\":\"97119994\",\"start\":\"2025-10-13T06:30:00.000Z\",\"stop\":\"2025-10-13T07:00:00.000Z\",\"title\":\"Spongebob v kalhotách VI (118)\",\"description\":\"Animovaný seriál USA (1999). SpongeBob adoptuje zatoulaného červa a k jeho překvapení se červovi v noci narodí malí červíčci! // Planktona už nebaví Karenina kritika a tak se rozhodne, že ji nahradí novými počítačovými vynálezy!\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119994\",\"channelId\":\"475\"},{\"id\":\"97119995\",\"start\":\"2025-10-13T07:00:00.000Z\",\"stop\":\"2025-10-13T07:30:00.000Z\",\"title\":\"Spongebob v kalhotách VI (119)\",\"description\":\"Animovaný seriál USA (1999). SpongeBob dostane v Křupavém Krabovi všechno na povel, zatímco si pan Krabs musí na 15 minut odskočit, a je rozhodnutý nastolit těch nejlépe vedených 15 minut všech dob! // SpongeBob má úplně plný den a je odhodlaný udělat všechno, co si naplánoval.\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119995\",\"channelId\":\"475\"},{\"id\":\"97119996\",\"start\":\"2025-10-13T07:30:00.000Z\",\"stop\":\"2025-10-13T08:00:00.000Z\",\"title\":\"Spongebob v kalhotách VI (120)\",\"description\":\"Animovaný seriál USA (1999). Patrika už nebaví, že všichni jeho kamarádi nejsou schopni si s ním hrát protože si musí nasadit své čepice Křupavého Kraba a jít do práce. // V Zátiší Bikin otevřeli nový obchod s hračkami a SpongeBob s Patrikem ani nemůžou mít větší radost!\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119996\",\"channelId\":\"475\"},{\"id\":\"97119997\",\"start\":\"2025-10-13T08:00:00.000Z\",\"stop\":\"2025-10-13T08:30:00.000Z\",\"title\":\"Spongebob v kalhotách VI (121)\",\"description\":\"Animovaný seriál USA (1999). Přátelské stavění hradů z písku se brzy zvrtne v bitku, když mezi sebou SpongeBob a Patrik soutěží o to, kdo bude mít lepší hrad. // Gary potřebuje novou ulitu. Všechny ulity na trhu jsou ale buď moc drahé, nebo křehké.\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119997\",\"channelId\":\"475\"},{\"id\":\"97119998\",\"start\":\"2025-10-13T08:30:00.000Z\",\"stop\":\"2025-10-13T09:00:00.000Z\",\"title\":\"Spongebob v kalhotách VI (122)\",\"description\":\"Animovaný seriál USA (1999). Plankton si najme Patrika, aby vymyslel reklamní slogany pro Kamarádský Kyblík. // SponbeBob pomáhá Planktonovi najít dokonalý dárek k výročí svatby pro Karen.\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119998\",\"channelId\":\"475\"},{\"id\":\"97119999\",\"start\":\"2025-10-13T09:00:00.000Z\",\"stop\":\"2025-10-13T09:30:00.000Z\",\"title\":\"Spongebob v kalhotách VI (123)\",\"description\":\"Animovaný seriál USA (1999). Je tu výročí Křupavého Kraba! Pan Krabs svolává všechny dřív, aby připravili velký večer. Jenže nešťastnou náhodou zůstane celý tým zavřený v mrazáku pana Krabse.\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97119999\",\"channelId\":\"475\"},{\"id\":\"97120000\",\"start\":\"2025-10-13T09:30:00.000Z\",\"stop\":\"2025-10-13T10:00:00.000Z\",\"title\":\"Spongebob v kalhotách VI (124)\",\"description\":\"Animovaný seriál USA (1999). Je tu výročí Křupavého Kraba! Pan Krabs svolává všechny dřív, aby připravili velký večer. Jenže nešťastnou náhodou zůstane celý tým zavřený v mrazáku pana Krabse.\",\"durationMin\":30,\"genre\":4,\"slug\":\"spongebob-v-kalhotach-vi-97120000\",\"channelId\":\"475\"},{\"id\":\"97120001\",\"start\":\"2025-10-13T10:00:00.000Z\",\"stop\":\"2025-10-13T10:35:00.000Z\",\"title\":\"Červený trpaslík XII (1)\",\"description\":\"\",\"durationMin\":35,\"genre\":4,\"slug\":\"cerveny-trpaslik-xii-97120001\",\"channelId\":\"475\"},{\"id\":\"97120002\",\"start\":\"2025-10-13T10:35:00.000Z\",\"stop\":\"2025-10-13T11:10:00.000Z\",\"title\":\"Červený trpaslík XII (2)\",\"description\":\"\",\"durationMin\":35,\"genre\":4,\"slug\":\"cerveny-trpaslik-xii-97120002\",\"channelId\":\"475\"},{\"id\":\"97120003\",\"start\":\"2025-10-13T11:10:00.000Z\",\"stop\":\"2025-10-13T11:55:00.000Z\",\"title\":\"Comedy Club Special Edition III (6)\",\"description\":\"\",\"durationMin\":45,\"genre\":1,\"slug\":\"comedy-club-special-edition-iii-97120003\",\"channelId\":\"475\"},{\"id\":\"97120004\",\"start\":\"2025-10-13T11:55:00.000Z\",\"stop\":\"2025-10-13T12:25:00.000Z\",\"title\":\"Comedy Club Special Edition II (27)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"comedy-club-special-edition-ii-97120004\",\"channelId\":\"475\"},{\"id\":\"97120005\",\"start\":\"2025-10-13T12:25:00.000Z\",\"stop\":\"2025-10-13T13:00:00.000Z\",\"title\":\"Comedy Club Special Edition II (28)\",\"description\":\"\",\"durationMin\":35,\"genre\":1,\"slug\":\"comedy-club-special-edition-ii-97120005\",\"channelId\":\"475\"},{\"id\":\"97120006\",\"start\":\"2025-10-13T13:00:00.000Z\",\"stop\":\"2025-10-13T14:00:00.000Z\",\"title\":\"Police Interceptors XXI (5)\",\"description\":\"Tento akcí nabitý díl začíná hlášením o vykradených nákladních autech na čerpací stanici v Trowellu a k zásahu vyrážejí Jim a Lewis z ozbrojené jednotky.\",\"durationMin\":60,\"genre\":null,\"slug\":\"police-interceptors-xxi-97120006\",\"channelId\":\"475\"},{\"id\":\"97120007\",\"start\":\"2025-10-13T14:00:00.000Z\",\"stop\":\"2025-10-13T15:00:00.000Z\",\"title\":\"Kriminálka Las Vegas X (14)\",\"description\":\"\",\"durationMin\":60,\"genre\":4,\"slug\":\"kriminalka-las-vegas-x-97120007\",\"channelId\":\"475\"},{\"id\":\"97120008\",\"start\":\"2025-10-13T15:00:00.000Z\",\"stop\":\"2025-10-13T16:00:00.000Z\",\"title\":\"Sherlock Holmes: Jak prosté V (14)\",\"description\":\"V úvodním díle páté řady se Holmes a Watsonová připojí k newyorské policii v pátrání po sériovém atentátníkovi, který je po šesti letech opět aktivní.\",\"durationMin\":60,\"genre\":4,\"slug\":\"sherlock-holmes-jak-proste-v-97120008\",\"channelId\":\"475\"},{\"id\":\"97120009\",\"start\":\"2025-10-13T16:00:00.000Z\",\"stop\":\"2025-10-13T17:00:00.000Z\",\"title\":\"Kriminálka Las Vegas X (15)\",\"description\":\"\",\"durationMin\":60,\"genre\":4,\"slug\":\"kriminalka-las-vegas-x-97120009\",\"channelId\":\"475\"},{\"id\":\"97120010\",\"start\":\"2025-10-13T17:00:00.000Z\",\"stop\":\"2025-10-13T18:00:00.000Z\",\"title\":\"Sherlock Holmes: Jak prosté V (15)\",\"description\":\"V úvodním díle páté řady se Holmes a Watsonová připojí k newyorské policii v pátrání po sériovém atentátníkovi, který je po šesti letech opět aktivní.\",\"durationMin\":60,\"genre\":4,\"slug\":\"sherlock-holmes-jak-proste-v-97120010\",\"channelId\":\"475\"},{\"id\":\"97120011\",\"start\":\"2025-10-13T18:00:00.000Z\",\"stop\":\"2025-10-13T20:00:00.000Z\",\"title\":\"Divoká dvojka\",\"description\":\"\",\"durationMin\":120,\"genre\":3,\"slug\":\"divoka-dvojka-97120011\",\"channelId\":\"475\"},{\"id\":\"97120012\",\"start\":\"2025-10-13T20:00:00.000Z\",\"stop\":\"2025-10-13T20:30:00.000Z\",\"title\":\"Comedy Club IX (18)\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"comedy-club-ix-97120012\",\"channelId\":\"475\"},{\"id\":\"97120013\",\"start\":\"2025-10-13T20:30:00.000Z\",\"stop\":\"2025-10-13T21:05:00.000Z\",\"title\":\"Comedy Club IX (19)\",\"description\":\"\",\"durationMin\":35,\"genre\":null,\"slug\":\"comedy-club-ix-97120013\",\"channelId\":\"475\"},{\"id\":\"97120014\",\"start\":\"2025-10-13T21:05:00.000Z\",\"stop\":\"2025-10-13T21:35:00.000Z\",\"title\":\"Comedy Club VIII (27)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"comedy-club-viii-97120014\",\"channelId\":\"475\"},{\"id\":\"97120015\",\"start\":\"2025-10-13T21:35:00.000Z\",\"stop\":\"2025-10-13T22:20:00.000Z\",\"title\":\"Červený trpaslík III (5)\",\"description\":\"\",\"durationMin\":45,\"genre\":4,\"slug\":\"cerveny-trpaslik-iii-97120015\",\"channelId\":\"475\"},{\"id\":\"97120016\",\"start\":\"2025-10-13T22:20:00.000Z\",\"stop\":\"2025-10-13T22:55:00.000Z\",\"title\":\"Červený trpaslík III (6)\",\"description\":\"\",\"durationMin\":35,\"genre\":4,\"slug\":\"cerveny-trpaslik-iii-97120016\",\"channelId\":\"475\"},{\"id\":\"97120017\",\"start\":\"2025-10-13T22:55:00.000Z\",\"stop\":\"2025-10-14T01:30:00.000Z\",\"title\":\"Terminál\",\"description\":\"\",\"durationMin\":155,\"genre\":3,\"slug\":\"terminal-97120017\",\"channelId\":\"475\"}],\"512\":[{\"id\":\"97275107\",\"start\":\"2025-10-13T00:35:00.000Z\",\"stop\":\"2025-10-13T01:10:00.000Z\",\"title\":\"Podstata věcí (2)\",\"description\":\"Komediální seriál Fr. (2025). Poté, co se Léa stala jednou z mála žen-rabínek, žongluje se složitými otázkami všech s chaotickým osobním životem a vlastním hledáním smyslu života.\",\"durationMin\":31,\"genre\":4,\"slug\":\"podstata-veci-97275107\",\"channelId\":\"512\"},{\"id\":\"97275108\",\"start\":\"2025-10-13T01:10:00.000Z\",\"stop\":\"2025-10-13T01:55:00.000Z\",\"title\":\"Město bohů: Boj zuří dál (5)\",\"description\":\"Krimiseriál Braz. (2024). Seriál HBO sleduje osudy obyvatel favely zvané \\\"Boží město\\\" dvacet let po smrti Li’l Zé.\",\"durationMin\":47,\"genre\":4,\"slug\":\"mesto-bohu-boj-zuri-dal-97275108\",\"channelId\":\"512\"},{\"id\":\"97275109\",\"start\":\"2025-10-13T01:55:00.000Z\",\"stop\":\"2025-10-13T04:00:00.000Z\",\"title\":\"Úsměv\",\"description\":\"Poté, co se dr. Rose Cotterová stane svědkem bizarní traumatické události, do níž je zapletena její pacientka, musí čelit své znepokojivé minulosti.\",\"durationMin\":111,\"genre\":3,\"slug\":\"usmev-97275109\",\"channelId\":\"512\"},{\"id\":\"97275110\",\"start\":\"2025-10-13T04:00:00.000Z\",\"stop\":\"2025-10-13T05:45:00.000Z\",\"title\":\"Cesta k dokonalosti\",\"description\":\"Drama Švýc./Fr. (2023). Sophie opouští rodinnou farmu, aby se zapsala do přípravné třídy. Zjišťuje, že dostat se na polytechniku není jen o konkurenci, ale také o postavení.\",\"durationMin\":103,\"genre\":3,\"slug\":\"cesta-k-dokonalosti-97275110\",\"channelId\":\"512\"},{\"id\":\"97275111\",\"start\":\"2025-10-13T05:45:00.000Z\",\"stop\":\"2025-10-13T07:20:00.000Z\",\"title\":\"Super Mario Bros. ve filmu\",\"description\":\"Zábavné dobrodružství o instalatérovi Mariovi a jeho vytáhlém bratrovi Luigim, kteří se snaží zachránit princeznu Peach před padouchem Bowserem.\",\"durationMin\":92,\"genre\":3,\"slug\":\"super-mario-bros-ve-filmu-97275111\",\"channelId\":\"512\"},{\"id\":\"97275112\",\"start\":\"2025-10-13T07:20:00.000Z\",\"stop\":\"2025-10-13T07:40:00.000Z\",\"title\":\"Teorie velkého třesku VIII (19)\",\"description\":\"Vpád na Skywalkerův ranč. Komediální seriál USA (2014). Brilantní fyzici Leonard a Sheldon jsou v laboratoři naprosto geniální, ale v obyčejném světě zůstávají totálně ztracení. Naštěstí mají po ruce krásnou a svobodomyslnou sousedku Penny, která se je snaží naučit pár věcí o reálném životě.\",\"durationMin\":20,\"genre\":4,\"slug\":\"teorie-velkeho-tresku-viii-97275112\",\"channelId\":\"512\"},{\"id\":\"97275113\",\"start\":\"2025-10-13T07:40:00.000Z\",\"stop\":\"2025-10-13T08:00:00.000Z\",\"title\":\"Teorie velkého třesku VIII (20)\",\"description\":\"Realizace bunkru. Komediální seriál USA (2014). Brilantní fyzici Leonard a Sheldon jsou v laboratoři naprosto geniální, ale v obyčejném světě zůstávají totálně ztracení. Naštěstí mají po ruce krásnou a svobodomyslnou sousedku Penny, která se je snaží naučit pár věcí o reálném životě.\",\"durationMin\":19,\"genre\":4,\"slug\":\"teorie-velkeho-tresku-viii-97275113\",\"channelId\":\"512\"},{\"id\":\"97275114\",\"start\":\"2025-10-13T08:00:00.000Z\",\"stop\":\"2025-10-13T08:20:00.000Z\",\"title\":\"Teorie velkého třesku VIII (21)\",\"description\":\"Rozkol v komunikaci. Komediální seriál USA (2014). Brilantní fyzici Leonard a Sheldon jsou v laboratoři naprosto geniální, ale v obyčejném světě zůstávají totálně ztracení. Naštěstí mají po ruce krásnou a svobodomyslnou sousedku Penny, která se je snaží naučit pár věcí o reálném životě.\",\"durationMin\":18,\"genre\":4,\"slug\":\"teorie-velkeho-tresku-viii-97275114\",\"channelId\":\"512\"},{\"id\":\"97275115\",\"start\":\"2025-10-13T08:20:00.000Z\",\"stop\":\"2025-10-13T09:50:00.000Z\",\"title\":\"Holky bez zábran\",\"description\":\"Dvě středoškolačky, PJ a Josie, založí Klubu bojových sportů, aby před maturitou přišly o panenství.\",\"durationMin\":87,\"genre\":3,\"slug\":\"holky-bez-zabran-97275115\",\"channelId\":\"512\"},{\"id\":\"97275116\",\"start\":\"2025-10-13T09:50:00.000Z\",\"stop\":\"2025-10-13T11:25:00.000Z\",\"title\":\"Taxikáři\",\"description\":\"Během jedné noci se dva taxikáři setkají s řadou cestujících, kteří tak či onak ovlivní jejich životy.\",\"durationMin\":91,\"genre\":3,\"slug\":\"taxikari-97275116\",\"channelId\":\"512\"},{\"id\":\"97275117\",\"start\":\"2025-10-13T11:25:00.000Z\",\"stop\":\"2025-10-13T13:20:00.000Z\",\"title\":\"Dalího kuchař\",\"description\":\"V Cadaqués v 70. letech 20. století se talentovaný kuchař Fernando setkává s proslulým Salvadorem Dalím, což podnítí zrod kulinářského génia.\",\"durationMin\":111,\"genre\":3,\"slug\":\"daliho-kuchar-97275117\",\"channelId\":\"512\"},{\"id\":\"97275118\",\"start\":\"2025-10-13T13:20:00.000Z\",\"stop\":\"2025-10-13T15:15:00.000Z\",\"title\":\"Vražda v Orient expresu\",\"description\":\"Detektivní drama USA/Malta (2017). Uznávaný detektiv Hercule Poirot (Kenneth Branagh) vyšetřuje vraždu zámožného amerického obchodníka cestujícího v nejslavnějším vlaku na světě v nové filmové adaptaci klasického románu spisovatelky Agathy Christie.\",\"durationMin\":109,\"genre\":3,\"slug\":\"vrazda-v-orient-expresu-97275118\",\"channelId\":\"512\"},{\"id\":\"97275119\",\"start\":\"2025-10-13T15:15:00.000Z\",\"stop\":\"2025-10-13T17:00:00.000Z\",\"title\":\"Ukradené údolí\",\"description\":\"Mexicko-navažská mechanička Lupe se spojí se zločineckou kovbojkou, aby jí pomohla zachránit umírající matku.\",\"durationMin\":100,\"genre\":3,\"slug\":\"ukradene-udoli-97275119\",\"channelId\":\"512\"},{\"id\":\"97275120\",\"start\":\"2025-10-13T17:00:00.000Z\",\"stop\":\"2025-10-13T17:30:00.000Z\",\"title\":\"Sex ve městě III (11)\",\"description\":\"$5b\",\"durationMin\":28,\"genre\":4,\"slug\":\"sex-ve-meste-iii-97275120\",\"channelId\":\"512\"},{\"id\":\"97275121\",\"start\":\"2025-10-13T17:30:00.000Z\",\"stop\":\"2025-10-13T18:00:00.000Z\",\"title\":\"Sex ve městě III (12)\",\"description\":\"$5c\",\"durationMin\":29,\"genre\":4,\"slug\":\"sex-ve-meste-iii-97275121\",\"channelId\":\"512\"},{\"id\":\"97275122\",\"start\":\"2025-10-13T18:00:00.000Z\",\"stop\":\"2025-10-13T19:00:00.000Z\",\"title\":\"Příběh služebnice IV (10)\",\"description\":\"Sci-fi seriál USA (2021). Seriál Příběh služebnice sleduje ženu, která je nucena žít jako konkubína v dystopické blízké budoucnosti pod fundamentalistickou teokratickou diktaturou v totalitním Gileádu, dříve známém jako USA, kde ženská práva prakticky neexistují.\",\"durationMin\":56,\"genre\":4,\"slug\":\"pribeh-sluzebnice-iv-97275122\",\"channelId\":\"512\"},{\"id\":\"97275123\",\"start\":\"2025-10-13T19:00:00.000Z\",\"stop\":\"2025-10-13T20:00:00.000Z\",\"title\":\"Jednotka (6)\",\"description\":\"Za hranicemi představ o dobru a zlu teče řeka. Dramatický seriál USA (2025). Agent FBI stojí v čele vyšetřování brutálních loupeží, za nimiž překvapivě stojí nenápadný rodinný typ se skrytou temnou stránkou.\",\"durationMin\":60,\"genre\":4,\"slug\":\"jednotka-97275123\",\"channelId\":\"512\"},{\"id\":\"97275124\",\"start\":\"2025-10-13T20:00:00.000Z\",\"stop\":\"2025-10-13T21:00:00.000Z\",\"title\":\"Židle (1)\",\"description\":\"\",\"durationMin\":60,\"genre\":4,\"slug\":\"zidle-97275124\",\"channelId\":\"512\"},{\"id\":\"97275125\",\"start\":\"2025-10-13T21:00:00.000Z\",\"stop\":\"2025-10-13T22:50:00.000Z\",\"title\":\"Ten pocit\",\"description\":\"Láska napříč kulturami a konvencemi. Pro Marii Theres a Fu neexistuje přímá cesta. Srdečná a chytrá romantická komedie o dvou ženách středního věku.\",\"durationMin\":106,\"genre\":3,\"slug\":\"ten-pocit-97275125\",\"channelId\":\"512\"},{\"id\":\"97275126\",\"start\":\"2025-10-13T22:50:00.000Z\",\"stop\":\"2025-10-14T00:20:00.000Z\",\"title\":\"Jiná žena\",\"description\":\"Eve, roky uvězněná na tropickém ostrově kvůli práci manžela, zanechala svých snů. Jak se izolace prohlubuje, tajemná žena začíná ovládat její život.\",\"durationMin\":82,\"genre\":3,\"slug\":\"jina-zena-97275126\",\"channelId\":\"512\"}],\"556\":[{\"id\":\"97327343\",\"start\":\"2025-10-13T00:45:00.000Z\",\"stop\":\"2025-10-13T01:50:00.000Z\",\"title\":\"Slunečná (26)\",\"description\":\"\",\"durationMin\":62,\"genre\":4,\"slug\":\"slunecna-97327343\",\"channelId\":\"556\"},{\"id\":\"97327344\",\"start\":\"2025-10-13T01:50:00.000Z\",\"stop\":\"2025-10-13T02:45:00.000Z\",\"title\":\"Cesty domů III (33)\",\"description\":\"\",\"durationMin\":55,\"genre\":4,\"slug\":\"cesty-domu-iii-97327344\",\"channelId\":\"556\"},{\"id\":\"97327345\",\"start\":\"2025-10-13T02:45:00.000Z\",\"stop\":\"2025-10-13T03:35:00.000Z\",\"title\":\"Nikdo není dokonalý\",\"description\":\"\",\"durationMin\":51,\"genre\":1,\"slug\":\"nikdo-neni-dokonaly-97327345\",\"channelId\":\"556\"},{\"id\":\"97327346\",\"start\":\"2025-10-13T03:35:00.000Z\",\"stop\":\"2025-10-13T03:59:00.000Z\",\"title\":\"Vodní kolo\",\"description\":\"\",\"durationMin\":24,\"genre\":null,\"slug\":\"vodni-kolo-97327346\",\"channelId\":\"556\"},{\"id\":\"97526088\",\"start\":\"2025-10-13T04:00:00.000Z\",\"stop\":\"2025-10-13T04:20:00.000Z\",\"title\":\"Čirá voda teče\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"cira-voda-tece-97526088\",\"channelId\":\"556\"},{\"id\":\"97526089\",\"start\":\"2025-10-13T04:20:00.000Z\",\"stop\":\"2025-10-13T05:10:00.000Z\",\"title\":\"Receptář prima nápadů\",\"description\":\"\",\"durationMin\":39,\"genre\":1,\"slug\":\"receptar-prima-napadu-97526089\",\"channelId\":\"556\"},{\"id\":\"97526090\",\"start\":\"2025-10-13T05:10:00.000Z\",\"stop\":\"2025-10-13T05:50:00.000Z\",\"title\":\"Vychytávky Ládi Hrušky\",\"description\":\"\",\"durationMin\":31,\"genre\":1,\"slug\":\"vychytavky-ladi-hrusky-97526090\",\"channelId\":\"556\"},{\"id\":\"97526091\",\"start\":\"2025-10-13T05:50:00.000Z\",\"stop\":\"2025-10-13T06:45:00.000Z\",\"title\":\"ZOO Nové začátky (165)\",\"description\":\"\",\"durationMin\":43,\"genre\":4,\"slug\":\"zoo-nove-zacatky-97526091\",\"channelId\":\"556\"},{\"id\":\"97526092\",\"start\":\"2025-10-13T06:45:00.000Z\",\"stop\":\"2025-10-13T08:05:00.000Z\",\"title\":\"Slunečná (27)\",\"description\":\"\",\"durationMin\":61,\"genre\":4,\"slug\":\"slunecna-97526092\",\"channelId\":\"556\"},{\"id\":\"97526093\",\"start\":\"2025-10-13T08:05:00.000Z\",\"stop\":\"2025-10-13T09:25:00.000Z\",\"title\":\"Cesty domů III (34)\",\"description\":\"\",\"durationMin\":59,\"genre\":4,\"slug\":\"cesty-domu-iii-97526093\",\"channelId\":\"556\"},{\"id\":\"97526094\",\"start\":\"2025-10-13T09:25:00.000Z\",\"stop\":\"2025-10-13T10:40:00.000Z\",\"title\":\"Mladá krev (7)\",\"description\":\"Na krajské oddelenie vrážd prichádza skupina policajných nováčikov, ktorí sa musia vyrovnať s nedôverou skúsených kolegov a obstáť v ostrej praxi. Na nelegálnej skládke stavebného odpadu sú nájdené pozostatky mladej ženy. Prípadu sa ujímajú Fojtek s Kamilou a stopy ich privádzajú k práve rekonštruovanej vile vplyvného radného Síbrta. Podľa patologičky sú však kosti oveľa staršieho pôvodu a môžu súvisieť s dávno premlčaným zločinom. Kamila sa spolu s Filipom, ktorý jej cez videohovor pomáha z nemocničného lôžka, ponorí do temnej minulosti. Nočné pátranie v pivnici vily nakoniec odhalí viac, než by ktokoľvek čakal.\",\"durationMin\":59,\"genre\":4,\"slug\":\"mlada-krev-97526094\",\"channelId\":\"556\"},{\"id\":\"97526095\",\"start\":\"2025-10-13T10:40:00.000Z\",\"stop\":\"2025-10-13T12:00:00.000Z\",\"title\":\"Slunečná (28)\",\"description\":\"\",\"durationMin\":61,\"genre\":4,\"slug\":\"slunecna-97526095\",\"channelId\":\"556\"},{\"id\":\"97526096\",\"start\":\"2025-10-13T12:00:00.000Z\",\"stop\":\"2025-10-13T13:15:00.000Z\",\"title\":\"Cesty domů III (35)\",\"description\":\"\",\"durationMin\":59,\"genre\":4,\"slug\":\"cesty-domu-iii-97526096\",\"channelId\":\"556\"},{\"id\":\"97526097\",\"start\":\"2025-10-13T13:15:00.000Z\",\"stop\":\"2025-10-13T15:00:00.000Z\",\"title\":\"Máme rádi Česko\",\"description\":\"\",\"durationMin\":79,\"genre\":1,\"slug\":\"mame-radi-cesko-97526097\",\"channelId\":\"556\"},{\"id\":\"97526098\",\"start\":\"2025-10-13T15:00:00.000Z\",\"stop\":\"2025-10-13T16:00:00.000Z\",\"title\":\"Prostřeno!\",\"description\":\"\",\"durationMin\":42,\"genre\":1,\"slug\":\"prostreno-97526098\",\"channelId\":\"556\"},{\"id\":\"97526099\",\"start\":\"2025-10-13T16:00:00.000Z\",\"stop\":\"2025-10-13T16:55:00.000Z\",\"title\":\"ZOO Nové začátky (166)\",\"description\":\"Mikovi sa páči Vlaďka a kvôli nej opravuje model pre malého Tondu. Brázda poškuľuje po Báre. Alex na obede s Tamarou rieši len darček pre Kiki. Haďák chváli Báru a Brázdu za prácu na potenciálnej spolupráci s reťazcom. Petra je zúfalá zo Skopalovho domu. Danielovi dôjde, že zdravotné problémy Nicka a Veroniky majú pôvod u potkana. Michaeline deti sa sťažujú na Lexu. Kříž povedal Ester, že od nej chce odísť, no tá sa ho nechce vzdať. Právnici na kartárku Janu vymysleli nový plán, pôjde za ňou viac ľudí. Kateřina bráni Prokopa pred Korálovým podozrením.\",\"durationMin\":43,\"genre\":4,\"slug\":\"zoo-nove-zacatky-97526099\",\"channelId\":\"556\"},{\"id\":\"97526100\",\"start\":\"2025-10-13T16:55:00.000Z\",\"stop\":\"2025-10-13T18:15:00.000Z\",\"title\":\"Polda (8)\",\"description\":\"Kuchárska hviezda je nájdená mŕtva na podlahe vo svojej reštaurácii. Zatiaľ čo Michal jedlom iba udržiava svoje telo v prevádzkyschopnom stave, Andrej má pre dobrú kuchyňu slabosť. I tak však obaja stoja pred rovnakou úlohou. Nájsť vraha šéfkuchára Horkého. Okruh podozrivých je veľký rovnako tak, ako úspech slávneho kuchára. Komu prekážal talentovaný šéfkuchár a prečo? A ako sa Bříza postaví k pozvaniu na svadbu od bývalej ženy?\",\"durationMin\":56,\"genre\":4,\"slug\":\"polda-97526100\",\"channelId\":\"556\"},{\"id\":\"97526101\",\"start\":\"2025-10-13T18:15:00.000Z\",\"stop\":\"2025-10-13T19:30:00.000Z\",\"title\":\"Hvězdy nad hlavou (15)\",\"description\":\"Učiteľka Nejezchlebová sa rozhodne skúšať divadlo, ale predstavenie Rómea a Júlie sa jej začne doslova sypať pod rukami. Mení sa obsadenie, nemá kostýmy, a navyše kľúčovú úlohu Romea chce hrať Filip namiesto Romana. Vzťah Lucie a Veselého sa ocitol v akejsi agónii. A neprispieva mu ani list, ktorý Veselý dostane zo Španielska. Statkár Prokeš chce po džokejovi Patrikovi, aby si vzal Táňu. Ale tá túži po inom.\",\"durationMin\":63,\"genre\":4,\"slug\":\"hvezdy-nad-hlavou-97526101\",\"channelId\":\"556\"},{\"id\":\"97526102\",\"start\":\"2025-10-13T19:30:00.000Z\",\"stop\":\"2025-10-13T20:55:00.000Z\",\"title\":\"Temný Kraj (11)\",\"description\":\"Petr Kraj je v nemocnici po operácii mozgu stále v kóme a nie je isté, či sa vôbec preberie. Prípravy na tradičné fašiangové oslavy a zabíjačku naruší nielen séria brutálnych vrážd, ale tiež príjazd tajomného cudzinca, ktorého Hamplová dobre pozná z minulosti. Desivé vraždy pripomínajú morbídne fašiangové legendy a prepoja vyšetrovateľov z okresu s prípadom v Prahe. Páchateľ prepustený na nedávnu amnestiu vraždí mäsiarskymi nástrojmi, obete čísluje a chystá sa znovu zaútočiť. Vo výhľade má však aj policajtov a v ohrození je nielen Hamplová, ale aj Petr. Koho zachráni zatúlaný Egon? Kto je zákerný fašiangový mäsiar?\",\"durationMin\":63,\"genre\":4,\"slug\":\"temny-kraj-97526102\",\"channelId\":\"556\"},{\"id\":\"97526103\",\"start\":\"2025-10-13T20:55:00.000Z\",\"stop\":\"2025-10-13T21:45:00.000Z\",\"title\":\"Receptář prima nápadů\",\"description\":\"\",\"durationMin\":39,\"genre\":1,\"slug\":\"receptar-prima-napadu-97526103\",\"channelId\":\"556\"},{\"id\":\"97526104\",\"start\":\"2025-10-13T21:45:00.000Z\",\"stop\":\"2025-10-13T22:15:00.000Z\",\"title\":\"Vychytávky Ládi Hrušky\",\"description\":\"\",\"durationMin\":31,\"genre\":1,\"slug\":\"vychytavky-ladi-hrusky-97526104\",\"channelId\":\"556\"},{\"id\":\"97526105\",\"start\":\"2025-10-13T22:15:00.000Z\",\"stop\":\"2025-10-13T23:05:00.000Z\",\"title\":\"Show Jana Krause\",\"description\":\"\",\"durationMin\":50,\"genre\":1,\"slug\":\"show-jana-krause-97526105\",\"channelId\":\"556\"},{\"id\":\"97526106\",\"start\":\"2025-10-13T23:05:00.000Z\",\"stop\":\"2025-10-14T00:25:00.000Z\",\"title\":\"Máme rádi Česko\",\"description\":\"\",\"durationMin\":79,\"genre\":1,\"slug\":\"mame-radi-cesko-97526106\",\"channelId\":\"556\"}],\"558\":[{\"id\":\"97820962\",\"start\":\"2025-10-13T00:40:00.000Z\",\"stop\":\"2025-10-13T01:40:00.000Z\",\"title\":\"Kobra 11 VII (4)\",\"description\":\"Akční seriál N (2003). Vyšetřování zločinů a pořádek na dálnici i v jejím okolí plně zaměstnává speciální tým kriminálky dálniční policie, který je posílen o nového, nadšeného a trochu zbrklého parťáka.\",\"durationMin\":60,\"genre\":4,\"slug\":\"kobra-11-vii-97820962\",\"channelId\":\"558\"},{\"id\":\"97820963\",\"start\":\"2025-10-13T01:40:00.000Z\",\"stop\":\"2025-10-13T02:05:00.000Z\",\"title\":\"Strážci hranic: Austrálie XIII (1)\",\"description\":\"\",\"durationMin\":25,\"genre\":1,\"slug\":\"strazci-hranic-australie-xiii-97820963\",\"channelId\":\"558\"},{\"id\":\"97820964\",\"start\":\"2025-10-13T02:05:00.000Z\",\"stop\":\"2025-10-13T02:30:00.000Z\",\"title\":\"Strážci hranic: Austrálie XIII (2)\",\"description\":\"\",\"durationMin\":25,\"genre\":1,\"slug\":\"strazci-hranic-australie-xiii-97820964\",\"channelId\":\"558\"},{\"id\":\"97820965\",\"start\":\"2025-10-13T02:30:00.000Z\",\"stop\":\"2025-10-13T03:00:00.000Z\",\"title\":\"Velkolepá sezóna PSG 2012/13\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"velkolepa-sezona-psg-2012-13-97820965\",\"channelId\":\"558\"},{\"id\":\"97512184\",\"start\":\"2025-10-13T03:00:00.000Z\",\"stop\":\"2025-10-13T03:40:00.000Z\",\"title\":\"Američtí sběratelé IX (13)\",\"description\":\"\",\"durationMin\":40,\"genre\":1,\"slug\":\"americti-sberatele-ix-97512184\",\"channelId\":\"558\"},{\"id\":\"97512185\",\"start\":\"2025-10-13T03:40:00.000Z\",\"stop\":\"2025-10-13T04:10:00.000Z\",\"title\":\"Mistři zastavárny VI (14)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":30,\"genre\":1,\"slug\":\"mistri-zastavarny-vi-97512185\",\"channelId\":\"558\"},{\"id\":\"97512186\",\"start\":\"2025-10-13T04:10:00.000Z\",\"stop\":\"2025-10-13T04:35:00.000Z\",\"title\":\"Mistři zastavárny VI (15)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":25,\"genre\":1,\"slug\":\"mistri-zastavarny-vi-97512186\",\"channelId\":\"558\"},{\"id\":\"97512187\",\"start\":\"2025-10-13T04:35:00.000Z\",\"stop\":\"2025-10-13T05:10:00.000Z\",\"title\":\"Strážci hranic: Austrálie XIII (1)\",\"description\":\"\",\"durationMin\":35,\"genre\":1,\"slug\":\"strazci-hranic-australie-xiii-97512187\",\"channelId\":\"558\"},{\"id\":\"97512188\",\"start\":\"2025-10-13T05:10:00.000Z\",\"stop\":\"2025-10-13T05:40:00.000Z\",\"title\":\"Strážci hranic: Austrálie XIII (2)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"strazci-hranic-australie-xiii-97512188\",\"channelId\":\"558\"},{\"id\":\"97512189\",\"start\":\"2025-10-13T05:40:00.000Z\",\"stop\":\"2025-10-13T06:35:00.000Z\",\"title\":\"Na lovu V (105)\",\"description\":\"\",\"durationMin\":55,\"genre\":1,\"slug\":\"na-lovu-v-97512189\",\"channelId\":\"558\"},{\"id\":\"97512190\",\"start\":\"2025-10-13T06:35:00.000Z\",\"stop\":\"2025-10-13T06:55:00.000Z\",\"title\":\"Teleshopping\",\"description\":\"\",\"durationMin\":20,\"genre\":null,\"slug\":\"teleshopping-97512190\",\"channelId\":\"558\"},{\"id\":\"97512191\",\"start\":\"2025-10-13T06:55:00.000Z\",\"stop\":\"2025-10-13T07:55:00.000Z\",\"title\":\"Knight Rider (22)\",\"description\":\"\",\"durationMin\":60,\"genre\":4,\"slug\":\"knight-rider-97512191\",\"channelId\":\"558\"},{\"id\":\"97512192\",\"start\":\"2025-10-13T07:55:00.000Z\",\"stop\":\"2025-10-13T08:55:00.000Z\",\"title\":\"Knight Rider II (1)\",\"description\":\"\",\"durationMin\":60,\"genre\":4,\"slug\":\"knight-rider-ii-97512192\",\"channelId\":\"558\"},{\"id\":\"97512193\",\"start\":\"2025-10-13T08:55:00.000Z\",\"stop\":\"2025-10-13T09:10:00.000Z\",\"title\":\"Teleshopping\",\"description\":\"\",\"durationMin\":15,\"genre\":null,\"slug\":\"teleshopping-97512193\",\"channelId\":\"558\"},{\"id\":\"97512194\",\"start\":\"2025-10-13T09:10:00.000Z\",\"stop\":\"2025-10-13T09:45:00.000Z\",\"title\":\"Válka skladů: Kanada (19)\",\"description\":\"Reality show Kan. (2013). Na aukcích po celé Kanadě se každý den scházejí nákupčí, kteří bojují o obsah zabavených či zapomenutých skladovacích jednotek. Ten, kdo jednotku nakonec získá, si může odnést spoustu harampádí anebo skutečný poklad. Sledujte profesionální život Roye Dirnbecka, známého jako Iniciátor, Cindy Haydenové a Ricka Coffilla - dua tzv. Veteránů. Ursuly Stolfové alias Kočky a dvojice otce se synem Paula a Bogarta Kennyových - přezdívaných Gambler a Špunt\",\"durationMin\":35,\"genre\":1,\"slug\":\"valka-skladu-kanada-97512194\",\"channelId\":\"558\"},{\"id\":\"97512195\",\"start\":\"2025-10-13T09:45:00.000Z\",\"stop\":\"2025-10-13T10:15:00.000Z\",\"title\":\"Válka skladů: Kanada (20)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"valka-skladu-kanada-97512195\",\"channelId\":\"558\"},{\"id\":\"97512196\",\"start\":\"2025-10-13T10:15:00.000Z\",\"stop\":\"2025-10-13T10:50:00.000Z\",\"title\":\"Válka skladů: Kanada (21)\",\"description\":\"Reality show Kan. (2013). Na aukcích po celé Kanadě se každý den scházejí nákupčí, kteří bojují o obsah zabavených či zapomenutých skladovacích jednotek. Ten, kdo jednotku nakonec získá, si může odnést spoustu harampádí anebo skutečný poklad. Sledujte profesionální život Roye Dirnbecka, známého jako Iniciátor, Cindy Haydenové a Ricka Coffilla - dua tzv. Veteránů. Ursuly Stolfové alias Kočky a dvojice otce se synem Paula a Bogarta Kennyových - přezdívaných Gambler a Špunt\",\"durationMin\":35,\"genre\":1,\"slug\":\"valka-skladu-kanada-97512196\",\"channelId\":\"558\"},{\"id\":\"97512197\",\"start\":\"2025-10-13T10:50:00.000Z\",\"stop\":\"2025-10-13T11:20:00.000Z\",\"title\":\"Válka skladů: Kanada (22)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"valka-skladu-kanada-97512197\",\"channelId\":\"558\"},{\"id\":\"97512198\",\"start\":\"2025-10-13T11:20:00.000Z\",\"stop\":\"2025-10-13T11:50:00.000Z\",\"title\":\"Mistři zastavárny VI (16)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":30,\"genre\":1,\"slug\":\"mistri-zastavarny-vi-97512198\",\"channelId\":\"558\"},{\"id\":\"97512199\",\"start\":\"2025-10-13T11:50:00.000Z\",\"stop\":\"2025-10-13T12:15:00.000Z\",\"title\":\"Mistři zastavárny VI (17)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":25,\"genre\":1,\"slug\":\"mistri-zastavarny-vi-97512199\",\"channelId\":\"558\"},{\"id\":\"97512200\",\"start\":\"2025-10-13T12:15:00.000Z\",\"stop\":\"2025-10-13T12:45:00.000Z\",\"title\":\"Mistři zastavárny VI (18)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":30,\"genre\":1,\"slug\":\"mistri-zastavarny-vi-97512200\",\"channelId\":\"558\"},{\"id\":\"97512201\",\"start\":\"2025-10-13T12:45:00.000Z\",\"stop\":\"2025-10-13T13:15:00.000Z\",\"title\":\"Mistři zastavárny VI (19)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":30,\"genre\":1,\"slug\":\"mistri-zastavarny-vi-97512201\",\"channelId\":\"558\"},{\"id\":\"97512202\",\"start\":\"2025-10-13T13:15:00.000Z\",\"stop\":\"2025-10-13T13:45:00.000Z\",\"title\":\"Strážci hranic: Austrálie XIII (3)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"strazci-hranic-australie-xiii-97512202\",\"channelId\":\"558\"},{\"id\":\"97512203\",\"start\":\"2025-10-13T13:45:00.000Z\",\"stop\":\"2025-10-13T14:15:00.000Z\",\"title\":\"Strážci hranic: Austrálie XIII (4)\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"strazci-hranic-australie-xiii-97512203\",\"channelId\":\"558\"},{\"id\":\"97512204\",\"start\":\"2025-10-13T14:15:00.000Z\",\"stop\":\"2025-10-13T15:20:00.000Z\",\"title\":\"Kobra 11 VII (5)\",\"description\":\"Akční seriál N (2003). Vyšetřování zločinů a pořádek na dálnici i v jejím okolí plně zaměstnává speciální tým kriminálky dálniční policie, který je posílen o nového, nadšeného a trochu zbrklého parťáka.\",\"durationMin\":65,\"genre\":4,\"slug\":\"kobra-11-vii-97512204\",\"channelId\":\"558\"},{\"id\":\"97512205\",\"start\":\"2025-10-13T15:20:00.000Z\",\"stop\":\"2025-10-13T16:25:00.000Z\",\"title\":\"Kobra 11 VII (6)\",\"description\":\"Akční seriál N (2003). Vyšetřování zločinů a pořádek na dálnici i v jejím okolí plně zaměstnává speciální tým kriminálky dálniční policie, který je posílen o nového, nadšeného a trochu zbrklého parťáka.\",\"durationMin\":65,\"genre\":4,\"slug\":\"kobra-11-vii-97512205\",\"channelId\":\"558\"},{\"id\":\"97512206\",\"start\":\"2025-10-13T16:25:00.000Z\",\"stop\":\"2025-10-13T16:55:00.000Z\",\"title\":\"Válka skladů: Kanada (23)\",\"description\":\"Reality show Kan. (2013). Na aukcích po celé Kanadě se každý den scházejí nákupčí, kteří bojují o obsah zabavených či zapomenutých skladovacích jednotek. Ten, kdo jednotku nakonec získá, si může odnést spoustu harampádí anebo skutečný poklad. Sledujte profesionální život Roye Dirnbecka, známého jako Iniciátor, Cindy Haydenové a Ricka Coffilla - dua tzv. Veteránů. Ursuly Stolfové alias Kočky a dvojice otce se synem Paula a Bogarta Kennyových - přezdívaných Gambler a Špunt\",\"durationMin\":30,\"genre\":1,\"slug\":\"valka-skladu-kanada-97512206\",\"channelId\":\"558\"},{\"id\":\"97512207\",\"start\":\"2025-10-13T16:55:00.000Z\",\"stop\":\"2025-10-13T17:30:00.000Z\",\"title\":\"Válka skladů: Kanada (24)\",\"description\":\"\",\"durationMin\":35,\"genre\":1,\"slug\":\"valka-skladu-kanada-97512207\",\"channelId\":\"558\"},{\"id\":\"97512208\",\"start\":\"2025-10-13T17:30:00.000Z\",\"stop\":\"2025-10-13T18:00:00.000Z\",\"title\":\"Mistři zastavárny VI (20)\",\"description\":\"Reality show USA (2011). Starožitnictví Gold \u0026 Silver Pawn Shop v Las Vegas je rodinný byznys založený Richardem „The Old Man“ Harrisonem v roce 1988. Spoluzakladem je jeho syn Rick Harrison. Dalé učinkují Rickův syn Corey „Big Hoss“ Harrison a jeho kamarád Austin „Chumlee“ Russell. A tihle hoši vyjednávají s prodejci nejrůznějších předmětů od kapesních hodinek přes auta a motorky, které se snaží prodat nebo dát do zástavy. Nechybí samozřejmě fascinující informace týkající se jednotlivých kousků stejně jako rodinné neshody bratrů Harrisonových. Prostě reality show jak má být\",\"durationMin\":30,\"genre\":1,\"slug\":\"mistri-zastav