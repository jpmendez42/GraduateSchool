                                    <p class="news__subtext">
                                        <span class="news__service-name"><%- model.get('cpName') %></span>
                                    </p>
                                </div>
                            </a>
                        </li>
                        <% if (index % 9 === 8) { %>
                    </ul>
                    <div class="js-news__scroll-point news__item--hidden"></div>
                    <% } %>
                    <% }); %>
                </script>

