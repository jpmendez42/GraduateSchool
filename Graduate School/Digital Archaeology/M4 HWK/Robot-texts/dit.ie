  <style>
/* --- H3 Banners TU Dublin Dark Blue --- */
h3 {
    color: #004c6c;
}

.useful-info-container h3 {
  padding-left: 15px;
  padding-right: 15px;
}

/* --- General Layout Adjustments for Article List & Gallery --- */

/* Adds top and bottom padding to article lists on desktop */
@media (min-width: 992px) {
  .article-list {
    padding-top: 40px !important;
    padding-bottom: 40px !important;
  }
}

/* Adds top padding to gallery sections on desktop */
@media (min-width: 992px) {
  .gallery-slider,
  .gallery-grid {
    padding-top: 50px !important;
  }
}

/* --- News Buttons --- */

/* Container for grouped news buttons */
.cta-newsbuttons {
  background-color: #fafafa;
  display: flex;
  justify-content: center;
  margin-bottom: 50px;
}

/* Stacks buttons vertically on smaller screens */
@media (max-width: 600px) {
  .cta-newsbuttons {
    flex-direction: column;
    align-items: center;
  }

  .cta-newsbuttonblue,
  .cta-newsbuttonwhite {
    width: 80%;
    margin: 5px 0 10px;
  }

  .cta-newsbuttonblue {
    margin-right: 0 !important;
  }
}

/* Blue button styling */
.cta-newsbuttonblue {
  background-color: #004c6c;
  color: #FFFFFF;
  font-family: 'visuelt-regular', sans-serif;
  font-weight: bold;
  font-size: 16px;
  padding: 10px 24px;
  border: 2px solid #004c6c;
  text-decoration: none;
  display: inline-block;
  margin-top: 2px;
  margin-right: 15px;
  margin-bottom: 2px;
  transition: background-color 0.3s ease;
  text-transform: uppercase;
  width: 230px;
  text-align: center;
}

.cta-newsbuttonblue:hover {
  background-color: #004c6c;
  border-color: #004c6c;
  color: #FFFFFF !important;
}

/* White button styling */
.cta-newsbuttonwhite {
  background-color: #fff;
  color: #004c6c;
  font-family: 'visuelt-regular', sans-serif;
  font-weight: bold;
  font-size: 16px;
  padding: 10px 24px;
  border: 2px solid #004c6c;
  text-decoration: none;
  display: inline-block;
  margin-top: 2px;
  margin-left: 0;
  margin-bottom: 2px;
  transition: background-color 0.3s ease;
  text-transform: uppercase;
  width: 230px;
  text-align: center;
}

.cta-newsbuttonwhite:hover {
  background-color: #004c6c;
  color: #FFFFFF;
}

/* --- Gallery Grid & Slider Adjustments --- */

/* Makes gallery items responsive with wrapping on mobile */
@media (max-width: 768px) {
  .gallery-slider__slider {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    justify-content: center;
  }

  .gallery-slider__item {
    width: 49%;
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    align-items: center;
  }
}

/* Adjusts inner padding for gallery slider text */
.gallery-slider__inner span {
  padding: 15px 30px 15px 15px !important;
}

/* Transparent borders on gallery items for consistent spacing */
@media (max-width: 768px) {
  .gallery-grid .gallery-slider__item {
    border: 5px solid transparent;
  }
}

/* --- Animation Utility --- */

/* Single Y-axis flip animation (used with .flip-once class) */
@keyframes flipOnce {
  0% {
    transform: rotateY(0);
  }
  100% {
    transform: rotateY(360deg);
  }
}

.flip-once {
  display: inline-block;
  animation: flipOnce 1s ease-in-out;
}

/* --- Course Search bar mobile --- */

@media (max-width: 767.98px) {
  .course-search-form__col {
    padding-left: 0 !important;
    padding-right: 2px !important;
  }

  .course-search-form__form fieldset {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .course-search-form__form input[type="text"] {
    flex: 1;
    min-width: 0;
  }

  .course-search-form__form button {
    white-space: nowrap;
    flex-shrink: 0;
  }
}

  /* CTA Banner styles with background graphic */
  .cta-bannerblue {
  background-color: #004C6C;
  color: #ffffff;
  text-align: left;
  padding: 20px;
  margin: 10px 0;
  font-family: 'visuelt-regular', Arial, sans-serif;
  position: relative;
  overflow: hidden;
}

a:hover {
text-decoration: none !important;
}

/* Background graphic style for CTA banner */
.cta-bannerblue::before {
  content: "";
  background-image: url('https://pxl-tudublinie.terminalfour.net/prod01/tudublin-cdn-pxl/media/website/site-assets/images/tu-mark-outline.svg');
  background-size: 50%;
  background-repeat: no-repeat;
  background-position: right;
  opacity: 0.5;
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
}

/* Heading styles for CTA banner */
.cta-bannerblue h2, .cta-bannerblue h3, .cta-buttonwhite {
  position: relative;
  z-index: 1;
}

.cta-bannerblue h2 {
  font-family: 'Prophet-Bold', sans-serif;
  font-weight: bold; 
  font-size: 26px;
  margin: 0;
  color: #ffffff; 
}

.cta-bannerblue h3 {
  font-family: 'Prophet-Regular', sans-serif;
  font-weight: normal;
  font-size: 20px;
  margin: 10px 0;
  color: #00a9b7;
}

/* square button styles with white color and uppercase font for CTA banner*/
.cta-buttonwhite {
  background-color: #fff; 
  color: #004C6C;
  font-family: 'Prophet-Bold', sans-serif;
  font-weight: bold;
  font-size: 16px;
  padding: 12px 30px;
  border: none;
  border-radius: 0px;
  text-decoration: none;
  display: inline-block;
  margin-top: 15px;
  transition: background-color 0.3s ease;
  text-transform: uppercase;
}

.cta-buttonwhite:hover {
  background-color: #eee;
  color: #004C6C;
}

/* Responsive layout for mobile devices for CTA banner */
@media (max-width: 768px) {
  .cta-bannerblue {
    flex-direction: column; /* Stack items vertically on mobile */
    text-align: left; /* Align text to the left*/
  }

  .cta-buttonwhite {
    margin-top: 15px;
    align-self: flex-start; /* Align button to the left */
  }
}

/* Responsive font for desktop devices for CTA banner */
@media (min-width: 992px) {
    .cta-bannerblue h1 {
     font-size: 34px;
 }
    .cta-bannerblue h2 {
    font-size: 28px;
  }
}
  /* CTA Banner styles with background graphic end*/

  /* Adjust news images height*/

.article-list__inner::after {
  content: "";
  clear: both;
  display: table;
}
.article-list__image img {
    display: flex;
    object-fit: cover;
    width: 100%;
    height: 308px; /* the height used by default (i.e. mobile width devices) */
}
/* This is for grid view */
@media (min-width: 500px) {
    .article-list__image img { 
    height: 450px; /* the height used on screens that are 500px wide and above */
    }
}
@media (min-width: 600px) {
    .article-list__image img { 
     height: 550px; /* the height used on screens that are 600px wide and above */
    }
}
@media (min-width: 768px) {
    .article-list__image img { 
     height: 260px; /* the height used on screens that are 768px wide and above */
    }
}
@media (min-width: 992px) {
    .article-list__image img {    
      height: 230px; /* the height used on screens that are 992px wide and above */
    }
}
@media (min-width: 1200px) {
    .article-list__image img {    
      height: 215px; /* the height used on screens that are 1200px wide and above */
    }
}
/* This is for list view */
@media (min-width: 250px) {
   .article-list--list .article-list__image img {
      height: 89px; /* the height used on screens that are 250px wide and above */
    }
}
@media (min-width: 768px) {
   .article-list--list .article-list__image img {
      height: 150px; /* the height used on screens that are 768px wide and above */
    }
}
@media (min-width: 1200px) {
   .article-list--list .article-list__image img {
      height: 196px; /* the height used on screens that are 1200px wide and above */
    }
}

.standard-content {
    padding-top: 30px;
    padding-bottom: 0;
}

</style>
