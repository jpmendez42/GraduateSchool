<!DOCTYPE html><html xmlns="http://www.w3.org/1999/xhtml"><head><base href="/"><title></title><meta http-equiv="X-UA-Compatible" content="IE=edge"><meta http-equiv="Pragma-Control" content="no-cache"><meta http-equiv="Cache-directive" content="no-cache"><meta http-equiv="Pragma-directive" content="no-cache"><meta http-equiv="Cache-Control" content="no-cache"><meta http-equiv="Pragma" content="no-cache"><meta http-equiv="Expires" content="0"><meta http-equiv="Pragma-directive: no-cache"><meta http-equiv="Cache-directive: no-cache"><script src="webconfig.js"></script><meta charset="utf-8"><!--[if (!IE)|(gt IE 8)]><!--><script src="https://ajax.googleapis.com/ajax/libs/jquery/2.2.0/jquery.min.js"></script><!--<![endif]--><!--[if lte IE 8]><script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.0/jquery.min.js"></script><![endif]--><link href="https://fonts.googleapis.com/css?family=Lato:400,100,300,700,900" rel="stylesheet"><link rel="shortcut icon" href="assets/favicon/favicon.ico?v=1733919816146" type="image/x-icon"><link rel="icon" href="assets/favicon/favicon.ico?v=1733919816146" type="image/x-icon"><script src="assets/js/vendor/mustache.min.js?v=1733919816146"></script><script src="assets/js/utils.js?v=1733919816146"></script><style>*{font-family:Roboto,Segoe UI,sans-serif!important}body,html{height:100%}body{margin:0;padding:0;height:100%;min-height:100%;background:url(assets/images/404/bg.jpg?v=1733919816146);background-size:cover;background-attachment:fixed}.main{z-index:1;position:relative;width:100%;height:100%;display:table}.container{display:table-cell;vertical-align:middle;text-align:center}.description p{color:#fff;font-weight:300;font-size:60px;letter-spacing:2px;text-shadow:2px 2px 2px rgba(0,0,0,.5)}.logo{margin-top:80px}.logo img{max-width:110px}.open-website-button{text-transform:uppercase;font-size:13px;color:#fff;text-decoration:none;border:1px solid #fff;display:inline-block;background:rgba(0,0,0,.2);font-weight:500;letter-spacing:1.1px;text-shadow:1px 1px 1px rgba(0,0,0,.5);padding:6px 12px 7px;border-radius:20px}.open-website-button:hover{text-decoration:none;background:#fff;color:#096172;text-shadow:none}.img_filter{position:absolute;width:100%;height:100%;background:#233eb8;opacity:.8}</style><script id="tmpl_main" type="x-tmpl-mustache"><div class="container">
            <div class="description">
                <p>{{desc}}</p>
                <a href="{{linkUrl}}" class="open-website-button">{{linkName}}</a>
            </div>

            <div class="logo">
                <img src="publicfiles/logo_edubox.png" />
            </div>
        </div></script></head><body><div class="img_filter"></div><main class="main"></main><script>let inUseLanguage=utils.getParameterByName("lang")||"pt",pageView={pt:{desc:"Página não encontrada",linkName:"Abrir website"},br:{desc:"Página não encontrada",linkName:"Abrir website"},fr:{desc:"Page non trouvée",linkName:"Ouvrir la page Web"},en:{desc:"Page not found",linkName:"Open website"},es:{desc:"Página no encontrada",linkName:"Abrir página web"}};pageView[inUseLanguage]||(inUseLanguage="pt"),pageView[inUseLanguage].linkUrl="."+("pt"===inUseLanguage?"":"?lang="+inUseLanguage),$("title").html("Edubox | "+pageView[inUseLanguage].desc),$("main").append(Mustache.render($("#tmpl_main").html(),pageView[inUseLanguage]))</script></body></html>