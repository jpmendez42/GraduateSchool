                                    });

                                    var $BR = $("<br/>");
                                    $('#divResponse').append($BR);
                                    //$('#divResponse').append('<label class="flb-chatbox-msg-server1 MessageAdded"style="background-color:#79797b"><b>Recent Bills for </b><br><br>');
