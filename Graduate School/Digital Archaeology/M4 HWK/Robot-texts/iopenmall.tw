<script type="text/javascript">
    	var loop = true;
    var owl_nav = true;
    var cnt = "12";

    if(cnt <= 3){
    	loop = false;
        owl_nav = false;
    }
	/* 電腦 */
	$("#it906-pbox2379542").owlCarousel({
		loop: loop,
		margin: 25,
		nav: owl_nav,
		dots:false,
		autoplayHoverPause: false ,// 滑鼠經過時暫停
		responsive: {
			0: {
			items: 3
			},
			600: {
			items: 3
			},
			1000: {
			items: 3
			}
		}
	});
    
    //youtube連結改embed
        var video_href = 'https://www.youtube.com/embed/V-UsmOAuaog';
    if (/watch\?v=/.test(video_href)){
        video_href = video_href.replace("watch?v=","embed/")+"?autoplay=0";
        $("#youtube_634326").attr('src',video_href);
    }
    

	$('.it906-video-mask').on('click',function (){
		$(this).hide();
		let video_href = $(this).attr('video-link');
		if (/facebook|fb/.test(video_href)){
			video_href = "https://www.facebook.com/plugins/video.php?href="+video_href+"&show_text=false&appId&width=560&height=332";
			$(this).next().attr('src', video_href);
		} else {
			if (/watch\?v=/.test(video_href)) {
				video_href = video_href.replace("watch?v=", "embed/") + "?autoplay=1";
				$(this).next().attr('src', video_href);
			} else {
				video_href = video_href + "?autoplay=1";
				$(this).next().attr('src', video_href);
			}
		}
		$(this).next().show();
	})

