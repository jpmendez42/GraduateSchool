    .v-pop-cont2 { position: relative; width: 170px; }
    .v-pop-img { width: 230px; height: auto; }
    .v-pop-none { display: none; }
    
    .v-pop-close-button { position: absolute; color: #fff; font-size: 50px; top: -55px; right: 10px; opacity: 0.7; cursor: pointer; }
    .v-pop-close-button:hover { opacity: 1; }

    .v-pop-email { width: 100%; height: 40px; font-family: inherit; color: #000; background-color: #ffffff; border-radius: 20px; box-sizing: border-box; font-size: 14px; font-weight: 400; line-height: 1.33; -webkit-appearance: none; padding: 0 20px; border: none; outline: none; }
    .v-pop-email-invalid { border: 1px solid #f03030 !important; animation: shake 0.3s; }
    
    .v-pop-error { display: none; position: absolute; bottom: 10px; width: 100%; color: #f03030; font-size: 10px; text-align: center; }

    .v-pop-checkbox { margin-bottom: 0; display: -webkit-box; display: -ms-flexbox; display: flex; -webkit-box-align: center; -ms-flex-align: center; align-items: center; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none; user-select: none; }
    .v-pop-checkbox input { position: absolute; z-index: -1; opacity: 0; margin: 0  }
    .v-pop-checkbox-toggle { position: relative; padding: 0 0 0 15px; cursor: pointer }
    .v-pop-checkbox-toggle:before { content: ''; position: absolute; left: 0; display: inline-block; vertical-align: middle; height: 15px; width: 15px; border: 2px solid #373833; -webkit-box-sizing: border-box; box-sizing: border-box; margin-right: 10px; -webkit-transition: all 0.2s; transition: all 0.2s; opacity: .6; }
    .v-pop-checkbox-toggle:after { content: ''; position: absolute; display: none; left: 5px; top: 2px; width: 3px; height: 8px; border: solid #373833; border-width: 0 2px 2px 0; -webkit-transform: rotate(45deg); -ms-transform: rotate(45deg); transform: rotate(45deg); -webkit-transition: all 0.2s; transition: all 0.2s; }
    .v-pop-checkbox input:checked+.v-pop-checkbox-toggle:before { opacity: 1; }
    .v-pop-checkbox input:checked+.v-pop-checkbox-toggle:after { display: block; }
    .v-pop-checkbox-toggle-invalid { position: relative; padding: 0 0 0 15px; cursor: pointer; animation: shake 0.3s; }
    .v-pop-checkbox-toggle-invalid:before { content: ''; position: absolute; left: 0; display: inline-block; vertical-align: middle; height: 15px; width: 15px; border: 2px solid #f03030; -webkit-box-sizing: border-box; box-sizing: border-box; margin-right: 10px; -webkit-transition: all 0.2s; transition: all 0.2s; opacity: .6; }
    .v-pop-checkbox-toggle-invalid:after { content: ''; position: absolute; display: none; left: 5px; top: 2px; width: 3px; height: 8px; border: solid #f03030; border-width: 0 2px 2px 0; -webkit-transform: rotate(45deg); -ms-transform: rotate(45deg); transform: rotate(45deg); -webkit-transition: all 0.2s; transition: all 0.2s; }
    .v-pop-checkbox input:checked+.v-pop-checkbox-toggle-invalid:before { opacity: 1; }
    .v-pop-checkbox input:checked+.v-pop-checkbox-toggle-invalid:after { display: block; }
    
    .v-pop-checkbox-text { margin-left: 10px; font-size: 10px; color: #373833; text-align: left; }
    .v-pop-checkbox-text-invalid { color: #f03030 !important; animation: shake 0.3s; }

    a.v-pop-link, a.v-pop-link:link, a.v-pop-link:visited { color: #373833 !important; font-weight: 600; text-decoration: none; }
    a.v-pop-link:hover, a.v-pop-link:active {  text-decoration: underline !important; }
    a.v-pop-link-invalid, a.v-pop-link-invalid:link, a.v-pop-link-invalid:visited { color: #f03030 !important; animation: shake 0.3s; }

    a.v-pop-link2, a.v-pop-link2:link, a.v-pop-link2:visited { color: #0098cc !important; font-weight: 500; text-decoration: none; }
    a.v-pop-link2:hover, a.v-pop-link2:active {  text-decoration: underline !important; }
    
    .v-pop-button, a.v-pop-button:link, a.v-pop-button:visited { position: relative; display: flex; align-self: flex-end; text-decoration: none; margin-top: auto; color: #373833 !important; font-size: 14px; font-family: 'Arial',Arial,sans-serif; line-height: 1.55; font-weight: 600; background-color: #e2b400; padding: 15px; width: 100%; -webkit-user-select: none; -khtml-user-select: none; -moz-user-select: none; -ms-user-select: none; user-select: none; align-items: center; justify-content: center; box-sizing: border-box; border-radius: 0 0 20px 20px; cursor: pointer; }
    .v-pop-button:hover, a.pop-button:active { opacity: .9; color: #373833 !important; text-decoration: none; }
    
    
    @media screen and (max-width: 639px) {
        .v-pop-item { width: 90%; overflow; hidden; border-radius: 20px; }
        .v-pop-desc-main { flex-direction: column; }
        .v-pop-cont1 { width: 100%; }
        .v-pop-cont2 { width: 100%; padding-bottom: 20px; text-align: center; display: none; }
        .v-pop-img { width: 150px; }
        .v-pop-close-button { font-size: 50px; top: -55px; }
        .v-pop-item-desc { border-radius: 20px 20px 0 0; }
    }
    
    @keyframes shake {
        0% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        50% { transform: translateX(5px); }
        75% { transform: translateX(-5px); }
        100% { transform: translateX(0); }
    }
    
