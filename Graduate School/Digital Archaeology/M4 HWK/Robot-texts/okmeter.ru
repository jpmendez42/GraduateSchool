
	
<!doctype html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,user-scalable=no,initial-scale=1,maximum-scale=1,minimum-scale=1">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/static/img/favicon-96x96.png" sizes="96x96"/>
    <link rel="icon" type="image/png" href="/static/img/favicon-144x144.png" sizes="144x144"/>
    <title>Okmeter – Умный мониторинг для вашей инфраструктуры</title>
    <script defer="defer" src="/static/landing/js/index.js"></script>
    <link href="/static/landing/css/style.css" rel="stylesheet">
</head>
<body>
<div class="sticky-footer">
    <header class="header">
        <div class="container">
            <div class="header__wrap">
                <div class="header__logo"><img src="/static/landing/assets/logo.svg" alt="okmeter-logo"></div>
                <div class="burger-menu"><span></span></div>
                <div class="header__nav">
                    <ul class="header__nav-list">
                        <li class="header__nav-list-item"><a href="/example" target="_blank">демо</a></li>
                        <li class="header__nav-list-item"><a href="#tariffs">тарифы</a></li>
                        <li class="header__nav-list-item"><a href="https://habr.com/ru/company/flant/profile/"
                                                             target="_blank">блог</a></li>
                        <li class="header__nav-list-item"><a href="#faq">FAQ</a></li>
                    </ul>
                    <div class="header__buttons header__buttons--small">
                        <button class="header__button button--register button button--hollow"><a
                                href="/user/signup_user/">регистрация</a></button>
                        <button class="header__button button--log-in button button--filling"><a
                                href="/user/login_user/">вход</a></button>
                    </div>
                </div>
                <div class="header__buttons">
                    <button class="header__button button--register button button--hollow"><a href="/user/signup_user/">регистрация</a>
                    </button>
                    <button class="header__button button--log-in button button--filling"><a href="/user/login_user/">вход</a>
                    </button>
                </div>
            </div>
        </div>
    </header>
    <main>
        <section class="be-prepared">
            <div class="container">
                <div class="be-prepared__wrap">
                    <div class="be-prepared__description"><h2 class="be-prepared__description-title title--h2">Будь
                        готов к&nbsp;любым сбоям на&nbsp;серверах</h2>
                        <div class="be-prepared__description-subtitle subtitle subtitle--dark">С каждого сервера
                            автоматически собираются тысячи метрик, чтобы вы&nbsp;знали обо&nbsp;всём, что происходит с&nbsp;базой
                            данных, сервисами и&nbsp;процессами
                        </div>
                        <a href="/user/signup_user/"
                           class="be-prepared__description-button button button--accent button--filling-accent">Начать
                            мониторинг</a></div>
                    <div class="be-prepared__picture"><img src="/static/landing/assets/be-prepared-schemes-blur.png"
                                                           alt="" class="be-prepared__picture--blur"> <img
                            src="/static/landing/assets/be-prepared-schemes.png" alt="schemes"
                            class="be-prepared__picture--schemes"></div>
                </div>
            </div>
        </section>
        <section class="if-breaks">
            <div class="container">
                <div class="if-breaks__wrap"><h3 class="if-breaks__title title--h3">Если что-то сломается<br/>Okmeter
                    оповестит вас</h3>
                    <div class="if-breaks__picture"><img src="/static/landing/assets/if-breaks-graphics.svg"
                                                         alt="graphics"></div>
                </div>
            </div>
        </section>
        <section class="high-detail">
            <div class="overflow-block">
                <div class="container">
                    <div class="high-detail__wrap">
                        <div class="high-detail__description"><h2 class="high-detail__description-title title--h2">
                            Высокая детализация данных</h2>
                            <div class="high-detail__description-subtitle subtitle subtitle--white">Okmeter
                                авто-магически собирает сотни и&nbsp;даже тысячи показателей работы каждой подсистемы.
                                Все&nbsp;нужные метрики каждого сервиса заранее собраны и&nbsp;визуализированы
                            </div>
                            <div class="high-detail__blur-1"><img src="/static/landing/assets/high-detail-1.svg" alt="">
                            </div>
                        </div>
                        <div class="high-detail__grid-logos">
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/nginx.png"
                                                                     alt="nginx-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/docker.png"
                                                                     alt="docker-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/java.png"
                                                                     alt="java-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/php.png"
                                                                     alt="php-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/statsd.png"
                                                                     alt="nginx-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/mysql.png"
                                                                     alt="docker-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/mongodb.png"
                                                                     alt="java-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/postgresql.png"
                                                                     alt="php-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/cassandra.png"
                                                                     alt="nginx-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/elastic.png"
                                                                     alt="docker-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/rabbitmq.png"
                                                                     alt="java-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/redis.png"
                                                                     alt="php-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/pgbouncer.png"
                                                                     alt="nginx-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/zookeeper.png"
                                                                     alt="docker-logo"></div>
                            <div class="high-detail__grid-item"><img src="/static/landing/assets/memcached.png"
                                                                     alt="java-logo"></div>
                            <div class="high-detail__grid-item empty"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="high-detail__shape"><img src="/static/landing/assets/high-detail-shape.svg" alt=""></div>
            <div class="high-detail__blur-2"><img src="/static/landing/assets/high-detail-2.svg" alt=""></div>
        </section>
        <section class="improve-your-service">
            <div class="container">
                <div class="improve-your-service__wrap"><h2 class="improve-your-service__title title--h2">Улучшай свой
                    сервис, а&nbsp;не&nbsp;мониторинг</h2>
                    <div class="improve-your-service__subtitle subtitle">Готовые и правильные графики, дашборды и&nbsp;алерты,
                        чтобы вы пользовались мониторингом, а&nbsp;не&nbsp;занимались его поддержкой и&nbsp;настройкой,
                        отвлекаясь от&nbsp;основных задач
                    </div>
                    <div class="improve-your-service__features">
                        <ul class="features__list">
                            <li class="features__item">
                                <div class="features__item-line"></div>
                                <div class="features__item-description"><h4 class="features__item-title title--h4">
                                    Нужные метрики «из&nbsp;коробки»</h4>
                                    <div class="features__item-text">Мы собрали чужой опыт и&nbsp;ошибки и&nbsp;подобрали
                                        правильные метрики, по&nbsp;которым понятно где&nbsp;сломалось и&nbsp;что&nbsp;делать.
                                    </div>
                                </div>
                            </li>
                            <li class="features__item">
                                <div class="features__item-line"></div>
                                <div class="features__item-description"><h4 class="features__item-title title--h4">
                                    Готовый настроенный мониторинг</h4>
                                    <div class="features__item-text">Мы не только собрали нужные метрики, но&nbsp;еще и&nbsp;знаем
                                        разнообразные сценарии поломок, которые Okmeter будет постоянно проверять для
                                        каждого вашего сервера и&nbsp;сервиса.
                                    </div>
                                </div>
                            </li>
                            <li class="features__item">
                                <div class="features__item-line"></div>
                                <div class="features__item-description"><h4 class="features__item-title title--h4">
                                    Авто-интеграция</h4>
                                    <div class="features__item-text">Okmeter сам найдет все сервисы и&nbsp;процессы и&nbsp;соберёт
                                        все метрики. Это работает автоматически и&nbsp;не&nbsp;требует ручного
                                        конфигурирования, а&nbsp;значит ничего важного не&nbsp;останется без
                                        мониторинга.
                                    </div>
                                </div>
                            </li>
                            <li class="features__item">
                                <div class="features__item-line"></div>
                                <div class="features__item-description"><h4 class="features__item-title title--h4">
                                    Мониторинг микросервисов</h4>
                                    <div class="features__item-text">Вы будете видеть как состояние кластера в&nbsp;целом,
                                        так и&nbsp;поведение конкретного сервера, контейнера, процесса. Вы легко
                                        локализуете проблему даже в&nbsp;сложной инфраструктуре.
                                    </div>
                                </div>
                            </li>
                        </ul>
                        <div class="improve-your-service__pictures"><img src="/static/landing/assets/features-pic.svg"
                                                                         alt=""></div>
                    </div>
                </div>
            </div>
        </section>
        
        <section class="monitoring">
            <div class="container">
                <div class="monitoring__wrap">
                    <div class="monitoring__intro">
                        <div class="monitoring__intro-description"><h2 class="monitoring__intro-title title--h2">
                            Мониторинг, который даёт ответы</h2>
                            <div class="monitoring__intro-subtitle subtitle">Больше не нужно идти на&nbsp;сервер и&nbsp;грепать
                                логи. Конкретные проблемы сразу видны на&nbsp;графиках.
                            </div>
                        </div>
                        <div class="monitoring__intro-picture"><img src="/static/landing/assets/monitoring-scheme.png"
                                                                    alt="monitoring-scheme"></div>
                        <div class="monitoring__blur-1"><img src="/static/landing/assets/monitoring-1.svg" alt=""></div>
                    </div>
                    <div class="monitoring__grid grid-schemes">

<script>
    window.navSettings = {
		site_name: ``,
    }
</script>

<link rel="stylesheet" href="/static/css/bundle.css?v=64b4ca">
<link href="/static/css/okmeter.css?v=64b4ca" rel="stylesheet">

