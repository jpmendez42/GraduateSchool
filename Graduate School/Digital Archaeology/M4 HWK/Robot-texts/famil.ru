g\":{}},{\"id\":\"6578d6a47929e66c401c73a5\",\"name\":\"LTB\",\"description\":\"Бренд LTB - часть семьи одного из крупнейших европейских холдингов по производству и продаже одежды CAK GROUP. Высочайшее качество, инновационные технологии производства, уникальный авторский стиль одежды и высокие идеалы компании – быстро сделали LTB Jeans настоящим «must-have» в гардеробе каждого ценителя casual. Безукоризненное качество – основополагающий принцип LTB. Вся продукция проходит тщательный контроль и сертифицирована международным сертификатом качества (ISO).\",\"category\":[\"men\",\"women\",\"accessories\",\"children\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:54:44.262Z\",\"updatedAt\":\"2025-03-04T03:11:32.624Z\",\"logo\":{\"id\":\"658bec9ff5b552729cafa240\",\"alt\":\"logo\",\"filename\":\"LTB-1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":9182,\"width\":225,\"height\":68,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":10,\"mimeType\":\"image/jpeg\",\"filesize\":533,\"filename\":\"LTB-1-32x10.jpg\",\"url\":\"/cms/media/LTB-1-32x10.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":867,\"filename\":\"LTB-1-64x19.jpg\",\"url\":\"/cms/media/LTB-1-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":39,\"mimeType\":\"image/jpeg\",\"filesize\":1654,\"filename\":\"LTB-1-128x39.jpg\",\"url\":\"/cms/media/LTB-1-128x39.jpg\"},\"w384\":{\"width\":384,\"height\":116,\"mimeType\":\"image/jpeg\",\"filesize\":5109,\"filename\":\"LTB-1-384x116.jpg\",\"url\":\"/cms/media/LTB-1-384x116.jpg\"},\"w640\":{