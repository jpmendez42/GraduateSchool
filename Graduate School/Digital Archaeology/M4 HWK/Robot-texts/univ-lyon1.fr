                <div class="colonne_deco"><div class="paragraphe--0"><div class="paragraphe__contenu--0 toolbox">
                                <div style="text-align: center;">                <img src="https://www.univ-lyon1.fr/medias/photo/1_1689602840735-png?ID_FICHE=449126" alt="" style="width: 220px; height: 220px; margin: 4px 5px; float: none;">    </div>

<p style="text-align: center;"><a class="lien_externe" href="https://www.univ-lyon1.fr/universite/international?mtm_campaign=home"><strong>INTERNATIONAL&nbsp;<span class="btn-arrow" ktag_span="true"><i class="fa fa-arrow-right"></i></span></strong></a><br>
<br>
