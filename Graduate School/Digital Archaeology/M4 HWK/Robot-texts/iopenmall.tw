.iopen-footer-downloadapp-mob h5{ font-size: 13px; color: #fff; line-height: 40px; margin-bottom: 10px;}
.iopen-footer-downloadapp-mob ul{ display: flex; justify-content: space-between;}
.iopen-footer-downloadapp-mob ul li{ width: 50%; align-items: baseline;}
.iopen-footer-downloadapp-mob a{display: block;width: 100%;height: 100%;}
.iopen-footer-downloadapp-mob .download_icon{ width: 97px;}
.seller-center{background-color: #008062; width: 88px; height: 60px; -moz-border-radius: 10px; -ms-border-radius: 10px; -o-border-radius: 10px; -webkit-border-radius: 10px; border-radius: 10px; display: -ms-box; display: -moz-webkit-flex; display: -webkit-flex; display: -ms-flexbox; display: flex; -ms-flex-align: center; -webkit-align-items: center; align-items: center; -ms-flex-pack: center; -webkit-justify-content: center; -webkit-box-pack: center; -moz-box-pack: center; justify-content: center; -ms-flex-wrap: wrap; -moz-flex-wrap: wrap; -webkit-flex-wrap: wrap; flex-wrap: wrap; text-align: center; padding: 10px 0; }
@media screen and (max-width: 1200px) {
    .iopen-footer .iopen-footer-list-web > .footer_menutitle,.iopen-footer .iopen-footer-list-web > ul.outter {padding:0 15px;}
}
@media screen and (max-width: 1024px) {
    .iopen-footer-downloadapp-mob{ display: block;}
    .iopen-footer-link{height: 60px; padding: 0;}
    .iopen-footer-link .link_area {-ms-flex-wrap: wrap; -moz-flex-wrap: wrap; -webkit-flex-wrap: wrap; flex-wrap: wrap;}
    .iopen-footer-link .link_area li.link_item{width:40%; -webkit-box-flex: 0 40%; -moz-box-flex: 0 40%; -webkit-flex: 0 40%; -ms-flex: 0 40%; flex: 0 40%;}
    .iopen-footer-link .link_area li.link_item a{ font-size: 15px; letter-spacing: .1em; display: -ms-box; display: -moz-webkit-flex; display: -webkit-flex; display: -ms-flexbox; display: flex; -ms-flex-wrap: wrap; -moz-flex-wrap: wrap; -webkit-flex-wrap: wrap; flex-wrap: wrap; -ms-flex-pack: center; -webkit-justify-content: center;-webkit-box-pack: center; -moz-box-pack: center; justify-content: center; -ms-flex-align: center; -webkit-align-items: center; align-items: center;}
    .iopen-footer-link .link_area li.link_item a span{display: block; margin-bottom:0px; margin-right: 10px;}
    .iopen-footer .iopen-footer-list-web { display: none;}
    .iopen-footer .iopen-footer-list-mob { display: block;}
    .seller-center{ margin: 0 auto;}
}
@media screen and (max-width: 450px) {
    .iopen_copyright{ text-align: left; font-size: 12px;}
    .iopen_copyright span{ display: block; padding-left: 0;}
}
@media screen and (max-width: 360px) {
    .iopen-footer-link .link_area li.link_item a span{ font-size: 13px;}
}
