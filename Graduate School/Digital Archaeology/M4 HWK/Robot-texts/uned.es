<script>
$(document).ready(function() {
    function changeCarouselHeight(){
        var videoHeight= $(window).innerWidth() * 31.99964 / 100;
        $('#carousel-uned4d045d9d-0249-464e-9fa9-344fa8f9d8e5').find('.carouselVideo').css({'cssText':'height:'+videoHeight+'px!important'});
        if(window.innerWidth <= 650) {
        	$('#carousel-uned4d045d9d-0249-464e-9fa9-344fa8f9d8e5').find('.responsiveVideo.carouselVideo').css({'cssText':'height:auto!important'});
        }
    }

    changeCarouselHeight();
    $(window).resize(function(){
        changeCarouselHeight();
    });
    $('#carousel-uned4d045d9d-0249-464e-9fa9-344fa8f9d8e5').attr('data-interval', "10000");
    
    const intervalsArray = new Map();    
    	intervalsArray.set("0", "10000");
    	intervalsArray.set("1", "10000");
    	intervalsArray.set("2", "10000");
    	intervalsArray.set("3", "10000");
    	intervalsArray.set("4", "10000");
    	intervalsArray.set("5", "10000");
    	intervalsArray.set("6", "39000");
    
    $('#carousel-uned4d045d9d-0249-464e-9fa9-344fa8f9d8e5').on('slide.bs.carousel', function(event) {
    	let nextPos = $(event.relatedTarget).index();
    	
		let interval = intervalsArray.get(String(nextPos));
		$('#carousel-uned4d045d9d-0249-464e-9fa9-344fa8f9d8e5').attr('data-interval', interval);
		const options = $('#carousel-uned4d045d9d-0249-464e-9fa9-344fa8f9d8e5').data()['bs.carousel']['_config'];
		options.interval = interval;
	})
});
</script>
  
    
  
