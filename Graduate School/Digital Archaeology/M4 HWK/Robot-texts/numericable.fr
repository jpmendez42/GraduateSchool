<section id="titreMiddle">
    <div class="container">
        <div class="row">
            <div class="col-xs-12 center">
                <div>
                    <h2 class="titre titre--XL">Sport, Ciné, Séries...</h2>
                    <h3 class="titre titre--M">Découvrez une large sélection de chaînes et services, à vous de choisir vos programmes préférés&nbsp;!</h3>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="calc-home">
    <!-- THEMES -->
    <div class="calc-themes">
    <div class="container-fluid container-fluid--noGutter">
        <div class="row">
            <div class="col-xs-12 col-sm-6" >
                <a href="https://www.sfr.fr/tv-sfr/bouquets-sport#sfrintid=LP_NumericableEtSFR_Cadre_Sport" class="calc-themes__theme theme">
                    <div class="theme__background" style="background-image : url('//static.s-sfr.fr/media/sport-min.jpg');">
                    </div>
                    <div class="theme__gradient"></div>
                   
                    <div class="theme__filter"></div>
                    <div class="theme__text-container">
                        <a class="theme__title title900">Sport</a>
                        <p class="theme__text text600">
                            Soyez sur tous les terrains et vibrez pour le meilleur du sport (foot, rugby, basket…) avec RMC Sport, beIN SPORTS et plus encore.
                        </p>
                        
                    </div>
                </a>
            </div>
            <div class="col-xs-12 col-sm-6">
                <a href="https://www.sfr.fr/tv-sfr/bouquets-cinema-et-series#sfrintid=LP_NumericableEtSFR_Cadre_cinema_series" class="calc-themes__theme theme">
                    <div class="theme__background" style="background-image : url('//static.s-sfr.fr/media/cine-series-min.jpg');">
                    </div>
                    <div class="theme__gradient"></div>
               
                    <div class="theme__filter"></div>
                    <div class="theme__text-container">
                        <a class="theme__title title900">Cinéma & Séries</a>
                        <p class="theme__text text600">
                           Fans de séries et de cinéma, il y en a pour tous les goûts avec Altice Studio, OCS, Netflix et nos chaînes TV exclusives.
                        </p>
                       
                    </div>
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-xs-12 col-sm-6">
                <a href="https://www.sfr.fr/tv-sfr/options#sfrintid=LP_NumericableEtSFR_Cadre_musique" class="calc-themes__theme theme">
                    <div class="theme__background" style="background-image : url('//static.s-sfr.fr/media/musique-min.jpg');">
                    </div>
                    <div class="theme__gradient"></div>
                    <div class="theme__filter"></div>
                    <div class="theme__text-container">
                        <a class="theme__title title900">Musique</a>
                        <p class="theme__text text600">
                    Accédez à un large choix de chaînes musicales.
                        </p>
                       
                    </div>
                </a>
            </div>
            <div class="col-xs-12 col-sm-6">
                <a href="https://www.sfr.fr/tv-sfr/bouquets-divertissement-et-decouverte#sfrintid=LP_NumericableEtSFR_Cadre_divertissement" class="calc-themes__theme theme">
                    <div class="theme__background" style="background-image : url('//static.s-sfr.fr/media/divertissement-decouverte-min.jpg');">
                    </div>
                    <div class="theme__gradient"></div>
                    <div class="theme__filter"></div>
                    <div class="theme__text-container">
                        <a class="theme__title title900">Divertissement & Découverte</a>
                        <p class="theme__text text600">
                            Amateur d’aventures ou de divertissement et de musique ? Avec SFR vous avez le choix parmi des dizaines de chaînes et services telles que Discovery Channel, Mezzo et bien d’autres.
                        </p>
                     
                    </div>
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-xs-12 col-sm-6">
                <a href="https://www.sfr.fr/tv-sfr/bouquets-jeunesse#sfrintid=LP_NumericableEtSFR_Cadre_jeunesse" class="calc-themes__theme theme">
                    <div class="theme__background" style="background-image : url('//static.s-sfr.fr/media/jeunesse-5.jpg');">
                    </div>
                    <div class="theme__gradient"></div>
                    <div class="theme__filter"></div>
                    <div class="theme__text-container">
                        <a class="theme__title title900">Jeunesse</a>
                        <p class="theme__text text600">
                            Découvrez une sélection de chaînes jeunesse pour tous les âges : Tiji, Canal J, Disney Channel, Boomerang… Soyez sûrs de faire plaisir à vos enfants.
                        </p>
                       
                    </div>
                </a>
            </div>
            <div class="col-xs-12 col-sm-6">
                <a href="https://www.sfr.fr/tv-sfr/options#sfrintid=LP_NumericableEtSFR_Cadre_infos" class="calc-themes__theme theme">
                    <div class="theme__background" style="background-image : url('//static.s-sfr.fr/media/presse-info-1.jpg');">
                    </div>
                    <div class="theme__gradient"></div>
                    <div class="theme__filter"></div>
                    <div class="theme__text-container">
                        <a class="theme__title title900">Presse & Info</a>
                        <p class="theme__text text600">
                           Le meilleur de l’info avec toutes les chaînes nationales et régionales.
                        </p>
                    </div>
                </a>
            </div>
        </div>
    </div>
