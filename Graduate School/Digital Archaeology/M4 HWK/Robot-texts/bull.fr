#btnContactUs {
position: fixed;
right:20px;
width:56px;
height:56px;
border-radius:50%;
background-color:#00005c;
margin:0;
padding:0;
border: 2px solid #FFFFFF;
box-shadow: 0 3px 20px 0 rgba(0,0,0,0.25);
}

#btnContactUs:hover {
background-color:#0073E6;
}

#btnContactUs:focus{
border-radius:50%;
border-color: #FFFFFF;
outline:1px;
}

#btnContactUs img {
    top:2px;
    left: 0px;
    max-width: 32px;
    position: relative;
}
.btnContactUsNormal {
bottom: 20px;
}
.btnContactUsShift {
bottom: 50px;
}
#btnContactUs:after {
display:none;
