&quot;openInBrowser&quot;:&quot;newTab&quot;,&quot;appLinkType&quot;:&quot;h5&quot;},&quot;rewardBtnInfo&quot;:{&quot;showFlag&quot;:false,&quot;btnName&quot;:&quot;Got it&quot;,&quot;link&quot;:{&quot;storeLink&quot;:&quot;&quot;,&quot;membershipLink&quot;:&quot;&quot;,&quot;inAppWebLink&quot;:&quot;https://www.oneplus.in/store&quot;,&quot;webLink&quot;:&quot;https://www.oneplus.in/store&quot;},&quot;openInApp&quot;:&quot;inApp&quot;,&quot;openInBrowser&quot;:&quot;newTab&quot;,&quot;appLinkType&quot;:&quot;h5&quot;}}],&quot;downloadInfo&quot;:{&quot;showFlag&quot;:&quot;display&quot;,&quot;field&quot;:{&quot;downloadTitle&quot;:&quot;Shop With Exclusive Benefits&quot;,&quot;downloadDes&quot;:&quot;&lt;p&gt;Download OnePlus store app on Google Play&lt;/p&gt;&quot;,&quot;downloadImgPc&quot;:&quot;https://image01.oneplus.net/media/202407/01/3366ee472982bff9a48adcc3d672fb46.png&quot;,&quot;downloadImgMobile&quot;:&quot;https://image01.oneplus.net/media/202407/01/93d757ebb22aa5f15adde8369f4d045f.png&quot;},&quot;type&quot;:&quot;display&quot;},&quot;subscribeInfo&quot;:{&quot;showFlag&quot;:&quot;display&quot;,&quot;field&quot;:{&quot;title&quot;:&quot;Always be the first to know.&quot;,&quot;subTitle&quot;:&quot;&lt;p&gt;Subscribe to receive news, promotions and recommendations about OnePlus products and services.&lt;/p&gt;&quot;,&quot;imagePc&quot;:&quot;https://image01.oneplus.net/media/202407/01/c10284f22fcce8ee1a30afae8dc7c973.png&quot;,&quot;imageMobile&quot;:&quot;https://image01.oneplus.net/media/202407/01/9bbcd0e8cb1b25d2a1a7ccf5853712c3.png&quot;}},&quot;themeInfo&quot;:{&quot;showFlag&quot;:&quot;dark-theme&quot;,&quot;field&quot;:{&quot;color&quot;:&quot;&quot;},&quot;type&quot;:&quot;dark-theme&quot;},&quot;textColor&quot;:{&quot;showFlag&quot;:&quot;white&quot;},&quot;subscribeEventCode&quot;:&quot;OE1847162813082087426&quot;,&quot;subscribedBtnName&quot;:&quot;Notified&quot;}},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;,&quot;id&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpSubscribe_5d5f43cb_&quot;,&quot;name&quot;:&quot;Subscribe_5d5f43cb&quot;},&quot;CmpSeparator_00c2fd8a_&quot;:{&quot;type&quot;:&quot;CmpSeparator&quot;,&quot;attr&quot;:{&quot;spacingData&quot;:{&quot;radioSymbol&quot;:&quot;PC:56px&quot;,&quot;pcHeight&quot;:56,&quot;mobileHeight&quot;:48}},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;,&quot;theme&quot;:&quot;theme-dark&quot;,&quot;backgroundColor&quot;:&quot;#000&quot;,&quot;id&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpSeparator_00c2fd8a_&quot;,&quot;name&quot;:&quot;Separator_00c2fd8a&quot;},&quot;CmpSeparator_3d419ab8_&quot;:{&quot;type&quot;:&quot;CmpSeparator&quot;,&quot;attr&quot;:{&quot;spacingData&quot;:{&quot;radioSymbol&quot;:&quot;Custom&quot;,&quot;pcHeight&quot;:24,&quot;mobileHeight&quot;:24}},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;,&quot;theme&quot;:&quot;theme-dark&quot;,&quot;backgroundColor&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpSeparator_3d419ab8_&quot;,&quot;name&quot;:&quot;Separator_3d419ab8&quot;},&quot;CmpSeparator_64c80116_&quot;:{&quot;type&quot;:&quot;CmpSeparator&quot;,&quot;attr&quot;:{&quot;spacingData&quot;:{&quot;radioSymbol&quot;:&quot;Custom&quot;,&quot;pcHeight&quot;:24,&quot;mobileHeight&quot;:24}},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;,&quot;theme&quot;:&quot;theme-dark&quot;,&quot;backgroundColor&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpSeparator_64c80116_&quot;,&quot;name&quot;:&quot;Separator_64c80116&quot;},&quot;CmpSeparator_8a699e07_&quot;:{&quot;type&quot;:&quot;CmpSeparator&quot;,&quot;attr&quot;:{&quot;spacingData&quot;:{&quot;radioSymbol&quot;:&quot;Custom&quot;,&quot;pcHeight&quot;:24,&quot;mobileHeight&quot;:24}},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;,&quot;theme&quot;:&quot;theme-light&quot;,&quot;backgroundColor&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpSeparator_8a699e07_&quot;,&quot;name&quot;:&quot;Separator_8a699e07&quot;},&quot;CmpHtmlScript_b1e43e10_&quot;:{&quot;type&quot;:&quot;CmpHtmlScript&quot;,&quot;attr&quot;:{&quot;html&quot;:&quot;&quot;,&quot;style&quot;:&quot;.productImg {\n    height: 32px;\n    padding-right: 8px;\n}\n.product-img {\n    height: 16px;\n    padding-right: 8px;\n}\n.cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .theme-light .main-info .description div{\n  padding-top: 4px;\n}\n@media (min-width:650px) and (max-width: 1023px){\n  .icon-wrap{\n    width: 476px;\n  }\n}&quot;},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;},&quot;id&quot;:&quot;CmpHtmlScript_b1e43e10_&quot;,&quot;name&quot;:&quot;Html Script_b1e43e10&quot;},&quot;CmpSeparator_b6fe9fa7_&quot;:{&quot;type&quot;:&quot;CmpSeparator&quot;,&quot;attr&quot;:{&quot;spacingData&quot;:{&quot;radioSymbol&quot;:&quot;PC:8px&quot;,&quot;pcHeight&quot;:8,&quot;mobileHeight&quot;:8}},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;,&quot;theme&quot;:&quot;theme-light&quot;,&quot;backgroundColor&quot;:&quot;&quot;},&quot;id&quot;:&quot;CmpSeparator_b6fe9fa7_&quot;,&quot;name&quot;:&quot;Separator_b6fe9fa7&quot;},&quot;CmpHtmlScript_c9ac5e54_&quot;:{&quot;type&quot;:&quot;CmpHtmlScript&quot;,&quot;attr&quot;:{&quot;html&quot;:&quot;&lt;script&gt;\n  // Swiper 自动轮播脚本 - 支持多个容器\n  (function () {\n    // 等待页面加载完成\n    function initSwiperAutoplay() {\n      // 查找页面上的所有 swiper 容器\n      const swiperContainers = document.querySelectorAll(&#39;.swiper.offer-swiper, .swiper-container.bank-offer-swiper-container&#39;);\n\n      if (swiperContainers.length === 0) {\n        return;\n      }\n\n\n      // 为每个 swiper 容器初始化自动播放\n      swiperContainers.forEach((swiperContainer, index) =&gt; {\n        initSingleSwiper(swiperContainer, index);\n      });\n    }\n\n    // 初始化单个 Swiper 容器\n    function initSingleSwiper(swiperContainer, index) {\n      // 检查是否已经初始化了 Swiper\n      if (swiperContainer.swiper) {\n        // 如果已经初始化，直接添加自动播放\n        if (swiperContainer.swiper.autoplay) {\n          swiperContainer.swiper.autoplay.start();\n          // 添加按钮点击事件监听\n          addButtonEventListeners(swiperContainer, index);\n        } else {\n          // 如果没有 autoplay 模块，手动实现自动轮播\n          startManualAutoplay(swiperContainer.swiper, index);\n          // 添加按钮点击事件监听\n          addButtonEventListeners(swiperContainer, index);\n        }\n      } else {\n        // 如果 Swiper 还没有初始化，等待初始化完成\n        const observer = new MutationObserver(function (mutations) {\n          mutations.forEach(function (mutation) {\n            if (mutation.type === &#39;attributes&#39; &amp;&amp; mutation.attributeName === &#39;class&#39;) {\n              if (swiperContainer.classList.contains(&#39;swiper-initialized&#39;)) {\n                observer.disconnect();\n                // Swiper 已初始化，添加自动播放\n                setTimeout(() =&gt; {\n                  if (swiperContainer.swiper &amp;&amp; swiperContainer.swiper.autoplay) {\n                    swiperContainer.swiper.autoplay.start();\n                  } else if (swiperContainer.swiper) {\n                    startManualAutoplay(swiperContainer.swiper, index);\n                  }\n                  // 添加按钮点击事件监听\n                  addButtonEventListeners(swiperContainer, index);\n                }, 100);\n              }\n            }\n          });\n        });\n\n        observer.observe(swiperContainer, {\n          attributes: true,\n          attributeFilter: [&#39;class&#39;]\n        });\n      }\n    }\n\n    // 添加按钮点击事件监听器\n    function addButtonEventListeners(swiperContainer, index) {\n      // 查找 prev 和 next 按钮（支持多种按钮类名）\n      const prevButton = swiperContainer.querySelector(&#39;.offer-swiper-button-prev, .swiper-button-prev, .bank-offer-swiper-button-prev&#39;);\n      const nextButton = swiperContainer.querySelector(&#39;.offer-swiper-button-next, .swiper-button-next, .bank-offer-swiper-button-next&#39;);\n\n      if (prevButton) {\n        prevButton.addEventListener(&#39;click&#39;, () =&gt; {\n          restartAutoplay(swiperContainer, index);\n        });\n      }\n\n      if (nextButton) {\n        nextButton.addEventListener(&#39;click&#39;, () =&gt; {\n          restartAutoplay(swiperContainer, index);\n        });\n      }\n    }\n\n    // 重新启动自动播放\n    function restartAutoplay(swiperContainer, index) {\n      setTimeout(() =&gt; {\n        if (swiperContainer.swiper) {\n          if (swiperContainer.swiper.autoplay) {\n            // 如果有原生 autoplay 模块，重新启动\n            swiperContainer.swiper.autoplay.start();\n          } else {\n            // 如果没有 autoplay 模块，重新启动手动自动播放\n            startManualAutoplay(swiperContainer.swiper, index);\n          }\n        }\n      }, 100);\n    }\n\n    // 手动实现自动轮播（当 Swiper 没有 autoplay 模块时）\n    function startManualAutoplay(swiperInstance, index) {\n      const swiperContainer = swiperInstance.el;\n\n      // 如果已经存在自动播放实例，先停止\n      if (swiperContainer._manualAutoplay) {\n        swiperContainer._manualAutoplay.stop();\n      }\n\n      // 创建新的自动播放实例\n      const autoplayInstance = {\n        interval: null,\n        delay: 3000, // 3秒间隔\n\n        start: function () {\n          this.stop(); // 先停止之前的定时器\n          this.interval = setInterval(() =&gt; {\n            if (swiperInstance &amp;&amp; !swiperInstance.destroyed) {\n              swiperInstance.slideNext();\n            }\n          }, this.delay);\n        },\n\n        stop: function () {\n          if (this.interval) {\n            clearInterval(this.interval);\n            this.interval = null;\n          }\n        }\n      };\n\n      // 将自动播放实例保存到容器上\n      swiperContainer._manualAutoplay = autoplayInstance;\n\n      // 开始自动播放\n      autoplayInstance.start();\n\n      // 鼠标悬停时暂停，离开时继续\n      swiperContainer.addEventListener(&#39;mouseenter&#39;, () =&gt; autoplayInstance.stop());\n      swiperContainer.addEventListener(&#39;mouseleave&#39;, () =&gt; autoplayInstance.start());\n\n      // 触摸时暂停\n      swiperContainer.addEventListener(&#39;touchstart&#39;, () =&gt; autoplayInstance.stop());\n      swiperContainer.addEventListener(&#39;touchend&#39;, () =&gt; {\n        setTimeout(() =&gt; autoplayInstance.start(), 1000); // 触摸结束后1秒再开始\n      });\n\n      // 页面可见性变化时控制自动播放\n      document.addEventListener(&#39;visibilitychange&#39;, () =&gt; {\n        if (document.hidden) {\n          autoplayInstance.stop();\n        } else {\n          autoplayInstance.start();\n        }\n      });\n    }\n\n    // 页面加载完成后执行\n    if (document.readyState === &#39;loading&#39;) {\n      document.addEventListener(&#39;DOMContentLoaded&#39;, initSwiperAutoplay);\n    } else {\n      initSwiperAutoplay();\n    }\n  })();\n&lt;/script&gt;&quot;,&quot;style&quot;:&quot;@media (max-width: 1023.98px) and (min-width: 650px){\n  #pad-height.cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .banner-img {\n    height: 550px !important;\n  }\n}\n.cmp-rich-text{\n  border: none !important;\n}\n/* @media (max-width: 1023.98px){\n  #pre-launch .v-btn.v-btn--variant-text-link .v-btn__content {\n    border: 1px solid rgba(var(--v-color_state_default));\n    padding: 0px 16px;\n    border-radius: 20px;\n    height: 28px;\n  }\n}\n@media (min-width: 1024px){\n  #pre-launch .v-btn.v-btn--variant-text-link .v-btn__content {\n    border: 1px solid rgba(var(--v-color_state_default));\n    padding: 0px 16px;\n    border-radius: 20px;\n    height: 32px;\n  }\n} */\n/* hero banner */\n.cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .card-info .bank-offer-swiper-container {\n    max-width: unset !important;\n    height: 32px !important;\n}\n.cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .card-info .bank-offer-swiper-container .bank-offer-swiper-wrapper .bank-offer-swiper-slide .offer-desc {\n    display: block !important;\n}\n@media (max-width: 649.98px) {\n    .cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .card-info .bank-offer-swiper-container .bank-offer-swiper-wrapper .bank-offer-swiper-slide .offer-desc {\n    font-size: 10px !important;\n    line-height: 12px !important;\n}\n.cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .card-info .bank-offer-swiper-container {\n    max-width: 420px !important;\n}\n}\n.cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .card-info .bank-offer-swiper-container .bank-offer-swiper-wrapper .bank-offer-swiper-slide {\n    height: 100% !important;\n}\n.cmp-product-card .parduct-card-theme .product-card-interest {\n  background: #F8F8F8!important;\n}\n.cmp-product-card .product-card-interest .interest-slide .interest-text{\n  font-size: 12px!important;\n}\n.cmp-product-card .product-card-img {\ndisplay: block;\n }\n.cmp__tab-card .cmp__secondary-banner-jimu .swiper-button {display: flex!important;}\n.cmp__secondary-banner-jimu .swiper-container .swiper-wrapper .swiper-slide .offer-swiper.theme-light {\n    background: #FAFAFA!important;\n}\n/* @media (min-width: 649.98px) { */\n  .theme-light.cmp__secondary-banner-jimu{\n    margin-top: 8px;\n  }\n/* } */\n\n\n  .cmp__hero-banner-jimu .hero-banner-container .hero-banner-swiper-container .hero-banner-swiper-wrapper .hero-banner-swiper-slide .card-info .bank-offer-swiper-container .bank-offer-swiper-wrapper .bank-offer-swiper-slide .offer-ico img {\n    height: 16px;\n  }\n&quot;},&quot;style&quot;:{&quot;showInApp&quot;:&quot;app-display&quot;},&quot;id&quot;:&quot;CmpHtmlScript_c9ac5e54_&quot;,&quot;name&quot;:&quot;Html Script_c9ac5e54&quot;},&quot;CmpHtmlScript_6cb033