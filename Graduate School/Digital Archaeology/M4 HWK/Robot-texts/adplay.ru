                                    2xl:min-w-[1024px] 2xl:max-w-[1024px]" style="color:transparent" src="/_next/static/media/dashboard.e958fb5b.webp"/></div></div></section><section id="about" class=""><div class="pt-10 px-4 relative
                            md:pt-20 md:px-6
                            2xl:grid 2xl:grid-cols-12 2xl:gap-x-18 2xl:pt-22 2xl:pb-[84px] 2xl:px-12"><div class="fixed inset-0 z-0 flex flex-col items-center justify-center"><div class=""><div class="hidden md:block"><div class="max-w-[1536px]"><img alt="bg" loading="lazy" width="1536" height="1645" decoding="async" data-nimg="1" class="w-full h-auto" style="color:transparent" src="/_next/static/media/bg.a86f8c90.png"/></div></div></div></div><div class="2xl:col-span-5 z-10 relative"><div class="sticky top-[84px]"><div class="text-[#1A2E4F]"><h2 class="text-[26px] leading-[32px] font-bold
                            md:text-[32px] md:leading-[40px]
                            2xl:text-[48px] 2xl:leading-[56px]">О нас</h2><div class="flex flex-col gap-y-4 text-base mt-4"><p>Добро пожаловать в мир инновационной рекламы и качественной монетизации!</p><p>Мы — команда энтузиастов с многолетним опытом в сфере рекламы, стремящихся переписать правила игры в индустрии рекламы через современные технологии и креативные решения. Наша компания основана на принципе сделать процесс монетизации сайтов более простым, прибыльным и доступным для широкого круга клиентов. На пути к этой цели, мы разработали уникальные технологические решения, в том числе собственную программатик платформу с собственным адсервером и запатентованными технологиями для показа рекламы на веб-сайтах.</p></div></div></div></div><div class="mt-14 grid gap-y-10 relative z-10
                                md:grid-cols-2 md:gap-x-8
                                2xl:col-span-7 2xl:mt-0"><div class="flex flex-col gap-y-10
                                    md:pt-[120px] overflow-hidden"><div style="opacity:0;transform:translateY(80px) translateZ(0)"><div class="p-px rounded-[4px] Card_gradient__3s_tK"><div class="flex flex-col gap-y-4 p-6 rounded-[4px] text-[#1A2E4F] light-bg"><div class="flex justify-end"><div><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none"><path fill="#1A2E4F" d="M4.623 42.224A.622.622 0 0 1 4 41.6V4.623c0-.245.141-.465.361-.565a.617.617 0 0 1 .664.092l18.572 15.82L42.17 4.15a.62.62 0 0 1 .876.07.62.62 0 0 1-.07.876L23.995 21.26c-.232.2-.572.2-.809 0L5.236 5.967v35.63a.622.622 0 0 1-.622.622l.009.005Z"></path><path fill="#1A2E4F" d="M42.577 42.133a.622.622 0 0 1-.623-.623V13.376l-17.95 15.293c-.232.2-.577.2-.809 0L8.196 15.891a.62.62 0 0 1-.07-.876.62.62 0 0 1 .875-.07l14.597 12.433 18.572-15.82a.618.618 0 0 1 .664-.091c.22.103.361.323.361.564V41.51a.622.622 0 0 1-.623.623h.005Z"></path><path fill="#1A2E4F" d="M42.577 42.133h-18.98a.622.622 0 1 1 0-1.245h18.98a.622.622 0 1 1 0 1.245ZM19.401 44a2.492 2.492 0 0 1-2.49-2.49 2.492 2.492 0 0 1 2.49-2.49 2.492 2.492 0 0 1 2.49 2.49 2.492 2.492 0 0 1-2.49 2.49Zm0-3.735c-.685 0-1.245.56-1.245 1.245s.56 1.245 1.245 1.245 1.245-.56 1.245-1.245-.56-1.245-1.245-1.245Z"></path></svg></div></div><h5 class="text-[16px] leading-[20px] font-bold md:text-[20px] md:leading-[24px]">Технологии</h5><p class="text-base">Мы вкладываемся в разработку уникальных технологий, которые обеспечивают нашим клиентам конкурентные преимущества в отрасли.</p></div></div></div><div style="opacity:0;transform:translateY(80px) translateZ(0)"><div class="p-px rounded-[4px] Card_gradient__3s_tK"><div class="flex flex-col gap-y-4 p-6 rounded-[4px] text-[#1A2E4F] light-bg"><div class="flex justify-end"><div><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none"><path fill="#1A2E4F" d="M18.304 42.929c-8.069 0-14.634-6.59-14.634-14.69s6.565-14.69 14.634-14.69c8.069 0 14.634 6.59 14.634 14.69s-6.565 14.69-14.634 