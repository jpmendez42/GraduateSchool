    </script>
    <script>
        jQuery(window).scroll(function () {
            if (jQuery(this).scrollTop() > 120) {
                jQuery('header').addClass('stickyclass');
                jQuery('.offer-category-menu').addClass('sticky-offer');
            } else {
                jQuery('header').removeClass('stickyclass');
                jQuery('.offer-category-menu').removeClass('sticky-offer');
            }
        });

        function AddToFavorite(sProductid, URL, sLanid, isLoggedIn) {
            var className = jQuery("#" + sProductid).attr('class');
            var catId = jQuery(".bf-product-list .submenu .center.active.selected a").attr('data-id');
            if (className === "add-to-favourite prodWishlistAdd") {
                jQuery("#" + sProductid).removeClass("prodWishlistAdd")
                jQuery("#" + sProductid).addClass("prodWishlistRemove")
                if (isLoggedIn == "true") {
                    jQuery("#" + sProductid).html("<i class='fa fa-heart' aria-hidden='true' style='color: red;'></i>");
                    jQuery.post(URL + '?Type=Product&Action=Add&Id=' + sProductid + '&lanid=' + sLanid + '&catId=' + catId, function (data) {
                        //location.reload();
                    });
                }
                else {
                    jQuery.post(URL + '?lanid=' + sLanid + '&catId=' + catId, function (data) {
                    window.location.href = "/Login.aspx";
                    });
                }
            }
            else if (className === "add-to-favourite prodWishlistRemove") {
                jQuery("#" + sProductid).removeClass("prodWishlistRemove")
                jQuery("#" + sProductid).addClass("prodWishlistAdd")
                jQuery("#" + sProductid).html("<i class='fa fa-heart-o' aria-hidden='true'></i>");
                if (isLoggedIn == "true") {
                    jQuery.post(URL + '?Type=Product&Action=Rem&Id=' + sProductid + '&lanid=' + sLanid + '&catId=' + catId, function (data) {
                        //location.reload();
                    });
                } else {
                    jQuery.post(URL + '?lanid=' + sLanid + '&catId=' + catId, function (data) {
                    window.location.href = "/Login.aspx";
                    });
                }
            }
        }
    </script>
</body>
