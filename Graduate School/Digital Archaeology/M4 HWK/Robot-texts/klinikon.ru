p" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="" data-field-widthunits-value="px" data-animate-sbs-event="scroll" data-animate-sbs-trg="1" data-animate-sbs-trgofst="0" data-animate-sbs-opts="[{'mx':0,'my':0,'sx':1,'sy':1,'op':1,'ro':0,'di':'0','dd':'0','fi':'0'},{'mx':0,'my':0,'sx':1,'sy':1,'op':0,'ro':0,'di':0,'dd':0,'fi':'0'},{'mx':0,'my':0,'sx':1,'sy':1,'op':1,'ro':0,'di':120,'dd':100,'fi':'0'}]" data-field-top-res-320-value="10" data-field-left-res-320-value="15" data-field-width-res-320-value="291" data-field-left-res-480-value="46" data-field-width-res-480-value="389" data-field-top-res-640-value="0" data-field-left-res-640-value="102" data-field-width-res-640-value="437" data-field-left-res-960-value="221" data-field-width-res-960-value="518"> <h2 class='tn-atom'field='tn_text_1711646877046'>SQNS уже внедрили ведущие игроки в своих отраслях</h2> </div> </div> </div> <script>t_onFuncLoad('t396_initialScale',function() {t396_initialScale('752532863');});t_onReady(function() {t_onFuncLoad('t396_init',function() {t396_init('752532863');});});</script> <!-- /T396 --> </div> <div id="rec753181695" class="r t-rec t-rec_pt_0 t-rec_pb_0" style="padding-top:0px;padding-bottom:0px;background-color:#f5f5f5; " data-record-type="533" data-bg-color="#f5f5f5"> <!-- t533 --> <div class="t533"> <ul role="list" class="t533__container t-list__container_inrow4 t-container"> <li class="t533__col t-col t-col_3 t-item t-list__item t-animate" data-animate-style="fadein" data-animate-chain="yes" style="padding-top: 35px;"> <div class="t533__content"> <div class="t533__textwrapper t-align_center" style="padding-top: 57px; border: 0px solid #000; background-color: #e5e5e5;"> <div class="t533__title t-name t-name_xs" field="li_title__6258106498530">Татьяна Васильевна</div> <div class="t533__uptitle t-descr t-descr_xxs" field="li_subtitle__6258106498530">Управляющая клиники «ОблакаStudio»</div> <div class="t533__descr t-text t-text_xs" field="li_descr__6258106498530"><p style="text-align: left;">«Администраторы перестали тратить время на звонки, а врачи увидели, насколько удобнее вести пациентов в одной МИС SQNS»</p></div> </div> <div class="t533__imgwrapper"> <div class="t533__img t-bgimg" data-original="https://static.tildacdn.com/tild3461-3938-4961-b964-643763646464/Picture.png"
bgimgfield="li_img__6258106498530"
style="width:70px; height:70px; background-image: url('https://thb.tildacdn.com/tild3461-3938-4961-b964-643763646464/-/resizeb/20x/Picture.png');"
itemscope itemtype="http://schema.org/ImageObject"> <meta itemprop="image" content="https://static.tildacdn.com/tild3461-3938-4961-b964-643763646464/Picture.png"> </div> </div> </div> </li> <li class="t533__col t-col t-col_3 t-item t-list__item t-animate" data-animate-style="fadein" data-animate-chain="yes" style="padding-top: 35px;"> <div class="t533__content"> <div class="t533__textwrapper t-align_center" style="padding-top: 57px; border: 0px solid #000; background-color: #e5e5e5;"> <div class="t533__title t-name t-name_xs" field="li_title__6258106498531">Алла</div> <div class="t533__uptitle t-descr t-descr_xxs" field="li_subtitle__6258106498531">Управляющая<br />«White Dental Clinic»</div> <div class="t533__descr t-text t-text_xs" field="li_descr__6258106498531"><p style="text-align: left;">«Нам очень нравится мобильное приложение МИС SQNS, функционал доступен с любого устройства. Стоматологам удобно работать с зубными формулами и сразу составлять план лечения. Мы однозначно рекомендуем МИС SQNS другим стоматологическим клиникам»</p></div> </div> <div class="t533__imgwrapper"> <div class="t533__img t-bgimg" data-original="https://static.tildacdn.com/tild3935-3435-4166-a237-343435326565/Picture_1.png"
bgimgfield="li_img__6258106498531"
style="width:70px; height:70px; background-image: url('https://thb.tildacdn.com/tild3935-3435-4166-a237-343435326565/-/resizeb/20x/Picture_1.png');"
itemscope itemtype="http://schema.org/ImageObject"> <meta itemprop="image" content="https://static.tildacdn.com/tild3935-3435-4166-a237-343435326565/Picture_1.png"> </div> </div> </div> </li> <li class="t533__col t-col t-col_3 t-item t-list__item t-animate" data-animate-style="fadein" data-animate-chain="yes" style="padding-top: 35px;"> <div class="t533__content"> <div class="t533__textwrapper t-align_center" style="padding-top: 57px; border: 0px solid #000; background-color: #e5e5e5;"> <div class="t533__title t-name t-name_xs" field="li_title__6258106498532">Алим Селимов</div> <div class="t533__uptitle t-descr t-descr_xxs" field="li_subtitle__6258106498532">Директор клиники <br />«#1 Цифровая стоматология»</div> <div class="t533__descr t-text t-text_xs" field="li_descr__6258106498532"><p style="text-align: left;">«Мы уже открываем новые филиалы, потому что видим, как быстро растёт наша продуктивность. SQNS не просто заменила 1С — она дала нам возможность масштабироваться»</p></div> </div> <div class="t533__imgwrapper"> <div class="t533__img t-bgimg" data-original="https://static.tildacdn.com/tild6432-3535-4266-b031-633062386465/Picture_2.png"
bgimgfield="li_img__6258106498532"
style="width:70px; height:70px; background-image: url('https://thb.tildacdn.com/tild6432-3535-4266-b031-633062386465/-/resizeb/20x/Picture_2.png');"
itemscope itemtype="http://schema.org/ImageObject"> <meta itemprop="image" content="https://static.tildacdn.com/tild6432-3535-4266-b031-633062386465/Picture_2.png"> </div> </div> </div> </li> <li class="t533__col t-col t-col_3 t-item t-list__item t-animate" data-animate-style="fadein" data-animate-chain="yes" style="padding-top: 35px;"> <div class="t533__content"> <div class="t533__textwrapper t-align_center" style="padding-top: 57px; border: 0px solid #000; background-color: #e5e5e5;"> <div class="t533__title t-name t-name_xs" field="li_title__1716563693881">Полина Пономарёва</div> <div class="t533__uptitle t-descr t-descr_xxs" field="li_subtitle__1716563693881">Управляющая филиалом <br />«Нейро Пси»</div> <div class="t533__descr t-text t-text_xs" field="li_descr__1716563693881">«Хотя мы получили медицинскую лицензию, SQNS поможет и обычному психологическому кабинету. С ним легче вести расписание, финансы, документы — особенно если клиентов становится больше. Мы рекомендуем его даже конкурентам из Самары: рынок большой, всем полезно удобное решение».</div> </div> <div class="t533__imgwrapper"> <div class="t533__img t-bgimg" data-original="https://static.tildacdn.com/tild3030-6330-4434-b563-313534323738/Picture_3.png"
