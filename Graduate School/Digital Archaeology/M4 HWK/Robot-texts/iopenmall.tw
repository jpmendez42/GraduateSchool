<script>
    if(typeof (top_refresh) === "undefined"){
		function top_refresh()
		{
			$.ajax({
				url: "api/api.shopping_cart.php",
				type: "POST",
				dataType: "json",
				data: {
					myAct: "getCartNumberByWeb",
					HasWebUid1: 1, //是否包含商城
                    switch: 1,
                    from: "top_refresh",
					[csrf_key]: csrf_val
				},
				success: function(Jdata) {
					let cart_t = 0;

					if (Jdata.error == 'C00') {
						$('#top_content').empty();
						var html = '';
						var count = 0;
						$.each(Jdata.content, function(key, value) {
							if (!value['web_uid']) {
                                return;
                            }
                            
                            html += '<ul class="clearfix">';
							html += '<li class="cartOpen_name"><a href="/' + value['web_byeurl'] + '/index.php?action=shopping_cart" title="' + value['web_name'] + '">' + value['web_name'] + '</a></li>';
							html += '<li class="cartOpen_num">(' + value['scar_count'] + ')</li>';
							html += '<li class="cartOpen_price">$' + value['scar_total'] + '</li>';
							html += '<li class="buy_cart"><a title="結帳" href="/'+value['web_byeurl']+'/index.php?action=shopping_cart"">結帳</a></li>';
							html += '<li class="cartOpen_btn cartOpen_delete"><a href="javascript: removeScarByWeb(' + "'" + value['web_byeurl'] + "'" +  ')" title="移除">移除</a></li>';
							html += '</ul>';

							count = count + parseInt(value['scar_count']);
						});

						$('#top_content').html(html);
                        if(typeof (top_refresh_authority) === "function"){
                            top_refresh_authority();
                        }

						if(count==0){
							$('#Cart_Total').text(0);
							$('#Cart_Total_bottom').hide();
						}else{
							$('#Cart_Total').text(count);
							$('#Cart_Total_bottom').show().text(count);
							cart_t = count;
						}

						$(".header_cart_box").stop(true, true).slideUp(0);

                        if (Jdata.prepare_for_cache.sys_arrPage.wpage_cache == '1'){
                            setLoginIconBBC(Jdata.prepare_for_cache);
                        }
					}

					var u = navigator.userAgent;
					if (u.indexOf('PartnerAPP') != -1) {
						var isAndroid = u.indexOf('Android') > -1 || u.indexOf('Adr') > -1; //android终端
						var isiOS = !!u.match(/\(i[^;]+;( U;)? CPU.+Mac OS X/); //ios终端
						if (isAndroid) {
							window.JavaScriptInterface.setShoppingCartBadge(cart_t.toString());
						} else if (isiOS) {
							window.webkit.messageHandlers.setShoppingCartBadge.postMessage(cart_t.toString());
						}
					}
				}
			});
		}
	}

    var sys_byeurl = 'iopen';
    function setLoginIconBBC(prepare_for_cache) {
        var web_style = prepare_for_cache.sys_arrPage.web_style_path;

        if(!""){
            var htm = '';
            if(prepare_for_cache.is_login){
            htm += '<li class="member_info"><span>'+prepare_for_cache.mem_name+'</span>您好</li>';
            htm += '<li class="member_center"><a href="https://mall.iopenmall.tw/member/index.php?action=member_account">會員中心</a></li>';
            htm += '<li class="logout"><a href="https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen&logout=true">登出</a></li>';
            }else{
                htm += '<li class="login"><a href="https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen">登入</a></li>';
            }
            htm += '<li class="trace"><a href="/member/index.php?action=product_trace_list" alt="收藏清單" title="收藏清單">收藏清單</a></li>';
            if(prepare_for_cache.is_login){
                htm += '<li class="noti"><a href="/member/index.php?action=notification" alt="我的通知" title="我的通知">我的通知(<span id="" class="iopen-notice-num">0</span>)</a></li>';
            }

            $(".member_info").remove();
            $(".member_center").remove();
            $(".logout").remove();
            $(".login").remove();
            $(".trace").remove();
            $(".noti").remove();
            $(".cart").before(htm); //電腦

            //我要開店
            $(".open_store").remove();
            if(!prepare_for_cache.isWebManager){
                htm = '';
                img_htm = '';
                if(web_style.indexOf('iopen_2') == '-1'){
                    img_htm = '<img src="'+prepare_for_cache.sys_arrPage.style_color_path+'iopen_logo.png">';
                }
                htm += '<li class="open_store"><a href="/iopen/index.php?action=shopconsent" alt="我要開店" title="我要開店">'+img_htm+'<span>我要開店</span></a></li>';
                $(".open_link").append(htm);
            }

            //賣家中心 iopen_2
            if(web_style.indexOf('iopen_2') != '-1'){
                $('.open_seller').html('');
                htm = '';
                if(!prepare_for_cache.is_login){
                    htm += '<a href="javascript:void(0);" alt="賣家中心" title="賣家中心" onclick="seller_center();">賣家中心</a>';
                }else if(prepare_for_cache.is_login && prepare_for_cache.isWebSeller){
                    htm += '<a href="javascript:void(0);" alt="賣家中心" title="賣家中心" onclick="seller_center();">賣家中心</a>';
                }
                $('.open_seller').html(htm);
            }

            if(prepare_for_cache.is_login){
                notificationRenew(prepare_for_cache.mem_uid);
            }
        }else{
            $(".member_info").html('');
            var htm_mobile = '';
            if(prepare_for_cache.is_login){
                htm_mobile += '<p><i class="icons-line icon-user-circle-01"></i><span class="mem_name">'+prepare_for_cache.mem_name+'</span></p>';
                htm_mobile += '<a href="https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen&logout=true"><i class="icons-line icon-logout-01"></i>登出</a>';
            }else{
                htm_mobile += '<span>您好，歡迎登入iOPEN商城會員</span>';
                htm_mobile += '<a href="https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen"><i class="icons-line icon-login-01"></i>登入</a>';
            }

            $(".member_info").html(htm_mobile);

            $(".open_store").remove();//我要開店
            $(".fix_sellercenter").remove();//賣家中心
            if(!prepare_for_cache.isWebManager){
                htm = ''; //我要開店
                htm += '<a href="/iopen/index.php?action=shopconsent" class="open_store" alt="我要開店" title="我要開店">我要開店</a>';
                $(".header_search").before(htm);
            }
            htm = ''; //賣家中心
            if(web_style.indexOf('iopen_2') == '-1'){
                if(prepare_for_cache.isWebSeller){
                    classname = 'seller_center_btn';
                }else{
                    classname = '';
                }
            }else{ //賣家中心 iopen_2
                if(prepare_for_cache.is_login && !prepare_for_cache.isWebSeller){
                    classname = 'not_seller_btn';
                }else{
                    classname = '';
                }
            }

            htm += '<li class="fix_sellercenter '+classname+'"><a href="javascript:void(0);" onclick="seller_center();">賣家中心</a></li>';
            $(".fix_menu").append(htm);
        }
    }

    // 九大行銷light_box
    $("a.cart_light_box").fancybox({
        width	    : 600,
        fitToView	: false,
        autoSize	: false,
        title		: false
    });

    /* prod_scm判斷購買方式 prod_lb判斷限定限量購買商品須登入*/
    function closeBoxBBC(prod_no, web_byeurl, prod_scm, prod_lb)
    {
        $(".fancybox-close").click(); //關閉 light box
        if(prod_scm=='1'){
            buyNowBBC(prod_no, web_byeurl);
        } else {
            goCartMainBBC(prod_no, web_byeurl, prod_lb);
        }
    }

    /*主商品加入購物車*/ /* prod_lb判斷限定限量購買商品須登入*/
    function goCartMainBBC(pno, web_byeurl, prod_lb) {
        if (window.is_login == 0 && prod_lb == '1') {
            if(typeof(mem_login) == 'function'){
                mem_login();
            }else{
                if ('1' == '1') {
                    alert('很抱歉！您選購的商品為會員限量訂購商品！').done(function () {
                        //TEST00 Checkmarkx Client DOM XSS
                        window.location = encodeURI('https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen');
                    })
                } else {
                    if(alert('很抱歉！您選購的商品為會員限量訂購商品！')){
                        //TEST00 Checkmarkx Client DOM XSS
                        window.location = encodeURI('https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen');
                    }
                }

            }
        } else {

            $.ajax({
                url: "api/api.shopping_cart.php",
                type: "POST",
                dataType: "json",
                data: {
					myAct: "check",
					HasWebUid1: 1, //是否包含商城
                    switch: 1,
                    from: "goCartMainBBC_check",
					[csrf_key]: csrf_val
				},
                success: function (Jdata) {
                    console.log('goCartMainBBC',Jdata);

                if (Jdata.error == 'C00') {
                    $.ajax({
                        url: '../'+web_byeurl+'/index.php?action=shopping_cart&web_cart_myAct=SHOPPING_CART',
                        type: "POST",
                        dataType: "json",
                        data: 'from=goCartMainBBC_addcart&myAct=ajaxadd&'+csrf_key+'='+csrf_val+'&scar_count[]=1&prod_no[]=' + pno,
                        success: function (response) {
                            if (response.error == 'C00') {
                                /*FB Pixel 加入購物車*/
                                if (typeof(fb_AddToCart) == 'function') {
                                    fb_AddToCart(pno, response.fbValue, response.fbContents);
                                }

                                // alert("購物車新增成功");/*購物車新增成功*/
                                $('.addCartBlock_txt').text('購物車新增成功');
                                $('.addCartBlock_img').children('img').attr('src','images/addCartIcon.png');
                                $('.addCartMask').delay(300).fadeIn(300).delay(300).fadeOut(800);

                                top_refresh(response.scar_no);
                            } else if (response.error.indexOf('E') == 0) {
                                alert(response.err_alert);
                            }
                        }
                    });
                }
            }
        });
        }
    }

    function buyNowBBC(prod_no, web_byeurl){
        var form = document.createElement("form");
        // 設定表單的一些屬性，包含網頁接收伺服器回應的頁面或框架
        form.setAttribute("method", "post");
        form.setAttribute("action", "../" + web_byeurl + "/index.php?action=shopping_cart&web_cart_myAct=CHECK_OUT");

        // 建立隱藏的表單控制項
        var hiddenField = document.createElement("input");
        hiddenField.setAttribute("type", "hidden");
        hiddenField.setAttribute("name", "prod_no");
        hiddenField.setAttribute("value", prod_no);
        form.appendChild(hiddenField);

        // 建立隱藏的表單控制項 CSRF
        var hiddenFieldCSRF = document.createElement("input");
        hiddenFieldCSRF.setAttribute("type", "hidden");
        hiddenFieldCSRF.setAttribute("name", "_token");
        hiddenFieldCSRF.setAttribute("value", "c38c38683a5920244950ae500497242c78fe9691383000e21090b28e555ba617b02649081aafdf559b3a182c04b1ca399f6637109bf303863cba4c75f29e31f0");
        form.appendChild(hiddenFieldCSRF);

        // 隱藏的submit按鈕，預防瀏覽器不支援模糊的表單設計。
        var hiddenSubmit = document.createElement("input");
        hiddenSubmit.setAttribute("type", "submit");
        hiddenSubmit.setAttribute("style", "display:none;");
        form.appendChild(hiddenSubmit);

        // 將表單加入網頁中
        document.body.appendChild(form);

        // 送出請求
        form.submit();
    }

    /*追蹤清單*/
    function add2traceBBC(puid, pno, psprice, pname) {
        if (window.is_login == 0) {
            if(typeof(mem_login) == 'function'){
                mem_login();
            }else{
                //TEST00 Checkmarkx Client DOM XSS
                window.location = encodeURI('https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen');
            }
        } else {
            $.ajax({
                url: "https://mall.iopenmall.tw/iopen/api/api.product_trace_list.php",
                type: "POST",
                dataType: "json",
                data: {
                    uid: puid,
                    myAct: "add",
                    prod_no: pno,
                    remove	: true
                },
                prod: {
                    id: pno,
                    name: pname,
                    price: psprice,
                    quantity: 1,
                    affiliation: ['2', 'iopen', 'iOPEN Mall'],
                },
                success: function (Jdata) {
                    if (Jdata.error == 'C00') {
                        if (Jdata.status == "1") {
                            /*FB Pixel 加到願望清單*/
                            if (typeof(fb_AddToWishlist) == 'function') {
                                fb_AddToWishlist(pno, psprice);
                            }

                            /*新增class*/
                            $(".addlist_"+puid).addClass("active");
                            // alert("追蹤清單新增成功");/*追蹤清單新增成功*/
                            $('.addCartBlock_txt').text('已加入收藏');
                            $('.addCartBlock_img').children('img').attr('src','images/addListIcon.png');
                            $('.addCartMask').delay(300).fadeIn(300).delay(300).fadeOut(800);
                        } else {
                            $(".addlist_"+puid).removeClass('active');
                        }
                    } else {
                        /*頁面過期，請重新整理！*/
                        alert('頁面過期，請重新整理！ ( ' + Jdata.error + ' )');
                    }
                }
            });
        }
    }

        $(window).load(function() {
        top_refresh();
        if (is_wpage_cache != '1')
            notificationRenew(0);
    });
    
    function seller_center(isWebSeller = true)
    {
		const u = navigator.userAgent;
		if (u.indexOf('PartnerAPP') != -1) {
			const isAndroid = u.indexOf('Android') > -1 || u.indexOf('Adr') > -1; //android终端
			const isiOS = !!u.match(/\(i[^;]+;( U;)? CPU.+Mac OS X/); //ios终端
			if (isAndroid) {
				window.stop();
				window.JavaScriptInterface.toSellerCenter();
			} else if (isiOS) {
				window.stop();
				window.webkit.messageHandlers.toSellerCenter.postMessage(null);
			}
		}else{
			if (isWebSeller) {
				const url = 'https://mall.iopenmall.tw/iopen/api/api.bbc_check_seller_center.php?check_seller=1';
				location.href = encodeURI(url);
			}else{
				const url = '/iopen/index.php?action=shopconsent';
				window.open(url, '_blank');
			}
		}
    }
</script>

<script>

	//通知中心
	function notificationRenew(mem_uid)
    {
        if (parseInt(mem_uid) > 0) {
            var mem_uid = parseInt(mem_uid);
        } else {
            var mem_uid = parseInt('');
        }

        if (mem_uid > 0) {
            $.ajax({
                url:      "https://mall.iopenmall.tw/iopen/api/api.notification.php",
                type:     "POST",
                dataType: "json",
                data:	{
                    myAct:		"GetNotificationNum",
                    mem_uid:	mem_uid,
                    push_object:"B",
                    [csrf_key]: csrf_val
                },
                success: function (Jdata) {
                    if(Jdata.error == 'C00'){
                        var notiNum = parseInt(Jdata.result,10);

                        
                        if(notiNum >= 100) {
                            $('.iopen-notice-num').text('99+');
                        }else{
                            $('.iopen-notice-num').text(notiNum);
                        }
                    }
                },
                error: function (e) {
                    console.log(e);
                }
            });
        }
	}

        function decodeHtml(html) {
        var txt = document.createElement("textarea");
        txt.innerHTML = html;
        return txt.value;
    }

</script>    <!---->

                

</body>
</html>