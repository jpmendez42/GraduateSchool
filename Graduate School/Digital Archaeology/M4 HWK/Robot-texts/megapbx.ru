                            window.__INITIAL_STATE__={"page":{"response":{"layout":"default","title":"Виртуальная АТС","metaTitle":"Виртуальная АТС для бизнеса от МегаФон | Облачная телефония для офиса","path":"vats","metaDescription":"Виртуальная АТС от МегаФон: выгодные тарифы на IP-телефонию, простое подключение, настройка и управление. Бесплатный тестовый период 7 дней. Готовое решение для бизнеса.","metaKeywords":"виртуальная атс, dbhnefkmyfz fnc, Виртуальная атс, Vbhnefkmyfz fnc, Ватс, Vats, ватс, vats, Ватс, Dfnc, ватс, dfnc, облачная атс, j,kfxyfz fnc, Облачная атс, J,kfxyfz fnc, fnc, атс, Fnc, Атс, многоканальный телефон, vyjujrfyfkmysq ntktajy, ip атс","metaCanonical":null,"isSearchable":true,"type":"","slug":"\u002Fcorporate\u002Fservices\u002Fvats","extraPath":"","components":[{"title":"Контейнер страницы (LandingPage)","type":"LandingPage","visibility":"all","children":[{"title":"Контейнер Баннер","type":"Container","visibility":"all","children":[{"title":"Баннер (с попапом vatsn)","type":"ImageBanner","visibility":"all","children":[],"props":{"title":"Виртуальная АТС","buttons":[{"href":"https:\u002F\u002Fordering.megafon.ru\u002Fvatsn","theme":"green","title":"Оставить заявку","target":"_blank","popupTarget":"order","addUtmToButtonHref":false},{"href":"https:\u002F\u002Fwizard.megapbx.ru\u002F","theme":"green","title":"Подключить самостоятельно","target":"_blank","addUtmToButtonHref":false}],"autoHeight":false,"advertising":{},"description":"IP&#8209;телефония — входящие и исходящие звонки через интернет с дополнительными возможностями для&nbsp;повышения продаж. Первые 7 дней можно тестировать бесплатно\u003C\u002Fbr\u003E\u003Ca href=\"#faq\"\u003EВажные изменения с 1 сентября\u003C\u002Fa\u003E","imageMobile":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fimagebanner_mobile.png","hasTopOffset":true,"imageDesktop":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fimagebanner_desktop.png","imageMobile2x":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fimagebanner_mobile2x.png","hasBreadcrumbs":true,"imageDesktop2x":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fimagebanner_desktop2x.png","backgroundColor":"gradient","isImageFullWidth":false,"imageVerticalAlign":"center","disableFullHeightOnMobile":false}}],"props":{"backgroundColor":"default","disablePaddingTop":false,"disablePaddingBottom":false}},{"title":"Контейнер Бенефиты","type":"Container","visibility":"all","children":[{"title":"Бенефиты с иконками","type":"InfoCards","visibility":"all","children":[],"props":{"size":"small","items":[{"href":"#calc","title":"Выгодный конструктор тарифа — добавляйте только нужные опции без переплат","imgSrc":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Finfocards_02.png","target":"_self","moreInfo":"Подробнее"},{"href":"https:\u002F\u002Flogin.megapbx.ru\u002F","title":"Лёгкое подключение и управление в Личном кабинете","imgSrc":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Finfocards_03.png","target":"_blank","moreInfo":"Личный кабинет"},{"href":"#faq","title":"Скидка 20% на номер 8&#8209;800 по акции «Бизнес уровня 800»","imgSrc":"https:\u002F\u002Fmoscow.megafon.ru\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Ficon_kodoviy_zamok.png","target":"_self","moreInfo":"Подробнее"}],"background":"stroke","imgPosition":"right-side","targetProductName":"Виртуальная АТС"}}],"props":{"backgroundColor":"default","disablePaddingTop":false,"disablePaddingBottom":false}},{"title":"Решение бизнес-задач","type":"Container","visibility":"all","children":[{"title":"Заголовок","type":"TitleDescriptionBox","visibility":"all","children":[],"props":{"title":"Решение бизнес‑задач с помощью облачной АТС"}},{"title":"Бенефиты с иконками","type":"InfoCards","visibility":"all","children":[],"props":{"size":"small","items":[{"title":"Повышение конверсии из звонка в покупку","imgSrc":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fbenefit_01.png","target":"_self","description":"Одновременно принимайте неограниченное количество звонков и настраивайте маршрутизацию"},{"title":"Автоматизация рутины","imgSrc":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fbenefit_02.png","target":"_self","description":"Принимайте звонки и ведите базу клиентов в одном окне. Для интеграции доступно более 100 CRM"},{"title":"Повышение лояльности клиентов","imgSrc":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fbenefit_03.png","target":"_self","description":"Настройте автоматическую отправку смс‑визитки при первом контакте или извинения при недозвоне, заказ обратного звонка или автоинформирование"},{"title":"Увеличение мобильности менеджеров","imgSrc":"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fdefault\u002F0001\u002F07\u002Fvats\u002Fbenefit_04.png","target":"_self","description":"Переводите звонки между городским телефоном, смартфоном и компьютером, не прерывая разговор"}],"background":"white","imgPosition":"top-left","targetProductName":"Виртуальная АТС"}}],"props":{"backgroundColor":"light-gray","disablePaddingTop":false,"disablePaddingBottom":false}},{"title":"Контейнер Калькулятор","type":"Container","visibility":"all","children":[{"title":"Калькулятор","type":"ServicesCalculator","visibility":"all","children":[],"props":{"staff":{"price":230,"disabled":false,"maxValue":1000,"minValue":7},"title":"Подключайте только нужные опции","result":{"title":"Расчёт стоимости","buttonHref":"vats","staffTitle":"Доп. сотрудники","buttonTitle":"Оставить заявку","optionsTitle":"Подключённые опции","addUtmToButtonHref":false},"textAlign":"left","description":"Если подключаете облачную АТС впервые — 7 дней все опции бесплатны, а плата только за исходящие звонки. До 25% от стоимости можно оплатить кешбэком","optionsInfo":{"title":"Опции","textAlign":"center"},"popupTarget":"order","requiredOptions":[{"price":1500,"title":"Базовый пакет","tooltip":"\u003Cul\u003E\u003Cli\u003EРаспределение звонков на нужные отделы и сотрудников, чтобы не было пропущенных.\u003C\u002Fli\u003E\n\u003Cli\u003EСохранение истории звонков.\u003C\u002Fli\u003E\n\u003Cli\u003EОзвучка приветствий и уведомлений из текста, голосовые меню, каталог мелодий вместо гудков и возможность добавить номер любого оператора для приёма входящих.\u003C\u002Fli\u003E\n\u003Cli\u003EИспользование на компьютере с Windows или macOS или на смартфоне Android или iPhone.\u003C\u002Fli\u003E\u003C\u002Ful\u003E"}],"additionalOptions":[{"price":1500,"title":"Запись и хранение разговоров","tooltip":"\u003Cp\u003EМожно прослушивать разговоры и повышать качество обслуживания.\u003C\u002Fp\u003E\n\u003Cul\u003E\u003Cli\u003EЗащита бизнеса от юридических рисков.\u003C\u002Fli\u003E\n\u003Cli\u003EСрок хранения записей — до 10 лет.\u003C\u002Fli\u003E\n\u003Cli\u003EНеограниченный объём хранилища.\u003C\u002Fli\u003E\n\u003Cli\u003EВыгрузка записей на ftp‑сервер.\u003C\u002Fli\u003E\u003C\u002Ful\u003E","selected":false},{"price":1000,"range":[{"price":2500,"value":8},{"price":5000,"value":50}],"title":"Интеграция с CRM","tooltip":"\u003Cp\u003EАвтоматический перенос клиентской базы и заказов.\u003C\u002Fp\u003E\n\u003Cul\u003E\u003Cli\u003EПеревод звонка на сотрудника, закреплённого в CRM.\u003C\u002Fli\u003E\n\u003Cli\u003EЗвонки по клику и digital‑воронки.\u003C\u002Fli\u003E\n\u003Cli\u003EИнтеграция с более 100 CRM‑системами.\u003C\u002Fli\u003E\u003C\u002Ful\u003E\n","selected":false},{"price":500,"title":"Эффективные продажи","tooltip":"\u003Cul\u003E\u003Cli\u003EАвтоматическая отправка смс с контактами менеджера после первого разговора или извинениями, если звонок пропущен.\u003C\u002Fli\u003E\n\u003Cli\u003EУведомление руководителя о пропущенных звонках.\u003C\u002Fli\u003E\n\u003Cli\u003EВозможность заказать обратный звонок, если все операторы заняты.\u003C\u002Fli\u003E\n\u003Cli\u003EСмс оплачиваются отдельно по \u003Ca target=\"_blank\" href=\"\u002Fcorporate\u002Fupload\u002Fmedia\u002Fvats\u002Fvats_service_terms.pdf\"\u003Eусловиям тарифа\u003C\u002Fa\u003E.\u003C\u002Fli\u003E\u003C\u002Ful\u003E","selected":false},{"price":500,"title":"Эффективное обслуживание","tooltip":"\u003Cul\u003E\u003Cli\u003EВозможность подключения к разговору старшего специалиста, его будет слышать только ваш сотрудник.\u003C\u002Fli\u003E\n\u003Cli\u003EОценка качества обслуживания по итогу разговора.\u003C\u002Fli\u003E\n\u003Cli\u003EИнформирование о номере в очереди.\u003C\u002Fli\u003E\u003C\u002Ful\u003E","selected":false},{"price":1000,"title":"Аналитика для руководителя","tooltip":"\u003Cp\u003EПакет графических отчётов.\u003C\u002Fp\u003E\n\u003Cul\u003E\u003Cli\u003EОтчёт обо всех пропущенных звонках и перезвонов по ним.\u003C\u002Fli\u003E\n\u003Cli\u003EГрафические отчёты — просматривайте, как меняется количество звонков, на какое время приходятся пики, с какой рекламы чаще звонят, какой сотрудник или филиал наиболее эффективен.\u003C\u002Fli\u003E\n\u003Cli\u003EПросмотр отчётов и статистики в мобильном приложении.\u003C\u002Fli\u003E\u003C\u002Ful\u003E","selected":false},{"price":2000,"title":"Разговоры на повышенных тонах","tooltip":"\u003Cp\u003EПомогает сосредоточиться на спорных ситуациях и не прослушивать все разговоры.\u003C\u002Fp\u003E\n\u003Cul\u003E\u003Cli\u003EАудиоспектральный анализ разговоров.\u003C\u002Fli\u003E\n\u003Cli\u003EВыделение эмоциональных разговоров специальным значком.\u003C\u002Fli\u003E\u003C\u002Ful\u003E","selected":false},{"price":2000,"title":"Большой бизнес","tooltip":"\u003Cp\u003EИнтеграция Виртуальной АТС с офисной IP‑телефонией или c другими доменами Виртуальной АТС.\u003C\u002Fp\u003E\n\u003Cul\u003E\u003Cli\u003EБесплатные звонки на короткие номера внутри офиса и на номера МегаФона.\u003C\u002Fli