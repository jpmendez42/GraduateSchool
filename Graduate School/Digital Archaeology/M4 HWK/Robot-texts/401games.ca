--640e1f23-a7de-4091-bf7a-d8badd19f900" class="dsgn-pck__block dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 dsgn-pck__block--buttons dsgn-pck__block--2"  style="--dsgn-pck-animate: 2;"><style>.dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 .dsgn-pck__button-area {                      display: grid;                      grid-gap: 1.3em;margin: 0 auto;grid-template-columns: repeat(2, 1fr);max-width: 100%;                      width: fit-content;                    }                    .dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 .dsgn-pck__button {                      display: flex;                      justify-content: center;                      align-items: center;                      text-align: center;                      text-decoration: none;                      padding: 0.5em 1.2em;                      margin-top: 0;                      border: thin solid;                      transition: all 0.3s ease-in-out;                      border-radius: 5px;                      line-height: calc(3px + 2ex + 3px);                      font-size: calc(var(--dp-g-body-size, var(--dp-body-size, 18px)) * 1.0);}                    .dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 .dsgn-pck__button-primary {                      color: #ffffff;                      border-color:#95b874;                      background-color: #95b874;                    }                    .dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 .dsgn-pck__button-secondary {                      color: #ffffff;                      border-color:#95b874;                      background-color: #95b874;                    }                    .dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 .dsgn-pck__button-primary:hover {                      opacity: 1;background-color: #7ba554;                      border-color: transparent;;                    }                    .dsgn-pck__block-id-640e1f23-a7de-4091-bf7a-d8badd19f900 .dsgn-pck__but