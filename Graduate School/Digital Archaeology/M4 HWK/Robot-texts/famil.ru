g\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-32x45.jpg\"},\"w64\":{\"width\":64,\"height\":91,\"mimeType\":\"image/jpeg\",\"filesize\":2473,\"filename\":\"f8wg3erhkk4bntn7yyma5a-64x91.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-64x91.jpg\"},\"w128\":{\"width\":128,\"height\":182,\"mimeType\":\"image/jpeg\",\"filesize\":6931,\"filename\":\"f8wg3erhkk4bntn7yyma5a-128x182.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-128x182.jpg\"},\"w384\":{\"width\":384,\"height\":543,\"mimeType\":\"image/jpeg\",\"filesize\":40332,\"filename\":\"f8wg3erhkk4bntn7yyma5a-384x543.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-384x543.jpg\"},\"w640\":{\"width\":640,\"height\":906,\"mimeType\":\"image/jpeg\",\"filesize\":93953,\"filename\":\"f8wg3erhkk4bntn7yyma5a-640x906.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-640x906.jpg\"},\"w1080\":{\"width\":1080,\"height\":1529,\"mimeType\":\"image/jpeg\",\"filesize\":218457,\"filename\":\"f8wg3erhkk4bntn7yyma5a-1080x1529.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-1080x1529.jpg\"},\"w1920\":{\"width\":1920,\"height\":2717,\"mimeType\":\"image/jpeg\",\"filesize\":523139,\"filename\":\"f8wg3erhkk4bntn7yyma5a-1920x2717.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-1920x2717.jpg\"},\"w3840\":{\"width\":3840,\"height\":5435,\"mimeType\":\"image/jpeg\",\"filesize\":1401377,\"filename\":\"f8wg3erhkk4bntn7yyma5a-3840x5435.jpg\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a-3840x5435.jpg\"}},\"createdAt\":\"2025-10-09T10:49:32.791Z\",\"updatedAt\":\"2025-10-09T10:49:32.791Z\",\"url\":\"/cms/media/f8wg3erhkk4bntn7yyma5a.jpg\"},\"id\":\"68e793342ebbba0274834bb2\"}],\"status\":\"draft\",\"startDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"07\",\"customCalendarMonth\":\"10\",\"customCalendarYear\":\"2025\"}},\"beginDate\":\"2025-10-07T00:00:00.001Z\",\"endDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"31\",\"customCalendarMonth\":\"10\",\"customCalendarYear\":\"2035\"}},\"endDate\":\"2035-10-31T00:00:00.001Z\",\"blockContent\":[{\"title\":\"\",\"type\":\"text\",\"text\":[{\"children\":[{\"text\":\"Приглашаем всех охотников за сокровищами на увлекательный ночной шопинг. Приходите на первую закрытую распродажу Secret Sale*, которая пройдёт в пяти городах России.\"}],\"type\":\"h5\"},{\"children\":[{\"text\":\"\"}]},{\"children\":[{\"text\":\"· Сокровища от 30+ премиальных брендов.\"}]},{\"children\":[{\"text\":\"· Выгода до -85% на одежду, обувь и аксессуары.\"}]},{\"children\":[{\"text\":\"· Особенная атмосфера ночного шопинга.\"}]},{\"children\":[{\"text\":\"\"}]},{\"children\":[{\"text\":\"Ждём вас в наших магазинах 8 ноября с 20:00 до 00:00:\",\"bold\":true}]},{\"children\":[{\"text\":\"· Москва, ТЦ «Мозаика»;\"}]},{\"children\":[{\"text\":\"· Краснодар, ТЦ «Центр города»;\"}]},{\"children\":[{\"text\":\"· Санкт-Петербург, ТЦ «Лондон молл»;\"}]},{\"children\":[{\"text\":\"· Нижний Новгород, ТЦ «Небо»;\"}]},{\"children\":[{\"text\":\"· Екатеринбург, ТЦ «Алатырь».\"}]},{\"children\":[{\"text\":\"\"}]},{\"children\":[{\"text\":\"Регистрация на мероприятие откроется 20 октября. А вся актуальная информация будет появляться в закрытом Telegram-канале.\"}]},{\"children\":[{\"text\":\"Подписывайтесь и следите за новостями, чтобы попасть на секретный шопинг:\",\"bold\":true}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"68e793462ebbba0274834bb3\"},{\"type\":\"button\",\"buttonText\":\"Подписаться\",\"buttonLink\":\"https://t.me/+Qjwu0VcK17FiZGIy\",\"buttonColor\":{\"color\":\"#631d76\"},\"buttonFrame\":{\"color\":\"#FFFFFF\"},\"buttonTextColor\":{\"color\":\"#FFFFFF\"},\"id\":\"68e793a52ebbba0274834bb4\"},{\"type\":\"text\",\"text\":[{\"children\":[{\"text\":\"*Секретная распродажа.\",\"italic\":true}]},{\"children\":[{\"text\":\"**Совершать покупки на распродаже смогут только участники программы лояльности.\",\"italic\":true}]},{\"children\":[{\"text\":\"\\n\"}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"68e79