,"~TIMESTAMP_X":"13.10.2025 15:30:10","DETAIL_PAGE_URL":"\/news\/11120\/","~DETAIL_PAGE_URL":"\/news\/11120\/","LIST_PAGE_URL":"\/news\/","~LIST_PAGE_URL":"\/news\/","DETAIL_TEXT":"<span style=\"font-family: Georgia, serif; font-size: 14pt;\">11 \u043e\u043a\u0442\u044f\u0431\u0440\u044f 2025 \u0441\u043e\u0441\u0442\u043e\u044f\u043b\u0430\u0441\u044c \u044d\u043a\u0441\u043a\u0443\u0440\u0441\u0438\u044f \u0432&nbsp;\u041f\u0430\u0440\u043a \u00ab\u041f\u0430\u0442\u0440\u0438\u043e\u0442\u00bb \u2014 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u043e\u0435\u043d\u043d\u043e-\u043f\u0430\u0442\u0440\u0438\u043e\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441, \u043e\u0442\u043a\u0440\u044b\u0442\u044b\u0439 \u043a 70-\u043b\u0435\u0442\u0438\u044e \u041f\u043e\u0431\u0435\u0434\u044b \u0432 \u041a\u0443\u0431\u0438\u043d\u043a\u0435 \u043f\u043e\u0434 \u041c\u043e\u0441\u043a\u0432\u043e\u0439.<br>\r\n <\/span><br>\r\n <br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\u0412 \u044d\u043a\u0441\u043a\u0443\u0440\u0441\u0438\u0438, \u043f\u0440\u0438\u0443\u0440\u043e\u0447\u0435\u043d\u043d\u043e\u0439 \u043a 80-\u043b\u0435\u0442\u0438\u044e \u041f\u043e\u0431\u0435\u0434\u044b \u0432 \u0412\u0435\u043b\u0438\u043a\u043e\u0439 \u041e\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0432\u043e\u0439\u043d\u0435,&nbsp;\u043f\u0440\u0438\u043d\u044f\u043b\u0438 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0441\u0442\u0443\u0434\u0435\u043d\u0442\u044b,&nbsp;\u043f\u0440\u0435\u043f\u043e\u0434\u0430\u0432\u0430\u0442\u0435\u043b\u0438 \u0438&nbsp;\u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u0413\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u043f\u0440\u043e\u0441\u0432\u0435\u0449\u0435\u043d\u0438\u044f.&nbsp;<br>\r\n <\/span><br>\r\n <br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\u042d\u043a\u0441\u043a\u0443\u0440\u0441\u0430\u043d\u0442\u044b \u043f\u043e\u0441\u0435\u0442\u0438\u043b\u0438&nbsp;\u0413\u043b\u0430\u0432\u043d\u044b\u0439 \u0445\u0440\u0430\u043c \u0412\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0445 \u0421\u0438\u043b \u0420\u0424, \u043f\u043e\u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0439 75-\u043b\u0435\u0442\u0438\u044e \u041f\u043e\u0431\u0435\u0434\u044b, \u0438 \u043c\u0435\u043c\u043e\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441 \u00ab\u0414\u043e\u0440\u043e\u0433\u0430 \u043f\u0430\u043c\u044f\u0442\u0438\u00bb. \u0417\u0434\u0430\u043d\u0438\u0435 \u0445\u0440\u0430\u043c\u0430 - \u043e\u0434\u043d\u043e \u0438\u0437 \u043a\u0440\u0443\u043f\u043d\u0435\u0439\u0448\u0438\u0445 \u0432 \u0420\u043e\u0441\u0441\u0438\u0438. \u0415\u0433\u043e \u0440\u0430\u0437\u043c\u0435\u0440\u044b \u0441\u0438\u043c\u0432\u043e\u043b\u0438\u0447\u043d\u044b: \u0434\u0438\u0430\u043c\u0435\u0442\u0440 \u0433\u043b\u0430\u0432\u043d\u043e\u0433\u043e \u043a\u0443\u043f\u043e\u043b\u0430 \u0440\u0430\u0432\u0435\u043d 19,45 \u043c (1945 \u0433\u043e\u0434), \u0432\u044b\u0441\u043e\u0442\u0430 \u043c\u0430\u043b\u043e\u0433\u043e \u043a\u0443\u043f\u043e\u043b\u0430 \u2014 14,18 \u043c (1418 \u0434\u043d\u0435\u0439 \u0434\u043b\u0438\u043b\u0430\u0441\u044c \u0412\u0435\u043b\u0438\u043a\u0430\u044f \u041e\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0432\u043e\u0439\u043d\u0430).<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">&nbsp;\u041c\u0435\u043c\u043e\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441 \u00ab\u0414\u043e\u0440\u043e\u0433\u0430 \u043f\u0430\u043c\u044f\u0442\u0438\u00bb, \u0441\u043e\u0441\u0442\u043e\u044f\u0449\u0438\u0439&nbsp;\u0438\u0437 35 \u0437\u0430\u043b\u043e\u0432,&nbsp;\u0440\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u043e \u043a\u0430\u0436\u0434\u043e\u043c \u0438\u0437 1418 \u0434\u043d\u0435\u0439 \u0432\u043e\u0439\u043d\u044b. \u0412 \u044d\u043a\u0441\u043f\u043e\u0437\u0438\u0446\u0438\u044f\u0445&nbsp;\u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044e\u0442\u0441\u044f \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0435 \u043c\u0443\u0437\u0435\u0439\u043d\u044b\u0435 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438, \u0441\u043e\u0437\u0434\u0430\u044e\u0449\u0438\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u0435 \u043f\u043e\u043b\u043d\u043e\u0433\u043e \u043f\u043e\u0433\u0440\u0443\u0436\u0435\u043d\u0438\u044f \u0432 \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443 \u0442\u043e\u0433\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438.<\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"><br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>&nbsp;\u041f\u043e\u0435\u0437\u0434\u043a\u0430 \u043f\u0440\u043e\u0438\u0437\u0432\u0435\u043b\u0430 \u043d\u0430 \u0432\u0441\u0435\u0445 \u0441\u0438\u043b\u044c\u043d\u043e\u0435 \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u0435 \u0438 \u043d\u0430\u0434\u043e\u043b\u0433\u043e \u043e\u0441\u0442\u0430\u043d\u0435\u0442\u0441\u044f \u0432 \u043f\u0430\u043c\u044f\u0442\u0438 \u043a\u0430\u043a \u044f\u0440\u043a\u043e\u0435 \u0441\u043e\u0431\u044b\u0442\u0438\u0435 \u0436\u0438\u0437\u043d\u0438.<\/b><\/span>","~DETAIL_TEXT":"<span style=\"font-family: Georgia, serif; font-size: 14pt;\">11 \u043e\u043a\u0442\u044f\u0431\u0440\u044f 2025 \u0441\u043e\u0441\u0442\u043e\u044f\u043b\u0430\u0441\u044c \u044d\u043a\u0441\u043a\u0443\u0440\u0441\u0438\u044f \u0432&nbsp;\u041f\u0430\u0440\u043a \u00ab\u041f\u0430\u0442\u0440\u0438\u043e\u0442\u00bb \u2014 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u043e\u0435\u043d\u043d\u043e-\u043f\u0430\u0442\u0440\u0438\u043e\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441, \u043e\u0442\u043a\u0440\u044b\u0442\u044b\u0439 \u043a 70-\u043b\u0435\u0442\u0438\u044e \u041f\u043e\u0431\u0435\u0434\u044b \u0432 \u041a\u0443\u0431\u0438\u043d\u043a\u0435 \u043f\u043e\u0434 \u041c\u043e\u0441\u043a\u0432\u043e\u0439.<br>\r\n <\/span><br>\r\n <br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\u0412 \u044d\u043a\u0441\u043a\u0443\u0440\u0441\u0438\u0438, \u043f\u0440\u0438\u0443\u0440\u043e\u0447\u0435\u043d\u043d\u043e\u0439 \u043a 80-\u043b\u0435\u0442\u0438\u044e \u041f\u043e\u0431\u0435\u0434\u044b \u0432 \u0412\u0435\u043b\u0438\u043a\u043e\u0439 \u041e\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0432\u043e\u0439\u043d\u0435,&nbsp;\u043f\u0440\u0438\u043d\u044f\u043b\u0438 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0441\u0442\u0443\u0434\u0435\u043d\u0442\u044b,&nbsp;\u043f\u0440\u0435\u043f\u043e\u0434\u0430\u0432\u0430\u0442\u0435\u043b\u0438 \u0438&nbsp;\u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0438 \u0413\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u043f\u0440\u043e\u0441\u0432\u0435\u0449\u0435\u043d\u0438\u044f.&nbsp;<br>\r\n <\/span><br>\r\n <br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\u042d\u043a\u0441\u043a\u0443\u0440\u0441\u0430\u043d\u0442\u044b \u043f\u043e\u0441\u0435\u0442\u0438\u043b\u0438&nbsp;\u0413\u043b\u0430\u0432\u043d\u044b\u0439 \u0445\u0440\u0430\u043c \u0412\u043e\u043e\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0445 \u0421\u0438\u043b \u0420\u0424, \u043f\u043e\u0441\u0432\u044f\u0449\u0435\u043d\u043d\u044b\u0439 75-\u043b\u0435\u0442\u0438\u044e \u041f\u043e\u0431\u0435\u0434\u044b, \u0438 \u043c\u0435\u043c\u043e\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441 \u00ab\u0414\u043e\u0440\u043e\u0433\u0430 \u043f\u0430\u043c\u044f\u0442\u0438\u00bb. \u0417\u0434\u0430\u043d\u0438\u0435 \u0445\u0440\u0430\u043c\u0430 - \u043e\u0434\u043d\u043e \u0438\u0437 \u043a\u0440\u0443\u043f\u043d\u0435\u0439\u0448\u0438\u0445 \u0432 \u0420\u043e\u0441\u0441\u0438\u0438. \u0415\u0433\u043e \u0440\u0430\u0437\u043c\u0435\u0440\u044b \u0441\u0438\u043c\u0432\u043e\u043b\u0438\u0447\u043d\u044b: \u0434\u0438\u0430\u043c\u0435\u0442\u0440 \u0433\u043b\u0430\u0432\u043d\u043e\u0433\u043e \u043a\u0443\u043f\u043e\u043b\u0430 \u0440\u0430\u0432\u0435\u043d 19,45 \u043c (1945 \u0433\u043e\u0434), \u0432\u044b\u0441\u043e\u0442\u0430 \u043c\u0430\u043b\u043e\u0433\u043e \u043a\u0443\u043f\u043e\u043b\u0430 \u2014 14,18 \u043c (1418 \u0434\u043d\u0435\u0439 \u0434\u043b\u0438\u043b\u0430\u0441\u044c \u0412\u0435\u043b\u0438\u043a\u0430\u044f \u041e\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0432\u043e\u0439\u043d\u0430).<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">&nbsp;\u041c\u0435\u043c\u043e\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441 \u00ab\u0414\u043e\u0440\u043e\u0433\u0430 \u043f\u0430\u043c\u044f\u0442\u0438\u00bb, \u0441\u043e\u0441\u0442\u043e\u044f\u0449\u0438\u0439&nbsp;\u0438\u0437 35 \u0437\u0430\u043b\u043e\u0432,&nbsp;\u0440\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u043e \u043a\u0430\u0436\u0434\u043e\u043c \u0438\u0437 1418 \u0434\u043d\u0435\u0439 \u0432\u043e\u0439\u043d\u044b. \u0412 \u044d\u043a\u0441\u043f\u043e\u0437\u0438\u0446\u0438\u044f\u0445&nbsp;\u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044e\u0442\u0441\u044f \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0435 \u043c\u0443\u0437\u0435\u0439\u043d\u044b\u0435 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438, \u0441\u043e\u0437\u0434\u0430\u044e\u0449\u0438\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u0435 \u043f\u043e\u043b\u043d\u043e\u0433\u043e \u043f\u043e\u0433\u0440\u0443\u0436\u0435\u043d\u0438\u044f \u0432 \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443 \u0442\u043e\u0433\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438.<\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"><br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>&nbsp;\u041f\u043e\u0435\u0437\u0434\u043a\u0430 \u043f\u0440\u043e\u0438\u0437\u0432\u0435\u043b\u0430 \u043d\u0430 \u0432\u0441\u0435\u0445 \u0441\u0438\u043b\u044c\u043d\u043e\u0435 \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u0435 \u0438 \u043d\u0430\u0434\u043e\u043b\u0433\u043e \u043e\u0441\u0442\u0430\u043d\u0435\u0442\u0441\u044f \u0432 \u043f\u0430\u043c\u044f\u0442\u0438 \u043a\u0430\u043a \u044f\u0440\u043a\u043e\u0435 \u0441\u043e\u0431\u044b\u0442\u0438\u0435 \u0436\u0438\u0437\u043d\u0438.<\/b><\/span>","DETAIL_TEXT_TYPE":"html","~DETAIL_TEXT_TYPE":"html","PREVIEW_TEXT":"","~PREVIEW_TEXT":"","PREVIEW_TEXT_TYPE":"text","~PREVIEW_TEXT_TYPE":"text","PREVIEW_PICTURE":{"ID":"6611","TIMESTAMP_X":"13.10.2025 15:30:10","MODULE_ID":"iblock","HEIGHT":"4000","WIDTH":"6000","FILE_SIZE":"3160896","CONTENT_TYPE":"image\/jpeg","SUBDIR":"iblock\/597\/59780edc8d7b4b6de5431abf6ad3eb15","FILE_NAME":"785c083d7aafd827cb4edd0d54d53429.JPG","ORIGINAL_NAME":"\u0424\u043e\u0442\u043e 1.JPG","DESCRIPTION":"","HANDLER_ID":"1","EXTERNAL_ID":"63fd938e724fc09a81e0603b82f45c63","VERSION_ORIGINAL_ID":null,"META":"","SRC":"https:\/\/corp-site.storage.yandexcloud.net\/iblock\/597\/59780edc8d7b4b6de5431abf6ad3eb15\/785c083d7aafd827cb4edd0d54d5