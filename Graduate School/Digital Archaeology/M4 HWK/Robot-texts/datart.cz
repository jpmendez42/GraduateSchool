    <script type="text/javascript">
      const currentUrl = window.location.href;

      if (currentUrl.includes("datart.cz")) {
        const datartElements = document.querySelectorAll(".datart");
        datartElements.forEach(element => {
          element.style.display = "block";
        }) 
      } else if (currentUrl.includes("nay.sk")) {
        const nayElements = document.querySelectorAll(".nay");
        nayElements.forEach(element => {
          element.style.display = "block";
        })
      } else {
        const datartElements = document.querySelectorAll(".datart");
        datartElements.forEach(element => {
          element.style.display = "block";
