03c/p\u003e\u003cp\u003e\u003cstrong\u003eCaracterísticas:\u003c/strong\u003e\u003c/p\u003e\u003cul\u003e\u003cli\u003eCierre de cordones\u003c/li\u003e\u003cli\u003eUpper de gamuza\u003c/li\u003e\u003cli\u003eSuela de caucho\u0026nbsp;\u003c/li\u003e\u003c/ul\u003e\u003c/div\u003e","thumbnail":"images/catalog/default/1037214-0400V1.jpg","language":"-5","shortDescription":" Añade un toque chunky y tradicional, con los nuevos tenis Grand Court Alpha 00S Día De Mu","fullImage":"images/catalog/default/1037214-0400V1.jpg","productName":"Tenis adidas Grand Court Alpha 00S Día De Muertos Hombre"}],"activityFormat":"web","ownerID":"7000000000000001001","activityIdentifierName":"DPV2_HomeLoMasNuevo_Hombre_Activitie","baseMarketingSpotActivityID":"3074457345618055838","baseMarketingSpotDataType":"CatalogEntry","productPartNumber":"001037214-0400","activityIdentifierID":"716121556","contractPrice":[{"minorVersionNumber":"0","contractPrice":"1699.00","origin":"6","name":"AuroraESite - AuroraESite","contractID":"10005","currency":"MXN","ownerID":"-5000","minimumQuantity":"1.0","majorVersionNumber":"1"}],"attributes":[{"stringValue":"ExtendedSitesCatalogAssetStore","name":"rootDirectory"},{"stringValue":"ShoppingArea/CatalogSection/CatalogEntrySubsection/ProductDisplay","name":"displayTemplate"}],"catalogEntryTypeCode":"ProductBean","activityPriority":"0","properties":[{"baseMarketingValue":"Recommend a catalog entry to a customer that satisfies the chosen target conditions.","baseMarketingKey":"mktActivityDescription"}]},{"baseMarketingSpotActivityName":"Tenis Lacoste Court Ace Hombre","productId":"3074457345618055856","description":[{"longDescription":" \u003cdiv class='container-description'\u003e\u003ch4\u003e¡Domina la ciudad con estilo atemporal! El \u003cstrong\u003eCourt Ace\u003c/strong\u003e es mucho más que un simple tenis.\u0026nbsp;\u003c/h4\u003e\u003cp\u003eCon líneas limpias y detalles minimalistas, este diseño captura la esencia de lo icónico. ¿Te imaginas luciendo un par de tenis que no solo complementan cada atuendo, sino que también resisten el paso del tiempo?\u0026nbsp;\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eCaracterísticas:\u003c/strong\u003e\u003c/p\u003e\u003cul\u003e\u003cli\u003eParte superior de Piel PU\u003c/li\u003e\u003cli\u003eEtiqueta tejida en la lengüeta\u003c/li\u003e\u003cli\u003eForro de malla suave y transpirable.\u003c/li\u003e\u003cli\u003eSuela de caucho estándar y reciclado\u003c/li\u003e\u003c/ul\u003e\u003c/div\u003e","thumbnail":"images/catalog/default/1037292-0106V1.jpg","language":"-5","shortDescription":" ¡Domina la ciudad con estilo atemporal! El Court Ace es mucho más que un simple tenis.\u0026nb","fullImage":"images/catalog/default/1037292-0106V1.jpg","productName":"Tenis Lacoste Court Ace Hombre"}],"activityFormat":"web","ownerID":"7000000000000001001","activityIdentifierName":"DPV2_HomeLoMasNuevo_Hombre_Activitie","baseMarketingSpotActivityID":"3074457345618055856","baseMarketingSpotDataType":"CatalogEntry","productPartNumber":"001037292-0106","activityIdentifierID":"716121556","contractPrice":[{"minorVersionNumber":"0","contractPrice":"2999.00","origin":"6","name":"AuroraESite - AuroraESite","contractID":"10005","currency":"MXN","ownerID":"-5000","minimumQuantity":"1.0","majorVersionNumber":"1"}],"attributes":[{"stringValue":"ExtendedSitesCatalogAssetStore","name":"rootDirectory"},{"stringValue":"ShoppingArea/CatalogSection/CatalogEntrySubsection/ProductDisplay","name":"displayTemplate"}],"catalogEntryTypeCode":"ProductBean","activityPriority":"0","properties":[{"baseMarketingValue":"Recommend a catalog entry to a customer that satisfies the chosen target conditions.","baseMarketingKey":"mktActivityDescription"}]},{"baseMarketingSpotActivityName":"Tenis Vans Upland Hombre","productId":"3074457345618058219","description":[{"longDescription":" \u003cdiv class='container-description'\u003e\u003ch4\u003eVans Upland: Estilo y moda retro para cada ocasión.\u003c/h4\u003e\u003cp\u003eLos nuevos Upland, son un modelo con aspecto grueso y una inspiración en los diseños retro. La parte superior combina materiales de primera calidad con el logotipo moldeado con forma de V para ofrecer un diseño emblemático. Cuenta con cordones de gran tamaño y el logotipo de la marca en la lengüeta y el talón.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eCaracterísticas:\u003c/strong\u003e\u003c/p\u003e\u003cul\u003e\u003cli\u003eCuellos acolchados para mayor sujeción.\u003c/li\u003e\u003cli\u003eSuela Cupsole adherida con cemento en frío.\u003c/li\u003e\u003cli\u003eAnte y material Sintético\u003c/li\u003e\u003c/ul\u003e\u003c/div\u003e","thumbnail":"images/catalog/default/1036963-0401V1.jpg","language":"-5","shortDescription":" Vans Upland: Estilo y moda retro para cada ocasión.Los nuevos Upland, son un modelo con a","fullImage":"images/catalog/default/1036963-0401V1.jpg","productName":"Tenis Vans Upland Hombre"}],"activityFormat":"web","ownerID":"7000000000000001001","activityIdentifierName":"DPV2_HomeLoMasNuevo_Hombre_Activitie","baseMarketingSpotActivityID":"3074457345618058219","baseMarketingSpotDataType":"CatalogEntry","productPartNumber":"001036963-0401","activityIdentifierID":"716121556","contractPrice":[{"minorVersionNumber":"0","contractPrice":"1899.00","origin":"6","name":"AuroraESite - AuroraESite","contractID":"10005","currency":"MXN","ownerID":"-5000","minimumQuantity":"1.0","majorVersionNumber":"1"}],"attributes":[{"stringValue":"ExtendedSitesCatalogAssetStore","name":"rootDirectory"},{"stringValue":"ShoppingArea/CatalogSection/CatalogEntrySubsection/ProductDisplay","name":"displayTemplate"}],"catalogEntryTypeCode":"ProductBean","activityPriority":"0","properties":[{"baseMarketingValue":"Recommend a catalog entry to a customer that satisfies the chosen target conditions.","baseMarketingKey":"mktActivityDescription"}]},{"baseMarketingSpotActivityName":"Tenis Nike Pegasus 41 Mujer","productId":"3074457345618060777","description":[{"longDescription":" \u003