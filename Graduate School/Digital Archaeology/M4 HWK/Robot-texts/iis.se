<img loading="lazy" decoding="async" width="700" height="406" src="https://internetstiftelsen.se/app/uploads/2021/09/elever-tyreso-alx-1195-700x406.jpg" alt="Elev i mellanstadieålder sitter på golvet i skolmiljö och använder en dator." srcset="https://internetstiftelsen.se/app/uploads/2021/09/elever-tyreso-alx-1195-700x406.jpg 700w, https://internetstiftelsen.se/app/uploads/2021/09/elever-tyreso-alx-1195-726x420.jpg 726w, https://internetstiftelsen.se/app/uploads/2021/09/elever-tyreso-alx-1195-500x290.jpg 500w, https://internetstiftelsen.se/app/uploads/2021/09/elever-tyreso-alx-1195-8x5.jpg 8w" sizes="auto, (max-width: 700px) 100vw, 700px" class="iis-m-card__image iis-m-card__media"/>
