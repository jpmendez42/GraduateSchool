		<script type="text/javascript" id="ct_code_block_js_22">



// Check viewport width on initial load
  checkViewport();

  // Check viewport width whenever the window is resized
  jQuery(window).resize(checkViewport);

  function checkViewport() {
      if (jQuery(window).width() > 767) {
          //
          // #tab functionality
          //
          jQuery( ".menu-item-has-children" ).addClass( "active" );
            jQuery('.menu-item-has-children').on( "click", function() {
              if (jQuery(this).hasClass('active')){
                jQuery(this).removeClass('active').find('.sub-menu').addClass('active');
              } else if(jQuery(this).not('.active')) {
                jQuery(this).addClass('active').find('.sub-menu').removeClass('active');
              } 
          });
          //
          // #appending two icons
          //
          jQuery(".menu-item-has-children").children('a').replaceWith( "<span>À propos<div class=\"menu-ico menu-ico--plus\"><div></div><div></div></div><div class=\"menu-ico menu-ico--chevron\"><div></div><div></div></div></span>");
          jQuery(".menu-item-has-children span").append("<div class=\"menu-ico menu-ico--plus\"><div></div><div></div></div>");
          jQuery(".menu-item a").append("<div class=\"menu-ico menu-ico--chevron\"><div></div><div></div></div>");
          jQuery('.menu-item-has-children span').on( "click", function() {
            jQuery(this).find('.menu-ico--plus').toggleClass( "clicked" );
          });
          jQuery('body').addClass('dostuff');
      } else {
          // don't do stuff
          jQuery('body').addClass('dontdostuff');
      }
  }
</script>
<!-- /WP_FOOTER --> 
