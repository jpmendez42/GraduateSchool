		<script >
			jQuery(document).ready(function($) {
				
				$('#hit_search_form_sticky').click(function(event) {
					event.preventDefault();
					var term = $('#com_liferay_portal_search_web_portlet_SearchPortlet_searchFormSticky').val();
					
					if(term != '' && term.startsWith('#')) {
						console.log('term: '+term);
						var tags = term.toLowerCase().split('#');
						if(tags.length > 0) {
						    window.open('/web/guest/ricerca-tag/-/tag/'+tags[1],'_top');
						}
					} else {
						form = document.getElementById("searchFormSticky"); 
					    form.submit();
					}
				});				
				$('#hit_search_form_mobile').click(function(event) {
					event.preventDefault();
					var term = $('#com_liferay_portal_search_web_portlet_SearchPortlet_search').val();
					
					if(term != '' && term.startsWith('#')) {
						console.log('term: '+term);
						var tags = term.toLowerCase().split('#');
						if(tags.length > 0) {
						    window.open('/web/guest/ricerca-tag/-/tag/'+tags[1],'_top');
						}
					} else {
						form = document.getElementById("searchFormMobile"); 
					    form.submit();
					}
				 });				
				$('#hit').click(function(event) {
					event.preventDefault();
					var term = $('#com_liferay_portal_search_web_portlet_SearchPortlet_search_searchFormPortal').val();
					
					if(term != '' && term.startsWith('#')) {
						console.log('term: '+term);
						var tags = term.toLowerCase().split('#');
						if(tags.length > 0) {
						    window.open('/web/guest/ricerca-tag/-/tag/'+tags[1],'_top');
						}
					} else {
						form = document.getElementById("searchForm"); 
					    form.submit();
					}
				 });
			});		
		</script>













































