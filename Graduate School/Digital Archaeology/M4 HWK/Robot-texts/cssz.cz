<style>
  /* Každý banner bude v .col-12 col-lg-6 => dva vedle sebe na desktopu, jeden na mobilu */
  .custom-banner-col {
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
 .cssz-theme.body__wrapper .col-lg-6.my-col-half {
    width: 50%;
    float:left;
    }
  }
  
  /* Samotný banner: zelené pozadí, flex rozložení (ikona - text - tlačítko) */
  .custom-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #066223; /* Default, přepíšeme inline stylem */
    border-radius: 0.25rem;
    min-height: 80px; /* Pro stabilnější výšku, upravte dle potřeby */
    padding: 0 1rem 0 0px;
    overflow: hidden;
  }
  
  /* Kontejner pro text a&nbsp;tlačítko */
.custom-banner-content {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

  /* Ikona vlevo */
  .custom-banner-icon img {
    max-height: 50px; /* Upravte výšku podle potřeby */
    display: block;
  }

  /* Text uprostřed (bílý) */
  .custom-banner-text {
    flex: 1;
    margin: 0 2rem 0 1rem;
    color: #fff;
    text-align: left;
    font-size: 1.8rem;
    font-weight: 700;
}
  
  /* Přepíšeme jakékoli barvy z&nbsp;WYSIWYG na bílou */
  .custom-banner-text * {
    color: #fff !important;
    margin: 0;
    padding: 0;
  }
  .custom-banner-text.custom-text-dark {
    color: #393939;
    }   

  /* Bílé tlačítko s&nbsp;černým textem */
  .custom-banner-btn-white {
    background-color: #fff !important;
    }
  .custom-banner-btn-white:hover {
    background-color: #b7d9c6 !important;
    color: #393939 !important;
    }
  /* Tmavé tlačítko (pokud je checkbox zaškrtnut) */
  .cssz-theme.body__wrapper .btn-default.custom-banner-btn-dark {
    background-color: #066223;
    color: #fff;
    }
  .custom-banner-btn-dark:hover {
    background-color: #555;
  }
  

    
    /* Vnější kontejner = samotný "tvar" s&nbsp;bílým okrajem */
.banner-image-container-border {
    position: relative;
    width: 100%;
    height: 140px;
    max-width: 140px;
    background: white;
    padding: 0px 5px 0px 0px;
    box-sizing: border-box;
    clip-path: polygon(0 0, 100% 0, 52% 100%, 0 100%);
    -webkit-clip-path: polygon(0 0, 100% 0, 52% 100%, 0 100%);
    overflow: hidden;
}
    
/* Kontejner, který drží obrázek v&nbsp;pevném rozměru a&nbsp;vytváří zkosení */
    .banner-image-container {
    width: 100%;
    height: 140px;
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 50% 100%, 0 100%);
    -webkit-clip-path: polygon(0 0, 100% 0, 50% 100%, 0 100%);
    max-width: 140px;
    }

/* Samotný obrázek uvnitř */
    .banner-image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;  /* klíčové pro ořez bez deformace */
        display: block;
        transition:0.5s;
        /* Chcete-li obrázek „přiblížit“, můžete ho zvětšit a&nbsp;nechat víc oříznout: */
        /* transform: scale(1.2); */
    }
    
    .custom-banner-col:hover .banner-image-container img {
        scale: 1.2;
    }

/* Media query pro tablety */
@media (max-width: 1024px) {
  /* Neměníme rozložení celého banneru, necháváme obrázek vlevo */
  .custom-banner-content {
    flex-direction: column;  /* text a&nbsp;tlačítko se seřadí pod sebe */
    align-items: flex-start; /* zarovnáno doleva */
  }
  .custom-banner-text {
    margin-right: 0;
    margin-bottom: 1rem;     /* odsazení mezi textem a&nbsp;tlačítkem */
    text-align: left;
  }
  .custom-banner-button {
    margin: 0;
    width: 100%;             /* případně tlačítko zabere celou šířku kontejneru */
  }
  .banner-btn {
    align-self: self-end;
}
}


@media (max-width: 767px) {
  /* Změna rozložení obsahu v&nbsp;banneru na sloupcové a&nbsp;nastavení relativního pozicování */
  .custom-banner-content {
    flex-direction: column;      /* text a&nbsp;tlačítko se řadí vertikálně */
    align-items: flex-start;      /* zarovnání textu doleva */
    position: relative;           /* nově přidané – umožňuje absolutní pozicování tlačítka uvnitř */
  }
  
  /* Absolutní umístění tlačítka do pravého dolního rohu kontejneru s&nbsp;obsahem */
  .banner-btn {
    position: absolute;           /* absolutní pozicování vůči .custom-banner-content */
    bottom: -2.5rem;                    /* tlačítko dole */
    right: 0;                     /* tlačítko vpravo */
    margin: 0;                    /* odstranění případného odsazení */
  }
  
  /* Přidání spodního odsazení u&nbsp;textu, aby se tlačítko nepřekrývalo */
  .custom-banner-text {
    margin-bottom: 4rem;          /* upravte hodnotu dle potřeby */
    text-align: left;
  }
}

@media (max-width: 489px) {
  /* Absolutní umístění tlačítka do pravého dolního rohu kontejneru s&nbsp;obsahem */
  .banner-btn {
    bottom: -1rem;                    /* tlačítko dole */
  }
  
  /* Přidání spodního odsazení u&nbsp;textu, aby se tlačítko nepřekrývalo */
  .custom-banner-text {
    margin-bottom: 5rem;          /* upravte hodnotu dle potřeby */
    text-align: left;
  }
  .banner-image-container-border {
    height: 180px;
}
    
/* Kontejner, který drží obrázek v&nbsp;pevném rozměru a&nbsp;vytváří zkosení */
    .banner-image-container {
    height: 180px;
    }
}
</style>

