<style id='mfn-custom-inline-css' type='text/css'>
.mfn-header-scrolled .mfn-header-tmpl.mfn-hasSticky .mfn-header-sticky-section {
    padding-top: 0;
}

.button {
			border-radius: 50px;
			padding-top: 15px;
			padding-bottom: 15px;
			font-size: 15px;
			font-weight: 900;
	}

button.button_right .button_icon, input[type=button].button_right .button_icon, input[type=reset].button_right .button_icon, input[type=submit].button_right .button_icon, .button.button_right .button_icon, .wp-block-button__link.button_right .button_icon, .woocommerce a.added_to_cart.button_right .button_icon, .wc-block-components-button:not(.is-link).button_right .button_icon, .wp-block-button__link.button_right .button_icon {
    order: 1;
    display: none;
}

.entry-content p a {
	text-decoration: underline !important;
}

/* PAGE LINKS */
.green-links {
	color: #FFF;
	font-weight: bold;
	text-decoration: underline;
}
/* END PAGE LINKS */

/* CUSTOM ICON IMAGE SIZE */

.custom-icon-img img {
	width: 50px;
}

/* END CUSTOM ICON IMAGE SIZE */

/* MEGAMENU */
.main-column:after {
    content: "";
    width: 30px;
    height: 30px;
    background: url(https://roomraccoon.com/wp-content/uploads/2023/07/Plus-Feature-Mega-menu.svg) no-repeat;
    /* background-color: red; */
    top: 43%;
    right: -15px;
    position: absolute;
    display: block;
    visibility: visible;
    background-size: cover;
}

.button {
	font-family: "Lato",-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Oxygen-Sans,Ubuntu,Cantarell,"Helvetica Neue",sans-serif !important;
}

.mfn-menu-subicon {
	margin-left: 3px !important;
}

.pricing-txt {
	  color: #929ca5;
    font-size: 11px;
    padding-left: 7px;
		font-weight: 400;
}

.pricing-img {
		max-height: 11px;
    margin-left: 3px;
}

.new-menu [class^="icon-"]:before, [class*=" icon-"]:before {
    font-family: "mfn-icons";
    font-style: normal;
    font-weight: 600 !important;
    speak: none;
    display: inline-block;
    text-decoration: none!important;
    width: 1.7em;
    margin-right: 0.2em;
    text-align: center;
    font-variant: normal;
    text-transform: none;
    line-height: 1em;
    margin-left: 0em;
    font-size: 11px !important;
    padding-bottom: 0px !important;
}


.wpml-ls-legacy-dropdown-click a.wpml-ls-item-toggle:after {
    font-family: "mfn-icons";
    font-style: normal;
    font-weight: 400 !important;
    speak: none;
    display: inline-block;
    text-decoration: none!important;
    width: 1.7em;
    margin-right: 0.2em;
    text-align: center;
    font-variant: normal;
    text-transform: none;
    line-height: 1em;
    margin-left: 0.7em;
    font-size: 14px !important;
    padding-bottom: 0px !important;
    content: '\e867';
    border-top: 0;
    top: calc(42% - 0.175em);
		padding-left: 10px;
}

.wpml-ls-legacy-dropdown-click .wpml-ls-current-language:hover>a, .wpml-ls-legacy-dropdown-click a:focus, .wpml-ls-legacy-dropdown-click a:hover {
    color: #FFF;
    background: #151b27;
}

.learn-mega img {
	max-width: 20px;
}

.platform-megamenu {
    padding: 0px;
/*   	background-image: linear-gradient(to bottom, transparent 81.4%, #151b27 37%), linear-gradient(to right, #273241 50%, #FFFFFF 50%);   */
	background-image: linear-gradient(90deg, #273241 50%, #eef5f5 50%);
	box-shadow: 1px 16px 13px 0px rgba(0,0,0,0.11);
-webkit-box-shadow: 1px 16px 13px 0px rgba(0,0,0,0.11);
-moz-box-shadow: 1px 16px 13px 0px rgba(0,0,0,0.11);
}

.other-megamenus {
    padding: 0px;
/*     background-image: linear-gradient(to bottom, transparent 81.4%, #151b27 37%), linear-gradient(to right, #273240 50%, rgb(238 245 245) 37%); */
    background-image: linear-gradient(90deg, #273240 50%, rgb(238 245 245) 37%);
	box-shadow: 1px 16px 13px 0px rgba(0,0,0,0.11);
-webkit-box-shadow: 1px 16px 13px 0px rgba(0,0,0,0.11);
-moz-box-shadow: 1px 16px 13px 0px rgba(0,0,0,0.11);
}

.mega-hide {
	display: none;
}

.shorter-megamenu {
    max-height: 270px;
}

.shorter-megamenu section {
    max-height: 270px;
}

.megamenu-images img {
	width: 25px !important;
}

.megamenu-insights-images img {
	width: 50px !important;
}

.new-menu li {
	height: 50px;
}

.mfn-header-menu > .mfn-menu-li .mfn-submenu li {
	height: auto;
}

.mfn-header-menu > .mfn-menu-li .mfn-menu-link span.menu-sub i [class^="icon-"]:before, [class*=" icon-"]:before {
    font-size: 11px;
		font-weight: 600;
}

/* @media screen and (min-width: 1025px) { 
.new-menu li:last-child {
	display:none;
}
} */

.menu-item .wpml-ls-slot-23 {
	height: auto;
}

.hidden-img {
	opacity: 0;
}

.image_frame .image_wrapper .image_links { 
	display: none !important; 
}

.wpml-ls-legacy-dropdown a.wpml-ls-item-toggle:after {
    display: none;
}

.mfn-header-menu .mfn-submenu {
    background-color: #f6f7f9;
    box-shadow: none;
}

@media only screen and (min-width: 1240px) {
.section_wrapper, .container {
    max-width: 1300px;
