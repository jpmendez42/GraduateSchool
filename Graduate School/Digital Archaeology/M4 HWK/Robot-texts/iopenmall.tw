<style>
/* 905 商品頁籤式輪播 */
.it905-default {position:relative;}
.it905-default .iopen-mall-item-title h3{ padding-left: 0; display: flex; align-items: center;}
.it905-default .iopen-mall-item-title h3::before{ display: none;}
.it905-default .iopen-mall-item-title h3 img{ margin-right: 5px; max-width: 100%; height: 30px;}
.it905-default .tabTit { top: 0; margin: 0 auto 10px auto; padding: 0; height: auto; bottom: initial; position: relative; text-align: left; width:100%; display: -ms-box; display:-moz-webkit-flex; display: -webkit-flex; display: flex;background: #222;  -ms-flex-wrap: wrap; -moz-flex-wrap: wrap; -webkit-flex-wrap: wrap; flex-wrap: wrap;}

/* USER客製 - 文字顏色 頁籤底色 */
.it905-default.it905-30467 .tabTit .swiper-pagination-bullet { 
    opacity: 1; 
    width: calc((100% / 4) - 2px); 
    height: auto; 
    text-align: center; 
    line-height: 22px; 
    font-size: 17px; 
    flex: 1; 
    position:relative; 
    padding: 11.5px; 
    font-weight: 500;
    color: #FFF;
    background-color:#6b6a6a !important; 
}

/* USER客製 - 頁籤線條顏色 */
.it905-default.it905-30467 .tabTit .swiper-pagination-bullet:not(:last-of-type):after{
    content: '';
    position: absolute;
    top:50%;
    right:0;
    transform: translateY(-50%);
    width: 1px;
    height: 15px;
    background-color: #F8F8F8;
}

/* 頁籤設定 */
.it905-default .tabTit .swiper-pagination-bullet.swiper-pagination-bullet-active { opacity:1; font-weight: 500; line-height: 22px; font-size: 17px; padding: 11.5px; border-radius: 0px; }
.it905-default .tabTit .swiper-pagination-bullet:first-of-type{-moz-border-radius: 10px 0 0 0; -ms-border-radius: 10px 0 0 0; -o-border-radius: 10px 0 0 0; -webkit-border-radius: 10px 0 0 0; border-radius: 10px 0 0 0;}
.it905-default .tabTit .swiper-pagination-bullet:last-of-type{-moz-border-radius: 0 10px 0 0; -ms-border-radius: 0 10px 0 0; -o-border-radius: 0 10px 0 0; -webkit-border-radius: 0 10px 0 0; border-radius: 0 10px 0 0;}

/* USER客製 - 商品區底色 */
.it905-default.it905-30467 .swiper-container{
    position: unset;-moz-border-radius: 10px; 
    -ms-border-radius: 10px; 
    -o-border-radius: 10px; 
    -webkit-border-radius: 10px; 
    border-radius: 10px; 
    background-color: var(--pic-neutral-25) !important;
}

.it905-default .swiper-container-horizontal>.swiper-pagination-bullets, .it905-default .swiper-pagination-custom, .swiper-pagination-fraction{margin: 0;}
.it905-default .swiper-container-horizontal>.swiper-pagination-bullets .swiper-pagination-bullet{margin:0 0px;}
.it905-default .swiper-container-horizontal>.swiper-pagination-bullets .swiper-pagination-bullet:first-of-type{margin:0 0px 0 0;}
.it905-default .swiper-container-horizontal>.swiper-pagination-bullets .swiper-pagination-bullet:last-of-type{margin:0 0 0 0px;}
.it905-default .swiper-container .it905-product_bg{position:absolute;bottom:0;left:0;max-width:100%; width:100%; height:100%;opacity:.12; -moz-border-radius: 10px; -ms-border-radius: 10px; -o-border-radius: 10px; -webkit-border-radius: 10px; border-radius: 10px;}
.it905-default .swiper-container .swiper-wrapper{height:auto !important;}
.it905-default .swiper-slide{display: -ms-box; display:-moz-webkit-flex; display: -webkit-flex; display: flex; -ms-flex-wrap: wrap; -moz-flex-wrap: wrap; -webkit-flex-wrap: wrap; flex-wrap: wrap; padding: 20px 30px 0;}
.it905-default .swiper-container-autoheight, .it905-default .swiper-container-autoheight .swiper-slide{height:auto !important;}
.it905-default .it905-item{ position: relative; flex:0 20%; text-align: left; margin-bottom: 20px;}
.it905-default .it905-item .it905-iteminner { -moz-border-radius: 3px; -ms-border-radius: 3px; -o-border-radius: 3px; -webkit-border-radius: 3px; border-radius: 3px;}
.it905-default .it905-item .it905-iteminner .it905-img{max-width:100%; width:100%; height:auto;overflow: hidden;padding: 10px;text-align: center;}
.it905-default .it905-item .it905-iteminner .it905-img > a,.it905-default .it905-item .it905-iteminner .it905-img > a > img{max-width:100%; width:100%; height:auto;display: block;vertical-align: top;}
.it905-default .it905-item .it905-iteminner .it905-namebox {padding-bottom:5px;}
.it905-default .it905-item .it905-iteminner .it905-namebox .it905-name{padding:0 10px;height:32px;overflow: hidden; text-overflow: ellipsis; display: -webkit-box !important; -webkit-line-clamp: 2; -webkit-box-orient: vertical;}
.it905-default .it905-item .it905-iteminner .it905-namebox .it905-name a{ display: block;line-height: 16px;text-decoration: none;color:#2e3a58;}
.it905-default .it905-item .it905-iteminner .it905-pricebox{border-bottom: 1px solid #f4f4f4;}
.it905-default .it905-item .it905-iteminner .it905-pricebox .it905-price{display: -ms-box; display:-moz-webkit-flex; display: -webkit-flex; display: flex;-ms-flex-pack: center;-webkit-justify-content: center;justify-content: center;}
.it905-default .it905-item .it905-iteminner .it905-pricebox .it905-price{flex:1;font-size:25px;color:#d41e8f;}
.it905-default .it905-item .it905-iteminner .it905-pricebox .it905-price li{vertical-align: bottom;}
.it905-default .it905-item .it905-iteminner .it905-pricebox .it905-price .it905-price_original{color:#bbb;text-decoration: line-through;font-size: 15px; line-height: 30px; vertical-align: bottom; padding-right: 5px;}
.it905-default .it905-item .it905-iteminner .it905-btnbox{display: -ms-box; display:-moz-webkit-flex; display: -webkit-flex; display: flex;-ms-flex-pack: center;-webkit-justify-content: center;justify-content: center;}
.it905-default .it905-item .it905-iteminner .it905-btnbox li{flex:1;text-align: center;}
.it905-default .it905-item .it905-iteminner .it905-btnbox li a{display: block; max-width:100%; width:100%; height:auto; line-height: 30px;text-decoration: none;color:#6a6a6a;}
.it905-default .swiper-button{width: 54px; height: 56px; position: absolute; color: transparent !important; top: 50%; }
.it905-default .swiper-button-next,
.it905-default .swiper-button-prev{ position: absolute; top: 50%; border-radius: 1px; margin-top: -25px; display: block; width: 50px;  height: 50px; text-indent: -9999px;}
.it905-default .swiper-button-next { right:-25px; background: url(css/images/pic/pic-owl-next.svg) top no-repeat; background-size: 50px;}
.it905-default .swiper-button-prev { left: -25px; background: url(css/images/pic/pic-owl-prev.svg) top no-repeat;  background-size: 50px;}
.it905-default .swiper-button-next:hover { background: url(css/images/pic/pic-owl-next.svg) bottom no-repeat; background-size: 50px;}
.it905-default .swiper-button-prev:hover { background: url(css/images/pic/pic-owl-prev.svg) bottom no-repeat;  background-size: 50px;}
.it905-default .swiper-pagination-bullet {border-radius: 0; display: -ms-box; display: -moz-webkit-flex; display: -webkit-flex; display: -ms-flexbox; display: flex; -ms-flex-pack: center; -webkit-justify-content: center;-webkit-box-pack: center; -moz-box-pack: center; justify-content: center; -ms-flex-align: center; -webkit-align-items: center; align-items: center;}

@media screen and (max-width: 996px) {
    .it905-default {padding: 0px;}
    .it905-default .swiper-container-horizontal>.swiper-pagination-bullets .swiper-pagination-bullet { flex: 0 50%; border-radius: 0px !important;}

    /* USER客製 - 頁籤分隔線顏色 */
    .it905-default.it905-30467 .tabTit .swiper-pagination-bullet:not(:last-of-type):after{display: none;}
    .it905-default.it905-30467 .tabTit .swiper-pagination-bullet{
        border-bottom: solid 1px #FFF;
    }
    .it905-default.it905-30467 .tabTit .swiper-pagination-bullet:nth-child(odd){
        border-right: solid 1px #FFF !important;
    }
        .it905-default.it905-30467 .tabTit .swiper-pagination-bullet:nth-last-child(-n+2) {
        border-bottom: none;
    }
    }
</style>

