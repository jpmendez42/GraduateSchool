 <script type="text/javascript">
    $(document).ready(function () {
        var fancyboxOptions = {
            width: 840,
            maxWidth: "80%",
            height: 350,
            commonCaption: true,
            closeBtn: false,
            beforeClose: function () {
                if ($("#todayNotShow").prop("checked")) {
                    var expire_days = 1; //1天後失效
                    var time = new Date();
                    var formattedDate = '20251014';
                    time.setTime(time.getTime() + expire_days * 24 * 60 * 60 * 1000); // 還是加上一天後失效
                    var expires = "expires=" + time.toGMTString() + "; ";
                    document.cookie = "it_429=" + formattedDate + "; " + expires + "domain=mall.iopenmall.tw; " + "path=/; secure=true;";
                }
            },
        };

        //沒有 COOKIE 才執行
        let it_429_cookies = getCookieValue("it_429");
        if (it_429_cookies != '20251014' && parseInt("4") > 0) {
            //跳出視窗
            $("#it429open").fancybox(fancyboxOptions).trigger("click");
            $("#it429open").fancybox();
            $(".it429-todayNotShow").show();
            let loop = false;
            let autoplay = false;
            let autoplayTimeout = 0;
            if (parseInt("4") > 1) loop = true;
            if ("1" == 1) autoplay = true;
            if ("1" == 1) autoplayTimeout = "5" * 1000;
            $(".it429-owl-carousel").owlCarousel({
                loop: loop,
                margin: 20,
                nav: false,
                autoplay: autoplay,
                autoplayTimeout: autoplayTimeout,
                responsive: {
                    0: {
                        items: 1,
                    },
                    1024: {
                        items: 1,
                    },
                },
            });
        }

        $(".it429_content").parents(".fancybox-inner").addClass("it429_fancybox");

        // 關閉fancybox按鈕
        $(".it429-fancybox-close").click(function () {
            parent.$.fancybox.close();
        });
    });
    
    function getCookieValue(cookieName) {
        var name = cookieName + "=";
        var decodedCookie = decodeURIComponent(document.cookie);
        var cookieArray = decodedCookie.split(';');
        
        for (var i = 0; i < cookieArray.length; i++) {
            var cookie = cookieArray[i];
            while (cookie.charAt(0) === ' ') {
            cookie = cookie.substring(1);
            }
            if (cookie.indexOf(name) === 0) {
            return cookie.substring(name.length, cookie.length);
            }
        }
        return "";
    }
</script>	
