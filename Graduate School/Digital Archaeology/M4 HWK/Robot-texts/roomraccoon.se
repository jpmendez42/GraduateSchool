.page-id-248062 input#gform_submit_button_23 {
    margin-top: 40px;
}


.grecaptcha-badge {
    visibility: hidden !important
  }

.mfn-header-menu > .mfn-menu-li > .mfn-menu-link > .label-wrapper > .menu-label {
    white-space: nowrap;
    font-weight: 800;
}



input.custFormSubmit {
    border-radius: 10px !important;
    width: 100% !important;
}

input#gform_submit_button_35 {
    border-radius: 30px !important;
}

section.section.mcb-section.mfn-default-section.mcb-section-q2pdv1jap.scroll-section.sticky-pms-nav.default-width {
    position: sticky;
    top: 40px;
