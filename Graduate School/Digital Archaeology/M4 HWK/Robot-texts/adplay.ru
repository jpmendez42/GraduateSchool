                                    2xl:min-w-[1001px] 2xl:max-w-[1001px]" style="color:transparent" src="/_next/static/media/payments.32750f3c.png"/></div></div></div></div></div></div></section><section id="auditory" class="dark-bg z-10 overflow-hidden text-white"><div class="relative px-4 py-14 md:px-6 md:py-22 2xl:grid 2xl:grid-cols-12 2xl:px-12"><div class="relative flex flex-col 2xl:col-span-6 2xl:justify-center"><div class="relative z-20 flex justify-center md:mx-auto md:max-w-[720px] 2xl:max-w-[640px]"><div class="text-center"><h2 class="text-[26px] leading-[32px] font-bold
                            md:text-[32px] md:leading-[40px]
                            2xl:text-[48px] 2xl:leading-[56px]">Находите свою аудиторию в ближайших городах</h2><div class="flex flex-col gap-y-4 text-base mt-4"><p>Публикуйте видео, чтобы монетизировать свой контент и зарабатывать больше с помощью наших алгоритмов</p></div></div></div><div class="relative z-20 flex max-w-[800px] flex-col pt-14 md:mx-auto"><div class="md:flex"><div class="pb-4 md:w-2/5 md:grow md:pb-0"><div class="flex flex-col items-center"><div><h3 class="text-center text-[32px] leading-[40px] font-bold">840 млн.</h3></div><div class="mt-2"><p class="text-sm text-center">Запросов кода в месяц</p></div></div><div class="flex w-full h-full items-center justify-center mt-8 md:hidden"><div class="w-14 h-0.5 bg-[#FFFFFF8F]"></div></div></div><div class="mx-8 hidden h-full w-1 md:block"><div class="flex w-full h-full items-center justify-center "><div class="w-0.5 h-14 bg-[#FFFFFF8F]"></div></div></div><div class="pb-4 md:w-2/5 md:grow md:pb-0"><div class="flex flex-col items-center"><div><h3 class="text-center text-[32px] leading-[40px] font-bold">11 стран.</h3></div><div class="mt-2"><p class="text-sm text-center">Россия и страны СНГ</p></div></div><div class="flex w-full h-full items-center justify-center mt-8 md:hidden"><div class="w-14 h-0.5 bg-[#FFFFFF8F]"></div></div></div></div><div class="mb-6 mt-8 hidden w-full justify-between md:flex"><div class="flex w-full h-full items-center justify-center w-2/4"><div class="w-14 h-0.5 bg-[#FFFFFF8F]"></div></div><div class="flex w-full h-full items-center justify-center w-2/4"><div class="w-14 h-0.5 bg-[#FFFFFF8F]"></div></div></div><div class="md:flex"><div class="pb-4 md:w-2/5 md:grow md:pb-0"><div class="flex flex-col items-center"><div><h3 class="text-center text-[32px] leading-[40px] font-bold">500 сайтов.</h3></div><div class="mt-2"><p class="text-sm text-center">Более 500 издателей</p></div></div><div class="flex w-full h-full items-center justify-center mt-8 md:hidden"><div class="w-14 h-0.5 bg-[#FFFFFF8F]"></div></div></div><div class="mx-8 hidden h-full w-1 md:block"><div class="flex w-full h-full items-center justify-center "><div class="w-0.5 h-14 bg-[#FFFFFF8F]"></div></div></div><div class="pb-4 md:w-2/5 md:grow md:pb-0"><div class="flex flex-col items-center"><div><h3 class="text-center text-[32px] leading-[40px] font-bold">330 млн.</h3></div><div class="mt-2"><p class="text-sm text-center">Уникальных посетителей в месяц</p></div></div><div class="flex w-full h-full items-center justify-center mt-8 md:hidden"><div class="w-14 h-0.5 bg-[#FFFFFF8F]"></div></div></div></div></div><div class="relative z-20 mt-24 hidden justify-center 2xl:flex"><button class="hover:cursor-pointer disabled:cursor-not-allowed w-full md:w-fit"><div class="flex w-full items-center justify-center font-medium text-white py-4 px-10 gap-x-2 text-[18px] leading-[24px] rounded-[4px] ButtonPrimary_button__zyWeL"><span>Начать зарабатывать</span></div></button></div><div class="absolute inset-0 z-0 flex items-center justify-center"><div class="w-[368px] h-[276px] rounded-[50%] Bg_gradient__Lnb8o"></div></div></div><div class="relative z-20 mt-6 2xl:col-span-6"><img alt="map" loading="lazy" width="720" height="458" decoding="async" data-nimg="1" class="mx-auto h-auto w-full md:max-w-[720px] 2xl:min-w-[811px]" style="color:transparent" src="/_next/static/media/map-small.37a13740.png"/></div><div class="relative z-20 mt-8 justify-center md:flex 2xl:hidden"><button class="hover:cursor-pointer disabled:cursor-not-allowed w-full md:w-fit"><div class="flex w-full items-center justify-center font-medium text-white py-4 px-10 gap-x-2 text-[18px] leading-[24px] rounded-[4px] ButtonPrimary_button__zyWeL"><span>Начать зарабатывать</span></div></button></div></div></section><section id="formats" class="overflow-hidden text-[#1A2E4F] "><div class="py-14 px-4
                            md:py-22 md:px-6
                            2xl:py-[84px] 2xl:pr-12 2xl:pl-8"><div class=""><div class="2xl:w-1/2 2xl:pr-6 2xl:pl-4"><div><h2 class="text-[26px] leading-[32px] font-bold
                            md:text-[32px] md:leading-[40px]
                            2xl:text-[48px] 2xl:leading-[56px]">Форматы AdPlay</h2><div class="flex flex-col gap-y-4 text-base mt-4"><p>Мы подготовили для вас лучшие рекламные форматы и кросс-платформенные решения, которые обеспечат вам максимальное покрытие аудитории и монетизацию.</p></div></div></div><div class="mt-8 relative"><div class="relative z-20"><div class="relative"><div class="overflow-auto py-8 
                            2xl:absolute 2xl:z-40 2xl:left-1/2 2xl:pl-6"><div class="flex gap-x-6"><div class="flex flex-col w-fit"><button class="font-semibold text-base">Sticky</button><div class="h-0.5 bg-[#4986FD]" style="width:0px"></div></div><div class="flex flex-col w-fit"><button class="font-semibold text-base">Inread</button><div class="h-0.5 bg-[#4986FD]" style="width:0px"></div></div><div class="flex flex-col w-fit"><button class="font-semibold text-base">Floating</button><div class="h-0.5 bg-[#4986FD]" style="width:0px"></div></div><div class="flex flex-col w-fit"><button class="font-semibold text-base">Interstitial</button><div class="h-0.5 bg-[#4986FD]" style="width:0px"></div></div><div class="flex flex-col w-fit"><button class="font-semibold text-base">Instream</button><div class="h-0.5 bg-[#4986FD]" style="width:0px"></div></div></div></div><div class="swiper pl-4"><div class="swiper-wrapper"><div class="swiper-slide undefined 2xl:pl-4"><div class="2xl:grid 2xl:grid-cols-2 2xl:gap-x-12"><div class="2xl:order-2 flex flex-col 2xl:pt-22"><h3 class="font-bold text-[26px] leading-[32px]
                                md:text-[24px]
                                2xl:text-[32px] 2xl:leading-[40px]">Sticky</h3><p class="mt-4 text-base">Рекламный блок Sticky, отображается в углу сайта и следует за пользователями, когда они прокручивают страницу вниз или вверх без влияния на взаимодействие с контентом. Плеер исчезнет после окончания показа видеорекламы или может быть закрыт вручную нажатием на крестик.</p></div><div class="mt-6 2xl:order-1 2xl:mt-0 p-5 -mx-5"><div class="relative w-full pb-[56.25%] rounded-[4px] overflow-hidden Slider_shadow__qZHef"><div class="absolute -inset-1"><video autoPlay="" muted="" loop="" playsInline="" class="w-full h-full" poster="/video/Sticky.webp"><source src="/video/sticky.mp4" type="video/mp4"/></video></div></div></div></div></div><div class="swiper-slide undefined 2xl:pl-4"><div class="2xl:grid 2xl:grid-cols-2 2xl:gap-x-12"><div class="2xl:order-2 flex flex-col 2xl:pt-22"><h3 class="font-bold text-[26px] leading-[32px]
                                md:text-[24px]
                                2xl:text-[32px] 2xl:leading-[40px]">Inread</h3><p class="mt-4 text-base">Созданный специально для того, чтобы обогатить ваш контент на странице, Stream Unit улучшает просмотр и поставляет премиум-видео.</p></div><div class="mt-6 2xl:order-1 2xl:mt-0 p-5 -mx-5"><div class="relative w-full pb-[56.25%] rounded-[4px] overflow-hidden Slider_shadow__qZHef"><div class="absolute -inset-1"><video autoPlay="" muted="" loop="" playsInline="" class="w-full h-full" poster="/video/Inread.webp"><source src="/video/inread.mp4" type="video/mp4"/></video></div></div></div></div></div><div class="swiper-slide undefined 2xl:pl-4"><div class="2xl:grid 2xl:grid-cols-2 2xl:gap-x-12"><div class="2xl:order-2 flex flex-col 2xl:pt-22"><h3 class="font-bold text-[26px] leading-[32px]
                                md:text-[24px]
                                2xl:text-[32px] 2xl:leading-[40px]">Floating</h3><p class="mt-4 text-base">Блок видеорекламы, который открывается, как формат Inread внутри статьи, и меняется на формат Sticky при прокрутке страницы.</p></div><div class="mt-6 2xl:order-1 2xl:mt-0 p-5 -mx-5"><div class="relative w-full pb-[56.25%] rounded-[4px] overflow-hidden Slider_shadow__qZHef"><div class="absolute -inset-1"><video autoPlay="" muted="" loop="" playsInline="" class="w-full h-full" poster="/video/Floating.webp"><source src="/video/floating.mp4" type="video/mp4"/></video></div></div></div></div></div><div class="swiper-slide undefined 2xl:pl-4"><div class="2xl:grid 2xl:grid-cols-2 2xl:gap-x-12"><div class="2xl:order-2 flex flex-col 2xl:pt-22"><h3 class="font-bold text-[26px] leading-[32px]
                                md:text-[24px]
                                2xl:text-[32px] 2xl:leading-[40px]">Interstitial</h3><p class="mt-4 text-base">Формат видеорекламы, который охватывает интерфейс сайта. Этот формат раскрывается на всю ширину экрана устройства. Объявления такого формата появляются, когда пользователь совершает действие, например, переход на другую статью.</p></div><div class="mt-6 2xl:order-1 2xl:mt-0 p-5 -mx-5"><div class="relative w-full pb-[56.25%] rounded-[4px] overflow-hidden Slider_shadow__qZHef"><div class="absolute -inset-1"><video autoPlay="" muted="" loop="" playsInline="" class="w-full h-full" poster="/video/Interstitial.webp"><source src="/video/interstitial.MP4" type="video/mp4"/></video></div></div></div></div></div><div class="swiper-slide undefined 2xl:pl-4"><div class="2xl:grid 2xl:grid-cols-2 2xl:gap-x-12"><div class="2xl:order-2 flex flex-col 2xl:pt-22"><h3 class="font-bold text-[26px] leading-[32px]
                                md:text-[24px]
                                2xl:text-[32px] 2xl:leading-[40px]">Instream</h3><p class="mt-4 text-base">Интеграция VAST с вашим плеером, показывает объявления перед видео на вашем сайте.</p></div><div class="mt-6 2xl:order-1 2xl:mt-0 p-5 -mx-5"><div class="relative w-full pb-[56.25%] rounded-[4px] overflow-hidden Slider_shadow__qZHef"><div class="absolute -inset-1"><video autoPlay="" muted="" loop="" playsInline="" class="w-full h-full" poster="/video/Instream.webp"><source src="video/instream.mp4" type="video/mp4"/></video></div></div></div></div></div></div></div></div></div></div></div></div></section><section class="text-white "><div class="md:pb-22 md:px-6 2xl:pb-[168px] 2xl:px-12"><div class="dark-bg px-4 py-10 flex flex-col items-center overflow-hidden relative
                                md:py-[72px]
                                2xl:py-[162px]"><div class="max-w-[460px] md:max-w-[620px] relative z-10"><div class="text-center"><h2 class="text-[26px] leading-[32px] font-bold
                            md:text-[32px] md:leading-[40px]
                            2xl:text-[48px] 2xl:leading-[56px]">Монетизируйте с нами</h2><div class="flex flex-col gap-y-4 text-base mt-4"><p>Зарегистрируйтесь на платформе, добавьте наш код на сайт и начните зарабатывать уже сегодня</p></div></div></div><div class="mt-18 relative z-10"><button class="hover:cursor-pointer disabled:cursor-not-allowed w-full md:w-fit"><div class="flex w-full items-center justify-center font-medium text-white py-4 px-10 gap-x-2 text-[18px] leading-[24px] rounded-[4px] ButtonPrimary_button__zyWeL"><span>Регистрация</span></div></button></div><div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"><div><div class="rounded-full flex items-center justify-center bg-[#FFFFFF05] w-[461px] h-[461px] md:w-[627px] md:h-[627px] xl:w-[1280px] xl:h-[1280px]"><div class="rounded-full flex items-center justify-center bg-[#FFFFFF05] w-[364px] h-[364px] md:w-[495px] md:h-[495px] xl:w-[1012px] xl:h-[1012px]"><div class="rounded-full flex items-center justify-center bg-[#FFFFFF05] w-[266px] h-[266px] md:w-[362px] md:h-[362px] xl:w-[740px] xl:h-[740px]"><div class="rounded-full flex items-center justify-center bg-[#FFFFFF05] w-[180px] h-[180px] md:w-[245px] md:h-[245px] xl:w-[500px] xl:h-[500px]"></div></div></div></div></div></div></div></div></section></main><footer class="dark-bg relative overflow-hidden px-4 py-14 pb-8 text-white md:px-6 md:py-22 md:pb-12 2xl:px-12 2xl:py-16 2xl:pb-8"><div class="relative z-20 mx-auto max-w-[1536px]"><div class="absolute left-[71px] top-[70px] z-10 h-[280px] w-[372px] rounded-full bg-[#13D6D6] opacity-[88%] md:left-[100px] md:top-[38px] 2xl:left-[140px] 2xl:top-[62px] Footer_small__jn3KH"></div><div class="absolute right-[-195px] top-[60px] z-10 hidden h-[348px] w-[388px] rounded-full bg-[#4986FD] opacity-[88%] md:block 2xl:right-[-88px] 2xl:top-[-56px] Footer_small__jn3KH"></div><div class="relative z-20 flex flex-col 2xl:grid 2xl:grid-cols-12 2xl:gap-x-18"><div class="2xl:col-span-5"><div class="fle