                                                                                        var response = JSON.parse(res.replaceAll('"0":{', '{').replaceAll('"1":{', '{').replaceAll('"2":{', '{').replaceAll('"3":{', '{').replaceAll('"4":{', '{').replaceAll('"5":{', '{').replaceAll('"6":{', '{').replaceAll('"7":{', '{').replaceAll('"8":{', '{').replaceAll('"9":{', '{').replaceAll('"10":{', '{').replace('{{"', '[{"').replace('"}}', '"}]'));
