<script>
    $(function() {
        var CACHE_TIME = 5 * 60 * 1000,
            INBETWEENER_URL = "/ru/inbetweeners/ru/inbetweener/296",
            WIDGET_ID = '3959022',
            CACHE_KEY = 'inbetweener:' + WIDGET_ID + ':' + wgsdk.vars.CURRENT_REQUEST_LANGUAGE,
            $widget = $('.js-inbetweener-content-' + WIDGET_ID),
            model = {
                isLoading: ko.observable(true)
            },
            renderInbetweener = function(data) {
                model.isLoading(false);
                $widget.html(data);
            };

        ko.applyBindings(model, $widget.get(0));

        if (amplify.store(CACHE_KEY)) {
            renderInbetweener(amplify.store(CACHE_KEY));
        } else {
            $.ajax({
                    url: INBETWEENER_URL,
                    dataType: 'html'
                })
                .done(function(data) {
                    /* Cleanup, delete expired cache data */
                    amplify.store();

                    amplify.store(CACHE_KEY, data, {'expires': CACHE_TIME });
                    renderInbetweener(data);
                })
                .fail(function() {
                    model.isLoading(false);
                    $widget.hide();
                });
        }
    });
</script>
