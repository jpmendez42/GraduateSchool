         		<style>
 

    .bannersland .spacer {
        height: 100%;
    }

    .bannersland__item {
        position: relative;
        display: block;
    }
    .bannersland__item:not(:first-child){
        margin-top: 1rem;
    } 
 
    .bannersland__item > img{
        display: block;
    }
 
      .banner__contract_army{ 
         grid-row: auto;
         box-sizing: border-box;
         border: 1px solid #2e2b2e;
    }
 
    
bannersland__item--rucode
rucode-d
rucode-m

 
 
 

    .frame-content>.content-partial.vertical {
        width: 100%;
        height: 43%;
    }
/*    ----------------------------*/
 
 


 


    /* ----------------banner-fns-----------------*/
    .banner_fns {
        display: flex;
        border: 1px solid black;
        box-sizing: border-box;
        padding: 2rem;
    }

    .spacer {
        display: block;
        width: 100%;
        height: auto;
    }

 

    @media screen and (max-width: 700px) {
        .banner_fns {
            flex-direction: column;
        }

    }
 


    /* ----------------banner-fns end-----------------*/

    @media screen and (max-width: 600px) {
        .bannersland {
            display: grid;
            grid-template-columns: repeat(1, 1fr);
            grid-column-gap: 1rem;
            grid-row-gap: 1rem;
        }

  
        .bannersland,  
        .bannersland .banner_fns  {
            grid-column: auto;
            grid-row: auto;
        }
       
    }

 


    .gorodsreda-wrapper {
        border: 1px solid #0ec702;
        padding: 1rem;
        grid-column: 1/13;
        grid-row: auto;
    }

    .gorodsreda-title {
        font-weight: 700;
        font-size: 3rem;
        line-height: 3.6rem;
    }

    .gorodsreda-main {
        display: flex;
    }


    .gorodsreda-information {
        display: flex;
        flex-direction: column;
    }

    .gorodsreda-information__text {
        display: flex;
        flex-direction: column;
        gap: 30px;
        margin-top: 14px;
    }


    .gorodsreda-information__link a {
        text-decoration: none;
        font-size: 2rem;
        background: linear-gradient(127deg, #02acc7, #b2c702);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .gorodsreda-information__link p {
        font-size: 1.5rem;
    }

    .gorodsreda-information__perfomance {
        display: flex;
        gap: 20px;
    }


    .gorodsreda-container__img {
        width: 32%;
        margin-left: auto;
    }

    .gorodsreda-information__perfomance img {
        width: 100%;
        height: 90px;
    }


    @media (max-width: 719px) {
        .gorodsreda-main {
            flex-direction: column;
            gap: 10px;
        }

        .gorodsreda-information__perfomance {
            flex-direction: column;
        }

        .gorodsreda-information__perfomance img {
            height: 100px;
        }

        .gorodsreda-information__perfomance img:first-child {
            height: 150px;
        }

        .gorodsreda-container__img {
            width: 100%;
        }
    }

    @media (min-width:720px) and (max-width:1024px) {
        .gorodsreda-main {
            gap: 20px;
            flex-direction: column;
        }

        .gorodsreda-information__perfomance {
            flex-direction: row;
        }

        .gorodsreda-information__perfomance img:first-child {
            height: 110px;
        }

        .gorodsreda-container__img {
            width: 90%;
        }


    }
    .bannersland__item--rucode img{ 
        width: 100%;
        height: auto;
    }
    .bannersland__item--rucode .rucode-d{
        display: block;
    }
    .bannersland__item--rucode .rucode-m{
        display: none;
    }
    @media screen and (max-width: 600px){
        .bannersland__item--rucode .rucode-d{
            display: none;
        }
        .bannersland__item--rucode .rucode-m{
            display: block;
        }
    }


</style>
