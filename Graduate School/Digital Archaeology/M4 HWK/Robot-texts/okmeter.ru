        </section>
        <section id="tariffs" class="tariffs">
            <div class="container">
                <div class="tariffs__wrap"><h2 class="tariffs__title title--h2">Тарифы</h2>
                    <h2 class="tariffs__subtitle subtitle subtitle--white">Бесплатная пробная версия</h2>
                    <div class="tariffs__grid card">
                        <div class="tariffs-card">
                            <div class="tariffs-card__header"><h4 class="tariffs-card__header-title title--h4">
                                Hacker</h4><h4 class="tariffs-card__header-prise">349₽</h4><h4
                                    class="tariffs-card__header-frequency">за сервер в месяц</h4></div>
                            <div class="tariffs-card__description">
                                <ul class="tariffs-card__description-list">
                                    <li class="tariffs-card__description-item">Только базовые метрики*</li>
                                    <li class="tariffs-card__description-item">1 неделя истории</li>
                                    <li class="tariffs-card__description-item">Email уведомления</li>
                                </ul>
                                <div class="tariffs-card__description-footnote">* процессор, оперативная память, диск,
                                    сеть, процессы
                                </div>
                            </div>
                        </div>
                        <div class="tariffs-card">
                            <div class="tariffs-card__header"><h4 class="tariffs-card__header-title title--h4">Lite</h4>
                                <h4 class="tariffs-card__header-prise">1499₽</h4><h4
                                        class="tariffs-card__header-frequency">за сервер в месяц</h4></div>
                            <div class="tariffs-card__description">
                                <ul class="tariffs-card__description-list">
                                    <li class="tariffs-card__description-item">1 неделя истории</li>
                                    <li class="tariffs-card__description-item">SMS/email уведомления</li>
                                    <li class="tariffs-card__description-item">Поддержка по email</li>
                                </ul>
                            </div>
                        </div>
                        <div class="tariffs-card">
                            <div class="tariffs-card__header"><h4 class="tariffs-card__header-title title--h4">
                                Standart</h4><h4 class="tariffs-card__header-prise">2499₽</h4><h4
                                    class="tariffs-card__header-frequency">за сервер в месяц</h4></div>
                            <div class="tariffs-card__description">
                                <ul class="tariffs-card__description-list">
                                    <li class="tariffs-card__description-item">2 месяца истории</li>
                                    <li class="tariffs-card__description-item">SMS/email уведомления</li>
                                    <li class="tariffs-card__description-item">Slack</li>
                                    <li class="tariffs-card__description-item">Live chat поддержка</li>
                                </ul>
                            </div>
                        </div>
                        <div class="tariffs-card">
                            <div class="tariffs-card__header"><h4 class="tariffs-card__header-title title--h4">
                                Enterprise</h4><h4 class="tariffs-card__header-prise"><img
                                    src="/static/landing/assets/build.svg" alt=""></h4><h4
