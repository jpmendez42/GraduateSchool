:1118,"category":1122,"specifications":1127,"additional_images":1146,"description":1163,"review_count":1164,"type":1165,"shop_rating_high_count":1114,"discount_max":1166,"video_count":1164,"videos":1113,"visit_count":1167,"questions_count":1164,"has_min_price":1123},8175442,"43LED-8259/UTS2C","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/01bc16477d4b92bc4e07f277a67d1603.JPEG","televizory/bbk-43led-8259-uts2c","LCD телевизор","LCD телевизор BBK 43LED-8259/UTS2C [43\", 3840 x 2160, IPS, 4K Ultra HD, 3840х2160, QLED, Яндекс.ТВ]","[43\", 3840 x 2160, IPS, 4K Ultra HD, 3840х2160, QLED, Яндекс.ТВ]",{"min":1110,"max":1111,"avg":1112,"last_price":1113},21826,30664,24818,null,7,90,"/stats/mv?d=eyJtb2RlbF9pZCI6ODE3NTQ0MiwiY2F0ZWdvcnlfaWQiOiIxNzEzIiwiYnJhbmRfaWQiOjU0MywicHJpY2UiOnsibWluIjoyMTgyNiwibWF4IjozMDY2NCwiYXZnIjoyNDgxOH19",9,{"id":1119,"name":1120,"slug":1121,"logo":1113},543,"BBK","brands/bbk",{"is_drug":1123,"is_dietary_supplement":1123,"is_baby_food":1123,"id":1124,"name":1125,"slug":1126},false,"1713","телевизоры и видеопанели","televizory",[1128,1131,1134,1138,1142],{"title":1129,"value":1130,"description":15,"link":1113},"Особенности звука","объемное звучание (Surround), cтереозвук NICAM",{"title":1132,"value":1106,"description":1133,"link":1113},"Тип устройства","В зависимости от технологии изготовления экрана телевизоры могут быть нескольких типов:\u003Cul>\u003Cli>\u003Cb>ЭЛТ-телевизоры\u003C/b>, в основе которых электронно-лучевые трубки.\u003C/li>\u003Cli>\u003Cb>LCD-телевизоры\u003C/b>, основу которых составляет жидкокристаллическая матрица\u003C/li>\u003Cli>\u003Cb>Плазменные телевизоры\u003C/b>, построенные на принципе работы неоновых ламп.\u003C/li>\u003Cli>\u003Cb>OLED\u003C/b> представляет собой светоизлучающий диод, который создан на основе органических соединений. Телевизоры, в которых применяется матрица из таких светодиодов 3 основных цветов, называются OLED-телевизорами.\u003C/li>\u003Cli>В \u003Cb>лазерном телевизоре\u003C/b> используется не лампа, а лазерный источник излучения, который создает световые лучи красного, синего и зеленого цветов, проецирующиеся на экран.\u003C/li>\u003C/ul>\n",{"title":1135,"value":1136,"description":1137,"link":1113},"Диагональ","43\"","Диагональ экрана определяется как расстояние между двумя противоположными углами экрана. Измеряется в дюймах.",{"title":1139,"value":1140,"description":1141,"link":1113},"Разрешение","3840 x 2160","Разрешение экрана телевизора.\n\u003Cul>\nРазрешение экрана показывает количество пикселей (по горизонтали и по вертикали), из которых формируется изображение. Чем выше разрешение экрана, тем более качественное и детальное изображение способен создать телевизор. \n\u003C/ul>",{"title":1143,"value":1144,"description":1145,"link":1113},"Поддержка Smart TV","есть","Возможность использования интернет-сервисов непосредственно с телевизора, без применения дополнительных устройств.\n\u003Cul>\nДоступ к онлайн-контенту обычно осуществляется с помощью интерактивных приложений, которыми удобно управлять с пульта телевизора.\n\u003C/ul>",[1147,1148,1149,1150,1151,1152,1153,1154,1155,1156,1157,1158,1159,1160,1161,1162],"https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/07f55052260218a2000256f10478be3d.JPEG","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/24b83dbfb3c3c80ad3f312a3192776d9.JPEG","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/38a6b8a80d1f0761b02721f8e6c26f10.JPEG","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/3b765ccab077f62a5b4f3dcf7dab490d.JPEG","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/77ce611cd06a6956c3441026d5c56472.JPEG","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/78464ad6faa04ee8a7ca97284c22a619.JPEG","https://static.price.ru/images/models/-/televizor/bbk-43led-8259-uts2c/8635db95f666b27cbd838c8feefbcb53.JPEG","https://static.price.ru/images/models/-/televizor/bbk-