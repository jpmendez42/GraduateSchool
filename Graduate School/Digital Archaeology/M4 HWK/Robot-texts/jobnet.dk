    <script>
        const userAgent = window.navigator.userAgent;
        const ie10OrOlder = userAgent.indexOf('MSIE ');
        const ie11 = userAgent.indexOf('Trident/');
        const ie11OrOlder = (ie10OrOlder >= 0 || ie11 >= 0);
        $('#BrowserInfoModal').attr('data-open-auto', ie11OrOlder);
        $(function () {
            //Solves IEs problem with placeholder
            Jobnet.Utility.Placeholder.setPlaceholderAttributeAtPageLevel();
            // serviceMessage slidedown if needed
            $('#ServiceMessage').hide().slideDown(500, "swing");
            $('#ServiceMessageClose').on('click', function () {
                $('#ServiceMessage').slideUp(500, "swing");
            });
            var submitHandler = new Jobnet.Forms.DisableOnSubmit(null, "#fff");
            submitHandler.setup();
        });
    </script>
    <script src="/CV/bundles/jobnet/scripts/angularjs?v=sojHBHn40Jd_BAbV41BSRUUM4lxpJ83AsOQKRcMn2jE1"></script>



