  <script src="//j1-nec.static.pub/resource/NEC_Public_Resource/site/data/batchNavPrice.js"></script> 
  <script src="//j1-nec.static.pub/resource/NEC_Public_Resource/site/data/third_nav_price_info.js"></script> 
  <script>
  function clonePriceToClones() {
  // .price クラスを持つ全ての要素を取得
    const priceElements = document.querySelectorAll('.price');
    const productCodes = new Set();

    // 各 .price 要素のクラスから productCode を抽出
    priceElements.forEach(el => {
      el.classList.forEach(cls => {
        if (cls !== 'price') {
          productCodes.add(cls); // 例: N15Slim_2505
        }
      });
    });

    // クラス名から自動抽出された productCodes を使って処理
    productCodes.forEach(code => {
      const originalPrice = document.querySelector(`.price.${code}`);
      const clonePrices = document.querySelectorAll(`.splide__slide--clone .price.${code}`);

      if (originalPrice && originalPrice.textContent.trim() !== '') {
        clonePrices.forEach(cloneEl => {
          cloneEl.textContent = originalPrice.textContent;
        });
      }

      const originalCoupon = document.querySelector(`.${code}_coupon`);
      const cloneCoupons = document.querySelectorAll(`.splide__slide--clone .${code}_coupon`);

      if (originalCoupon && originalCoupon.textContent.trim() !== '') {
        cloneCoupons.forEach(cloneEl => {
          cloneEl.textContent = originalCoupon.textContent;
        });
      }
    });
  }
</script> 
  <script>
  // クーポン率がない場合は親要素を非表示
  function monitorCouponSpans() {
    const couponSpans = document.querySelectorAll('.lavie_cardCarousel__info__coupon span[class$="_coupon"]');

    couponSpans.forEach(span => {
      const observer = new MutationObserver(() => {
        const dd = span.closest('.lavie_cardCarousel__info__coupon');
        if (!dd) return;

        const isEmpty = span.textContent.trim() === '';
        dd.style.display = isEmpty ? 'none' : '';
      });

      observer.observe(span, {
        characterData: true,
        childList: true,
        subtree: true
      });

      // 初期状態でも一度チェック
      const dd = span.closest('.lavie_cardCarousel__info__coupon');
      if (dd) {
        dd.style.display = span.textContent.trim() === '' ? 'none' : '';
      }
    });
  }

  window.addEventListener('DOMContentLoaded', () => {
    monitorCouponSpans();
  });
</script>   
 

<script>
