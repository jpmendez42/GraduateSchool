Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-11%2F_dsc3631.jpg%3Fitok%3DOSyuINDp&amp;w=3840&amp;q=75"/></div></div><div class="sc-6f3709af-1 dVlYyt"><div class="sc-6f3709af-2 eABxIX"><h2 id="paragraph-anchor--51b10b2b-268f-49ea-b97a-96d1ae5c8f2a">Opiskelijaksi Tampereelle</h2><div class="sc-6f3709af-7 hZCMx"><p class="sc-6f3709af-4 cSUVX">Tampereen yliopisto ja Tampereen ammattikorkeakoulu tarjoavat lukuisia mahdollisuuksia opiskella tutkintotavoitteisesti tai syventää osaamistasi vaikkapa työn ohessa. Tutustu opiskelumahdollisuuksiin ja tule opiskelemaan!</p></div><div class="sc-6f3709af-5 qtRPc"><div class="sc-b338a374-0 bUGziY"><a href="https://www.tuni.fi/fi/tule-opiskelemaan/hae-yliopistoon" rel="noreferrer"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="21" width="24" aria-hidden="true"><path d="M6 4v4h7.17L2.59 18.59l2.82 2.82L16 10.83V18h4V4z"></path></svg><span>Opiskelijaksi yliopistoon</span></a></div><div class="sc-b338a374-0 bUGziY"><a href="https://www.tuni.fi/fi/tule-opiskelemaan/hae-tamkiin" rel="noreferrer"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="21" width="24" aria-hidden="true"><path d="M6 4v4h7.17L2.59 18.59l2.82 2.82L16 10.83V18h4V4z"></path></svg><span>Opiskelijaksi TAMKiin</span></a></div><div class="sc-b338a374-0 bUGziY"><a href="https://www.tuni.fi/fi/tule-opiskelemaan/avoimet-korkeakouluopinnot" rel="noreferrer"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="21" width="24" aria-hidden="true"><path d="M6 4v4h7.17L2.59 18.59l2.82 2.82L16 10.83V18h4V4z"></path></svg><span>Avoimet korkeakouluopinnot</span></a></div><div class="sc-b338a374-0 bUGziY"><a href="https://www.tuni.fi/fi/tule-opiskelemaan/taydennyskoulutus" rel="noreferrer"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="21" width="24" aria-hidden="true"><path d="M6 4v4h7.17L2.59 18.59l2.82 2.82L16 10.83V18h4V4z"></path></svg><span>Täydennyskoulutus</span></a></div></div></div></div></div></div><div class="sc-5a6a23e1-1 fPczXS"><div color="port-gore" class="sc-6f3709af-0 icbcjT"><div class="sc-6f3709af-1 dVlYyt"><div class="sc-6f3709af-3 gfPQsk"><img alt="" loading="lazy" width="870" height="580" decoding="async" data-nimg="1" style="color:transparent" sizes="(max-width: 768px) 100vw, (min-width: 769px) 33vw" srcSet="/_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=3840&amp;q=75 3840w" src="/_next/image?url=https%3A%2F%2Fcontent-webapi.tuni.fi%2Fimage-style%2Flandscape%2Fproxy%2Fpublic%2F2024-12%2Ftohtori-091122-jr-vio-900x600.jpg%3Fitok%3Dr6PeRExB&amp;w=3840&amp;q=75"/></div></div><div class="sc-6f3709af-1 dVlYyt"><div class="sc-6f3709af-2 eABxIX"><h2 id="paragraph-anchor--231dccc5-0c03-475f-84cb-84365212e04b">Väitökset</h2><div class="sc-6f3709af-7 hZCMx"><p class="sc-6f3709af-4 cSUVX">Tampereen yliopistosta valmistuu vuosittain noin 200 tohtoria. Väitöstilaisuudet ovat kaikille avoimia. Osallistu tapahtumaan paikan päällä tai seuraa etäyhteydellä!</p></div><div color="black-2" class="sc-6f3709af-5 qtRPc"><div color="port-gore" class="sc-b338a374-0 hjqcPU"><a href="https://www.tuni.fi/etsi?view_mode=grid&amp;search_type=events&amp;event_category=1384" rel="noreferrer"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="21" width="24" aria-hidden="true"><path d="M6 4v4h7.17L2.59 18.59l2.82 2.82L16 10.83V18h4V4z"></path></svg><span>Katso tulevat väitökset</span></a></div></div></div></div></div></div><div class="sc-5a6a23e1-1 fPczXS"><div class="sc-e0f336f-0 iBVQge"><div class="sc-e0f336f-1 iuIRdC"><div class="sc-e0f336f-2 iKgPhG"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 24H0V0h18v5H5z"></path></svg></div><h2 id="paragraph-anchor--b3598b0e-b7b0-4c01-b60a-678cc932aac6" class="sc-e0f336f-3 eYyzlo">Tapahtumat</h2></div><div mode="grid" class="sc-a4c70d55-0 jmGhJZ"><div class="sc-a4c70d55-1 lplHKt"><div class="sc-e204741e-0 fGFqRO"><a href="/fi/ajankohtaista/roboai-roadshow-tulee-taas-talla-kertaa-euraan"><div color="--color-news" class="sc-e204741e-1 DWDkn"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="24" width="24" aria-hidden="true"><path d