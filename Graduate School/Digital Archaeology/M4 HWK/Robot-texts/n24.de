images.welt.de/68e7b174d3ab2139f9f118da/1c73a635c7fefc2a0f3fbf9d75635f94-master/ci23x11-w1600/adolescent-threatening-a-group-with-a-knife 1600w, https://images.welt.de/68e7b174d3ab2139f9f118da/1c73a635c7fefc2a0f3fbf9d75635f94-master/ci23x11-w1800/adolescent-threatening-a-group-with-a-knife 1800w, https://images.welt.de/68e7b174d3ab2139f9f118da/1c73a635c7fefc2a0f3fbf9d75635f94-master/ci23x11-w2000/adolescent-threatening-a-group-with-a-knife 2000w" sizes="(min-width: 910px) calc(970px / 3), (min-width: 600px) 50vw, 100vw"/><img src="https://images.welt.de/68e7b174d3ab2139f9f118da/1c73a635c7fefc2a0f3fbf9d75635f94-master/ci23x11-w200/adolescent-threatening-a-group-with-a-knife" class="c-picture__image" alt="Jugendkriminalität" loading="lazy" decoding="async"/></picture></div></header></div><div class="c-teaser__container is-full-height-flex"><div class="c-teaser__overline"><div class="c-teaser__ellipsis-container"><span class="c-teaser__badge is-premium" data-external="Teaser.PremiumIcon"><svg class="c-teaser__premium-icon u-icon is-logo-welt-plus-small"><title>Weltplus Artikel</title><use href="#logo-welt-plus-small"></use></svg></span><span class="c-teaser__topic" data-external="Teaser.Topic">Jugendkriminalität</span></div></div><div class="c-teaser__body" data-external="Teaser.Body"><h4 class="c-teaser__headline" data-external="Teaser.Title"><a class="is-link c-teaser__headline-link is-teaser-link" href="/politik/deutschland/plus68e7b174d3ab2139f9f118da/jugendkriminalitaet-juengere-taeter-und-eine-neue-haerte-auf-der-strasse.html" title="Jüngere Täter und eine neue Härte auf der Straße" data-external="Teaser.Link" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;politik_a_plus&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/politik/deutschland/plus68e7b174d3ab2139f9f118da/jugendkriminalitaet-juengere-taeter-und-eine-neue-haerte-auf-der-strasse.html&quot;,&quot;trackingName&quot;:&quot;Jüngere Täter und eine neue Härte auf der Straße&quot;,&quot;trackingLabel&quot;:&quot;Jüngere Täter und eine neue Härte auf der Straße&quot;}}" aria-label="Weltplus Artikel - Jugendkriminalität: Jüngere Täter und eine neue Härte auf der Straße">Jüngere Täter und eine neue Härte auf der Straße</a></h4><p class="c-teaser__intro" data-external="Teaser.Intro">„Ein richtiger Mann ist bereit, zuzuschlagen.“ Dieser Satz bekommt in Deutschland mehr Zustimmung. Messerangriffe, Prügeleien, Raub: Ist die Jugend brutaler geworden? In der größten Untersuchung zur Jugendkriminalität fällt vor allem eine Gruppe besonders auf.</p></div><script type="application/hydration-data" data-internal-ref="TeaserFooter-3a406507-8930-4876-7e0d-db4e650a40f3">{"teaserId":"68e7b174d3ab2139f9f118da","showCommentCount":true,"author":{"name":"Philipp Woldin"}}</script><div data-component="TeaserFooter" data-internal-id="TeaserFooter-3a406507-8930-4876-7e0d-db4e650a40f3" class="is-teaser-footer-hydrated"><footer class="c-teaser__footer" data-external="Teaser.Footer"><ul class="c-teaser__footer-list"><li class="c-teaser__footer-list-item"><span class="c-teaser__author" data-external="Teaser.Author">Philipp Woldin</span></li></ul></footer></div></div></article></div><div data-external="Stage.Item" class="u-grid-item is-grid-col-mobile-s-12 is-grid-col-mobile-l-6 is-grid-col-tablet-l-4"><article class="c-teaser c-teaser--default is-last has-hint-icon" data-external="Teaser" data-external-id="68ec9ef70bda2290ccea9392"><div class="c-teaser__container"><header class="c-teaser__header" data-external="Teaser.Header"><div class="c-picture has-placeholder-image is-aspect-ratio-mobile-s-23x11  c-picture--default" data-external="Teaser.PictureElement.Placeholder"><picture class="c-picture__image-container is-aspect-ratio-mobile-s-23x11 "><source media="(min-width:0px)" srcSet="https://images.welt.de/68ec9ef70bda2290ccea9392/6f32ac1be50631c098