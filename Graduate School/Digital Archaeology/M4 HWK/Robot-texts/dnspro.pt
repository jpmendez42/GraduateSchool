/*buy mailbox*/
.pro {
    border: 1px solid hsla(0,0%,50.2%,.2);
    border-radius: 2px;
    box-shadow: -10px 10px 35px RGBA(20,114,226,.1);
    margin: 0 0.5%;
    -webkit-transition: all 0.2s ease;
    -moz-transition: all 0.2s ease;
    -ms-transition: all 0.2s ease;
    -o-transition: all 0.2s ease;
    transition: all 0.2s ease;
}
.box-3 {
    padding: 5px 25px 60px;    
}
.box-3 a.more-mailbox {
    text-decoration: underline;
    margin-right: 8px;
}
.box-3 a.more-mailbox:hover {
    text-decoration: none;
    color: #d4262c;
}
.box-3 p {
    font-size: 16px;
    color: #777;
}
a.button-pro {
    font-family: 'brandon' !important;
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 1px;
    background: #eb1d24;
    padding: 15px 50px;
    color: #fff;
    border-radius: 2px;
    transition: .2 ease;
}
a.button-pro:hover {
    background: #d4262c;
    color: #fff;
}
a.button-mailbox {
    font-family: 'brandon' !important;
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 1px;
    background: #eee;
    padding: 15px 50px;
    color: #777;
    border-radius: 2px;
    transition: .2 ease;
}
a.button-mailbox:hover {
    background: #d7d7d7;
    color: #222;
}
.price {
    font-size: 46px;
    font-weight: 300;
    color: #212121;
    padding-bottom: 12px;
}
.standard:hover, .pro:hover {
    transform: translate(0,-20px);
    transition-delay: 0s !important;  
}
.standard {
    border: 1px solid hsla(0, 0%, 50.2%, 0.2);
    border-radius: 2px;
    box-shadow: -10px 10px 35px RGBA(20, 114, 226, 0.1);
    margin: 0 0.5% !important;
    -webkit-transition: all 0.2s ease;
    -moz-transition: all 0.2s ease;
    -ms-transition: all 0.2s ease;
    -o-transition: all 0.2s ease;
    transition: all 0.2s ease;
}
.box-1 {
