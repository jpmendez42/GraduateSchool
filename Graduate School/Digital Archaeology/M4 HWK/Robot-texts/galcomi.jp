/title/97zswu9a"><img src="/files/images/showStory_scroll/97zswu9a/02_08.jpg" alt="グラぱらっ！"></a></li></ul></div></div></div></div></div><div class="classicComic_typeC2_inn"><a href="/sd/page/title/97zswu9a/?volume=2"><div class="classicComic_typeC2_left_img shadow"><img src="/sd/image/permit/240/k6smvhi9.jpg" alt="グラぱらっ！"></div><div class="classicComic_typeC2_right_detail"><p class="classicComic_typeC2_catch">【最新刊入荷!】グラぱらっ！</p><p class="classicComic_typeC2_info">さえないフリーター・隅田忍は、ひょんなことから駆け出しのグラビアアイドル・葛木さくらと同棲生活をスタートするが…。</p></div><div class="classicComic_typeC2_btn">今すぐCHECK</div></a></div></div></div><div class="contentsBox contentsBox_staff" id="contentsBox_staff">
<div class="box_label">
<h2 class="box_ttl"><span class="box_ttl_subTxt">毎週金曜更新！</span>書店員激推し特集</h2>
<div class="box_link">
            <a href="https://ch.galcomi.jp/" class="link_more">特集をもっと見る</a>
          </div>
</div><!-- 非表示テンプレート -->
<div style="display: none;">
  <!-- 最新記事テンプレート -->
  <article class="chComicArticleMainWrap" id="template-main">
    <a href="{link}" class="chComicArticlelnk">
      <div class="chComicArticleInfoBox">
        <div class="chComicArticledisc">
          <span class="chComicArticlediscTag chComicArticlediscTag__new">New</span>
          <span class="chComicArticlediscStaff">書店員：{dc:creator}</span>
        </div>
        <p class="chComicArticleInfoTxt">{title}</p>
        <ul class="chComicArticleInfoTagWrap">
          <li class="">#&nbsp;{category}</li>
        </ul>
        <div class="chComicArticleUnderItems">
          <span class="chComicArticleUnderItems__date">{lastBuildDate}</span>
          <span class="chComicArticleUnderItems__btn">この記事を見る</span>
        </div>
      </div>
      <img class="chComicArticle__img" src="{img}" alt="「{title}」 紹介画像">
    </a>
  </article>

  <!-- 2〜3番目の記事テンプレート -->
  <article class="chComicArticleMidWrap" id="template-mid">
    <a href="{link}" class="chComicArticlelnk">
      <div class="chComicArticleInfoBox">
        <p class="chComicArticleInfoTxt">{title}</p>
        <div class="chComicArticleUnderItems">
          <span class="chComicArticleUnderItems__date">{lastBuildDate}</span>
          <span class="chComicArticleUnderItems__btn">この記事を見る</span>
        </div>
      </div>
      <img class="chComicArticle__img" src="{m_thumbnail}" alt="「{title}」 紹介画像">
    </a>
  </article>
</div>
<!-- 記事を差し込む場所（一般） -->
<div id="feed-container-ippan"></div>

<script>
$(function () {
  const genre = 'ippan';
  const apiUrl = `https://ch.galcomi.jp/wp-json/galcomi-api/v1/feed-json/?genre=${genre}&limit=4`;

  const agencyCode = getAgencyCode();

  $.getJSON(apiUrl, function (posts) {
    const $container = $(`#feed-container-${genre}`);

    posts.forEach(function (post, index) {
      const dateObj = new Date(post.pubDate);
      const date = `${dateObj.getFullYear()}年${dateObj.getMonth() + 1}月${dateObj.getDate()}日更新`;

      let $template;

      let linkUrl = new URL(post.link);
      if (agencyCode) {
        linkUrl.searchParams.set('p1', agencyCode);
      }

      // カテゴリ1つ目（または全カテゴリを結合する場合は調整可）
      const category = post.categories?.[0] || '';

      if (index === 0) {
        $template = $('#template-main').clone().removeAttr('id').show();

        $template.find('a').attr('href', linkUrl.toString());
        $template.find('.chComicArticlediscStaff').text('書店員：' + (post.creator || ''));
        $template.find('.chComicArticleInfoTxt').text(post.title);
        $template.find('.chComicArticleInfoTagWrap li').html('#&nbsp;' + category);
        $template.find('.chComicArticleUnderItems__date').text(date);
        $template.find('.chComicArticle__img')
          .attr('src', post.thumbnails?.first_img)
          .attr('alt', `「${post.title}」 紹介画像`);

      } else {
        $template = $('#template-mid').clone().removeAttr('id').show();

        $template.find('a').attr('href', linkUrl.toString());
        $template.find('.chComicArticleInfoTxt').text(post.title);
        $template.find('.chComicArticleUnderItems__date').text(date);
        $template.find('.chComicArticle__img')
          .attr('src', post.thumbnails?.m_thumbnail)
          .attr('alt', `「${post.title}」 紹介画像`);
      }

      $container.append($template);
    });
  }).fail(function (err) {
    console.error("記事取得失敗:", err);
  });

  function getAgencyCode() {
    const scripts = document.getElementsByTagName('script');
    const regex = /ga\(['"]set['"],\s*['"]dimension6['"],\s*['"]([^'"]+)['"]\)/;

    for (let script of scripts) {
      if (script.textContent) {
        const match = script.textContent.match(regex);
        if (match) {
          return match[1];
        }
      }
    }
    return null;
  }
});
</script><a href="https://ch.galcomi.jp/" class="link_more_bottom_ico ico_arrow_right link_more_bottom__ico_staff"><span class="link_more_bottom_innTxt">ハズレなし!! 絶対面白いマンガがてんこ盛り★</span>書店員激推し特集を全部見る</a>
