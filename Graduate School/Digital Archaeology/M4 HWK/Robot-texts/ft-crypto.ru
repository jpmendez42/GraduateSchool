    <app-root _nghost-ng-c750168442="" ng-version="16.2.12" ngh="1" ng-server-context="ssr|httpcache,hydration"><app-header-menu _ngcontent-ng-c750168442="" _nghost-ng-c1852634560="" ngh="0"><div _ngcontent-ng-c1852634560="" class="container"><div _ngcontent-ng-c1852634560="" class="header-menu"><a _ngcontent-ng-c1852634560="" class="header-menu-logo" href="/"><img _ngcontent-ng-c1852634560="" src="assets/img/header/ft-logo.svg" alt="ФТ-Крипто"></a><div _ngcontent-ng-c1852634560="" class="header-menu-block"><ul _ngcontent-ng-c1852634560="" class="header-menu-list"><li _ngcontent-ng-c1852634560="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link header-menu-list-link-active"><a _ngcontent-ng-c1852634560="" href="/edo">ЭДО</a></li><li _ngcontent-ng-c1852634560="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link"><a _ngcontent-ng-c1852634560="" href="/priority">Приоритет</a></li><li _ngcontent-ng-c1852634560="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link"><a _ngcontent-ng-c1852634560="" href="/docs">Документы</a></li><li _ngcontent-ng-c1852634560="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link"><a _ngcontent-ng-c1852634560="" href="/tariffs">Тарифы</a></li><li _ngcontent-ng-c1852634560="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link"><a _ngcontent-ng-c1852634560="" href="/techsupport">Техподдержка</a></li></ul><a _ngcontent-ng-c1852634560="" title="Войти" class="btn header-menu-enter" href="https://eds-pro.ft-crypto.ru/">Вход</a></div></div></div></app-header-menu><router-outlet _ngcontent-ng-c750168442=""></router-outlet><app-edo-page _nghost-ng-c813524803="" ngh="0"><app-edo-main-head _ngcontent-ng-c813524803="" _nghost-ng-c2342409515="" ngh="0"><div _ngcontent-ng-c2342409515="" class="main-head"><div _ngcontent-ng-c2342409515="" class="main-head-block"><div _ngcontent-ng-c2342409515="" class="main-head-info-block"><div _ngcontent-ng-c2342409515="" class="container"><div _ngcontent-ng-c2342409515="" class="main-head-info-text"><div _ngcontent-ng-c2342409515="" class="main-head-text"><div _ngcontent-ng-c2342409515="" class="main-head-text-h1-wrapper"><h1 _ngcontent-ng-c2342409515="" class="ft-text_h1">Электронный документооборот <br _ngcontent-ng-c2342409515="">в рамках госконтрактов</h1></div><p _ngcontent-ng-c2342409515="">Отправляйте акты, накладные, счета‑фактуры <br _ngcontent-ng-c2342409515="">и другие документы без дублирования на бумаге</p></div><div _ngcontent-ng-c2342409515="" class="main-head-btns"><a _ngcontent-ng-c2342409515="" class="btn" href="https://eds-pro.ft-crypto.ru/">Войти</a><a _ngcontent-ng-c2342409515="" class="btn-gray" href="https://eds-pro.ft-crypto.ru/Account/Register">Регистрация</a></div></div></div><div _ngcontent-ng-c2342409515="" class="main-head-info-block-img"><div _ngcontent-ng-c2342409515="" class="main-head-info-block-img-superimposition"></div></div></div><ul _ngcontent-ng-c2342409515="" class="main-head-advantages"><li _ngcontent-ng-c2342409515=""><div _ngcontent-ng-c2342409515=""><img _ngcontent-ng-c2342409515="" src="assets/img/edo/main-head/officially.svg" alt="Официально"></div><div _ngcontent-ng-c2342409515="" class="main-head-advantages-text"><h2 _ngcontent-ng-c2342409515="">Официально</h2><p _ngcontent-ng-c2342409515="">100% юридическая значимость</p></div></li><li _ngcontent-ng-c2342409515="" class="main-head-advantages-long"><div _ngcontent-ng-c2342409515=""><img _ngcontent-ng-c2342409515="" src="assets/img/edo/main-head/securely.svg" alt="Надежно"></div><div _ngcontent-ng-c2342409515="" class="main-head-advantages-text"><h2 _ngcontent-ng-c2342409515="">Надежно</h2><p _ngcontent-ng-c2342409515="">ООО «Финтендер-крипто» входит в Реестр доверенных операторов ЭДО и имеет Паспорт ФНС РФ №0237 от 16.05.2017</p></div></li><li _ngcontent-ng-c2342409515=""><div _ngcontent-ng-c2342409515=""><img _ngcontent-ng-c2342409515="" src="assets/img/edo/main-head/conveniently.svg" alt="Удобно"></div><div _ngcontent-ng-c2342409515="" class="main-head-advantages-text"><h2 _ngcontent-ng-c2342409515="">Удобно</h2><p _ngcontent-ng-c2342409515="">Документооборот и подача отчетности — в одном сервисе</p></div></li></ul></div></div></app-edo-main-head><app-edo-main-content _ngcontent-ng-c813524803="" _nghost-ng-c1068757304="" ngh="0"><app-document-management _ngcontent-ng-c1068757304="" _nghost-ng-c1554322588="" ngh="0"><div _ngcontent-ng-c1554322588="" class="container"><div _ngcontent-ng-c1554322588="" class="document-management"><div _ngcontent-ng-c1554322588="" class="document-management-text"><div _ngcontent-ng-c1554322588="" class="document-management-text-wrapper"><h2 _ngcontent-ng-c1554322588="" class="ft-text_h2">Документооборот в рамках исполнения государственных и муниципальных контрактов</h2></div><div _ngcontent-ng-c1554322588="" class="document-management-regions"><ul _ngcontent-ng-c1554322588="" class="document-management-regions-name"><li _ngcontent-ng-c1554322588="">Ненецкий автономный округ (НАО)</li><li _ngcontent-ng-c1554322588="">Вологодская область</li><li _ngcontent-ng-c1554322588="">Белгородская область</li><li _ngcontent-ng-c1554322588="">Московская область</li><li _ngcontent-ng-c1554322588="">г. Омск</li><li _ngcontent-ng-c1554322588="">г. Анапа</li><li _ngcontent-ng-c1554322588="">Минцифры России</li></ul><div _ngcontent-ng-c1554322588="" class="document-management-regions-img"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/min-numb-rus.svg" alt="Минцифры России"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/nenec.png" alt="Ненецкий автономный округ (НАО)"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/belgorod.png" alt="Белгородская область"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/vologodsk.png" alt="Вологодская область"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/anapa.png" alt="г. Анапа"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/mosoblast.png" alt="Московская область"><img _ngcontent-ng-c1554322588="" src="assets/img/edo/document/omsk.png" alt="г. Омск"></div></div></div></div></div></app-document-management><app-reporting _ngcontent-ng-c1068757304="" _nghost-ng-c2189572139="" ngh="0"><div _ngcontent-ng-c2189572139="" class="container"><div _ngcontent-ng-c2189572139="" class="reporting"><div _ngcontent-ng-c2189572139="" class="reporting-text"><h2 _ngcontent-ng-c2189572139="" class="ft-text_h2 ft-space_bottom-2">Подача отчетности <br _ngcontent-ng-c2189572139="">в контролирующие органы</h2><p _ngcontent-ng-c2189572139="" class="ft-text_p-l">Федеральная налоговая служба РФ, Федеральная служба государственной статистики РФ (Росстат), Фонд социального страхования РФ, Пенсионный фонд РФ</p></div><div _ngcontent-ng-c2189572139="" class="reporting-img"><div _ngcontent-ng-c2189572139="" class="reporting-img-block"><img _ngcontent-ng-c2189572139="" src="assets/img/edo/reporting/pfr.png" alt="Пенсионный фонд РФ"></div><div _ngcontent-ng-c2189572139="" class="reporting-img-block"><img _ngcontent-ng-c2189572139="" src="assets/img/edo/reporting/fsgs.png" alt="Федеральная служба государственной статистики РФ (Росстат)"></div><div _ngcontent-ng-c2189572139="" class="reporting-img-block"><img _ngcontent-ng-c2189572139="" src="assets/img/edo/reporting/fss.png" alt="Фонд социального страхования РФ"></div><div _ngcontent-ng-c2189572139="" class="reporting-img-block"><img _ngcontent-ng-c2189572139="" src="assets/img/edo/reporting/fns.png" alt="Федеральная налоговая служба РФ"></div></div></div></div></app-reporting><app-our-capabilities _ngcontent-ng-c1068757304="" _nghost-ng-c1765622890="" ngh="0"><div _ngcontent-ng-c1765622890="" class="capabilities"><div _ngcontent-ng-c1765622890="" class="container"><div _ngcontent-ng-c1765622890="" class="capabilities-title-wrapper"><h2 _ngcontent-ng-c1765622890="" class="ft-text_h2">Наши возможности</h2></div><ul _ngcontent-ng-c1765622890="" class="capabilities-items"><li _ngcontent-ng-c1765622890="" class="capabilities-items-el"><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb"><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">01</p><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb-line"></div></div><div _ngcontent-ng-c1765622890="" class="capabilities-items-text"><h3 _ngcontent-ng-c1765622890="" class="ft-text_h3">Хранение</h3><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">Загрузка документов в систему <br _ngcontent-ng-c1765622890=""> и хранение в электронном виде</p></div></li><li _ngcontent-ng-c1765622890="" class="capabilities-items-el"><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb"><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">02</p><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb-line"></div></div><div _ngcontent-ng-c1765622890="" class="capabilities-items-text"><h3 _ngcontent-ng-c1765622890="" class="ft-text_h3">Управление</h3><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">Направление отчетов <br _ngcontent-ng-c1765622890=""> в контролирующие органы в 1 клик</p></div></li><li _ngcontent-ng-c1765622890="" class="capabilities-items-el"><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb"><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">03</p><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb-line"></div></div><div _ngcontent-ng-c1765622890="" class="capabilities-items-text"><h3 _ngcontent-ng-c1765622890="" class="ft-text_h3">Контроль</h3><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">Отслеживание статуса обработки документов. Исключение налоговых рисков</p></div></li><li _ngcontent-ng-c1765622890="" class="capabilities-items-el"><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb"><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">04</p><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb-line"></div></div><div _ngcontent-ng-c1765622890="" class="capabilities-items-text"><h3 _ngcontent-ng-c1765622890="" class="ft-text_h3">Упрощение</h3><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">Загрузка файлов из любых бухгалтерских систем, поддерживающих форматы ФНС</p></div></li><li _ngcontent-ng-c1765622890="" class="capabilities-items-el"><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb"><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">05</p><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb-line"></div></div><div _ngcontent-ng-c1765622890="" class="capabilities-items-text"><h3 _ngcontent-ng-c1765622890="" class="ft-text_h3">Оптимизация</h3><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">Автоматизация документооборота для исключения ошибок <br _ngcontent-ng-c1765622890="">и экономии ресурсов</p></div></li><li _ngcontent-ng-c1765622890="" class="capabilities-items-el"><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb"><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">06</p><div _ngcontent-ng-c1765622890="" class="capabilities-items-numb-line"></div></div><div _ngcontent-ng-c1765622890="" class="capabilities-items-text"><h3 _ngcontent-ng-c1765622890="" class="ft-text_h3">Поддержка</h3><p _ngcontent-ng-c1765622890="" class="ft-text_p-l">Поддержка по работе в сервисе, телефонная линия и обращения через сайт</p></div></li></ul></div></div></app-our-capabilities><app-get-started _ngcontent-ng-c1068757304="" _nghost-ng-c1629313585="" ngh="0"><div _ngcontent-ng-c1629313585="" class="container"><div _ngcontent-ng-c1629313585="" class="get-started"><h2 _ngcontent-ng-c1629313585="" class="ft-text_h2 ft-space_bottom-7">Как начать работу</h2><div _ngcontent-ng-c1629313585="" class="get-started-steps ft-space_bottom-6"><div _ngcontent-ng-c1629313585="" class="get-started-steps-item"><h3 _ngcontent-ng-c1629313585="" class="ft-text_h3 get-started-steps-item-head">01</h3><a _ngcontent-ng-c1629313585="" title="Регистрация" class="ft-text_a get-started-steps-item-link" href="https://eds-pro.ft-crypto.ru/Account/Register">Зарегистрируйтесь</a></div><div _ngcontent-ng-c1629313585="" class="get-started-steps-arrow"><img _ngcontent-ng-c1629313585="" src="assets/img/edo/steps/arrow-steps.svg" alt="Следующий шаг"></div><div _ngcontent-ng-c1629313585="" class="get-started-steps-item"><h3 _ngcontent-ng-c1629313585="" class="ft-text_h3 get-started-steps-item-head">02</h3><p _ngcontent-ng-c1629313585="" class="ft-text_p-l get-started-steps-item-text">Работайте</p></div></div></div></div></app-get-started></app-edo-main-content><app-footer _ngcontent-ng-c813524803="" _nghost-ng-c1477821897="" ngh="0"><footer _ngcontent-ng-c1477821897=""><div _ngcontent-ng-c1477821897="" class="container"><div _ngcontent-ng-c1477821897="" class="top"><div _ngcontent-ng-c1477821897="" class="top-contact"><h2 _ngcontent-ng-c1477821897="" class="top-contact-title">ОБЩЕСТВО С ОГРАНИЧЕННОЙ ОТВЕТСТВЕННОСТЬЮ «ФИНТЕНДЕР-КРИПТО»</h2><a _ngcontent-ng-c1477821897="" href="tel:+74996382882" title="Позвонить" class="top-contact-phone">+7(499) 638-28-82</a></div><div _ngcontent-ng-c1477821897="" class="top-menu"><ul _ngcontent-ng-c1477821897="" class="top-menu-link"><li _ngcontent-ng-c1477821897="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link ft-space_bottom-8 ft-space_right-8 header-menu-list-link-active"><a _ngcontent-ng-c1477821897="" href="/edo">ЭДО</a></li><li _ngcontent-ng-c1477821897="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link ft-space_bottom-8 ft-space_right-8"><a _ngcontent-ng-c1477821897="" href="/priority">Приоритет</a></li><li _ngcontent-ng-c1477821897="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link ft-space_bottom-8 ft-space_right-8"><a _ngcontent-ng-c1477821897="" href="/docs">Документы</a></li><li _ngcontent-ng-c1477821897="" routerlinkactive="header-menu-list-link-active" class="header-menu-list-link ft-space_bottom-8 ft-space_right-8"><a _ngcontent-