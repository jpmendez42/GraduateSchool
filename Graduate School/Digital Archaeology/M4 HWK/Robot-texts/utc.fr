id="image-4728-35681-2" alt="" src="https://www.utc.fr/wp-content/uploads/sites/28/2021/09/prbvl.jpg" class="ct-image" data-id="image-4728-35681"><div id="text_block-5880-35681-2" class="ct-text-block" data-id="text_block-5880-35681"></div><h3 id="headline-4729-35681-2" class="ct-headline" data-id="headline-4729-35681"><span id="span-4730-35681-2" class="ct-span" data-id="span-4730-35681"><a href="https://www.utc.fr/breves-actualites/38e-prix-roberval-annonce-des-finalistes/">38<sup class="ordinal">e</sup> Prix Roberval &ndash; Annonce des finalistes</a></span></h3></div><div id="div_block-4727-35681-3" class="ct-div-block" data-id="div_block-4727-35681"><img id="image-4728-35681-3" alt="" src="https://www.utc.fr/wp-content/uploads/sites/28/2025/09/visiterectricelille.jpg" class="ct-image" data-id="image-4728-35681"><div id="text_block-5880-35681-3" class="ct-text-block" data-id="text_block-5880-35681"></div><h3 id="headline-4729-35681-3" class="ct-headline" data-id="headline-4729-35681"><span id="span-4730-35681-3" class="ct-span" data-id="span-4730-35681"><a href="https://www.utc.fr/breves-actualites/retour-sur-la-visite-de-la-rectrice-deleguee-esri-de-la-region-academique-de-lille-a-lutc/">Retour sur la visite de la rectrice d&eacute;l&eacute;gu&eacute;e ESRI, de la R&eacute;gion acad&eacute;mique de Lille &agrave; l&rsquo;UTC</a></span></h3></div><div id="div_block-4727-35681-4" class="ct-div-block" data-id="div_block-4727-35681"><img id="image-4728-35681-4" alt="" src="https://www.utc.fr/wp-content/uploads/sites/28/2025/09/l-durand.jpg" class="ct-image" data-id="image-4728-35681"><div id="text_block-5880-35681-4" class="ct-text-block" data-id="text_block-5880-35681"></div><h3 id="headline-4729-35681-4" class="ct-headline" data-id="headline-4729-35681"><span id="span-4730-35681-4" class="ct-span" data-id="span-4730-35681"><a href="https://www.utc.fr/breves-actualites/lecon-inaugurale-de-lancelot-durand-co-fondateur-deppur/">Le&ccedil;on inaugurale de Lancelot Du