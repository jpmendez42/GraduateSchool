pe":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"38I7TFnJdBJZ5wCoDag8Jv","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion - Forkert opsætning eller indbruds forsøg","title":"Forkert opsætning eller indbruds forsøg","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Vi har begrænset din adgang, fordi en enhed (pc, mac, smartphone, webcam, HTC-anlæg, virus m.v.) forsøger at få adgang, med forkert brugernavn/adgangskode.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Der kan være en eller flere årsager:\na) en mail konto forsøger at få adgang med forkert adgangskode.\nb) en mail konto forsøger at få adgang med forkert brugernavn. Kontroller om brugernavn er korrekt og kig efter mellemrum før/efter brugernavnet.\nc) en mail konto forsøger at sende via TDC's asmtp server med et fremmed domæne (som ikke tilhører TDC).\nd) din maskine er virus inficeret og den forsøger at bryde ind på TDCs mailserver.\ne) web kamera, HTC-anlæg er opsat forkert og forsøger adgang.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Vigtigt:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nNår du har løst problemet, går der en time før du igen kan sende (såfremt problemet er løst og der ikke har været nye forsøg i mellemtiden).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nasmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"","marks":[],"data":{}}]}]}}}],"showSmileyFeedback":true}},"enableChat":true}}},"__N_SSG":true},"page":"/[pageSlug]","query":{"pageSlug":"fejlmeddelelser-i-asmtp-udgaende-post"},"buildId":"XBSVBvra61G6GX36t3_MO","assetPrefix":"/hjaelp","isFallback":false,"gsp":true,"scriptLoader":[]}</script></body></html>