_svs.widgets.data.extraContent=[{"data":{"areaName":"extraContent","childElements":"<div class=\"banner-slider widget-full-height\">\n    <div class=\"slider-top relative\">\n        <h2 class=\"widget-title  f-center margin-bottom-2\">Läs mer om Svenska Spel</h2>\n        \n    </div>\n    <div class=\"js-banner-slider-group slider-container\">\n        <div class=\"js-slider-wrapper slider-wrapper slider-wrapper-snap grid-row\">\n            <div class=\"js-slider-slide slider-slide card-puff-group col-xs-10 col-sm-7 col-am-4 col-md-3 col-lg-3 col-xl-3\">\n  <div class=\"banner-slider-item\">\n    <div aria-disabled=\"false\" class=\"paper inline-block banner-edit-paper banner-card-paper clip paper-link elevation-100 paper-neutral\"\n><div class=\"banner-card-puff-item  banner-card-puff bg-white f-content\" \n    \n    data-impression=true data-impression-tracking=\"banner-slider/vattendelare-slider/1/card_puff/omnikanalt-\">\n    <div class=\"banner-card-top-image\">\n        \n        <div\n          class=\"image-wrapper\"\n          itemscope itemtype=\"http://schema.org/ImageObject\"\n          style=\"\">\n          <meta itemprop=\"url\" content=\"//cdn1.svenskaspel.net/content/cms/images/042903b9-dfa7-4b12-9558-66062606a1b6/productImage/a89e4dd0-d2a4-4f0b-bc7e-a529d5ab1bc8/1.0/210702-Svenska-Spel-B-574.1.jpg\">\n          <picture>\n            <source \n               sizes=\"100vw\"   srcSet=\"//cdn1.svenskaspel.net/content/cms/images/320/auto/042903b9-dfa7-4b12-9558-66062606a1b6/productImage/a89e4dd0-d2a4-4f0b-bc7e-a529d5ab1bc8/1.0/210702-Svenska-Spel-B-574.1.jpg 320w,//cdn1.svenskaspel.net/content/cms/images/480/auto/042903b9-dfa7-4b12-9558-66062606a1b6/productImage/a89e4dd0-d2a4-4f0b-bc7e-a529d5ab1bc8/1.0/210702-Svenska-Spel-B-574.1.jpg 480w,//cdn1.svenskaspel.net/content/cms/images/640/auto/042903b9-dfa7-4b12-9558-66062606a1b6/productImage/a89e4dd0-d2a4-4f0b-bc7e-a529d5ab1bc8/1.0/210702-Svenska-Spel-B-574.1.jpg 640w\" >\n            <img src=\"//cdn1.svenskaspel.net/content/cms/images/042903b9-dfa7-4b12-9558-66062606a1b6/productImage/a89e4dd0-d2a4-4f0b-bc7e-a529d5ab1bc8/1.0/210702-Svenska-Spel-B-574.1.jpg\" alt=\"\"\n              \n              \n              class=\"js-image image\" \n              decoding=\"sync\"\n              \n              width=\"291\"\n              height=\"129\"\n              loading=\"eager\">\n          </picture>\n        </div>\n        \n    </div>\n    <div class=\"banner-card-body padding-left-1 padding-right-1\">\n        <div class=\"margin-bottom-half f-center\">\n            <span class=\"block f-800 f-bold fc-navy margin-0 banner-card-lineheight-compact\">Ditt spelkonto</span>\n        </div>\n        <div class=\"margin-bottom-half f-center\">\n            <span class=\"block f-content fc-navy margin-0\">Välj själv hur du vill ta ut dina vinster och hur du vill betala för spel.</span>\n        </div>\n    </div>\n</div>\n<div class=\"banner-card-bottom-container\">\n    <div class=\"padding-lg-left-2 padding-lg-right-2 padding-md-left-1 padding-md-right-1\">\n        <a href=\"/spelkonto\" id=\"042903b9-dfa7-4b12-9558-66062606a1b6\" class=\"btn btn-green btn-block\" data-click-tracking=\"banner-slider/vattendelare-slider/1/card_puff/omnikanalt-\" title=\"Läs mer\"><span class=\"btn-link-text\">Läs mer</span></a>\n\n    </div>\n</div>\n</div>\n\n  </div>\n</div>\n<div class=\"js-slider-slide slider-slide card-puff-group col-xs-10 col-sm-7 col-am-4 col-md-3 col-lg-3 col-xl-3\">\n  <div class=\"banner-slider-item\">\n    <div aria-disabled=\"false\" class=\"paper inline-block banner-edit-paper banner-card-paper clip paper-link elevation-100 paper-neutral\"\n><div class=\"banner-card-puff-item  banner-card-puff bg-white f-content\" \n    \n    data-impression=true data-impression-tracking=\"banner-slider/vattendelare-slider/2/card_puff/spelkoll-vattendelare-nyh-kvm-brnd\">\n    <div class=\"banner-card-top-image\">\n        \n        <div\n          class=\"image-wrapper\"\n          itemscope itemtype=\"http://schema.org/ImageObject\"\n          style=\"\">\n          <meta itemprop=\"url\" content=\"//cdn1.svenskaspel.net/content/cms/images/9a602452-abd4-457e-8e67-5fba11c6b484/productImage/2f23b8cd-96ab-49fd-ad09-b66a78de1451/1.0/210630-Svenska-Spel-A-073.1.jpg\">\n          <picture>\n            <source \n               sizes=\"100vw\"   srcSet=\"//cdn1.svenskaspel.net/content/cms/images/320/auto/9a602452-abd4-457e-8e67-5fba11c6b484/productImage/2f23b8cd-96ab-49fd-ad09-b66a78de1451/1.0/210630-Svenska-Spel-A-073.1.jpg 320w,//cdn1.svenskaspel.net/content/cms/images/480/auto/9a602452-abd4-457e-8e67-5fba11c6b484/productImage/2f23b8cd-96ab-49fd-ad09-b66a78de1451/1.0/210630-Svenska-Spel-A-073.1.jpg 480w,//cdn1.svenskaspel.net/content/cms/images/640/auto/9a602452-abd4-457e-8e67-5fba11c6b484/productImage/2f23b8cd-96ab-49fd-ad09-b66a78de1451/1.0/210630-Svenska-Spel-A-073.1.jpg 640w\" >\n            <img src=\"//cdn1.svenskaspel.net/content/cms/images/9a602452-abd4-457e-8e67-5fba11c6b484/productImage/2f23b8cd-96ab-49fd-ad09-b66a78de1451/1.0/210630-Svenska-Spel-A-073.1.jpg\" alt=\"\"\n              \n              \n              class=\"js-image image\" \n              decoding=\"sync\"\n              \n              width=\"291\"\n              height=\"129\"\n              loading=\"eager\">\n          </picture>\n        </div>\n        \n    </div>\n    <div class=\"banner-card-body padding-left-1 padding-right-1\">\n        <div class=\"margin-bottom-half f-center\">\n            <span class=\"block f-800 f-bold fc-navy margin-0 banner-card-lineheight-compact\">Spela med Spelkoll</span>\n        </div>\n        <div class=\"margin-bottom-half f-center\">\n            <span class=\"block f-content fc-navy margin-0\">Med våra smarta spelansvarsverktyg kan du minska risken för att du spelar mer än du tänkt dig.</span>\n        </div>\n    </div>\n</div>\n<div class=\"banner-card-bottom-container\">\n    <div class=\"padding-lg-left-2 padding-lg-right-2 padding-md-left-1 padding-md-right-1\">\n        <a href=\"https://om.svenskaspel.se/tillsammans-har-vi-spelkoll/\" id=\"9a602452-abd4-457e-8e67-5fba11c6b484\" class=\"btn btn-green btn-block\" data-click-tracking=\"banner-slider/vattendelare-slider/2/card_puff/spelkoll-vattendelare-nyh-kvm-brnd\" rel=\"nofollow noopener noreferrer\" title=\"Läs mer\"><span class=\"btn-link-text\">Läs mer</span></a>\n\n    </div>\n</div>\n</div>\n\n  </div>\n</div>\n<div class=\"js-slider-slide slider-slide card-puff-group col-xs-10 col-sm-7 col-am-4 col-md-3 col-lg-3 col-xl-3\">\n  <div class=\"banner-slider-item\">\n    <div aria-disabled=\"false\" class=\"paper inline-block banner-edit-paper banner-card-paper clip paper-link elevation-100 paper-neutral\"\n><div class=\"banner-card-puff-item  banner-card-puff bg-white f-content\" \n    \n    data-impression=true data-impression-tracking=\"banner-slider/vattendelare-slider/3/card_puff/ungdomsidrott-vattendelare-nyh-kvm-brnd\">\n    <div class=\"banner-card-top-image\">\n        \n        <div\n          class=\"image-wrapper\"\n          itemscope itemtype=\"http://schema.org/ImageObject\"\n          style=\"\">\n          <meta itemprop=\"url\" content=\"//cdn1.svenskaspel.net/content/cms/images/55c73cb3-d146-4f3d-bfdc-ce0555ea3eaa/productImage/a6d07b54-cfe0-4806-925d-95647bb6cfc2/1.0/210701-Svenska-Spel-D-081.1.jpg\">\n          <picture>\n            <source \n               sizes=\"100vw\"   srcSet=\"//cdn1.svenskaspel.net/content/cms/images/320/auto/55c73cb3-d146-4f3d-bfdc-ce0555ea3eaa/productImage/a6d07b54-cfe0-4806-925d-95647bb6cfc2/1.0/210701-Svenska-Spel-D-081.1.jpg 320w,//cdn1.svenskaspel.net/content/cms/images/480/auto/55c73cb3-d146-4f3d-bfdc-ce0555ea3eaa/productImage/a6d07b54-cfe0-4806-925d-95647bb6cfc2/1.0/210701-Svenska-Spel-D-081.1.jpg 480w,//cdn1.svenskaspel.net/content/cms/images/640/auto/55c73cb3-d146-4f3d-bfdc-ce0555ea3eaa/productImage/a6d07b54-cfe0-4806-925d-95647bb6cfc2/1.0/210701-Svenska-Spel-D-081.1.jpg 640w\" >\n            <img src=\"//cdn1.svenskaspel.net/content/cms/images/55c73cb3-d146-4f3d-bfdc-ce0555ea3eaa/productImage/a6d07b54-cfe0-4806-925d-95647bb6cfc2/1.0/210701-Svenska-Spel-D-081.1.jpg\" alt=\"\"\n              \n              \n              class=\"js-image image\" \n              decoding=\"sync\"\n              \n              width=\"291\"\n              height=\"129\"\n              loading=\"eager\">\n          </picture>\n        </div>\n        \n    </div>\n    <div class=\"banner-card-body padding-left-1 padding-right-1\">\n        <div class=\"margin-bottom-half f-center\">\n            <span class=\"block f-800 f-bold fc-navy margin-0 banner-card-lineheight-compact\">Vi stöttar svensk idrott</span>\n        </div>\n        <div class=\"margin-bottom-half f-center\">\n            <span class=\"block f-content fc-navy margin-0\">Vi föddes ur idrottsrörelsen och bidrar till att idrotten utvecklas på alla nivåer, från ungdom till elit.</span>\n        </div>\n    </div>\n</div>\n<div class=\"banner-card-bottom-container\">\n    <div class=\"padding-lg-left-2 padding-lg-right-2 padding-md-left-1 padding-md-right-1\">\n        <a href=\"https://om.svenskaspel.se/sponsring/\" id=\"55c73cb3-d146-4f3d-bfdc-ce0555ea3eaa\" class=\"btn btn-green btn-block\" data-click-tracking=\"banner-slider/vattendelare-slider/3/card_puff/ungdomsidrott-vattendelare-nyh-kvm-brnd\" rel=\"nofollow noopener noreferrer\" title=\"Läs mer\"><span class=\"btn-link-text\">Läs mer</span></a>\n\n    </div>\n</div>\n</div>\n\n  </div>\n</div>\n\n        </div>\n    </div>\n</div>\n","background":"","inverted":false,"centerItems":true,"widgetId":"5980c33e-54f8-474e-933b-94c1c619c27a","isMobile":false},"partial":"widget-banner_slider-index","widget":"banner_slider"}];
