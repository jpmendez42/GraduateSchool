    <script>
        function buildTermsCookie() {
            function getMainDomain() {
                let domain = window.location.hostname
                // remove www. from domain
                if (domain.indexOf("www.") !== -1) {
                    domain = domain.replace("www.", "");
                }
                // check if there is shortcode language subdomain through regex
                // and remove it
                let langSubdomain = domain.match(/^^(?:[a-z]{2}|zh-hans|zh-hant)\./)
                if (langSubdomain) {
                    domain = domain.replace(langSubdomain[0], "");
                }
                // Add a dot in front of the domain if it's not there
                if (domain.indexOf(".") !== 0) {
                    domain = "." + domain;
                }
                return domain;
            }
            var oneYearFromNow = new Date();
            oneYearFromNow.setFullYear(oneYearFromNow.getFullYear() + 1);
            document.cookie = "agreeterms=1;expires=" + oneYearFromNow.toUTCString() + ";path=/" + `;domain=${getMainDomain()}`;
        }
    </script>


