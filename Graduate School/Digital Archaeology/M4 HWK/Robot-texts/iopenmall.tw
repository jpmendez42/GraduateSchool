<div id="gototop">
    <button onclick="topFunction()" id="myBtn"><span>回到頂部</span></button>
</div>

<script>
    function setLoginIcon() {
        var html = '';
        if (mem_uid) {
            html = '<a href="https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=&r_byeurl=iopen&logout=true">會員登出</a>\n';
        } else {
            html = '<a href="/member/index.php?action=member_into_00&r_byeurl=member">註冊</a>／<a href="https://mall.iopenmall.tw/member/index.php?action=member_login">登入</a>\n';
        }
        $("#member_display").html(html);
    }
    $(document).ready(function() {
        if ( $(".history_sidebar > div").hasClass("history_box") ){
        } else {
            $('.history_sidebar').addClass('totopfixed');
        }
    });
    $('.single-item').slick({
        dot: false,
        infinite: true,
        speed: 500,
        slidesToShow: 3,
        slidesToScroll: 1,
        autoplay: false,
        autoplaySpeed: 1000,
        vertical: true,
        verticalSwiping: true,
        arrows: true
    });
</script>

<script>   
    const user_key = mem_uid? mem_uid : "default_user"     

    //抓網址get變數
    function getQueryParams(qs) {
        qs = qs.split("+").join(" ");
        var params = [],
            tokens,
            re = /[?&]?([^=]+)=([^&]*)/g;
        while (tokens = re.exec(qs)) {
            params[decodeURIComponent(tokens[1])] = decodeURIComponent(tokens[2]);
        }
        return params;
    }
    var _GET = getQueryParams(document.location.search); //網址get變數

    $(function() {       
        $(".search_bar_submit").on('click', function() {          
            var action = $("#search_type").val(),
                keyword = $("#keyword").val();
            prod_search(keyword, action);                       
        });       
        $(".search_bar_submit2").on('click', function() {
            var action = $("#search_type2").val(),
                keyword = $("#keyword_top").val();
            prod_search(keyword, action);
        });
        $('#keyword').on('click', function(){
            show_recent_searches()           
        });
        $('#keyword').on('focus', function(){
            show_recent_searches()
        });
        $(document).on('click', function(event) {
            if (!$(event.target).closest('#keyword').length && !$(event.target).closest('#search_history_panel').length) {
                $('#search_history_panel').hide();
            }
        });
        $('#keyword').keypress(function(event) {          
            if (event.keyCode == 13) {
                prod_search($(this).val(), $("#search_type").val());
            }
        });
        $('#keyword_top').keypress(function(event) {           
            if (event.keyCode == 13) {
                prod_search($(this).val(), $("#search_type2").val());
            }
        });
        $('#keyword').keyup(function(event) {
            $("#keyword_top").val($(this).val());
        })
        $('#keyword_top').keyup(function(event) {
            $("#keyword").val($(this).val());
        })
        $('#btn_clear_searches').on('click',function(){
            clear_searches()
        })
        
        // Handle keyword link clicks
        $('.popular-keyword-link').on('click', function() {
            var keyword = $(this).data('keyword');
            save_search(keyword);
            prod_search(keyword, 1);
        });
    });

    function get_recent_searches(){      
        const user_obj = localStorage.getItem(user_key) ? JSON.parse(localStorage.getItem(user_key)) : {}
        const searches = user_obj.recentSearches? user_obj.recentSearches : []
        return searches
    }

    function save_search(term){
        if (!term.trim()) return;        
        let searches = get_recent_searches();        
        searches = searches.filter(search => search !== term);        
        searches.unshift(term);        
        searches = searches.slice(0, 10);              
        localStorage.setItem(user_key, JSON.stringify({"recentSearches": searches}));
    }


    function clear_searches(){
        const searches = localStorage.getItem(user_key)? JSON.parse(localStorage.getItem(user_key)) : {}
        delete searches.recentSearches
        localStorage.setItem(user_key, JSON.stringify(searches));
        $('#search_history_panel').hide();
        $('.search_history_panel_list').empty();               
    }

    function show_recent_searches(){
        const recent_searches = get_recent_searches()
        $('.search_history_panel_list').empty()
        recent_searches.forEach((i)=>{           
            const listItem = document.createElement('li');
            listItem.textContent = i;            
            listItem.addEventListener('click', function() {
                prod_search(i,1);                
            });
            $('.search_history_panel_list').append(listItem)
        })

        if (recent_searches.length){
            $('#search_history_panel').show()
        }        
    }

    function prod_search(Kw, at)
    {
        save_search(Kw); 
        var keyword, action;
        action = (at == 3) ? "web_store" : "store_product_search";
        keyword = (Kw) ? Kw : $("#keyword").val();
        keyword = keyword.replace(/\s/g, '');
        action = (at == 2) ? action+='&type=prod' : action ;
        
        if (keyword != '') {
                        window.location.href = encodeURI('../iopen/index.php?action=' + action + '&prod_keyword=')+encodeURIComponent(keyword);
                    } else {
            alert("請先輸入關鍵字！");
        }
    }


    function headtop_removeScar(uid) {
        $.ajax({
            url: "/iopen/api/api.shopping_cart.php",
            type: "POST",
            dataType: "json",
            data: {
                myAct: "removeScarByUid",
                uid: uid,
                _token: 'c38c38683a5920244950ae500497242c78fe9691383000e21090b28e555ba617b02649081aafdf559b3a182c04b1ca399f6637109bf303863cba4c75f29e31f0'
            },
            success: function(Jdata) {
                if (Jdata.error == 'C00') {
                    top_refresh();
                }
            }
        });
    }

    //版頭fixed
    $(window).scroll(function(){
        if($(this).scrollTop() > 1 && $(document).height() > 600){
            $(".header_top , .top_menu_list_all").addClass("top_fixed");
        } else {
            $(".header_top , .top_menu_list_all").removeClass("top_fixed");
        }
    });

    $(function() {
        //瀏覽展開
        $(".history_title").click(function(){
            $(this).closest(".history_sidebar").toggleClass("history_sidebar_open");
        });
        //版頭購物車展開
        $(".header_cart > div").hover(function(){
            if($(".header_cart_box ul").length > 0 ){
                $(".header_cart_box").stop(true, true).slideToggle(0);
            }
        });
    });

    //版頭廣告展開
    $(function() {
        $(".header_adopen").on('click', function() {
            var num = $(this).attr("value");
            $(".gh_TopAD0" + num).show(500);
        });
        $(".header_adclose").on('click', function() {
            var num = $(this).attr("value");
            $(".gh_TopAD0" + num).hide(500);
        });
    });

    //TOP按鈕
    window.onscroll = function() {
        scrollFunction()
    };
    function scrollFunction() {
        if (document.body.scrollTop > 600 || document.documentElement.scrollTop > 600) {
            document.getElementById("gototop").style.display = "block";
        } else {
            document.getElementById("gototop").style.display = "none";
        }
    }
    $(function() {
        $("#myBtn").click(function() {
            $("html,body").animate({
                scrollTop: 0
            }, 900);
            return false;
        });
    });

    function add_trace_list(prod_uid, prod_no, add_trace_class)
    {
        var mem_uid = "";
        var trace_class = add_trace_class ? add_trace_class : "active";

        //check
        if(mem_uid > 0){
            $.ajax({
                url:"https://mall.iopenmall.tw/iopen/api/api.product_trace_list.php",
                type:"POST",
                dataType:"json",
                data:{
                    uid		: prod_uid,
                    myAct	: "add",
                    prod_no	: prod_no,
                    mem_uid	: mem_uid,
                    remove	: true
                },
                success: function(Jdata){
                    if(Jdata.error == 'C00'){
                        if(Jdata.status == "1"){
                            $(".trace_"+prod_uid).addClass(trace_class);
                            alert("追蹤清單新增成功");
                        }else{
                            alert("追蹤清單移除成功");
                            $(".trace_"+prod_uid).removeClass(trace_class);
                        }
                    }else{
                        /**/
                        alert( '頁面過期，請重新整理！ ( ' + Jdata.error + ' )' );
                    }
                }
            });
        }else{
            $.ajax({
                url: "https://mall.iopenmall.tw/iopen/api/api.product_trace_list.php",
                type: "POST",
                dataType: "json",
                data: {
                    uid		: prod_uid,
                    prod_no	: prod_no,
                    myAct	: "check"
                },
                success: function(Jdata){
                    if( Jdata.error == 'C00' ){
                        window.location.href = encodeURI("https://mall.iopenmall.tw/member/index.php?action=member_login&b_action=index");//Checkmarkx Client DOM XSS
                    }
                }
            });
        }
    }

    //加入購物車
    function add_shopping_cart(pno, psprice, web_byeurl)
    {
        $.ajax({
            url: "https://mall.iopenmall.tw/iopen/api/api.shopping_cart.php",
            type: "POST",
            dataType: "json",
            data: {
                myAct: "check",
                [csrf_key]: csrf_val
            },
            success: function (Jdata) {
                if (Jdata.error == 'C00') {
                    $.ajax({
                        url: '../'+web_byeurl+'/index.php?action=shopping_cart&web_cart_myAct=SHOPPING_CART',
                        type: "POST",
                        dataType: "json",
                        data: 'myAct=ajaxadd&' + csrf_key + '=' + csrf_val + '&scar_count[]=1&prod_no[]=' + pno,
                        success: function (response) {
                            if (response.error == 'C00') {
                                //FB Pixel 加入購物車
                                if (typeof(fb_AddToCart) == 'function') {
                                    pno = pno ? pno : prod_no;
                                    psprice = psprice ? psprice : p_selling_price[index_pno];
                                    fb_AddToCart(pno, response.fbValue, response.fbContents);
                                }
                                alert("成功加入購物車！");// 成功加入購物車！

                                top_refresh(response.scar_no);
                            } else if (response.error.indexOf('E') == 0) {
                                alert(response.error + ': ' + response.err_alert);
                            }
                        }
                    });
                }
            }
        });
    }
</script>

<script>
