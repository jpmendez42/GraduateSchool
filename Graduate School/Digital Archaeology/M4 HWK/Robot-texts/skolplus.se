        <div id="login_form" style="background-color:rgba(0, 0, 0, 0.5);position: fixed;z-index:1000;top:0px;left:0px;bottom:0px;right:0px;visibility:hidden">
        <div style="background-color:white; width:450px;padding:10px;text-align:center;border-radius:12px;border:3px solid black;margin-left:auto;margin-right:auto;margin-top:100px">
            <div class='mini' style='float:right'><a href='#'  onclick="document.getElementById('login_form').style.visibility = 'hidden';">STÄNG</a></div>
            <div style='clear:both'></div>
            <h1>Logga in här</h1>
            <form method="post" action="https://skolplus.se/" style='padding:10px;border:2px solid #3672C3;border-radius:5px;width:280px;margin-left:auto;margin-right:auto;background-color:#DFE8F5;' class="submitForm"  >
                <input name="logaction" type="hidden" value="login" />
                <input style="width:220px;margin:5px;" type="text" placeholder="Användarnamn" name="login_username" id="login_username"/><br/>
                <div class="input-icons">
                    <i class="fa fa-user icon" id="eyes" onmousedown="toggleFaEye(this)"></i>
                    <input style="width:220px;margin:5px;padding-right:30px;" type="password" placeholder="******" id="login_password" name="login_password" onKeyPress="if (event.keyCode==13) document.loginform.submit();"/>
                </div>
                <br>
                <input name="login_remember" type="checkbox" id="login_remember" checked="checked" value='1'>
                <label for="login_remember">Kom ihåg mig på denna dator</label>
                <br/>
                <input class='butn2' style='margin:8px' name="submit" type="submit" value="Logga in" /><br/>
                <a href="https://skolplus.se/login?action=lost"><span class='mini'>Glömt dina inloggningsuppgifter?</span></a><br/>
            </form>

            <br/><br/>eller om du har konto via Skolon<br/>
            <a href="https://skolplus.se/skolon"><img src="https://skolplus.se/images/skolon.png" style="width:185px;" alt="Skolon" /></a><br/>

