.jpg\"},\"hero\":{\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":232485,\"filename\":\"76a6b6txawamsjjgtwc1ue-1920x1080.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-1920x1080.jpg\"},\"w32\":{\"width\":32,\"height\":45,\"mimeType\":\"image/jpeg\",\"filesize\":896,\"filename\":\"76a6b6txawamsjjgtwc1ue-32x45.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-32x45.jpg\"},\"w64\":{\"width\":64,\"height\":91,\"mimeType\":\"image/jpeg\",\"filesize\":2370,\"filename\":\"76a6b6txawamsjjgtwc1ue-64x91.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-64x91.jpg\"},\"w128\":{\"width\":128,\"height\":182,\"mimeType\":\"image/jpeg\",\"filesize\":7974,\"filename\":\"76a6b6txawamsjjgtwc1ue-128x182.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-128x182.jpg\"},\"w384\":{\"width\":384,\"height\":543,\"mimeType\":\"image/jpeg\",\"filesize\":52310,\"filename\":\"76a6b6txawamsjjgtwc1ue-384x543.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-384x543.jpg\"},\"w640\":{\"width\":640,\"height\":906,\"mimeType\":\"image/jpeg\",\"filesize\":121515,\"filename\":\"76a6b6txawamsjjgtwc1ue-640x906.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-640x906.jpg\"},\"w1080\":{\"width\":1080,\"height\":1529,\"mimeType\":\"image/jpeg\",\"filesize\":274390,\"filename\":\"76a6b6txawamsjjgtwc1ue-1080x1529.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-1080x1529.jpg\"},\"w1920\":{\"width\":1920,\"height\":2717,\"mimeType\":\"image/jpeg\",\"filesize\":612621,\"filename\":\"76a6b6txawamsjjgtwc1ue-1920x2717.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-1920x2717.jpg\"},\"w3840\":{\"width\":3840,\"height\":5435,\"mimeType\":\"image/jpeg\",\"filesize\":1548044,\"filename\":\"76a6b6txawamsjjgtwc1ue-3840x5435.jpg\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue-3840x5435.jpg\"}},\"createdAt\":\"2025-10-06T08:17:40.415Z\",\"updatedAt\":\"2025-10-06T08:17:40.415Z\",\"url\":\"/cms/media/76a6b6txawamsjjgtwc1ue.jpg\"},\"id\":\"68e37b1ca0fa6efe289f8111\"}],\"status\":\"published\",\"isVisible\":true,\"startDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"06\",\"customCalendarMonth\":\"10\",\"customCalendarYear\":\"2025\"}},\"beginDate\":\"2025-10-06T00:00:00.001Z\",\"endDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"31\",\"customCalendarMonth\":\"12\",\"customCalendarYear\":\"2035\"}},\"endDate\":\"2035-12-31T00:00:00.001Z\",\"blockContent\":[{\"title\":\"К нашим ежедневным скидкам до -85% мы добавляем до -83% на следующие категории товаров:\",\"type\":\"text\",\"text\":[{\"type\":\"ul\",\"children\":[{\"children\":[{\"text\":\"До -83% на женские блузки и рубашки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -80% на женские платья.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -77% на мужские пиджаки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -74% на женские юбки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -70% на мужские рубашки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -66% на женские брюки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -59% на женские пиджаки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -58% на женские комбинезоны.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -45% на мужские классические брюки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -24% на женские джемперы.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"До -21% на мужские джемперы.\"}],\"type\":\"li\"}]},{\"children\":[{\"text\":\"Ждём вас на охоте за сокровищами в магазинах Familia!\"}]},{\"children\":[{\"text\":\"*Указанные скидки — от первой цены продажи в Familia. Финальная стоимость с учётом всех скидок отображена на розовых ценниках. Цены на товары в отдельных розничных магазинах могут отличаться.\",\"italic\":true}]},{\"children\":[{\"text\":\"**На категориях указан средний размер дополнительной скидки. Скидки на выделенный ассортимент могут достигать -85%.\",\"italic\":true}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"68e37b49a0fa6efe289f8112\"}],\"startPromoDateBlock\":{\"castomCalendarBlock\":{}},\"beginPromoDate\":null,\"endPromoDateBlock\":{\"castomCalendarBlock\":{}},\"endPromoDate\":null,\"sort\":1,\"URLname\":\"osenniy-vygodnyy-shoping-v-familia\",\"publicationLocale\":\"locale_all\",\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"meta\":{},\"createdAt\":\"2025-10-06T08:18:49.206Z\",\"updatedAt\":\"2025-10-06T08:18:50.456Z\"},{\"id\":\"68a472ae8083db6a48e90343\",\"title\":\"Открываем новую Familia в Калининграде!\",\"generalSort\":1001755561600,\"typeName\":\"news\",\"isWebShow\":true,\"isMobileShow\":true,\"domainZone\":[\"ru\"],\"preview\":{\"id\":\"68a472518083db6a48e90193\",\"filename\":\"6idb9d65nehau32nzp5u9n.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":42492,\"width\":564,\"height\":798,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/6idb9d65nehau32nzp5u9n-480x320.webp\",\"width\":480,\"height\":320,\"mimeType\":\"image/webp\",\"filesize\":10348,\"filename\":\"6idb9d65nehau32nzp5u9n-480x320.webp\"},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"url\":\"/cms/media/6idb9d65nehau32nzp5u9n-32x45.webp\",\"width\":32,\"height\":45,\"mimeType\":\"image/webp\",\"filesize\":310,\"filename\":\"6idb9d65nehau32nzp5u9n-32x45.webp\"},\"w64\":{\"url\":\"/cms/media/6idb9d65nehau32nzp5u9n-64x91.webp\",\"width\":64,\"height\":91,\"mimeType\":\"image/webp\",\"filesize\":844,\"filename\":\"6idb9d65nehau32nzp5u9n-64x91.webp\"},\"w128\":{\"url\":\"/cms/media/6idb9d65nehau32nzp5u9n-128x181.webp\",\"width\":128,\"height\":181,\"mimeType\":\"image/webp\",\"filesize\":2144,\"filename\":\"6idb9d65nehau32nzp5u9n-128x181.webp\"},\"w384\":{\"url\":\"/cms/media/6idb9d65nehau32nzp5u9n-384x543.webp\",\"width\":384,\"height\":543,\"mimeType\":\"image/webp\",\"filesize\":12946,\"filename\":\"6idb9d65nehau32nzp5u9n-384x543.webp\"},\"w640\":{\"url\":\"/cms/medi