span> Pro vývojáře </span> </a> </li> <li class="dropdown"> <a title='Společnost'> <span> Společnost </span> </a> <div class="submenu"> <ul> <li > <a href="/cs/o-nas/" title='O nás'> O nás </a> </li> <li> <a href='https://jobs.gopay.com/' title='Volná místa' target="_blank" > <span class="hrInfoTagMenu"> Volná místa <span class="hrInfoTag hrInfoTag--menu"></span> </span> </a> </li> <li > <a href="/cs/pro-media/" title='Pro média'> Pro média </a> </li> <li> <a href='https://www.gopay.com/blog/' title='Blog' target="_blank" > Blog </a> </li> <li> <a href="/cs/kontakt/" title='Kontakt'> Kontakt </a> </li> </ul> </div> </li> </ul> </nav> <div class="actions"> <div class="btn-dropdown login-dropdown"> <form action="/cs/" method="post" id="frm-header-langSwitchForm"> <div class="lang-switcher mobile-visible"> <select name="locale" id="frm-header-langSwitchForm-locale" onChange="this.form.submit()"><option value="cs" selected>CZ</option><option value="sk">SK</option><option value="en">EN</option><option value="pl">PL</option><option value="hu">HU</option></select> </div> <input type="hidden" name="_do" value="header-langSwitchForm-submit"></form> <span class="btn-login"> <a title='Přihlásit se' class="btn btn-transparent btn-s"> Přihlásit se </a> </span> <a href='https://registration.gopay.com/cs/?utm_source=direct&amp;utm_medium=direct' title='Mám zájem' class="btn btn-primary btn-s mobile-visible" > Mám zájem </a> <div class="submenu"> <ul> <li> <a href='https://auth.gopay.com/' title='GOPAY OBCHODNÍ ÚČET' > <span class="ic ic-business"></span> <div class="text"> GOPAY OBCHODNÍ ÚČET <span> Přijímám platby přes platební bránu </span> </div> </a> </li> <li> <a href='https://auth.gopay.com/' title='GOPAY OSOBNÍ ÚČET' > <span class="ic ic-personal"></span> <div class="text"> GOPAY OSOBNÍ ÚČET <span>Platím GoPay</span> </div> </a> </li> </ul> </div> </div> <a href='https://registration.gopay.com/cs/?utm_source=direct&amp;utm_medium=direct' title='Mám zájem' class="btn btn-primary btn-s mobile-hidden" target="_blank" > Mám zájem </a> </div> </div> <!-- Hamburger btn /--> <button class="menu-btn"> <span class="lines"></span> </button> </header> <!-- prettier-ignore --> <main id="main" role="main"> <section class="home-herounit"> <div class="container flex-row"> <div class="col-1 mobile-hidden">&nbsp;</div> <div class="col-6"> <div class="header"> <h1> Maximálně výkonná platební brána </h1> <div class="infoTag infotag--top"> <span> nyní na 12 měsíců <strong>zdarma</strong> </span> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/cesko-plati-kartou-logo.svg" width="28" class="img img-responsive lazy" alt="Česko platí kartou"/> </div> </div> <div class="row m-40"> <ul class="checklist"> <li>18 419 obchodníků</li> <li>10 let na trhu</li> <li>1 brána pro všechny platební metody</li> </ul> </div> <div class="btn-group mobile-hidden"> <a href='https://registration.gopay.com/cs/?utm_source=direct&amp;utm_medium=direct' title="Mám zájem" class="btn btn-primary btn-l"> Mám zájem </a> <a data-href="#zjistit-vice" title="Zjisti více" class="btn btn-secondary btn-l scroll-to"> Zjisti více </a> </div> </div> <div class="col-4"> <video class="lazy video" width="100%" playsinline preload autoplay muted loop> <source data-src="https://site.gopaycdn.com/static/animations/cs/animace_top.mp4" type="video/mp4"> </video> <div class="btn-group btn-group-nowrap mobile-visible"> <a href='https://registration.gopay.com/cs/?utm_source=direct&amp;utm_medium=direct' title="Mám zájem" class="btn btn-primary btn-l"> Mám zájem </a> <a data-href="#zjistit-vice" title="Zjisti více" class="btn btn-secondary btn-l mobile-hidden"> Zjisti více </a> </div> </div> </div> </section> <section class="partners default"> <div class="container text-center"> <a data-href='#dalsi-hodnoceni' title='Další hodnocení' target="_blank" class="scroll-to google-place-rating-link" > <div class="star-rating"> <div class="ic ic-star-filled"></div><div class="ic ic-star-filled"></div><div class="ic ic-star-filled"></div><div class="ic ic-star-filled"></div><div class="ic ic-star-half"></div> </div> <span class="rating-number">4,5</span> <span><div class="ic ic-google-dark"></div></span> </a> <div class="mobile-visible text-center mt-20 mb-30">Na&nbsp;GoPay spoléhají</div> <ul class="img-list list-xs"> <li class="mobile-hidden">Na&nbsp;GoPay spoléhají</li> <li><img data-src="https://site.gopaycdn.com/static/partners/grizly-logo.png" alt="Grizly" class="lazy img-responsive" /></li> <li><img data-src="https://site.gopaycdn.com/static/partners/kytary-logo.svg" alt="Kytary" class="lazy img-responsive" /></li> <li><img data-src="https://site.gopaycdn.com/static/partners/footshop.svg" alt="Footshop" class="lazy img-responsive" /></li> <li><img data-src="https://site.gopaycdn.com/static/partners/ikea-logo.svg" alt="Ikea" class="lazy img-responsive" /></li> <li><img data-src="https://site.gopaycdn.com/static/partners/zalando-logo.svg" alt="Zalando" class="lazy img-responsive" /></li> <li><img data-src="https://site.gopaycdn.com/static/partners/bonami-logo.svg" alt="Bonami" class="lazy img-responsive" /></li> <li class="partners-last-item">a 18 000+ dalších e-shopů</li> </ul> </div> </section> <section class="home-cards"> <div class="container w-80"> <div class="header text-center mobile-text-left" id="zjistit-vice"> <h2 class="h3 mobile-text-24"> Za 10 let jsme zprostředkovali přes 100 milionů plateb </h2> <p class="mobile-text-16"> Díky tomu přesně víme, jak placení zákazníkům co nejvíce zjednodušit. </p> </div> <div id="how-it-works" class="container slider slider-home mt-90"> <div class="column slides"> <div class="switch-content active" data-id="desktop"> <div class="slide active" data-id="how-it-works-0"> <video class="lazy video" width="100%" playsinline preload autoplay muted loop> <source data-src="https://site.gopaycdn.com/static/animations/cs/animace_0.mp4" type="video/mp4"> </video> </div> <div class="slide" data-id="how-it-works-1"> <video class="lazy video" width="100%" playsinline preload autoplay muted loop> <source data-src="https://site.gopaycdn.com/static/animations/cs/animace_1.mp4" type="video/mp4"> </video> </div> <div class="slide" data-id="how-it-works-2"> <video class="lazy video" width="100%" playsinline preload autoplay muted loop> <source data-src="https://site.gopaycdn.com/static/animations/cs/animace_2.mp4" type="video/mp4"> </video> </div> <div class="slide" data-id="how-it-works-3"> <video class="lazy video" width="100%" playsinline preload autoplay muted loop> <source data-src="https://site.gopaycdn.com/static/animations/cs/animace_3.mp4" type="video/mp4"> </video> </div> </div> </div> <div class="column slider-nav"> <span class="separator mb-30"></span> <div class="slider-text-wrap"> <div class="row"> <div class="slider-text"> <div class="item active" data-id="how-it-works-0"> <h3 class="h3 mb-30"> Uložení karty </h3> <p class="text-24"> Brána si zapamatuje kartu pro další nákupy. Díky tomu ušetříte zákazníkům 23 kliknutí navíc. </p> </div> <div class="item" data-id="how-it-works-1"> <h3 class="h3 mb-30"> 55 platebních metod </h3> <p class="text-24"> Platby kartou, Apple Pay, Google Pay nebo online bankovní převody pod jednou střechou. </p> </div> <div class="item" data-id="how-it-works-2"> <h3 class="h3 mb-30"> 8 měn, 19 jazyků </h3> <p class="text-24"> Lokalizovaný platební zážitek pro zákazníky ze všech koutů Evropy. </p> </div> <div class="item" data-id="how-it-works-3"> <h3 class="h3 mb-30"> Správa uložených karet </h3> <p class="text-24"> Získejte přehled nad uloženými kartami díky pojmenování a nastavení barvy karty. </p> </div> </div> </div> <ul class="list-dash" data-id="desktop"> <li class="active"> <a data-href="how-it-works-0" title="Uložení karty"> Uložení karty </a> </li> <li> <a data-href="how-it-works-1" title="55 platebních metod"> 55 platebních metod </a> </li> <li> <a data-href="how-it-works-2" title="8 měn, 19 jazyků"> 8 měn, 19 jazyků </a> </li> <li> <a data-href="how-it-works-3" title="Správa uložených karet"> Správa uložených karet </a> </li> </ul> </div> <div class="row action mt-30"> <a href="/cs/vyhody/" title="Další výhody" class="btn btn-secondary btn-m"> <span class="ic ic-arrow-simple dir-right"></span> Další výhody </a> </div> </div> </div> </div> </section> <section class="home-business"> <div class="container"> <div class="col-6 text"> <div class="header text-highlight-white"> <h2 class="h3"> Denně řešíme online byznys s 18 tisíci obchodníky, jako jste vy. </h2> <p> Díky tomu přesně víme, co od platební brány očekáváte a dokážeme vám to nabídnout. </p> </div> </div> <div class="text-carousel-images"> <div class="item active" data-id="1"> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/macbook/cs/gopay-macbook-1.png" alt="O 10 % více konverzí" class="lazy macbook img-responsive" /> </div> <div class="item" data-id="2"> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/macbook/cs/gopay-macbook-2.png" alt="Opakované platby" class="lazy macbook img-responsive" /> </div> <div class="item" data-id="3"> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/macbook/cs/gopay-macbook-3.png" alt="Vrácení platby" class="lazy macbook img-responsive" /> </div> <div class="item" data-id="4"> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/macbook/cs/gopay-macbook-4.png" alt="Předautorizované platby" class="lazy macbook img-responsive" /> </div> </div> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/dotted-bg-2.png" class="lazy dotted-bg-mobile mobile-visible img-responsive" alt="Denně řešíme online byznys s 18 tisíci obchodníky, jako jste vy." /> <div class="col-5 last carousel-wrap"> <div class="text-carousel"> <div class="inner"> <div data-id="0" class="item"> <h3 class="h5"> O 10 % více konverzí </h3> <p> Díky GoPay získáte až o 10 % více konverzí oproti běžnému platebnímu řešení. Zaintegrujte inline variantu brány, která se zobrazí přímo na stránce vašeho e-shopu. Když lidé platí na stejném místě, kde nakupují, platbu snadněji dokončí. </p> </div> <div data-id="1" class="item"> <h3 class="h5"> Opakované platby </h3> <p> Opakované platby vám umožní přijímat peníze pravidelně a bez práce. Sami si určete, jak často chcete zákazníkovi strhávat peníze a brána se podle toho zařídí. </p> </div> <div data-id="2" class="item"> <h3 class="h5"> Vrácení platby </h3> <p> Potřebujete zákazníkovi vrátit platbu? S funkcí storna to zvládnete hravě. Vrátit můžete i jen část platby. </p> </div> <div data-id="3" class="item"> <h3 class="h5"> Předautorizované platby </h3> <p> Kolísají u vás skladové zásoby a zákazníci si objednávají zboží, které nemáte? Díky funkci předautorizovaných plateb můžete zákazníkovi strhnout platbu jen za to, co můžete skutečně dodat. </p> </div> <div data-id="4" class="item"> <h3 class="h5"> Vyúčtování podle potřeb </h3> <p> Chcete dostávat peníze za přijaté platby tak často, jak potřebujete? Nechte si zasílat platby měsíčně, týdně, nebo klidně i denně. </p> </div> </div> <div class="controls"> <div class="control control-prev" data-carousel="text-carousel"></div> <div class="control control-next" data-carousel="text-carousel"></div> </div> <div class="count"> <span class="count-current">1</span>/<span class="count-total">5</span> </div> </div> </div> </div> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/triangle-ocean-bg.svg" class="lazy triangle-bg" alt="Denně řešíme online byznys s 18 tisíci obchodníky, jako jste vy."/> </section> <section class="home-start-now"> <div class="container"> <div class="header text-center"> <h2 class="h3 text-ocean-gradient mobile-text-24"> Začněte hned a do týdne přijímáte platby </h2> </div> <div class="row m-60"> <div class="flex-container flex-wrap"> <div class="column"> <div class="item"> <div class="text"> <h3 class="h5"> Registrace </h3> <p> Vyplníte informace o sobě </p> </div> <div class="icon"> <span class="ic ic-register"></span> </div> </div> </div> <div class="column columns-2"> <div class="item"> <div class="text"> <h3 class="h5"> Smlouva </h3> <p> Připravíme vám smlouvu k podpisu </p> </div> <div class="icon"> <span class="ic ic-contract"></span> </div> </div> <div class="item"> <div class="text"> <h3 class="h5"> Integrace </h3> <p> Mezitím se můžete pustit do technického napojení </p> </div> <div class="icon"> <span class="ic ic-integration"></span> </div> </div> </div> <div class="column"> <div class="item"> <div class="text"> <h3 class="h5"> Hotovo! </h3> <p> Do týdne můžete začít přijímat platby přes GoPay </p> </div> <div class="icon"> <span class="ic ic-launch"></span> </div> </div> </div> </div> </div> <div class="row text-center"> <div class="infoTag infotag--bottom"> <span> AKCE na 12 měsíců <strong>zdarma</strong> </span> <img data-src="https://site.gopaycdn.com/static/layout/home_b2b/cesko-plati-kartou-logo.svg" width="28" class="img img-responsive lazy" alt="Česko platí kartou"/> </div> </div> <div class="row text-center"> <a href='https://registration.gopay.com/cs/?utm_source=direct&amp;utm_medium=direct' title="Mám zájem" class="btn btn-primary btn-xl"> Mám zájem </a> </div> </div> </section> <section class="testimonials"> <div class="container flex-column-center"> <div class="col-7"> <h2 class="h3 text-center mb-60"> Už 18 419 obchodníků objevilo kouzlo GoPay </h2> </div> </div> <div class="container pb-60 flex-row-center flex-align-center flex-justify-space-between"> <div class="col-5"> <div class="image-carousel"> <div class="images"> <div data-id="0" class="item active"> <img data-src="https://site.gopaycdn.com/static/profiles/dominik-pichal.png" class="lazy img-responsive" alt="dominik-pichal"> </div> <div data-id="1" class="item"> <img data-src="https://site.gopaycdn.com/static/profiles/jan-pils.png" class="lazy img-responsive" alt="jan-pils"> </div> <div data-id="2" class="item"> <img data-src="https://site.gopaycdn.com/static/profiles/david-demian.png" class="lazy img-responsive" alt="david-demian"> </div> <div data-id="3" class="item"> <img data-src="https://site.gopaycdn.com/static/profiles/jan-linhart.png" class="lazy img-responsive" alt="jan-linhart"> </div> <div data-id="4" class="item"> <img data-src="https://site.gopaycdn.com/static/profiles/martin-palencik.png" class="lazy img-responsive" alt="martin-palencik"> </div> <div data-id="5" class="item"> <img data-src="https://site.gopaycdn.com/static/profiles/petr-sigut.png" class="lazy img-responsive" alt="petr-sigut"> </div> </div> <div class="carousel-controls"> <div class="carousel-profiles"> <div data-id="0" class="profile active"> <h4 class="h6"> Dominik Píchal </h4> <small> Zakladatel a majitel Grizly.cz </small> </div> <div data-id="1" class="profile"> <h4 class="h6"> Jan Pils </h4> <small> Zakladatel Kytary.cz </small> </div> <div data-id="2" class="profile"> <h4 class="h6"> David Demian </h4> <small> Head of Payments Tipsport </small> </div> <div data-id="3" class="profile"> <h4 class="h6"> Jan Linhart </h4> <small> ProgresGuru.cz </small> </div> <div data-id="4" class="profile"> <h4 class="h6"> Martin Palenčík </h4> <small> obchodní ředitel, MTBIKER.cz </small> </div> <div data-id="5" class="profile"> <h4 class="h6"> Petr Šigut </h4> <small> CEO Hlídačky.cz </small> </div> </div> <div class="count"> <span class="count-current">1</span>/<span class="count-total">6</span> </div> <div class="controls"> <div class="control control-prev"></div> <div class="control control-next"></div> </div> </div> </div> </div> <div class="text col-6"> <div class="m-3"> <span class="ic ic-quotes"></span> </div> <div class="quotes"> <p data-id="0" class="quote active"> Platební brána byla jednou z prvních služeb, které jsme před 10 lety implementovali – a GoPay s námi zůstává dodnes. <br /><br /> <a href="https://www.gopay.com/blog/grizly-cz-spoleha-na-gopay-uz-10-let-a-chysta-se-na-miliardovy-obrat/" class="case-study-link"> Přečtěte si případovou studii<span class="ic ic-arrow-simple dir-right"></span> </a> </p> <p data-id="1" class="quote"> Díky GoPay je placení kartou hračka. Odpadá zdlouhavé opisování platebních údajů a zákazníkům stačí k zaplacení nákupu jen pár kliknutí. Na konverzích je to hned vidět. <br /><br /> <a href="https://www.gopay.com/blog/ulozeni-karty-pouziva-24-pravidelne-nakupujicich/" class="case-study-link"> Přečtěte si případovou studii<span class="ic ic-arrow-simple dir-right"></span> </a> </p> <p data-id="2" class="quote"> Platobnú bránu od&nbsp;GoPay by&nbsp;som odporučil všetkým obchodníkom, ktorí hľadajú modernú a&nbsp;intuitívnu platobnú bránu, skvelú podporu a&nbsp;prijateľné poplatky. Za&nbsp;mňa jednotka na&nbsp;súčasnom trhu. <br /><br /> <a href="https://www.gopay.com/blog/jak-gopay-pomohl-tipsportu-ziskat-vyssi-konverzi" class="case-study-link"> Přečtěte si případovou studii<span class="ic ic-arrow-simple dir-right"></span> </a> </p> <p data-id="3" class="quote"> Během tří let jsme využili GoPay Financování pětkrát, pokaždé s jinými podmínkami dle aktuálních potřeb. Tento typ flexibility je v e-commerce neocenitelný. <br /><br /> <a href="https://www.gopay.com/blog/jak-progresguru-roste-s-gopay-financovanim-od-lemonero/" class="case-study-link"> Přečtěte si případovou studii<span class="ic ic-arrow-simple dir-right"></span> </a> </p> <p data-id="4" class="quote"> GoPay bych určitě doporučil i dalším e-shopům. Když srovnám naše předchozí zkušenosti, tak je GoPay nejlepší řešení, jakým jsme si historicky prošli. <br /><br /> <a href="https://www.gopay.com/blog/cesta-mtbiker-s-gopay-na-zahranicni-trhy/" class="case-study-link"> Přečtěte si případovou studii<span class="ic ic-arrow-simple dir-right"></span> </a> </p> <p data-id="5" class="quote"> Posílat návštěvníky při placení pryč nedává smysl. GoPay Inline brána zákazníka nikam nepřesměrovává a skvěle konvertuje i na mobilních zařízeních. <br /><br /> <a href="https://www.gopay.com/blog/pres-inline-platebni-branu-dokonci-zakaznici-o-93-vice-plateb/" class="case-study-link"> Přečtěte si případovou studii<span class="ic ic-arrow-simple dir-right"></span> </a> </p> </div> <div class="testimonials-images carousel-images"> <div data-id="0" class="icon active"> <img data-src="https://site.gopaycdn.com/static/partners/grizly-cz-logo.svg" alt="grizly-cz-logo.svg" class="lazy img-responsive" /> </div> <div data-id="1" class="icon"> <img data-src="https://site.gopaycdn.com/static/partners/kytary-cz-logo.svg" alt="kytary-cz-logo.svg" class="lazy img-responsive" /> </div> <div data-id="2" class="icon"> <img data-src="https://site.gopaycdn.com/static/partners/tipsport-logo.svg" alt="tipsport-logo.svg" class="lazy img-responsive" /> </div> <div data-id="3" class="icon"> <img data-src="https://site.gopaycdn.com/static/partners/progressguru-logo.png" alt="progressguru-logo.png" class="lazy img-responsive" /> </div> <div data-id="4" class="icon"> <img data-src="https://site.gopaycdn.com/static/partners/mtbiker-logo.png" alt="mtbiker-logo.png" class="lazy img-responsive" /> </div> <div data-id="5" class="icon"> <img data-src="https://site.gopaycdn.com/static/partners/hlidacky-cz-logo.svg" alt="hlidacky-cz-logo.svg" class="lazy img-responsive" /> </div> </div> </div> </div> </section> <section class="home-press"> <div class="container"> <ul class="img-list"> <li> <a href="https://fintree.cz/rozhovory/gopay-inovace-ve-financnim-svete/" title="GoPay: Inovace ve finančním světě, zakotvená v Jihočeských kořenech" target="_blank"> <img data-src="https://site.gopaycdn.com/static/press/fintree-logo.png" alt="Fintree" class="lazy img-responsive" /> </a> </li> <li> <a href="https://www.lupa.cz/aktuality/prodany-gopay-loni-zdvojnasobil-zisk-i-diky-covidu-je-to-jen-zacatek/" title="Prodaný GoPay loni zdvojnásobil zisk, i díky covidu je to jen začátek" target="_blank"> <img data-src="https://site.gopaycdn.com/static/press/lupa-logo.png" alt="Lupa.cz" class="lazy img-responsive" /> </a> </li> <li> <a href="https://www.penize.cz/ucty-karty/322973-michal-baboucek-z-gopay-svet-bez-hotovosti" title="Michal Babouček z GoPay: Svět bez hotovosti" target="_blank"> <img data-src="https://site.gopaycdn.com/static/press/penize-cz-logo.png" alt="Peníze.cz" class="lazy img-responsive" /> </a> </li> <li> <a href="https://www.idnes.cz/ceske-budejovice/zpravy/gopay-internet-nakupovani-online-platebni-brana-michal-baboucek-pavel-schwarz.A180321_390687_budejovice-zpravy_jbr" title="Banky se nejdřív bály. S GoPay jsme předběhli dobu, říkají podnikatelé" target="_blank"> <img data-src="https://site.gopaycdn.com/static/press/idnes-cz-logo.png" alt="Idnes.cz" class="lazy img-responsive" /> </a> </li> <li> <a href="https://archiv.ihned.cz/c1-66048510-jihocesky-paypal-platebni-branu-gopay-pouzila-vetsina-cechu-aniz-by-to-vedeli-uspesna-firma-sidli-u-ceskych-budejovic-a-do-prahy-se-nechysta" title="Jihočeský PayPal: Platební bránu GoPay použila většina Čechů, aniž by to věděli." target="_blank"> <img data-src="https://site.gopaycdn.com/static/press/hn-logo.png" alt="HN" class="lazy img-responsive" /> </a> </li> </ul> </div> </section> <section id="latest-blog"> <div class="container w-76"> <div class="header text-center"> <h3 class="h4">Novinky z blogu</h3> </div> <div id="latest-blog-items-cta">Přečíst článek</div> <div id="latest-blog-items" class="row mt-60 items-wrap scrollX"></div> </div> </section> </main> <!-- prettier-ignore --> <footer role="contentinfo"> <div class="section-info"> <div class="container flex-row-center flex-justify-space-between"> <div class="position-relative"> <h2 class="h5">Produkty</h2> <nav role="navigation"> <ul class="nav"> <li> <a href="/cs/" title='Platební brána'> Platební brána </a> </li> <li> <a href="/cs/financovani/" title='Financování'> Financování </a> </li> <li> <a href="/cs/platebni-terminaly/" title='Terminály' > Terminály </a> </li> <li> <a href="/cs/osobni-ucet/" title='Osobní účet'> Osobní účet </a> </li> <li> <a href="/cs/pro-municipality/" title='Pro municipality'> Pro municipality </a> </li> <li> <a href='https://demo.gopay.com/' title='Ukázková brána' target="_blank" > Ukázková brána </a> </li> <li> <a href="/cs/srovnani-platebnich-bran/" title='Srovnání platebních bran'> Srovnání platebních bran </a> </li> </ul> </nav> <div class="mobile-visible"> <div class="copyrightLogos"> <img data-src="https://static1.gopaycdn.com/images/logo/PCIDSS.svg" width="65" class="lazy img-grayscale" class="img img-responsive lazy" /> <img data-src="https://static1.gopaycdn.com/images/logo/AMAZON_WEB_SERVICES.svg" width="55" class="lazy img-grayscale" class="img img-responsive lazy" /> <img data-src="https://static1.gopaycdn.com/images/logo/MINISTERSTVO_FINANCI.svg" width="65" class="lazy img-grayscale" class="img img-responsive lazy" /> </div> </div> </div> <div> <h2 class="h5">Společnost</h2> <nav role="navigation"> <ul class="nav"> <li> <a href="/cs/o-nas/" title='O nás'> O nás </a> </li> <li> <a href="/cs/pro-media/" title='Pro média'> Pro média </a> </li> <li> <a href='https://jobs.gopay.com/' title='Volná místa' target="_blank" > <span class="hrInfoTagMenu"> Volná místa <span class="hrInfoTag hrInfoTag--footer"></span> </span> </a> </li> <li> <a href="/cs/kontakt/" title='Kontakt'> Kontakt </a> </li> </ul> </nav> </div> <div> <h2 class="h5">Zdroje</h2> <nav role="navigation"> <ul class="nav"> <li> <a href='https://help.gopay.com/cs/' title='Centrum nápovědy' target="_blank" data-beyond > Centrum nápovědy </a> </li> <li> <a href='https://help.gopay.com/cs/s/g7' title='Ceník a obchodní podmínky' target="_blank" data-beyond > Ceník a obchodní podmínky </a> </li> <li> <a href="https://help.gopay.com/cs/s/mao" target="_blank" title='Reklamační řád' data-beyond > Reklamační řád </a> </li> <li> <a href="https://www.gopay.com/blog/category/pripadove-studie/" target="_blank" title='Případové studie' > Případové studie </a> </li> <li> <a href='https://www.gopay.com/blog/' title='Blog' target="_blank" > Blog </a> </li> <li> <a href='https://doc.gopay.cz/' title='Dokumentace' target="_blank" > Dokumentace </a> </li> <li> <a href='https://help.gopay.com/cs/s/m2I' title='Vnitřní oznamovací systém' target="_blank" > Vnitřní oznamovací systém </a> </li> <li> <a href="/cs/pruvodce-svetem-platebnich-bran/" target="_blank" title='Průvodce světem platebních bran' > Průvodce světem platebních bran </a> </li> </ul> </nav> </div> <div> <h2 class="h5">Rychlý kontakt</h2> <nav> <ul class="nav"> <li> <span class="ic ic-phone"></span> +420 387 685 123 </li> <li> <span class="ic ic-mail"></span> <a href='mailto:gopay@gopay.cz' title='gopay@gopay.cz' target="_blank" > gopay@gopay.cz </a> </li> <li> <span class="ic ic-chat"></span> <a href='https://www.facebook.com/groups/507514693003831/' title='Facebook poradna' target="_blank" > Facebook poradna </a> </li> </ul> </nav> <ul class="socials"> <li> <a href="https://www.facebook.com/gopay.cz" title="GoPay Facebook" target="_blank" ><span class="ic ic-fb"></span></a> </li> <li> <a href="https://twitter.com/gopaycz" title="GoPay Twitter" target="_blank" ><span class="ic ic-twitter"></span></a> </li> <li> <a href="https://www.linkedin.com/company/gopay-s-r-o-/" title="GoPay LinkedIn" target="_blank" ><span class="ic ic-linkedin"></span></a> </li> </ul> </div> <div class="mobile-hidden"> <h2 class="h5">Jazyk</h2> <nav role="navigation"> <ul class="nav"> <li> <a href="/cs/" title='Česky' > Česky </a> </li> <li> <a href="/sk/" title='Slovensky' > Slovensky </a> </li> <li> <a href="/en/" title='English' > English </a> </li> <li> <a href="/pl/" title='Polski' > Polski </a> </li> <li> <a href="/hu/" title='Magyar' > Magyar </a> </li> </ul> </nav> </div> </div> <div class="container"> <div class="systemStatus"> <a href="https://gopay.status.io/" title="Status.io GoPay" target="_blank"> <span class="systemStatus__msg systemStatus__msg--good"> <span class="ic ic-checkmark"></span>Všechny systémy GoPay jsou funkční </span> <span class="systemStatus__msg systemStatus__msg--medium"> <span class="ic ic-alert"></span>Snížená funkčnost některých GoPay systémů </span> <span class="systemStatus__msg systemStatus__msg--bad"> <span class="ic ic-remove"></span>Některé systémy GoPay jsou dočasně nedostupné </span> </a> </div> </div> </div> <div class="copyright"> <div class="container flex-row flex-align-flex-end"> <div class="col-6 flex-row"> <img data-src="https://static1.gopaycdn.com/images/gopay-logo/simple.svg" alt="GoPay s.r.o." width="35" class="lazy mr-10" class="img img-responsive lazy" /> <span class="copyright-claim">&copy; 2025 GoPay Czech odštěpný závod</span> <a href="#" title='Nastavení cookies' class="rules-link" data-cc="c-settings" aria-haspopup="dialog" > Nastavení cookies </a> </div> <div class="col-6 mobile-hidden"> <div class="copyrightLogos"> <img data-src="https://static1.gopaycdn.com/images/logo/PCIDSS.svg" width="108" class="lazy img-grayscale" class="img img-responsive lazy" /> <img data-src="https://static1.gopaycdn.com/images/logo/AMAZON_WEB_SERVICES.svg" width="80" class="lazy img-grayscale" class="img img-responsive lazy" /> <img data-src="https://static1.gopaycdn.com/images/logo/MINISTERSTVO_FINANCI.svg" width="108" class="lazy img-grayscale" class="img img-responsive lazy" /> </div> </div> </div> </div> </footer> <!-- prettier-ignore --> <script>
