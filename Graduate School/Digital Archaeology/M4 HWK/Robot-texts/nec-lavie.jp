    <script>
        (function(){
            $(".cms_news_list_cc_contine38f91287-a792-42ad-aa24-5ad8417b03b5").on("click",".newsItemsC38f91287-a792-42ad-aa24-5ad8417b03b5",function(event){
                event.preventDefault();
                window.open($(this).data("href"));
            })
            let url = "https://s.nec-lavie.jp/news/sortListV2?cate=10&pageSize=5";
            nec_fe_core_tool.ajax.jsonp(url,"callback",null,false).then(function(res){
                let data = res.data.data;
                let html = "";
                res.data.data.forEach(function (item){
                    html += "<tr>";
                    html += "<th>"+item.startTimeStr+"</th>";
                    html += "<td>";
                    html += "<a href='javascript:void(0)' data-href='"+ item.pcUrl + "' data-id='"+ item.id + "' class='newsItemsC38f91287-a792-42ad-aa24-5ad8417b03b5'>";
                    html += item.title;
                    html += "</a>";
                    html += "</td>";
                    html += "</tr>"
                });
                $(".cms_news_list_cc_contine38f91287-a792-42ad-aa24-5ad8417b03b5").html(html);
            })
        })()
    </script>
