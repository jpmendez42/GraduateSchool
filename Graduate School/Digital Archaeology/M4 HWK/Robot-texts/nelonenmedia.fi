        'rcmd.content.background.color' : 'none',
        'rcmd.description.font.color' : 'black',
        'rcmd.cta.background.color' : 'transparent',
        'rcmd.cta.font.color' : 'black'
      }
    });
    rtp('get','rcmd', 'richmedia');
  }
}, false);</script>
