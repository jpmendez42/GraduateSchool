Z"}],"layouts":[]},{"alias":"Vertical_1_2","items":[{"_id":"67d9947d96f3c90013e81155","flags":{"isMain":false},"cover":{"_id":"67d99453ab631600133770e3","media":{"W450":{"url":"https://static.life.ru/ip/unsafe/rs:fill:450:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS8zLzE4LzE0NzIwODQyOTk3NjguNzY3My53ZWJw","name":"s3://life-static/publications/2025/3/18/1472084299768.7673.webp"},"W1200":{"url":"https://static.life.ru/ip/unsafe/rs:fill:1200:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS8zLzE4LzE0NzIwODQyOTk3NjguNzY3My53ZWJw","name":"s3://life-static/publications/2025/3/18/1472084299768.7673.webp"},"W600":{"url":"https://static.life.ru/ip/unsafe/rs:fill:600:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS8zLzE4LzE0NzIwODQyOTk3NjguNzY3My53ZWJw","name":"s3://life-static/publications/2025/3/18/1472084299768.7673.webp"}},"index":5871655,"storage":"FILE_STORAGE_RT_S3","storageBucket":"life-static","posts":[],"name":"1472084299768.7673.webp","url":"https://static.life.ru/publications/2025/3/18/1472084299768.7673.webp","mimeType":"image/webp","size":152752,"fileName":"publications/2025/3/18/1472084299768.7673.webp","width":1200,"height":675,"hash":"dfbd1156da23a001e87594e55ffc51f6f7b9e938","createdAt":"2025-03-18T15:42:11.154Z","updatedAt":"2025-03-18T15:42:11.154Z"},"coverTitle":"","order":5,"visible":true,"description":"Проект «SHOT Проверка» навестил столичные новостройки, возводимые известным холдингом ПИК, и увидел там множество нарушений. Какие дома оставляет компания и как она ведёт свой бизнес.","publicationDate":null,"section":"SPECIAL_PROJECT_SHOT_CHECK","title":"Душ с током, кривые стены и подвалы с водой: Как корпорация ПИК зарабатывает сотни миллиардов на новостройках","type":"SPECIAL_PROJECT_EDITORING","url":"https://life.ru/p/1735037","createdAt":"2025-03-18T15:42:53.924Z","updatedAt":"2025-03-18T15:42:53.965Z"},{"_id":"67a1e073b0812c001ad48c35","flags":{"isMain":false},"cover":{"_id":"67a1e0644e4306001ad6485b","media":{"W450":{"url":"https://static.life.ru/ip/unsafe/rs:fill:450:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS8yLzQvMjcxNzM2NTAwMC44MjEzMDYud2VicA==","name":"s3://life-static/publications/2025/2/4/2717365000.821306.webp"},"W1200":{"url":"https://static.life.ru/ip/unsafe/rs:fill:1200:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS8yLzQvMjcxNzM2NTAwMC44MjEzMDYud2VicA==","name":"s3://life-static/publications/2025/2/4/2717365000.821306.webp"},"W600":{"url":"https://static.life.ru/ip/unsafe/rs:fill:600:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS8yLzQvMjcxNzM2NTAwMC44MjEzMDYud2VicA==","name":"s3://life-static/publications/2025/2/4/2717365000.821306.webp"}},"index":5851988,"storage":"FILE_STORAGE_RT_S3","storageBucket":"life-static","posts":[],"name":"2717365000.821306.webp","url":"https://static.life.ru/publications/2025/2/4/2717365000.821306.webp","mimeType":"image/webp","size":143316,"fileName":"publications/2025/2/4/2717365000.821306.webp","width":1200,"height":675,"hash":"a91043f35542eacba93561948a96061536f1bbfd","createdAt":"2025-02-04T09:39:48.015Z","updatedAt":"2025-02-04T09:39:48.015Z"},"coverTitle":"","order":6,"visible":true,"description":"Агенты «SHOT Проверки» проверили несколько заведений сети Subway и выяснили, что от высоких стандартов качества в них не осталось практически ничего. Почему американский офис больше не беспокоится о безопасности клиентов и своей репутации в России?","publicationDate":null,"section":"SPECIAL_PROJECT_SHOT_CHECK","title":"Жижа на полу, тараканы и обмороки персонала от усталости. Как ведут дела некоторые закусочные Subway","type":"SPECIAL_PROJECT_EDITORING","url":"https://life.ru/p/1724586","createdAt":"2025-02-04T09:40:03.730Z","updatedAt":"2025-02-04T09:40:03.759Z"},{"_id":"6745adef15b8b2001336dd28","flags":{"isMain":false},"cover":{"_id":"6745adda143edc0013158422","media":{"W450":{"url":"https://static.life.ru/ip/unsafe/rs:fill:450:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC8xMS8yNi82MDc1Nzc0OTA0MTAuODkwMS53ZWJw","name":"s3://life-static/publications/2024/11/26/607577490410.8901.webp"},"W1200":{"url":"https://static.life.ru/ip/unsafe/rs:fill:1200:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC8xMS8yNi82MDc1Nzc0OTA0MTAuODkwMS53ZWJw","name":"s3://life-static/publications/2024/11/26/607577490410.8901.webp"},"W600":{"url":"https://static.life.ru/ip/unsafe/rs:fill:600:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC8xMS8yNi82MDc1Nzc0OTA0MTAuODkwMS53ZWJw","name":"s3://life-static/publications/2024/11/26/607577490410.8901.webp"}},"index":5820293,"storage":"FILE_STORAGE_RT_S3","storageBucket":"life-static","posts":[],"name":"607577490410.8901.webp","url":"https://static.life.ru/publications/2024/11/26/607577490410.8901.webp","mimeType":"image/webp","size":447602,"fileName":"publications/2024/11/26/607577490410.8901.webp","width":2953,"height":1661,"hash":"e731787de65d7baba9a900e0423313f827534426","createdAt":"2024-11-26T11:15:38.094Z","updatedAt":"2024-11-26T11:15:38.094Z"},"coverTitle":"","order":7,"visible":true,"description":"Агенты «SHOT Проверки» проводят рейды в магазинах, кафе и ресторанах, фиксируя там различные нарушения. Однако даже бывалые сотрудники проекта были удивлены: сеть магазинов-кафе «Моремания» ведёт дела страшно. Как работает знаменитая сеть рыбных ресторанов?","publicationDate":null,"section":"SPECIAL_PROJECT_SHOT_CHECK","title":"Антисанитария, роллы с кровью. Шокирующая изнанка сети магазинов-кафе «Моремания»","type":"SPECIAL_PROJECT_EDITORING","url":"https://life.ru/p/1706149","createdAt":"2024-11-26T11:15:59.235Z","updatedAt":"2024-11-26T11:15:59.272Z"}],"layouts":[]},{"alias":"SliderLine","items":[{"_id":"6734659a3ca35300138d806f","flags":{"isMain":false},"cover":{"_id":"673465949b6a93001a4d9dfc","media":{"W450":{"url":"https://static.life.ru/ip/unsafe/rs:fill:450:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC8xMS8xMy82OTUzMzI3Nzc1NzQuM