  --h-2-line-height: 72px;
  --h-3-font-size-value: 48;
  --h-3-line-height-value: 56;
  --h-3-font-size: 48px;
  --h-3-line-height: 56px;
  --h-3-medium-font-weight: 700;
  --h-4-font-size-value: 40;
  --h-4-line-height-value: 48;
  --h-4-font-size: 40px;
  --h-4-line-height: 48px;
  --h-5-font-size-value: 32;
  --h-5-line-height-value: 40;
  --h-5-font-size: 32px;
  --h-5-line-height: 40px;
  --h-6-font-size-value: 24;
  --h-6-line-height-value: 32;
  --h-6-font-size: 24px;
  --h-6-line-height: 32px;
  --h-1-font-size-base-md-narrower: 40px;
  --h-1-line-height-base-md-narrower: 48px;
  --h-1-font-size-base-xs-narrower: 40px;
  --h-1-line-height-base-xs-narrower: 48px;
  --h-2-font-size-base-xs-narrower: 32px;
  --h-2-line-height-base-xs-narrower: 40px;
  --h-3-font-size-base-xs-narrower: 24px;
  --h-3-line-height-base-xs-narrower: 32px;
  --h-4-font-size-base-md-narrower: 32px;
  --h-4-line-height-base-md-narrower: 40px;
  --h-4-font-size-base-xs-narrower: 32px;
  --h-4-line-height-base-xs-narrower: 40px;
  --h-5-font-size-base-xs-narrower: 16px;
  --h-5-line-height-base-xs-narrower: 24px;
  --h-6-font-size-base-xs-narrower: 16px;
  --h-6-line-height-base-xs-narrower: 24px;
  /** text on page */
  --body-text-N-light-font-weight: 300;
  --body-text-N-standard-font-weight: 400;
  --body-text-N-medium-font-weight: 500;
  --body-text-N-bold-font-weight: 700;
  --body-text-1-font-size-value: 32;
  --body-text-1-line-height-value: 48;
  --body-text-1-font-size: 32px;
  --body-text-1-line-height: 48px;
  --body-text-2-font-size-value: 24;
