                                </g>
                            </g>

                            <!-- Balken -->
                            <image height="12" width="400" x="7.5px" y="277px" opacity="100%" href="/media/swisslos/eurodreams/eurodreams_ufo_balken.webp"/>

                            <!-- Text -->
                            <text class="text">
