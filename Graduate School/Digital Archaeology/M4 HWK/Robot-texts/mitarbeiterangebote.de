        <div class="header mt-0 custom-header overflow-hidden   bg-dark text-white section-border border-after-black home_header" style="background-image: url(/fileadmin/user_upload/CB_Files/Global/Images/corporate_benefits_home_header_1920x1200.jpg);">
    
    
    <div class="container">
        <div class="row align-items-center mt-8">
            <div class="col-lg-12">
                

    
            <h1 class="display-2 lh-1 mt-13 mt-sm-9 mt-xl-10 mt-sm-0 overflow-width-header">Wir steigern<br>die Zufriedenheit<br>Ihrer Mitarbeiter.</h1>
        



                

    
            <p class="lead-3 fw-400">Vorteilsportale vom europäischen Marktführer.</p>
        



                <div class="gap-y home-btn mt-7">
                    
                        <a href="/fuer-arbeitgeber" title="Für Arbeitgeber" class="btn btn-primary btn-round btn-animate mb-2 mb-md-0 mr-5 text-left">
                            Für Arbeitgeber <span class="btn-arrow"></span>
                            <span class="btn-animation-container"></span>
                        </a>
                    
                    
                        <a href="/fuer-anbieter" title="Für Anbieter" class="btn btn-secondary btn-round btn-animate text-left">
                            Für Anbieter <span class="btn-arrow"></span>
                            <span class="btn-animation-container"></span>
                        </a>
                    
                </div>
            </div>
        </div>

        
            
            

            
                <img class="header-logo" src="/typo3conf/ext/skouz/Resources/Public/images/logos/COR_Stoerer_kostenfrei_DE.svg" alt="COR Stoerer kostenfrei DE" width="150" height="150">
            
            
            
            
            
            
            
            
            
        
    </div>
