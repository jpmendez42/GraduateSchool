tical_poster/3255342201.png\",\"horizontal_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/horizontal_poster/3555966147.jpeg\",\"url\":\"https://ctc.ru/projects/serials/tetya-marta/\"},{\"vertical_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/vertical_poster/1326290085.jpeg\",\"horizontal_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/horizontal_poster/862657792.png\",\"url\":\"https://ctc.ru/projects/serials/molodezhka-novaya-smena/\"},{\"vertical_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/vertical_poster/3882104105.jpeg\",\"horizontal_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/horizontal_poster/1333975222.jpeg\",\"url\":\"https://domashniy.ru/serials/vernaia-zena\"},{\"vertical_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/vertical_poster/1272284321.jpeg\",\"horizontal_poster\":\"https://ctcmedia-static.ctc.ru/uploads/project/horizontal_poster/3174176783.jpeg\",\"url\":\"https://ctc.ru/projects/serials/solntse-more-dva-stvola/\"}]}]}]}]\n"])</script><script>self.__next_f.push([1,"1e:I[8835,[\"980\",\"static/chunks/980-1160d67b4e517498.js\",\"377\",\"static/chunks/377-c1e921aec3da02e1.js\",\"931\",\"static/chunks/app/page-62df044f07bed5e0.js\"],\"List\"]\n"])</script><script>self.__next_f.push([1,"1c:[\"$\",\"div\",null,{\"className\":\"News_news__mx7Ji News_links__XV25u\",\"children\":[\"$\",\"div\",null,{\"className\":\"Container_container__WdcCr Container_M__x6tqn Container_padding__MslNK\",\"children\":[\"$\",\"$L1e\",null,{\"data\":{\"news\":[{\"id\":\"7a0d43e3-d88b-49fe-868f-89a4136e4121\",\"title\":\"27 августа на СТС вернется «Кино в деталях»\",\"date\":\"21 августа\",\"description\":\"\u003cp\u003e\u003cspan\u003eНовый сезон программы Фёдора Бондарчука стартует в День российского кино.\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003eТеперь отвечать на вопросы в студии будут не только звездные гости, но и сам ведущий. Зрителей ждут новости, эксклюзивные материалы и новые рубрики. Например, сценарист Андрей Золотарёв расскажет о знаковых сериалах, а историк моды Анатоль Вовк оценит наряды звезд и костюмы их героев.\u003c/span\u003e\u003cbr\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cimg src=\\\"https://ctcmedia-static.ctc.ru/uploads/news_files/1.png\\\"\u003e\u003c/p\u003e\",\"preview_picture\":\"https://ctcmedia-static.ctc.ru/uploads/news/preview_picture/277006604.png\",\"corner\":\"top-left\"},{\"id\":\"a29073a8-ff36-451d-b689-7f11bce099e2\",\"title\":\"«Остров сокровищ» возвращается на СТС\",\"date\":\"11 августа\",\"description\":\"\u003cp\u003e\u003cspan\u003e31 августа на СТС вернется приключенческое шоу «Остров сокровищ. Знаки судьбы» с ведущим Дмитрием Масленниковым.\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003eВ этот раз за приз в 10 миллионов рублей поборются 65 участников, которым предстоит целый месяц выживать на тайском острове. В их числе – американский бизнесмен, золотодобытчик, модель, боксёр, учитель биологии, почтальон, радиоведущий, медсестра, парикмахер, стоматолог, рэпер, шеф-повар и другие.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cimg src=\\\"https://ctcmedia-static.ctc.ru/uploads/news_files/11.png\\\"\u003e\u003c/p\u003e\",\"preview_picture\":\"https://ctcmedia-static.ctc.ru/uploads/news/preview_picture/3157133780.png\",\"corner\":\"bottom-left\"},{\"id\":\"bc132097-6877-40c6-b14d-2b22b99992fc\",\"title\":\"СТС и Art Pictures Vision начали съемки продолжения сериала «Молодежка. Новая смена».\",\"date\":\"7 июля\",\"description\":\"\u003cp\u003e\u003cspan\u003eВ хоккейном хите вновь сыграют: Влад Канопка, Иван Мулин, Владимир Зайцев, Алёна Бабенко, Игорь Верник и другие актеры.\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003eВ продолжении сериала ставки для «Акул Политеха» повышаются: им предстоит бороться за участие в международном турнире среди университетских команд. Чтобы усилить состав, Казанцев принимает нестандартные решения и даже привлекает в команду девушку-вратаря. Теперь на кону не только борьба за престижный кубок, но и дружба бывших «Медведей», ведь Кисляку и Антипову вновь предстоит стать соперниками.\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cimg src=\\\"https://ctcmedia-static.ctc.ru/uploads/news_files/10.png\\\"\u003e\u003c/p\u003e\",\"preview_picture\":\"https://ctcmedia-static.ctc.ru/uploads/news/preview_picture/3289083124.png\",\"corner\":\"full\"},{\"id\":\"dea385d6-725b-4762-b67a-c9bdf9d84b58\",\"title\":\"В Кисловодске завершились съемки фильма «Папины дочки. В кино».\",\"date\":\"4 июля\",\"description\":\"\u003cp\u003e\u003cspan\u003eПолнометражный фильм продолжит историю семьи Васнецовых: они отправляются на важное торжество в Кисловодск, не подозревая, чем обернётся это путешествие. Над картиной работают телеканал СТС, студия Yellow, Black and White и онлайн-кинотеатр START при поддержке Коммерческого фонда развития кино и анимации. Для фонда «Папины дочки. В кино» стали первым инвестиционным проектом. Премьера в кинотеатрах состоится 30 октября.\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cimg src=\\\"https://ctcmedia-static.ctc.ru/uploads/news_files/9.png\\\"\u003e\u003c/p\u003e\",\"preview_picture\":\"https://ctcmedia-static.ctc.ru/uploads/news/preview_picture/50237201.png\",\"corner\":\"bottom-left\"},{\"id\":\"0be4ea04-e66e-4894-8e9e-2598e4644eb7\",\"title\":\"Реалити-расследования «ЧЕ!» стали победителями премии «Лучшие ESG-проекты России»\",\"date\":\"26 июня\",\"description\":\"\u003cp\u003e\u003cspan\u003e«Заступницы» были отмечены жюри конкурса второй год подряд и стали лучшими в категории «Эффективные институты и программы. Доступ к правосудию и право на судебную защиту». В номинации «Качественное образование. Цифровая грамотность» награду получил проект «Найди по ID». Также жюри отметило реалити «Проверим всё» в категории «Партнерство в интересах устойчивого развития. Укрепление доверия потребителей».\u003c/span\u003e\u003cbr\u003e\u003cbr\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cimg src=\\\"https://ctcmedia-static.ctc.ru/uploads/news_files/41.jpg\\\"\u003e\u003c/p\u003e\",\"preview_picture\":\"https://ctcmedia-static.ctc.ru/uploads/news/preview_picture/1552590926.jpeg\",\"corner\":\"right\"},{\"id\":\"3ff0154c-7473-4afc-99d7-df0b688086f1\",\"title\":\"СТС объявил о запуске приключенческого шоу «Форт. Возвращение легенды»\",\"date\":\"18 июня\",\"description\":\"\u003cp\u003e\u003cspan\u003eВ каждом выпуске шесть звездных героев пройдут испытание временем, страхами и головоломками, а в финале поборются за сокровища Петра Первого. Масштабные съемки впервые пройдут на территории туристско-рекреационного кластера «Остров фортов» после реставрации. Кроме основной локации — форта Император Александр Первый — также задействуют форт Кроншлот, в котором будут спрятаны сокровища.\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003eПремьера шоу состоится этой осенью.\u003co:p\u003e\u003c/o:p\u003e\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cimg src=\\\"https://ctcmedia-static.ctc.ru/uploads/news_files/8.png\\\"\u003e\u003c/p\u003e\",\"preview_picture\":\"https://ctcmedia-static.ctc.ru/uploads/news/preview_picture/1704964638.png\",\"corner\":\"bottom-left\"}],\"meta\":{\"has_next\":true,\"next\":\"ec3311c0-a279-4d62-a7e8-b626fe453f84\"}},\"count\":6,\"isLinks\":true}]}]}]\n"])</script></body></html>