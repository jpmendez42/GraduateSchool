-ss-layer n2-ow n-uc-fMBb54520uLQ" data-sstype="slide" data-pm="default"><div class="n2-ss-layer n2-ow n-uc-P3F6SMUpL9Uo" data-pm="default" data-sstype="content" data-hasbackground="0"><div class="n2-ss-section-main-content n2-ss-layer-with-background n2-ss-layer-content n2-ow n-uc-P3F6SMUpL9Uo-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-veDhxXQEYnda" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-veDhxXQEYnda-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-fdmNeFxUIx6G" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-fdmNeFxUIx6G-inner"><div class="n2-ss-layer n2-ow n-uc-mDqQj3wBY1Yk" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item36" class="n2-font-bb8a8ebbef82965b045c7cc66415e973-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Smaïn Fettem</div></div><div class="n2-ss-layer n2-ow n-uc-KJCMlwvKQxts" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.05,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item37" class="n2-font-53800138ef911fbb422d999cedf39f67-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Un jeune homme qui a le sens du rebond</div></div><div class="n2-ss-layer n2-ow n-uc-YzqT5nWoOr2C" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-hidemobileportrait="1" data-sstype="layer"><div class="n2-ss-item-content n2-ss-text n2-ow-all"><div class=""><p class="n2-font-d90a9b84626b12a176d70e24355b0ebb-paragraph   ">Diplômé de l’UTC en génie biologique en 2023, Smaïn Fettem est actuellement ingénieur de recherche au European Genomic Institue for Diabetes (EGID), un institut international dédié aux recherches sur les diabètes (types 1 et 2). Il travaille sur des outils d’IA destinés à prédire en amont si une personne est susceptible de développer un diabète de type 2. Portrait d’un jeune homme qui, malgré quelques accrocs dans son parcours, a toujours trouvé en lui des ressources pour rebondir.</p>
</div></div></div><div class="n2-ss-layer n2-ow n-uc-RChxOmCcB2mV n2-ss-layer--auto" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bas&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div class="n2-ss-button-container n2-ss-item-content n2-ow n2-font-beb2df7d76a016c9d6eab777c4c577a1-link  n2-ss-nowrap n2-ss-button-container--non-full-width"><a class="n2-style-cdb60a339019064a62b500c95f67f4e3-heading  n2-ow " target="_blank" href="https://interactions.utc.fr/thematiques/regards-sur-le-monde/un-jeune-homme-qui-a-le-sens-du-rebond/"><div><div>Lire</div></div></a></div></div><div class="n2-ss-layer n2-ow n2-ss-layer--auto n2-ss-has-self-align n-uc-S3joWZVQ1q20" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.25,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-S3joWZVQ1q20-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-ydQasmoh95Wg" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'previous');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-ydQasmoh95Wg-inner"><div class="n2-ss-layer n2-ow n-uc-sP1aaSiWeJ0x n2-ss-layer--auto" data-pm="normal" data-sstype="layer"><span class="n2i  n2-ss-859item40 nicomoon nicomoon-arrow-left2 n2-ss-item-content" style="font-size:125%;"></span></div></div></div><div class="n2-ss-layer n2-ow n-uc-Gh0urJlRrfQ5" data-pm="default" role="button" onclick="n2ss.applyActionWithClick(event, 'next');" data-href="#" tabindex="0" data-force-pointer="" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-back