<script type="text/javascript">
//-----------------------------------------
// View slug: uutiset-etusivu - start
//-----------------------------------------
var STORE = 'iotech2';
var store = JSON.parse(localStorage.getItem(STORE) || '{}');
var set = function set(key, value) {

    try {
        store[key] = value;
        localStorage.setItem(STORE, JSON.stringify(store));

        return true;
    } catch (e) {
        console.error(e); // Incognito does this
        return false;
    }
};

var get = function get(key) {
    return store[key] || false;
};

var el = function el(tagName, options) {
    var element = document.createElement(tagName);
    var propMap = ['textContent', 'onclick'];

    Object.keys(options).forEach(function(key) {
        if (propMap.indexOf(key) > -1) {
            element[key] = options[key];
        } else {
            element.setAttribute(key, options[key]);
        }
    });

    return element;
};

var previewCSS = '.view-toggle-element .view-preview { display: flex !important; /* Override inline */  } .view-toggle-element .view-full { display: none; }';

var fullCSS = '';
var styleEl = document.createElement('style');
var setCSS = function setCSS(css) {
    return styleEl.textContent = css;
};
document.body.appendChild(styleEl);

var changeViewTo = function changeViewTo(target) {
  
    switch (target) {
        case 'Esikatselu': {
            setCSS(previewCSS);
            break;
        }

        case 'Täysi': {
            setCSS(fullCSS);
            break;
        }
    }
};

var viewToggleHandler = function viewToggleHandler(e) {
    var choice = get('view');
  
    if (choice === e.target.dataset.title) {
        return; // Don't do anything.
    }

    viewBtns.filter(function(btn) {
        return btn !== e.target;
    }).forEach(function(btn) {
        return btn.classList.remove('active');
    });
    e.target.classList.add('active');

    changeViewTo(e.target.dataset.title);
    set('view', e.target.dataset.title);
};


var viewChoice = get('view');
var defaultChoice = 'Täysi';

var viewToggle = el('div', {
    'class': 'view-toggle'
});
var fullBtn = el('a', {
    role: 'button',
    'class': viewChoice === defaultChoice ? 'fa fa-window-maximize' : 'fa fa-window-maximize',
    'data-title': 'Täysi',
    // title: 'Näytä kokonaiset uutiset', // I don't understand why this breaks it, both data-title and title cant be present
    onclick: viewToggleHandler
});
var previewBtn = el('a', {
    role: 'button',
    'class': viewChoice !== defaultChoice ? 'fa fa-list-ul' : 'fa fa-list-ul',

    'data-title': 'Esikatselu',
    // title: 'Näytä uutisten esikatselu',
    onclick: viewToggleHandler
});
var viewBtns = [fullBtn, previewBtn];

viewToggle.appendChild(fullBtn);
viewToggle.appendChild(previewBtn);

var saveFilterChoice = function saveFilterChoice(e) {
    var filter = e.target;
    var choice = filter.textContent;
    var view = get('view');
  
    if (get('filter') !== choice) {
        set('filter', choice);

        changeViewTo(view);
    }
};

var filterContainer = document.querySelector('.post-body .filtteri');
var filters = filterContainer.querySelectorAll('.radios-taxonomies-title');

window.addEventListener('click', function(e) {
    if (e.target.classList.contains('radios-taxonomies-title')) {
        saveFilterChoice(e);
    }
})

var filterChoice = get('filter');
[].forEach.call(filters, function(filter) {
    if (filterChoice) {
        if (filter.textContent === filterChoice) {
            // filter.previousElementSibling.setAttribute('checked', true); // We need to trigger the event :(
          setTimeout(function() {
                        filter.click();

          }, 100);
        } else {
            filter.previousElementSibling.removeAttribute('checked');
        }
    }
});

if (viewChoice) {
    changeViewTo(viewChoice);
}

[].forEach.call(viewBtns, function(btn) {
    var choice = viewChoice || defaultChoice;
    if (btn.dataset.title === choice) {
        btn.classList.add('active');
    }
});

document.querySelector('#post-65 .col-lg-8').insertAdjacentElement('afterbegin', viewToggle); // work please
//-----------------------------------------
// View slug: uutiset-etusivu - end
//-----------------------------------------
</script>
