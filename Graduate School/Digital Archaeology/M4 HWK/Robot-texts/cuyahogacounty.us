    <div id="ContentPlaceholderFeaturedItems_TB5860D3B012_Col01" class="sf_colsIn col-lg-4  p-3  d-flex align-items-stretch" data-sf-element="Column 2" data-placeholder-label="Column 2">


<div>
  <div class="card shadow-lg mt-1 h-100">
      <img class="card-img-top img-fluid" src="https://cuyahogacms.blob.core.windows.net/home/images/default-source/countynews/snap-medicaid424797073.jpg?sfvrsn=a5c7703e_0" title="Snap-medicaid" alt="Five people sitting at a table in front of an audience and a man standing doing sign language." width=600 height=185 />
    <div class="card-body">
        <h5 class="card-title">Changes to Medicaid and SNAP</h5>
              <p class="card-text">County leaders and community partners shared information about federal changes to benefits and impact on residents.</p>

      <a class="stretched-link" href="https://www.youtube.com/watch?v=Qt_61ip-NFQ" aria-label='Changes to Medicaid and SNAP'>Watch the recording </a>

    </div>
  </div>
</div>
