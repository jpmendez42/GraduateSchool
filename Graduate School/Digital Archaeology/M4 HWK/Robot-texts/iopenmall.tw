<script>

    var menu = [];
                        menu.push("家樂福");
                                menu.push("鮮拾");
                                menu.push("利捷維");
                                menu.push("雅漾");
                                menu.push("美麗日記");
                                menu.push("市集樂購");
                                menu.push("星巴克");
                                menu.push("德記洋行");
            
    if(menu.length == 0){
        $(".it905-default").hide()

    }else if(menu.length == 1){
        $(".swiper-button").hide();
    }

    var swiper = new Swiper('.swiper-container_30467', {
        autoHeight: true,
        navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev'
        },
        pagination: {
            el: '.swiper-pagination',
            clickable: true,
            renderBullet: function (index, className) {
            return '<div class="' + className + '">' + (menu[index]) + '</div>';
            }
        },
        simulateTouch: false
    });

    $(document).ready(function() {
        var style = $('<style>.it905-30467 .swiper-pagination-bullet-active:after { border-color: ' + '#6b6a6a' +' transparent transparent transparent;; }</style>');
        $(".it905-30467 .swiper-pagination-bullet-active")
            .css({"background-color":"#6b6a6a"}).append(style)
            .siblings().css({"background-color":"#6b6a6a"});
    });

    $(".it905-30467 .swiper-pagination-bullet").click(function() {
        if ($(this).hasClass('swiper-pagination-bullet-active')) {
            $(this).css({"background-color":"#6b6a6a"});
            $(this).siblings().css({"background-color":"#6b6a6a"});
        } else {
            $(this).css({"background-color":"#6b6a6a"});
            $(this).siblings().css({"background-color":"#6b6a6a"});
        }
    });

    $(".it905-30467 .swiper-button-next").click(function() {
        $(this).siblings('.tabTit').children('.swiper-pagination-bullet').siblings().css({"background-color":"#6b6a6a"});
        $(this).siblings('.tabTit').children('.swiper-pagination-bullet-active').css({"background-color":"#6b6a6a"});
    });

    $(".it905-30467 .swiper-button-prev").click(function() {
        $(this).siblings('.tabTit').children('.swiper-pagination-bullet').siblings().css({"background-color":"#6b6a6a"});
        $(this).siblings('.tabTit').children('.swiper-pagination-bullet-active').css({"background-color":"#6b6a6a"});
    });

$(function(){
    let wpitem_30467_list = [];
    document.querySelectorAll(".iopen-mall-item-container[data-wpitem='30467'] .swiper-wrapper .swiper-slide[data-num]").forEach(el => {
        observerForViewItemList.observe(el);
        let num = $(el).data('num');
        wpitem_30467_list.push(num);
    });
