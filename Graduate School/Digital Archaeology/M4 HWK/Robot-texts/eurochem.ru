<style>
    /* */ 
.kt {
  position: relative;
  width: 100%;
  margin-bottom: 3%;
  background-position: center center;
}

.kt img {
  filter: brightness(50%); /* Old Value 90% */
  width: 100%;
  height: 900px;
  object-fit: cover;
}

.kt-viev {
  display: flex;
  flex-direction: column;
  position: absolute;
  top: 200px;
  left: 15%;
  width: 755px;
}

.kt-viev h1, .kt-text, .kt-button p {
  color: #fff;
  font-size: 54px;
  line-height: 54px;
  font-family: 'Proxima Nova',Arial,sans-serif;
  font-weight: 600;
  padding-bottom: 20px;
}

.kt-text {
  font-size: 22px;
  line-height: 26px;
  font-weight: 400;
  opacity: 0.8;
}

.kt-button {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  width: 270px;
  height: 51px;
  background-color: #FDC600;
  margin-top: 30px;
}

.kt-button p {
  font-size: 18px;
  line-height: 22px;
  font-weight: 400;
  color: #333333;
  margin-left: 20px;
  padding-bottom: 0;
  margin-bottom: 0;
}

.kt-viev a {
  display: block;
  width: 270px;
  height: 51px;
}

@media (max-width: 1145px) {
  .kt-viev {
    left: 12px;
  }
}

@media (max-width: 770px) {
  .kt-viev {
    width: 560px;
    text-align: center;
    left: 50%;
    margin-left: -280px !important;
  }

  .kt-viev a {
    margin: 0 auto;
  }
}

@media (max-width: 565px) {
  .kt-viev h1 {
    font-size: 32px;
    line-height: 32px;
  }

  .kt-text {
    font-size: 18px;
    line-height: 21px;
  }

  .kt-viev {
    width: 320px;
    margin-left: -160px !important;
  }
}

.imgFooter {
    width: 46px;
    height: 46px;
}
 /* */

/* */
.footer-logo img {
    padding-right: 75px;
}

.logo img {
    padding-right: 75px;
}

@media (max-width: 639px) {
    .footer-logo img {
        padding-right: 0;
    }

    .logo img {
        padding-right: 0;
    }
}
/* */

/* */
.panel-nav__my {
