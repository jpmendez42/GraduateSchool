    <script type="text/partytown">
    function loadDecibelInsightScript() {
        (function (d, e, c, i, b, el, it) {
            d._da_ = d._da_ || [];
            _da_.oldErr = d.onerror;
            _da_.err = [];
            d.onerror = function () {
                _da_.err.push(arguments);
                if (_da_.oldErr) {
                    _da_.oldErr.apply(d, Array.prototype.slice.call(arguments));
                }
            };

            d.DecibelInsight = b;
            d[b] = d[b] || function () {
                (d[b].q = d[b].q || []).push(arguments);
            };

            var isProd = window.location.hostname === "www.bajajfinserv.in";
            var scriptURL = isProd
                ? "https://cdn.decibelinsight.net/i/14099/992937/di.js"
                : "https://cdn.decibelinsight.net/i/14099/2441757/di.js";

            el = e.createElement(c);
            it = e.getElementsByTagName(c)[0];
            el.async = 1;
            el.src = scriptURL;
            it.parentNode.insertBefore(el, it);
        })(window, document, 'script', '', 'decibelInsight');
    }
    window.addEventListener('DOMContentLoaded', function () {
        loadDecibelInsightScript();
    });
</script>
    <script type="text/javascript">
    window.addEventListener('DOMContentLoaded', function () {
        (function () {
            var wzrk = document.createElement('script');
            wzrk.type = 'text/javascript';
            wzrk.async = true;
            wzrk.src = ('https:' == document.location.protocol ? 'https://d2r1yp2w7bby2u.cloudfront.net' : 'http://static.clevertap.com') + '/js/clevertap.min.js';
            var s = document.getElementsByTagName('script')[0];
            s.parentNode.insertBefore(wzrk, s);
        })();
    });
    var _Utm_details_id = "";
    var queryparameters2 = window.location.search;
    if (queryparameters2.includes("utm_source")) {
        var utmobj = {
            utm_source: queryparameters2,
            time: new Date().getTime()
        }
        localStorage.setItem("utmsource", JSON.stringify(utmobj));
    }
    var utmsource = (localStorage.getItem("utmsource") !== null) ? localStorage.getItem("utmsource") : '';
    _Utm_details_id = "R9K-97K-8Z6Z";
    var clevertap = { event: [], profile: [], region: 'in1', account: [], onUserLogin: [], notifications: [], privacy: [] };
    const envPageType = document.querySelector('.global-dataset-wrapper');
    const page_Type = envPageType?.getAttribute('data-pageType') || '';
    clevertap.account.push({ "id": _Utm_details_id }); clevertap.privacy.push({ optOut: false });
    clevertap.privacy.push({ useIP: false });
    function ClevertapEventOnLoad() {
        if (decodeURIComponent(localStorage.getItem("WZRK_G")).slice(1, -1) != null) {

            clevertap.event.push("page_view", { "Page name": document.URL, "page_type": page_Type });
            clevertap.notifications.push({
                "titleText": "Would you like to receive Push Notifications?",
                "bodyText": "We promise to only send you relevant content and give you updates on your transactions",
                "okButtonText": "Allow",
                "rejectButtonText": " I'll do it later",
                "okButtonColor": "#F28046",
                "hidePoweredByCT": 'true',
                "askAgainTimeInSeconds": 259200,
                "serviceWorkerPath": "/service-worker.js"
            });
        } else {
            setTimeout(ClevertapEventOnLoad, 1000);
        }

    }
    ClevertapEventOnLoad();
