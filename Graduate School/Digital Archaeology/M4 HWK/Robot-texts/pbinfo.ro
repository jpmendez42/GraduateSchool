<script>
	(() => {
        'use strict'

        const storedTheme = localStorage.getItem('theme')

        const getPreferredTheme = () => {
            if (storedTheme)
                return storedTheme
            return 'light'
        }

        const setTheme = function (theme) {
            document.documentElement.setAttribute('data-bs-theme', theme)
        }

        setTheme(getPreferredTheme())

        const showActiveTheme = theme => {
            if(theme == 'dark')
                document.getElementById('darkThemeSwitch').checked = true
        }

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            if (storedTheme !== 'light' || storedTheme !== 'dark') {
                setTheme(getPreferredTheme())
            }
        })

        window.addEventListener('DOMContentLoaded', () => {
            showActiveTheme(getPreferredTheme())
            document.getElementById('darkThemeSwitch').addEventListener('change', () => {
                const theme = document.getElementById('darkThemeSwitch').checked ? 'dark' : 'light'
                localStorage.setItem('theme', theme)
                setTheme(theme)
                showActiveTheme(theme)

				const colorModeEvent = new CustomEvent('bootstrapColorModeChanged', {
					detail: {
						mode: document.getElementById('darkThemeSwitch').checked ? 'dark' : 'light'
					}
				});

				window.dispatchEvent(colorModeEvent);
            })
        })
    })()
</script></div>
