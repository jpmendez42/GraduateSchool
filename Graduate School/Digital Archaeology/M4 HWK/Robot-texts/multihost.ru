<template id="domain_item_template">
    <div data-target="domain_item" data-domain="">
    <div class="domain-search-result flex aic jcsb">
        <div class="domain-search-result-info">
            <div class="domain-search-result-info-top flex aic">
                <div class="domain-search-result_title" data-target="domain_name"></div>
                <div class="domain-search-result_discount" data-target="domain_discount" style="display:none"></div>
            </div>
            <div class="domain-sr-prices">
                <div class="domain-search-result-price_old" data-target="domain_old_price"></div>
                <div class="domain-search-result-price_current" data-target="domain_price"></div>
                <a href="javascript:void(0)" class="link"  data-target="domain_link_whois" onclick="toggleWhois();return false;">Whois</a>
                
            </div>
            <div class="domain-search-result-status" data-target="domain_status"></div>
            <div class="domain-search-result-help pos-relative d-none" data-target="domain_is_free">
                <span>Можно бесплатно</span>
                <div class="domain-search-result-help_text">
                    Можно бесплатно при оплате Виртуального хостинга или Виртуального сервера (VPS) на 1 год                </div>
            </div>
        </div>
        <div class="domain-search-result-actions flex aic skeleton-loading">
            <div class="domain-search-result-price_old" data-target="domain_old_price"></div>
            <div class="domain-search-result-price_current" data-target="domain_price"></div>
            <button class="domain-search-result-btn" data-target="domain_action_button"></button>
            <a href="javascript:void(0)" class="link"  data-target="domain_link_whois" onclick="toggleWhois(this);return false;">Whois</a>
            
        </div>
    </div>
    <div class="domain-whios-info" data-target="domain_whios_info"></div>
    </div>
    
