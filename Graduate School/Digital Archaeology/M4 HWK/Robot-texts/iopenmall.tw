.iopen-footer .iopen-footer-list-mob > ul > li > .footer_menutitle_mob > span.inner_arrow-up{ background: url(/iopen/templates/web_style/iopen_2/color_1/inner_arrow-up.svg) right center no-repeat; background-size: 10px;}
