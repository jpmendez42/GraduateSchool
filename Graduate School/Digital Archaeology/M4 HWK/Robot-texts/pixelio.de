<section id="helix-faq" class="helix-faq pt-60 sm-pt-30 pb-130 sm-pb-60">
    <div class="container">
        <div class="row section-title-area">
            <div class="col-md-12">
                <div class="section-title mb-70 sm-mb-40">
                    <h3>Get Help</h3>
                    <h2>Frequently Asked Questions</h2>
                </div>
            </div>
        </div>
        <div class="row faq-area">
            <div class="col-md-12">
                <div class="accordion" data-multiple-open="true" data-keep-open="true" data-open-item="3" data-speed="300" data-icons='["fa-plus","fa-minus"]'>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="accordion-item">
                                <div class="accordion-header" data-target="#content1">Are the images really free? <i class="fa fa-plus"></i></div>
                                <div class="accordion-content" id="content1">
                                    Yes, the images are free, but the usage depends on the image license. Photographers can select 3 types of license to share their photos
                                </div>
                            </div>
                            <div class="accordion-item">
                                <div class="accordion-header" data-target="#content2">Can I upload other photos than my own? <i class="fa fa-plus"></i></div>
                                <div class="accordion-content" id="content2">
                                    Yes, the images are free, but the usage depends on the image license. Photographers can select 3 types of license to share their photos
                                </div>
                            </div>
                            <div class="accordion-item">
