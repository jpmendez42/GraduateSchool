    -webkit-line-clamp: 2;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.5;
    max-height: calc(2* 1.5em);
}

 #heading-rotate {
    position: relative;
    overflow: hidden;
    display: inline;
	  color: #20827C;
	  vertical-align: bottom;
}

.word {
    position: absolute;
    opacity: 0;
    top: -2px;
    left: 15px;
    white-space: nowrap;
    transition: opacity 0.5s, transform 0.5s;
    width: 100%;
}

.word.visible {
    opacity: 1;
    transform: translateY(0);
}

.word.enter {
    opacity: 0;
    transform: translateY(100%);
}

.word.exit {
    opacity: 0;
    transform: translateY(-100%);
}

