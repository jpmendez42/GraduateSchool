        <div class="two-col-content-shape__image-wrapper two-col-content-shape__shape-height-small overflow-hidden">
          <div class="left-0 md:left-5 xl:-right-44 two-col-content-shape__image-wrapper-width-overlap relative md:absolute">
            <picture>
              
              <source
                srcset="
                  https://websupport.se/app/uploads/sites/6/bis-images/30059/BUSINESS-MAIL_1200x1200-1-1095x922.png 2x,
                  https://websupport.se/app/uploads/sites/6/bis-images/30059/BUSINESS-MAIL_1200x1200-1-730x615.png
                "
                media="(min-width: 480px)"
              />
              
              <img decoding="async"
                src="https://img.websupport.se/spio/ret_img,q_cdnize,to_auto,s_webp:avif/websupport.se/app/uploads/sites/6/bis-images/30059/BUSINESS-MAIL_1200x1200-1-480x420.png"
                width="420"
                height="420"
