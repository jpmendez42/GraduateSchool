		<style>
    .it902-default .it902-item-title{ display: flex; color: white; background-color: var(--pic-orange); padding: 10px 10px 10px 10px; align-items: center; justify-content: space-between; border-top-left-radius: 10px; border-top-right-radius: 10px;}
    .it902-default_30461 .it902-item-title h3{ font-size: 22px; background: url(css/images/pic/icon_clock.svg) left center no-repeat; padding-left: 40px; background-size: 30px;}
    .it902-default .it902-item-title .it902-right-tabs{ display: flex; align-items: center;}
    .it902-default .it902-item-title .it902-time-box{ display: flex; align-items: center; margin-right: 10px; font-size: 20px; line-height: 30px;}
    .it902-default .it902-item-title .it902-time-box span{ display: block; min-width: 30px; padding:0 5px; height: 30px; text-align: center; border-radius: 7px;background-color: var(--pic-color-grey-100);}
    .it902-default .it902-item-title .it902-time-box span:nth-child(1){ margin-left: 10px;}
    .it902-default .it902-tab-pdbox{ display: block;  width:100%; padding: 30px 20px;}

    .it902-default .it902-item-content{ background:#fff6e7; border-bottom-left-radius: 10px; border-bottom-right-radius: 10px;}
    .it902-default input { display: none;}
    .it902-default label { font-size: 17px; color: var(--pic-orange); font-weight: 500; display: inline-block; cursor: pointer; min-width: 155px; text-align: center; background: #fff; margin-left:6px; line-height: 48px; border-radius: 10px;}
    .it902-default input:checked+label { background: var(--pic-light-orange); color:white;}

    .it902-default .it902-item-content .owl-carousel .owl-nav .owl-next{ right: -45px;}
    .it902-default .it902-item-content .owl-carousel .owl-nav .owl-prev{ left: -45px;}


    @media screen and (max-width: 960px) {
        .it902-default .it902-item-title{ display: block;}
        .it902-default .it902-item-title h3{ font-size: 17px; line-height: 30px;}
