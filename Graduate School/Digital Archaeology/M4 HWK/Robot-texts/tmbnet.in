			function reveal() {
				var reveals = document.querySelectorAll(".reveal");
				for (var i = 0; i < reveals.length; i++) {
					var windowHeight = window.innerHeight;
					var elementTop = reveals[i].getBoundingClientRect().top;
					var elementVisible = 50;
					if (elementTop < windowHeight - elementVisible) {
					  reveals[i].classList.add("active");
					} else {
					  reveals[i].classList.remove("active");
					}
				}
			/*var revealsFooter = document.querySelectorAll(".reveal-footer");
				var fixed = document.querySelectorAll(".fixed");
				
				for (var i = 0; i < revealsFooter.length; i++) {
					var windowHeight = window.innerHeight;
					var elementTop = revealsFooter[i].getBoundingClientRect().top;
					var elementVisible = 50;
					if (elementTop < windowHeight - elementVisible) {
					  modal.style.display = "none";
					  fixed[i].classList.remove("hide");
					  fixed[i].classList.add("flip-img");
					} else {
					  fixed[i].classList.add("hide");
					}
				} */
			}
			
			function revealload() {
				var reveals = document.querySelectorAll(".revealmenu");
				for (var i = 0; i < reveals.length; i++) {
					var windowHeight = window.innerHeight;
					var elementTop = reveals[i].getBoundingClientRect().top;
					var elementVisible = 150;
					if (elementTop < windowHeight - elementVisible) {
					  reveals[i].classList.add("active");
					} else {
					  reveals[i].classList.remove("active");
					}
				}
			}
			function ShowSocialMediaIcon() {
				var element = document.getElementById("socialnetworkicons");
				element.classList.remove("hide");
				//element.classList.add("move-img-top");
				var shwbtn = document.getElementById("showbutton");
				shwbtn.classList.add("hide");
				var closebtn = document.getElementById("closebutton");
				closebtn.classList.remove("hide");
			}
			function HideSocialMediaIcon() {
				var element = document.getElementById("socialnetworkicons");
				element.classList.add("hide");
				var shwbtn = document.getElementById("closebutton");
				shwbtn.classList.add("hide");
				var closebtn = document.getElementById("showbutton");
				closebtn.classList.remove("hide");
			}
			var txt = document.getElementById("chatbot__submit").disabled;
			window.addEventListener("scroll", reveal);
			window.addEventListener("load", reveal);
			window.addEventListener("load", revealload);
		</script>
