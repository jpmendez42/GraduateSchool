layer n2-ow n-uc-71nbJKiiCYzD" data-sstype="slide" data-pm="default"><div class="n2-ss-layer n2-ow n-uc-BQiYThu3KZa6" data-pm="default" data-sstype="content" data-hasbackground="0"><div class="n2-ss-section-main-content n2-ss-layer-with-background n2-ss-layer-content n2-ow n-uc-BQiYThu3KZa6-inner"><div class="n2-ss-layer n2-ow n2-ss-layer--block n2-ss-has-self-align n-uc-1YCvgi9vG0iP" data-pm="normal" data-sstype="row"><div class="n2-ss-layer-row n2-ss-layer-with-background n-uc-1YCvgi9vG0iP-inner"><div class="n2-ss-layer-row-inner "><div class="n2-ss-layer n2-ow n-uc-VogUfi3rOfKD" data-pm="default" data-sstype="col"><div class="n2-ss-layer-col n2-ss-layer-with-background n2-ss-layer-content n-uc-VogUfi3rOfKD-inner"><div class="n2-ss-layer n2-ow n-uc-WZblSa4XSKxy" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item99" class="n2-font-bb8a8ebbef82965b045c7cc66415e973-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">Delphine Kervarec-Vicq</div></div><div class="n2-ss-layer n2-ow n-uc-mbwD3uXoO0Y8" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.05,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-sstype="layer"><div id="n2-ss-859item100" class="n2-font-53800138ef911fbb422d999cedf39f67-hover   n2-ss-item-content n2-ss-text n2-ow" style="display:block;">« Une vie professionnelle, ça se construit pas à pas »</div></div><div class="n2-ss-layer n2-ow n-uc-dseSNDwfwLc0" data-pm="normal" data-animv2="{&quot;basic&quot;:{&quot;in&quot;:{&quot;type&quot;:&quot;basic&quot;,&quot;name&quot;:&quot;Bottom fade&quot;,&quot;keyFrames&quot;:[{&quot;delay&quot;:0.15,&quot;opacity&quot;:0,&quot;y&quot;:&quot;-20&quot;}]}}}" data-hidemobileportrait="1" data-sstype="layer"><div class="n2-ss-item-content n2-ss-text n2-ow-all"><div class=""><p class="n2-font-d90a9b84626b12a176d70e24355b0ebb-paragraph   ">Delphine Kervarec-Vicq, 50 ans, est directrice de la sûreté de fonctionnement au sein du groupe Valeo. Diplômée de l’UTC en 1996 en génie mécanique, elle estime avoir un métier à impact aujourd’hui dans ce domaine de la « safety » où l’argumentation a une place importante.</p>
