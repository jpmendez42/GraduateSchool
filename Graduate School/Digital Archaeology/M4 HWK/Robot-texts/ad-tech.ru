                          src="https://a-static.sber.ru/assets/images/results-counter.png"
                          srcset="https://a-static.sber.ru/assets/images/results-counter@2x.png 2x">
                      </picture>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
