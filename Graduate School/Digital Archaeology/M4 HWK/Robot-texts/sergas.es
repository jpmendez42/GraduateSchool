<script type="text/javascript">
    $(document).ready(function () {
        //Corrixir ligazóns baleiras no menú para accesibilidade
        $(".slicknav_collapsed.slicknav_parent > a").each(function () {
            var textoMenu = $(this).find("a:first-of-type").text();
            $(this).attr("aria-label", textoMenu);
        });

        //engádese tabindex=0 por temas de accesibilidade no bloque da caixa de busca
        $("div[role='textbox'].home-search").each(function () {
            $(this).attr("tabindex", "0");
        });
        $("div[role='textbox'].searchbox").each(function () {
            $(this).attr("tabindex", "0");
        });

        var attrs = {};
        $.each($(".slicknav_collapsed.slicknav_parent > a > a")[0].attributes, function (idx, attr) {
            attrs[attr.nodeName] = attr.nodeValue;
        });
        $(".slicknav_collapsed.slicknav_parent > a > a").replaceWith(function () {
            return $("<span />", attrs).append($(this).contents());
        });
    });
</script>

