                    <img src="https://web.static.mmcdn.com/images/id-scan.svg" alt="ID">
                    
                    <span>ID Scan</span>
                </label>
            </div>
            <div class="right-half">
                <div class="age-gate-tooltip-container">
                    <span class="age-gate-info-icon"></span>
                    <div class="age-gate-tooltip">
                        <p>Verify your age by taking a photo of your driver's license or passport. This image will not be provided to us and will be discarded by Incode immediately after confirming your age.</p>
                    </div>
                </div>
            </div>
        </div>
        
        </div>
        
