.single-help_center_stores #ajaxsearchpro2_1, .single-help_center_stores #ajaxsearchpro2_2, .single-help_center_stores div.asp_m.asp_m_1{
    border: none;
    box-shadow: none;
    border: 1px solid #3C3D38;
}

.helpcenter-links a {
	color:#fff;
	display:block;
	padding-top: 5px;
}
.helpcenter-links a:firs-of-type {
	padding-top: 0;
}

div.helpcenter-links:not(:empty){
	margin-bottom:1.5rem!important;
}

.product-widget.product-domain {
	background: #fff;
  background-blend-mode: normal;
  box-shadow: 0 0 10px 0 #0000001a;
  padding: 20px 0px;
  border-left: 4px solid #ffcd02;
}

.cpv.h2-small{
	font-size:40px;
	font-weight:700;
	line-height:45px;
}
.cpv-grey-row{
	    background-color: hsla(100, 5%, 89%, .35);
	padding-top:70px;
}


.cpv-yellow-hero{
	background-image: url('https://cyberfolks.ro/wp-content/uploads/2022/10/hero-hosting-scaled-1.jpg.webp');
    background-position: 60% center;
}
.cpv-row {
	padding:100px 0 50px 0;
	margin:50px auto;
}

.cpv-row.wp-block-columns{
	padding:0;
	width:1115px;
	margin:0 auto;
}
.cpv-row .wp-block-column{
	width:465px;
	margin:0 auto;
}

.cpv-row .h3:before{
	color: #ffcd02;
    content: ">";
    white-space: nowrap;
}
.cpv-row .h3:after{
color: #ffcd02;
    content: "_";
    position: absolute;
}
.cpv-row ul{
	margin-top:50px;
}
.cpv-row li{
	    padding-left: 40px;
    position: relative;
	list-style-type:none;
	line-height:35px
}
.cpv-row li:before{
	    background-image: url('https://cyberfolks.ro/wp-content/themes/cyber_folks/dist/images/icons/check.svg');
    background-position: 0;
    background-repeat: no-repeat;
    background-size: 17px 13px;
    content: "";
    height: 24px;
    left: 0;
    position: absolute;
    top: 0;
    width: 24px;
}

.cpv-row .wp-block-buttons{
	align-items:center;
	flex-direction: column;
	margin-top:50px
}

.cpv-row .wp-block-buttons a{
	background-color: #ffcd02;
    border: 1px solid #ffcd02;
    color: #3c3d38;
	border-radius:0;
}

.h2-small{
	font-size:36px;
	line-height:40px;
	font-weight:700;
	margin-bottom:50px;
}


.cpv-row.bg-lighter{
	width:100%;
	align-content:center;
	flex-direction:column;
	padding:100px 0;
}
.cpv-row.bg-lighter .wp-block-column{
	width:1115px;
}

.cpv-row.faq summary{
	font-weight:600;
	font-size:22px;
	line-height:45px;
	
}

.cpv-row.faq summary:after{
	    content: "\e90c";
    color: #ffcd02;
	font-size: 10px;
	font-family: 'icomoon' !important;
    speak: none;
    font-style: normal;
    font-weight: normal;
    font-variant: normal;
    text-transform: none;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
	margin-left:10px;
}
.cpv-row.faq details p{
	font-size:18px;
	padding:10px 0 40px;
}
.cpv-promo-eu {
    align-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.cpv-promo-eu .content {
    width: 1024px;
    background-color: #ffcd02;
    text-align: center;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    font-weight: 600;

     
}

.cpv-promo-eu .content img {
    margin: 0 10px;
    vertical-align: middle;
	width:78px;
}


@media screen and (max-width: 900px){
	.cpv-promo-eu .content {
		width:90%;
		font-size:14px;
		padding: 10px 20px;
	}
}
.cpv-benefit h3, .cpv-benefit h2{
	display:none;
}
.cpv-benefit b{
	font-size:21px;
	font-weight:700;
	line-height:80px;
	color:#000000;

}
.cpv-benefit h3, .cpv-benefit-icon h3{
	/*display:none;*/
}
.cpv-benefit b{
	line-height:35px;
}
.cpv-benefit b:before{
	    color: #ffcd02;
    content: ">";
    white-space: nowrap;
}
.cpv-benefit b:after{
	    color: #ffcd02;
    content: "_";
    white-space: nowrap;
}

.cpv-benefit-icon strong{
	font-size:21px;
	font-weight:700;
	line-height:80px;
	color:#000000;

}
.cpv-benefit h3{
	display:none;
}
.cpv-benefit-icon strong:before{
	    color: #ffcd02;
    content: ">";
    white-space: nowrap;
}
.cpv-benefit-icon strong:after{
	    color: #ffcd02;
    content: "_";
    white-space: nowrap;
}

.cpv-image-text{
	column-gap:0;
	margin-bottom:50px;
}
.cpv-image-text .cpv-text{
	padding-bottom:100px
}
.cpv-image-text .cpv-text .h2{
	padding-top:100px;
	font-size:48px;
	line-height:55px
}
.cpv-image-text .cpv-text p{
	padding:0 150px 0 120px;
	font-size:15px;
	line-height:22px
}

.cpv-image-text .cpv-image{
	background-image:url('https://cyberfolks.ro/wp-content/uploads/2023/02/vps-administation.jpg');
	background-size:cover;
	background-position: center top;
	background-repeat:no-repeat;
}

.cpv-title{
	padding-top:130px;
}

.cpv-benefit.tech{
	padding-top:0;
	border:none;
}

.benefit-section {
	padding-bottom:0;
}
.benefit-section .mb-100{
	margin-bottom:50px
}
.cpv-padding{
	margin-top:0;
	margin-bottom:-70px;
	padding:0;
}


.bg-grey{
	background-color:#f6f6f6;
	padding-bottom:0;
}

.zigzag-bottom {
	    mask-image: url(data:image/svg+xml;base64,), linear-gradient(to top, transparent 0, transparent calc(43px - 1px), #000 40px, #000 100%);
    mask-position: left bottom;
    mask-repeat: repeat-x;
