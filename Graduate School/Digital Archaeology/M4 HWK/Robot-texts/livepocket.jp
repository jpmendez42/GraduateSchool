//リンクを取得して飛ばす
$(function(){
    $('.js-link').on('click', function(e){
        //伝播をストップ
        e.stopPropagation();
        e.preventDefault();
        location.href = $(this).attr('data-url');
    });
});

// キービジュアルスライダー
$(function() {
    $('.keyvisual-slide').slick({
        autoplay: true,
        autoplaySpeed: 5000, // 5秒ごとにスライドする
        speed: 800,
        arrows: false,
        pauseOnFocus: false,
        pauseOnHover: false,
        pauseOnDotsHover: false
    }); 
});

$(window).scroll(function () {
    if($(window).scrollTop() > 0) {
        $('header').addClass('fixed');
        $('.about').addClass('hidden');
        $('.search').addClass('hidden');
        $('.sell').addClass('hidden');
        $('.buy span').addClass('scroll-position');
        $('.buy a').addClass('scroll-position');
    } else {
        $('header').removeClass('fixed');
        $('.about').removeClass('hidden');
        $('.search').removeClass('hidden');
        $('.sell').removeClass('hidden');
        $('.buy span').removeClass('scroll-position');
        $('.buy a').removeClass('scroll-position');
    }
});
</script>


