                    <!----------------- GA & Ewebs Analytics ----------------->
            

<script>
// Google Analytics 使用者識別
var gaUser = {};

// Google Analytics 商品資料格式處理
const gaProducts = function (prods, coupon = []) {
    const arr_split = ($array) => {
        const $size = 20;
        const $result = [];
        for (let i = 0; i < $array.length; i += $size) {
            const chunk = $array.slice(i, i + $size);
            $result.push(chunk);
        }
        return $result; 
    }; 

    if (!prods) 
        return [];

    prods = Array.isArray(prods) ? prods : [prods];

    return arr_split(prods.reduce((items, p) => {
        const _prod = {
            'item_id': p.prod_no,
            'item_name': p.content_name,
            'price': (+p.price),
            'quantity': +(p.quantity || 1),
        };
        if (p.coupon_id > 0 && coupon.indexOf(p.coupon_id) === -1) {
            coupon.push(p.coupon_id);
        }
        if (p.category_layers) {
            _prod['item_category'] = p.category_layers[1]?.prod_sort_name || '';
            _prod['item_category2'] = p.category_layers[2]?.prod_sort_name || '';
            _prod['item_category3'] = p.category_layers[3]?.prod_sort_name || '';
            _prod['item_category4'] = p.category_layers[4]?.prod_sort_name || '';
            _prod['item_category5'] = p.category_layers[5]?.prod_sort_name || '';
        }
        if (p.affiliation) {
            _prod['affiliation'] = [p.affiliation[0], p.affiliation[2]].join('_');
        }
        if (p.variant) {
            _prod['item_variant'] = (p.variant.filter(spec => spec) || []).join('|');
        }
        items.push(_prod);
        return items;
    }, []));
};

// 設定使用者
window.addEventListener("set_user", (e) => {
    if (e.detail?.user_id) {
        Object.assign(gaUser, { user_id: e.detail?.user_id });
        // 設定使用者 ID
        gtag('set', { user_id: e.detail?.user_id });
        // 設定使用者屬性
        gtag('set', { user_properties: { member_id: e.detail?.user_id } });
    }
});

// 註冊資訊
window.addEventListener("sign_up", (e) => {
    gtag('event', 'sign_up', {
        'user_id': e.detail?.username,
        'method': e.detail?.method || '',
    });
});

// 登入資訊
window.addEventListener("login", (e) => {
    gtag('event', 'login', {
        'user_id': e.detail?.username,
        'method': e.detail?.method || '',
    });
});

//  瀏覽產品列表
window.addEventListener("view_item_list", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    _products.forEach(_items => {
        gtag('event', 'view_item_list', {
            'item_list_name': e.detail.item_list_name,
            'item_list_id': e.detail.item_list_id,
            'currency': 'TWD',
            // 'value': _items.reduce((sum, p) => sum + (p.price * p.quantity), 0),
            'items': _items,
            ...gaUser
        });
    });
});

// 加入追蹤
window.addEventListener("add_to_favorite", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    gtag('event', 'add_to_wishlist', {
        'currency': 'TWD',
        'value': _products[0].reduce((sum, p) => sum + (p.price * p.quantity), 0),
        'items': _products[0],
        ...gaUser
    });
});

// 加入購物車
window.addEventListener("add_to_cart", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    gtag('event', 'add_to_cart', {
        'currency': 'TWD',
        'value': _products[0].reduce((sum, p) => sum + (p.price * p.quantity), 0),
        'items': _products[0],
        ...gaUser
    });
});

// 瀏覽商品頁
window.addEventListener("view_item", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    gtag('event', 'view_item', {
        'currency': 'TWD',
        'value': _products[0].reduce((sum, p) => sum + (p.price * p.quantity), 0),
        'items': _products[0],
        ...gaUser
    });
});

// 瀏覽購物車
window.addEventListener("view_cart", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    _products.forEach(_items => {
        gtag('event', 'view_cart', {
            'currency': 'TWD',
            'value': _items.reduce((sum, p) => sum + (p.price * p.quantity), 0),
            'items': _items,
            ...gaUser
        });
    });
});

// 前往結帳
window.addEventListener("begin_checkout", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    _products.forEach(_items => {
        gtag('event', 'begin_checkout', {
            'currency': 'TWD',
            'value': _items.reduce((sum, p) => sum + (p.price * p.quantity), 0),
            'items': _items,
            ...gaUser
        });
    });
});

// 填寫結帳資訊
window.addEventListener("add_shipping_info", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    var shipping_tier = e.detail?.shipping_tier || 'unknown';
    var coupon = e.detail?.coupon || '';
    var coupon_v = [0, 0];

    if (e.detail?.coupon_value > 0) {
        coupon_v[0] = +e.detail?.coupon_value;
        if (_products.length > 1) {
            coupon_v[1] = parseInt(+e.detail?.coupon_value / _products.length);
            coupon_v[0] = coupon_v[0] - (coupon_v[1] * (_products.length - 1));
         }
    }

    _products.forEach((_items, _idx) => {
        gtag('event', 'add_shipping_info', {
            'shipping_tier': shipping_tier,
            'coupon': coupon,
            'currency': 'TWD',
            'value': _items.reduce((sum, p) => sum + (p.price * p.quantity), -coupon_v[(_idx > 0 ? 1 : 0)]),
            'items': _items,
            ...gaUser
        });
    });
});

// 填寫結帳資訊
window.addEventListener("add_payment_type", (e) => {
    const _products = gaProducts(e.detail.items);
    if (!_products) return;

    var payment_type = e.detail?.payment_type || 'unknown';
    var coupon = e.detail?.coupon || '';
    var coupon_v = [0, 0];

    if (e.detail?.coupon_value > 0) {
        coupon_v[0] = +e.detail?.coupon_value;
        if (_products.length > 1) {
            coupon_v[1] = parseInt(+e.detail?.coupon_value / _products.length);
            coupon_v[0] = coupon_v[0] - (coupon_v[1] * (_products.length - 1));
        }
    }

    _products.forEach((_items, _idx) => {
        gtag('event', 'add_payment_info', {
            'payment_type': payment_type,
            'coupon': coupon,
            'currency': 'TWD',
            'value': _items.reduce((sum, p) => sum + (p.price * p.quantity), -coupon_v[(_idx > 0 ? 1 : 0)]),
            'items': _items,
            ...gaUser
        });
    });
});

// 結帳完成
window.addEventListener("purchase", (e) => {
    const _transaction_id = e.detail?.transaction_id || '';
    const _shipping = e.detail?.delivery_carriage ?? 0;
    const _coupons = [];
    
    const _products = gaProducts(e.detail.items, _coupons);
    if (!_products || !_transaction_id) return;
    
    _products.forEach(_items => {
        gtag('event', 'purchase', {
            'transaction_id': _transaction_id,
            'coupon': _coupons.join(','),
            'shipping': _shipping,
            'currency': 'TWD',
            'value': _items.reduce((sum, p) => sum + (p.price * p.quantity), 0),
            'items': _items,
            ...gaUser
        });
    });
});

// Google GTM
window.dataLayer = window.dataLayer || [];
if (typeof gtag === 'undefined') {
    window.gtag = function () {};
}
const ga_app = {
    custom_u: navigator.userAgent.indexOf('PartnerAPP'),
    android: navigator.userAgent.indexOf('Android') > -1 || navigator.userAgent.indexOf('Adr') > -1,
    ios: !!navigator.userAgent.match(/\(i[^;]+;( U;)? CPU.+Mac OS X/),
};
if (ga_app.custom_u != -1) {
    //  for firebase ios
    if (ga_app.ios && window.webkit && 
        window.webkit.messageHandlers && 
        window.webkit.messageHandlers.GaLogEvent) {
        gtag = new Proxy(gtag, {
            apply: async (target, thisArg, args) => {
                // console.log(`iOS::${args[1]}`, args[2]);
                if (args[0] == 'event') {
                    window.webkit.messageHandlers.GaLogEvent.postMessage({
                        eventName: args[1],
                        parameters: args[2]
                    });
                };
            }
        });
    } 
    //  for firebase android
    if (ga_app.android && window.GaLogEvent) {
        gtag = new Proxy(gtag, {
            apply: async (target, thisArg, args) => {
                // console.log(`android::${args[1]}`, args[2]);
                if (args[0] == 'event') {
                    window.GaLogEvent.postMessage(args[1], JSON.stringify(args[2]));
                };
            }
        });
    }
}
// gtag 觸發寫入datalayer
if (ga_app.custom_u == -1 || 
    (!ga_app.android && !ga_app.ios)) {
    // for GA360
    gtag = new Proxy(gtag, {
        apply: async (target, thisArg, args) => {
            // console.log(args[1], args[2]);
            if (args[0] == 'event') {
                window.dataLayer.push({'ecommerce': null});
                window.dataLayer.push({
                    'event': args[1],
                    'ecommerce': args[2],
                });
            } else if (args[0] == 'set' && (args[1].hasOwnProperty('user_id') || args[1].hasOwnProperty('user_properties'))) {
                if (args[1].hasOwnProperty('user_properties')) {
                    window.dataLayer.push({
                        'event': 'set_user_properties',
                        'user_properties': args[1].user_properties,
                    });
                } else  {
                    window.dataLayer.push({
                        'user_id': args[1].user_id,
                    });
                }
            } else {
                dataLayer.push(...args);
            } 
            // Reflect.apply(target, thisArg, args);
        }
    });
}
</script>
            <!----------------- Facebook Pixel Code ----------------->
                                    <script>
                var allCookies = document.cookie;
                var cookieArray = allCookies.split("; ");

                var _fbp = '';
                var _fbc = '';
                for (var i = 0; i < cookieArray.length; i++) {
                    var cookie = cookieArray[i].split("=");
                    if (cookie[0] === "_fbp") {
                        _fbp = decodeURIComponent(cookie[1]);
                        break;
                    }
                    if (cookie[0] === "_fbc") {
                        _fbc = decodeURIComponent(cookie[1]);
                        break;
                    }
                }
                
                var metaData = {
                    web_uid: '2',
                    event_source_url: window.location.href,
                    client_ip_address: userIP,
                    client_user_agent: navigator.userAgent
                };
                if (_fbp) metaData.fbp = _fbp;
                if (_fbc) metaData.fbc = _fbc;
                metaData.member = jsonMember;

                !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
                n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
                n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
                t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
                document,'script','https://connect.facebook.net/en_US/fbevents.js');

                fbq('init', '1922038611490297', jsonMember);
                fbq('track', 'PageView');

                metaData.event_name = 'PageView';
                $.ajax({
                    url: 'api/api.meta_conversions_api.php',
                    type: 'POST',
                    dataType: 'json',
                    data: {
                        metaData: metaData,
                        [csrf_key]: csrf_val
                    },
                    success: function(r){},
                    error: function(r){}
                });

                
                function fb_AddToCart(prodNo, value, contents) {
                    value = parseInt(value);

                    if (prodNo && value > 0) {
                        var content_ids = [];
                        content_ids.push(prodNo);
                    
                        var obj = {
                            content_ids: content_ids,
                            content_type: 'product',
                            value: value,
                            currency: 'TWD'
                        };
                    
                        if (typeof contents != undefined)
                            obj.contents = contents;
                    
                        fbq('track', 'AddToCart', obj);
                    
                        metaData.event_name = 'AddToCart';
                        metaData.custom_data = obj;
                        $.ajax({
                            url: 'api/api.meta_conversions_api.php',
                            type: 'POST',
                            dataType: 'json',
                            data: {
                                metaData: metaData,
                                [csrf_key]: csrf_val 
                            },
                            success: function(r){},
                            error: function(r){}
                        });
                    }
                }

                function fb_AddToWishlist(prodNo, value) {
                    value = parseInt(value);

                    if (prodNo && value > 0) {
                        var content_ids = [];
                        content_ids.push(prodNo);
                    
                        var obj = {
                            content_ids: content_ids,
                            content_type: 'product',
                            value: value,
                            currency: 'TWD'
                        };
                            
                        fbq('track', 'AddToWishlist', obj);
                    
                        metaData.event_name = 'AddToWishlist';
                        metaData.custom_data = obj;

                        $.ajax({
                            url: 'api/api.meta_conversions_api.php',
                            type: 'POST',
                            dataType: 'json',
                            data: {
                                metaData: metaData,
                                [csrf_key]: csrf_val 
                            },
                            success: function(r){},
                            error: function(r){}
                        });
                    }
                }
            </script>
