slug\":\"hura-za-hadankou-97271070\",\"channelId\":\"77\"},{\"id\":\"97271071\",\"start\":\"2025-10-13T23:46:00.000Z\",\"stop\":\"2025-10-13T23:56:00.000Z\",\"title\":\"Messyho skvělá dobrodružství (6)\",\"description\":\"\",\"durationMin\":10,\"genre\":8,\"slug\":\"messyho-skvela-dobrodruzstvi-97271071\",\"channelId\":\"77\"},{\"id\":\"97271072\",\"start\":\"2025-10-13T23:56:00.000Z\",\"stop\":\"2025-10-14T00:09:00.000Z\",\"title\":\"Messyho skvělá dobrodružství (7)\",\"description\":\"\",\"durationMin\":13,\"genre\":8,\"slug\":\"messyho-skvela-dobrodruzstvi-97271072\",\"channelId\":\"77\"}],\"78\":[{\"id\":\"97316793\",\"start\":\"2025-10-13T00:40:00.000Z\",\"stop\":\"2025-10-13T02:30:00.000Z\",\"title\":\"Hostitel\",\"description\":\"Sci-fi film USA (2013). Po úspěšné invazi teď Zemi kontrolují neviditelní mimozemšťané. Takzvané Duše přebírají kontrolu nad myslí člověka, používají jeho tělo a zdánlivě beze změny žijí jejich životy. Každý člověk se stane pro Duši pouhou schránkou a hostitelem. Melanie, mladá dívka, která patří mezi zbývající divoké lidi a která se bezhlavě zamiluje do kluka jménem Jared je po jedné z honiček zajata a její tělo si bere Duše jménem Poutnice. Melanie se odmítá své mysli a svého těla vzdát a začíná boj o lásku a přežití.\",\"durationMin\":111,\"genre\":3,\"slug\":\"hostitel-97316793\",\"channelId\":\"78\"},{\"id\":\"97512420\",\"start\":\"2025-10-13T02:30:00.000Z\",\"stop\":\"2025-10-13T04:25:00.000Z\",\"title\":\"Dračí srdce 3: Čarodějova kletba\",\"description\":\"$36\",\"durationMin\":94,\"genre\":3,\"slug\":\"draci-srdce-3-carodejova-kletba-97512420\",\"channelId\":\"78\"},{\"id\":\"97512421\",\"start\":\"2025-10-13T04:25:00.000Z\",\"stop\":\"2025-10-13T06:45:00.000Z\",\"title\":\"Footloose: Tanec zakázán\",\"description\":\"$37\",\"durationMin\":113,\"genre\":3,\"slug\":\"footloose-tanec-zakazan-97512421\",\"channelId\":\"78\"},{\"id\":\"97512422\",\"start\":\"2025-10-13T06:45:00.000Z\",\"stop\":\"2025-10-13T10:30:00.000Z\",\"title\":\"Posel budoucnosti\",\"description\":\"$38\",\"durationMin\":165,\"genre\":3,\"slug\":\"posel-budoucnosti-97512422\",\"channelId\":\"78\"},{\"id\":\"97512423\",\"start\":\"2025-10-13T10:30:00.000Z\",\"stop\":\"2025-10-13T12:30:00.000Z\",\"title\":\"Táta za všechny peníze\",\"description\":\"$39\",\"durationMin\":85,\"genre\":3,\"slug\":\"tata-za-vsechny-penize-97512423\",\"channelId\":\"78\"},{\"id\":\"97512424\",\"start\":\"2025-10-13T12:30:00.000Z\",\"stop\":\"2025-10-13T13:55:00.000Z\",\"title\":\"Setkání v červenci\",\"description\":\"Komedie ČR (1978). Studijní neúspěchy Jakuba má napravit nenáviděná učitelka Klára v jazykovém kurzu. Jenže má syna Davida a díky němu se rafinovaná pomsta žáka změní v lásku...\",\"durationMin\":83,\"genre\":3,\"slug\":\"setkani-v-cervenci-97512424\",\"channelId\":\"78\"},{\"id\":\"97512425\",\"start\":\"2025-10-13T13:55:00.000Z\",\"stop\":\"2025-10-13T15:10:00.000Z\",\"title\":\"Cukrárna (8)\",\"description\":\"$3a\",\"durationMin\":75,\"genre\":4,\"slug\":\"cukrarna-97512425\",\"channelId\":\"78\"},{\"id\":\"97512426\",\"start\":\"2025-10-13T15:10:00.000Z\",\"stop\":\"2025-10-13T16:05:00.000Z\",\"title\":\"Život na zámku IV (2)\",\"description\":\"\",\"durationMin\":55,\"genre\":4,\"slug\":\"zivot-na-zamku-iv-97512426\",\"channelId\":\"78\"},{\"id\":\"97512427\",\"start\":\"2025-10-13T16:05:00.000Z\",\"stop\":\"2025-10-13T18:00:00.000Z\",\"title\":\"Moderní Popelka\",\"description\":\"$3b\",\"durationMin\":88,\"genre\":3,\"slug\":\"moderni-popelka-97512427\",\"channelId\":\"78\"},{\"id\":\"97512428\",\"start\":\"2025-10-13T18:00:00.000Z\",\"stop\":\"2025-10-13T20:50:00.000Z\",\"title\":\"Muž z oceli\",\"description\":\"$3c\",\"durationMin\":128,\"genre\":3,\"slug\":\"muz-z-oceli-97512428\",\"channelId\":\"78\"},{\"id\":\"97512429\",\"start\":\"2025-10-13T20:50:00.000Z\",\"stop\":\"2025-10-13T22:45:00.000Z\",\"title\":\"Venom 2: Carnage přichází\",\"description\":\"$3d\",\"durationMin\":86,\"genre\":3,\"slug\":\"venom-2-carnage-prichazi-97512429\",\"channelId\":\"78\"},{\"id\":\"97512430\",\"start\":\"2025-10-13T22:45:00.000Z\",\"stop\":\"2025-10-14T00:55:00.000Z\",\"title\":\"Muž na odstřel\",\"description\":\"Akční film Šp./USA/VB/Fr. (2015). Američan Terrier je bývalý příslušník speciálních sil, který se stal žoldákem v soukromé skupině. Jediné, po čem nyní touží, je konečně se usadit se svou dávnou láskou. Tajné služby se ale jen tak snano opustit nedají...\",\"durationMin\":110,\"genre\":3,\"slug\":\"muz-na-odstrel-97512430\",\"channelId\":\"78\"}],\"82\":[{\"id\":\"97432741\",\"start\":\"2025-10-13T00:12:00.000Z\",\"stop\":\"2025-10-13T00:58:00.000Z\",\"title\":\"Lovci z divočiny (3)\",\"description\":\"Hadi. Dokumentární seriál Šp. (2018). Jedovatí hadi patří k nejnebezpečnějším tvorům planety. V jediném okamžiku jsou schopni rozhodnout o životě a smrti.\",\"durationMin\":46,\"genre\":5,\"slug\":\"lovci-z-divociny-97432741\",\"channelId\":\"82\"},{\"id\":\"97432742\",\"start\":\"2025-10-13T00:58:00.000Z\",\"stop\":\"2025-10-13T01:44:00.000Z\",\"title\":\"Lovci z divočiny (4)\",\"description\":\"Seriál Lovci z divočiny je velkolepou cestou po světě ve snaze nalézt nejnebezpečnější dravce přírody. Jedná se o inspirativní detailní pohled na každodenní život ve volné přírodě.\",\"durationMin\":46,\"genre\":5,\"slug\":\"lovci-z-divociny-97432742\",\"channelId\":\"82\"},{\"id\":\"97432743\",\"start\":\"2025-10-13T01:44:00.000Z\",\"stop\":\"2025-10-13T02:28:00.000Z\",\"title\":\"Veterináři z Nebrasky - výběr (1)\",\"description\":\"\",\"durationMin\":44,\"genre\":5,\"slug\":\"veterinari-z-nebrasky-vyber-97432743\",\"channelId\":\"82\"},{\"id\":\"97432744\",\"start\":\"2025-10-13T02:28:00.000Z\",\"stop\":\"2025-10-13T03:14:00.000Z\",\"title\":\"Lovci z divočiny (1)\",\"description\":\"Kočky. Dokumentární seriál Šp. (2018). Od rysa ostrovida v Evropě po oceloty Margay v Indii: všichni mají jedno společné; jsou vražednými stroji. Opravdoví atleti na lovu!\",\"durationMin\":46,\"genre\":5,\"slug\":\"lovci-z-divociny-97432744\",\"channelId\":\"82\"},{\"id\":\"97432745\",\"start\":\"2025-10-13T03:14:00.000Z\",\"stop\":\"2025-10-13T04:00:00.000Z\",\"title\":\"Lovci z divočiny (3)\",\"description\":\"Hadi. Dokumentární seriál Šp. (2018). Jedovatí hadi patří k nejnebezpečnějším tvorům planety. V jediném okamžiku jsou schopni rozhodnout o životě a smrti.\",\"durationMin\":46,\"genre\":5,\"slug\":\"lovci-z-divociny-97432745\",\"channelId\":\"82\"},{\"id\":\"97432746\",\"start\":\"2025-10-13T04:00:00.000Z\",\"stop\":\"2025-10-13T04:21:00.000Z\",\"title\":\"Skvělá farma doktora Pola (7)\",\"description\":\"Stoletá stodola. Dokumentární seriál USA (2022). Manželé Polovi se pouští do dalšího velkého projektu: chtějí na farmu přemístit 100 let starou stodolu a obnovit její bývalou slávu. Nejdřív ji ale budou muset opatrně a bezchybně rozebrat.\",\"durationMin\":21,\"genre\":5,\"slug\":\"skvela-farma-doktora-pola-97432746\",\"channelId\":\"82\"},{\"id\":\"97432747\",\"start\":\"2025-10-13T04:21:00.000Z\",\"stop\":\"2025-10-13T04:43:00.000Z\",\"title\":\"Jedinečná zvířata - výběr (1)\",\"description\":\"Sloni a orangutani. Dokumentární seriál USA (2017). Slon je dost silný na to, aby převrhl dodávku, orangutan má sílu jako sedm mužů. A oba jsou extrémně chytří.\",\"durationMin\":22,\"genre\":5,\"slug\":\"jedinecna-zvirata-vyber-97432747\",\"channelId\":\"82\"},{\"id\":\"97432748\",\"start\":\"2025-10-13T04:43:00.000Z\",\"stop\":\"2025-10-13T05:06:00.000Z\",\"title\":\"Zrozeni přežít (9)\",\"description\":\"Jaká zvířata jsou schopna přežít v těch nejextrémnějších podmínkách? Pedagog a dobrodruh Phil Breslin nás vezme na neobvyklou cestu australským kontinentem, aby odhalil, kteří ze tvorů zvířecí říše byli stvořeni k tomu, aby přežili v pouštích, mangrovech, deštných pralesech, řekách nebo moři.\",\"durationMin\":23,\"genre\":5,\"slug\":\"zrozeni-prezit-97432748\",\"channelId\":\"82\"},{\"id\":\"97432749\",\"start\":\"2025-10-13T05:06:00.000Z\",\"stop\":\"2025-10-13T05:29:00.000Z\",\"title\":\"Zrozeni přežít (10)\",\"description\":\"Jaká zvířata jsou schopna přežít v těch nejextrémnějších podmínkách? Pedagog a dobrodruh Phil Breslin nás vezme na neobvyklou cestu australským kontinentem, aby odhalil, kteří ze tvorů zvířecí říše byli stvořeni k tomu, aby přežili v pouštích, mangrovech, deštných pralesech, řekách nebo moři.\",\"durationMin\":23,\"genre\":5,\"slug\":\"zrozeni-prezit-97432749\",\"channelId\":\"82\"},{\"id\":\"97432750\",\"start\":\"2025-10-13T05:29:00.000Z\",\"stop\":\"2025-10-13T06:14:00.000Z\",\"title\":\"Afričtí lovci III (5)\",\"description\":\"Soupeři a soupeřky. Dokumentární seriál VB (2018). Thandi a Lula, jediné samice z vrhu šesti mláďat psů hyenových, se hodně liší. Zatímco Lula ráda dovádí se svými brášky, Thandi se často vydává na průzkum stranou ostatních.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-iii-97432750\",\"channelId\":\"82\"},{\"id\":\"97432751\",\"start\":\"2025-10-13T06:14:00.000Z\",\"stop\":\"2025-10-13T06:59:00.000Z\",\"title\":\"Afričtí lovci II (2)\",\"description\":\"Těchto šest filmů mapuje životy impozantních zambijských predátorů – lvů, leopardů, hyen a divokých psů.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-ii-97432751\",\"channelId\":\"82\"},{\"id\":\"97432752\",\"start\":\"2025-10-13T06:59:00.000Z\",\"stop\":\"2025-10-13T07:45:00.000Z\",\"title\":\"Afričtí lovci III (1)\",\"description\":\"Vzestup Kimby. Dokumentární seriál VB (2018). Lví smečka Mwamba kraluje oblastem na západním břehu řeky Luangwa v Zambii. Čelí ovšem nejisté budoucnosti.\",\"durationMin\":46,\"genre\":5,\"slug\":\"africti-lovci-iii-97432752\",\"channelId\":\"82\"},{\"id\":\"97432753\",\"start\":\"2025-10-13T07:45:00.000Z\",\"stop\":\"2025-10-13T08:30:00.000Z\",\"title\":\"Afričtí lovci III (5)\",\"description\":\"Soupeři a soupeřky. Dokumentární seriál VB (2018). Thandi a Lula, jediné samice z vrhu šesti mláďat psů hyenových, se hodně liší. Zatímco Lula ráda dovádí se svými brášky, Thandi se často vydává na průzkum stranou ostatních.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-iii-97432753\",\"channelId\":\"82\"},{\"id\":\"97432754\",\"start\":\"2025-10-13T08:30:00.000Z\",\"stop\":\"2025-10-13T09:15:00.000Z\",\"title\":\"Afričtí lovci II (2)\",\"description\":\"Těchto šest filmů mapuje životy impozantních zambijských predátorů – lvů, leopardů, hyen a divokých psů.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-ii-97432754\",\"channelId\":\"82\"},{\"id\":\"97432755\",\"start\":\"2025-10-13T09:15:00.000Z\",\"stop\":\"2025-10-13T10:00:00.000Z\",\"title\":\"Afričtí lovci II (3)\",\"description\":\"Těchto šest filmů mapuje životy impozantních zambijských predátorů – lvů, leopardů, hyen a divokých psů.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-ii-97432755\",\"channelId\":\"82\"},{\"id\":\"97432756\",\"start\":\"2025-10-13T10:00:00.000Z\",\"stop\":\"2025-10-13T10:45:00.000Z\",\"title\":\"Afričtí lovci II (4)\",\"description\":\"Těchto šest filmů mapuje životy impozantních zambijských predátorů – lvů, leopardů, hyen a divokých psů.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-ii-97432756\",\"channelId\":\"82\"},{\"id\":\"97432757\",\"start\":\"2025-10-13T10:45:00.000Z\",\"stop\":\"2025-10-13T11:31:00.000Z\",\"title\":\"Afričtí lovci III (1)\",\"description\":\"Vzestup Kimby. Dokumentární seriál VB (2018). Lví smečka Mwamba kraluje oblastem na západním břehu řeky Luangwa v Zambii. Čelí ovšem nejisté budoucnosti.\",\"durationMin\":46,\"genre\":5,\"slug\":\"africti-lovci-iii-97432757\",\"channelId\":\"82\"},{\"id\":\"97432758\",\"start\":\"2025-10-13T11:31:00.000Z\",\"stop\":\"2025-10-13T12:16:00.000Z\",\"title\":\"Afričtí lovci III (2)\",\"description\":\"Údolí kolem řeky Luangwa v Zambii je pro špičkové africké šelmy perfektním místem k lovu. Lví smečky i psi hyenoví, klany hyen i osamělí levharti soupeří o nadvládu nad oblastí, která je v období sucha nutným útočištěm jejich kořisti.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-iii-97432758\",\"channelId\":\"82\"},{\"id\":\"97432759\",\"start\":\"2025-10-13T12:16:00.000Z\",\"stop\":\"2025-10-13T13:01:00.000Z\",\"title\":\"Afričtí lovci III (3)\",\"description\":\"Odpadlík na cestě k dospělosti. Dokumentární seriál VB (2018). Misfit, jedno ze lvíčat, to v životě nemá jednoduché. Muselo čelit starším sourozencům, jeho matka se ho vzdala, ale přesto z něj vyrostl teenager.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-iii-97432759\",\"channelId\":\"82\"},{\"id\":\"97432760\",\"start\":\"2025-10-13T13:01:00.000Z\",\"stop\":\"2025-10-13T13:46:00.000Z\",\"title\":\"Afričtí lovci III (4)\",\"description\":\"Případ levhartice. Dokumentární seriál VB (2018). Údolí kolem řeky Luangwa v Zambii je pro špičkové africké šelmy perfektním místem k lovu. V období sucha je nutným útočištěm kořisti.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-iii-97432760\",\"channelId\":\"82\"},{\"id\":\"97432761\",\"start\":\"2025-10-13T13:46:00.000Z\",\"stop\":\"2025-10-13T14:32:00.000Z\",\"title\":\"Afričtí lovci III (5)\",\"description\":\"Soupeři a soupeřky. Dokumentární seriál VB (2018). Thandi a Lula, jediné samice z vrhu šesti mláďat psů hyenových, se hodně liší. Zatímco Lula ráda dovádí se svými brášky, Thandi se často vydává na průzkum stranou ostatních.\",\"durationMin\":46,\"genre\":5,\"slug\":\"africti-lovci-iii-97432761\",\"channelId\":\"82\"},{\"id\":\"97432762\",\"start\":\"2025-10-13T14:32:00.000Z\",\"stop\":\"2025-10-13T15:16:00.000Z\",\"title\":\"Skvělý dr. Pol XXII (4)\",\"description\":\"Zaseknutý problém. Dokumentární seriál USA (2022). Doktor Pol odstraní dikobrazí ostny z čenichu mastifa. Nicole vytáhne skoro metrovou strunu z kočky a Lisa sundá psí úlovek z rybářského háčku. Později vyráží Pol a Brenda do terénu.\",\"durationMin\":44,\"genre\":5,\"slug\":\"skvely-dr-pol-xxii-97432762\",\"channelId\":\"82\"},{\"id\":\"97432763\",\"start\":\"2025-10-13T15:16:00.000Z\",\"stop\":\"2025-10-13T16:00:00.000Z\",\"title\":\"Skvělý dr. Pol XXII (5)\",\"description\":\"\",\"durationMin\":44,\"genre\":5,\"slug\":\"skvely-dr-pol-xxii-97432763\",\"channelId\":\"82\"},{\"id\":\"97057497\",\"start\":\"2025-10-13T16:00:00.000Z\",\"stop\":\"2025-10-13T16:43:00.000Z\",\"title\":\"Příšerky v péči jižanských veterinářů IV (2)\",\"description\":\"Dlouholetí kamarádi doktor Hodges a doktor Ferguson žijí zhruba 160 kilometrů jižně od Atlanty, kde společně provozují veterinární kliniku Critter Fixers. Společně se svými kolegy se starají o 20 tisíc zvířecích pacientů, a to nejen v ordinaci, ale i na farmách v širokém okolí.\",\"durationMin\":43,\"genre\":5,\"slug\":\"priserky-v-peci-jizanskych-veterinaru-iv-97057497\",\"channelId\":\"82\"},{\"id\":\"97432764\",\"start\":\"2025-10-13T16:43:00.000Z\",\"stop\":\"2025-10-13T17:27:00.000Z\",\"title\":\"Veterináři z Nebrasky IV (12)\",\"description\":\"Veterináři Ben a Erin Schroederovi zasvětili svůj život péči o zdraví všech malých i velkých tvorů ve své komunitě v Nebrasce.\",\"durationMin\":44,\"genre\":5,\"slug\":\"veterinari-z-nebrasky-iv-97432764\",\"channelId\":\"82\"},{\"id\":\"97432765\",\"start\":\"2025-10-13T17:27:00.000Z\",\"stop\":\"2025-10-13T18:12:00.000Z\",\"title\":\"Afričtí lovci III (5)\",\"description\":\"Soupeři a soupeřky. Dokumentární seriál VB (2018). Thandi a Lula, jediné samice z vrhu šesti mláďat psů hyenových, se hodně liší. Zatímco Lula ráda dovádí se svými brášky, Thandi se často vydává na průzkum stranou ostatních.\",\"durationMin\":45,\"genre\":5,\"slug\":\"africti-lovci-iii-97432765\",\"channelId\":\"82\"},{\"id\":\"97432766\",\"start\":\"2025-10-13T18:12:00.000Z\",\"stop\":\"2025-10-13T18:55:00.000Z\",\"title\":\"Příšerky v péči jižanských veterinářů IV (2)\",\"description\":\"Dlouholetí kamarádi doktor Hodges a doktor Ferguson žijí zhruba 160 kilometrů jižně od Atlanty, kde společně provozují veterinární kliniku Critter Fixers. Společně se svými kolegy se starají o 20 tisíc zvířecích pacientů, a to nejen v ordinaci, ale i na farmách v širokém okolí.\",\"durationMin\":43,\"genre\":5,\"slug\":\"priserky-v-peci-jizanskych-veterinaru-iv-97432766\",\"channelId\":\"82\"},{\"id\":\"97432767\",\"start\":\"2025-10-13T18:55:00.000Z\",\"stop\":\"2025-10-13T19:38:00.000Z\",\"title\":\"Skvělý dr. Pol XXII (4)\",\"description\":\"Zaseknutý problém. Dokumentární seriál USA (2022). Doktor Pol odstraní dikobrazí ostny z čenichu mastifa. Nicole vytáhne skoro metrovou strunu z kočky a Lisa sundá psí úlovek z rybářského háčku. Později vyráží Pol a Brenda do terénu.\",\"durationMin\":43,\"genre\":5,\"slug\":\"skvely-dr-pol-xxii-97432767\",\"channelId\":\"82\"},{\"id\":\"97432768\",\"start\":\"2025-10-13T19:38:00.000Z\",\"stop\":\"2025-10-13T20:22:00.000Z\",\"title\":\"Skvělý dr. Pol XXII (5)\",\"description\":\"\",\"durationMin\":44,\"genre\":5,\"slug\":\"skvely-dr-pol-xxii-97432768\",\"channelId\":\"82\"},{\"id\":\"97432769\",\"start\":\"2025-10-13T20:22:00.000Z\",\"stop\":\"2025-10-13T21:06:00.000Z\",\"title\":\"Veterináři z Nebrasky IV (12)\",\"description\":\"Veterináři Ben a Erin Schroederovi zasvětili svůj život péči o zdraví všech malých i velkých tvorů ve své komunitě v Nebrasce.\",\"durationMin\":44,\"genre\":5,\"slug\":\"veterinari-z-nebrasky-iv-97432769\",\"channelId\":\"82\"},{\"id\":\"97432770\",\"start\":\"2025-10-13T21:06:00.000Z\",\"stop\":\"2025-10-13T21:49:00.000Z\",\"title\":\"Příšerky v péči jižanských veterinářů IV (2)\",\"description\":\"Dlouholetí kamarádi doktor Hodges a doktor Ferguson žijí zhruba 160 kilometrů jižně od Atlanty, kde společně provozují veterinární kliniku Critter Fixers. Společně se svými kolegy se starají o 20 tisíc zvířecích pacientů, a to nejen v ordinaci, ale i na farmách v širokém okolí.\",\"durationMin\":43,\"genre\":5,\"slug\":\"priserky-v-peci-jizanskych-veterinaru-iv-97432770\",\"channelId\":\"82\"},{\"id\":\"97432771\",\"start\":\"2025-10-13T21:49:00.000Z\",\"stop\":\"2025-10-13T22:34:00.000Z\",\"title\":\"Afričtí 