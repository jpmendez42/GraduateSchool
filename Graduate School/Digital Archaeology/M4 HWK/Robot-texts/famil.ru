/media/logo-roccobarocco-1080x473.jpg\"},\"w1920\":{\"width\":1920,\"height\":841,\"mimeType\":\"image/jpeg\",\"filesize\":43137,\"filename\":\"logo-roccobarocco-1920x841.jpg\",\"url\":\"/cms/media/logo-roccobarocco-1920x841.jpg\"},\"w3840\":{\"width\":3840,\"height\":1681,\"mimeType\":\"image/jpeg\",\"filesize\":111161,\"filename\":\"logo-roccobarocco-3840x1681.jpg\",\"url\":\"/cms/media/logo-roccobarocco-3840x1681.jpg\"}},\"createdAt\":\"2023-12-18T11:21:46.069Z\",\"updatedAt\":\"2025-08-29T10:51:30.278Z\",\"url\":\"/cms/media/logo-roccobarocco.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d7167929e66c401c75f4\",\"name\":\"ADIDAS\",\"description\":\"Adidas - крупнейший немецкий производитель спортивной одежды, обуви и аксессуаров. Бренд не устает удивлять разнообразием и качеством изготавливаемого ассортимента – сотни моделей, каждая из которых отличается необыкновенной комфортностью и эффективностью для занятия спортом и активного отдыха.\",\"category\":[\"men\",\"women\",\"accessories\",\"children\",\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":true,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:56:38.048Z\",\"updatedAt\":\"2025-03-04T03:11:52.129Z\",\"logo\":{\"id\":\"65802822e2f304ddab7c0483\",\"alt\":\"logo\",\"filename\":\"ADIDAS-1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":11014,\"width\":450,\"height\":135,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/jpeg\",\"filesize\":480,\"filename\":\"ADIDAS-1-32x9.jpg\",\"url\":\"/cms/media/ADIDAS-1-32x9.jpg\"},\"w64\":{\"width\":64,\"height\":19,\"mimeType\":\"image/jpeg\",\"filesize\":1013,\"filename\":\"ADIDAS-1-64x19.jpg\",\"url\":\"/cms/media/ADIDAS-1-64x19.jpg\"},\"w128\":{\"width\":128,\"height\":38,\"mimeType\":\"image/jpeg\",\"filesize\":2184,\"filename\":\"ADIDAS-1-128x38.jpg\",\"url\":\"/cms/media/ADIDAS-1-128x38.jpg\"},\"w384\":{\"width\":384,\"height\":115,\"mimeType\":\"image/jpeg\",\"filesize\":7190,\"filename\":\"ADIDAS-1-384x115.jpg\",\"url\":\"/cms/media/ADIDAS-1-384x115.jpg\"},\"w640\":{\"width\":640,\"height\":192,\"mimeType\":\"image/jpeg\",\"filesize\":11382,\"filename\":\"ADIDAS-1-640x192.jpg\",\"url\":\"/cms/media/ADIDAS-1-640x192.jpg\"},\"w1080\":{\"width\":1080,\"height\":324,\"mimeType\":\"image/jpeg\",\"filesize\":21142,\"filename\":\"ADIDAS-1-1080x324.jpg\",\"url\":\"/cms/media/ADIDAS-1-1080x324.jpg\"},\"w1920\":{\"width\":1920,\"height\":576,\"mimeType\":\"image/jpeg\",\"filesize\":43186,\"filename\":\"ADIDAS-1-1920x576.jpg\",\"url\":\"/cms/media/ADIDAS-1-1920x576.jpg\"},\"w3840\":{\"width\":3840,\"height\":1152,\"mimeType\":\"image/jpeg\",\"filesize\":113303,\"filename\":\"ADIDAS-1-3840x1152.jpg\",\"url\":\"/cms/media/ADIDAS-1-3840x1152.jpg\"}},\"createdAt\":\"2023-12-18T11:08:18.868Z\",\"updatedAt\":\"2025-08-29T10:51:36.631Z\",\"url\":\"/cms/media/ADIDAS-1.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d7087929e66c401c75b0\",\"name\":\"BELLFIELD\",\"description\":\"Торговая марка Bellfield появилась в 1970-х годах в Англии, специализируясь на производстве повседневной мужской и женской одежде. Потребителями бренда стали молодые активные люди, которые стремились выразить свою индивидуальность и выделиться из толпы.\",\"category\":[\"men\",\"women\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:56:24.396Z\",\"updatedAt\":\"2025-03-04T03:11:49.429Z\",\"logo\":{\"id\":\"6581f41d1766398cf584e8e2\",\"alt\":\"logo\",\"filename\":\"BELLFIELD (1).png\",\"mimeType\":\"image/png\",\"filesize\":4611,\"width\":225,\"height\":65,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":9,\"mimeType\":\"image/png\",\"filesize\":529,\"filename\":\"BELLFIELD (1)-32x9.png\",\"url\":\"/cms/media/BELLFIELD (1)-32x9.png\"},\"w64\":{\"width\":64,\"height\":18,\"mimeType\":\"image/png\",\"filesize\":1222,\"filename\":\"BELLFIELD (1)-64x18.png\",\"url\":\"/cms/media/BELLFIELD (1)-64x18.png\"},\"w128\":{\"width\":128,\"height\":37,\"mimeType\":\"image/png\",\"filesize\":2925,\"filename\":\"BELLFIELD (1)-128x37.png\",\"url\":\"/cms/media/BELLFIELD (1)-128x37.png\"},\"w384\":{\"width\":384,\"height\":111,\"mimeType\":\"image/png\",\"filesize\":14590,\"filename\":\"BELLFIELD (1)-384x111.png\",\"url\":\"/cms/media/BELLFIELD (1)-384x111.png\"},\"w640\":{\"width\":640,\"height\":185,\"mimeType\":\"image/png\",\"filesize\":33290,\"filename\":\"BELLFIELD (1)-640x185.png\",\"url\":\"/cms/media/BELLFIELD (1)-640x185.png\"},\"w1080\":{\"width\":1080,\"height\":312,\"mimeType\":\"image/png\",\"filesize\":79986,\"filename\":\"BELLFIELD (1)-1080x312.png\",\"url\":\"/cms/media/BELLFIELD (1)-1080x312.png\"},\"w1920\":{\"width\":1920,\"height\":555,\"mimeType\":\"image/png\",\"filesize\":202973,\"filename\":\"BELLFIELD (1)-1920x555.png\",\"url\":\"/cms/media/BELLFIELD (1)-1920x555.png\"},\"w3840\":{\"width\":3840,\"height\":1109,\"mimeType\":\"image/png\",\"filesize\":601841,\"filename\":\"BELLFIELD (1)-3840x1109.png\",\"url\":\"/cms/media/BELLFIELD (1)-3840x1109.png\"}},\"createdAt\":\"2023-12-19T19:50:53.893Z\",\"updatedAt\":\"2025-08-29T10:50:04.157Z\",\"url\":\"/cms/media/BELLFIELD (1).png\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d7087929e66c401c75ae\",\"name\":\"BENCH\",\"description\":\"Спортивная мода Одежда Bench — бренд, который популярен не только среди спортивной молодежи, он давно стал истинно молодежным, независимо насколько ты спортивен. Функциональность и удобство, модные усовершенствованные ткани, приемлемые цены, интерес молодежных кругов к марке — вот, что отличает Bench и делает ее узнаваемой не только среди молодежи Манчестера. Именно Манчестер (Великобритания) стал местом зарождения талантливой уникальной марки с хорошим набором качеств, за которые ее и любят. Современный урбанистический стиль бенч считается трендовым и знаком всему миру.\",\"category\":[\"men\",\"women\",\"accessories\",\"children\",\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:56:24.002Z\",\"updatedAt\":\"2025-03-04T03:11:49.339Z\",\"logo\":{\"id\":\"6581f40c1766398cf584e8a7\",\"alt\":\"logo\",\"filename\":\"bench-1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":5368,\"width\":195,\"height\":82,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"portrait\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"hero\":{\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null},\"w32\":{\"width\":32,\"height\":13,\"mimeType\":\"image/jpeg\",\"filesize\":545,\"filename\":\"bench-1-32x13.jpg\",\"url\":\"/cms/media/bench-1-32x13.jpg\"},\"w64\":{\"width\":64,\"height\":27,\"mimeType\":\"image/jpeg\",\"filesize\":922,\"filename\":\"bench-1-64x27.jpg\",\"url\":\"/cms/media/bench-1-64x27.jpg\"},\"w128\":{\"width\":128,\"height\":54,\"mimeType\":\"image/jpeg\",\"filesize\":2024,\"filename\":\"bench-1-128x54.jpg\",\"url\":\"/cms/media/bench-1-128x54.jpg\"},\"w384\":{\"width\":384,\"height\":161,\"mimeType\":\"image/jpeg\",\"filesize\":6341,\"filename\":\"bench-1-384x161.jpg\",\"url\":\"/cms/media/bench-1-384x161.jpg\"},\"w640\":{\"width\":640,\"height\":269,\"mimeType\":\"image/jpeg\",\"filesize\":11498,\"filename\":\"bench-1-640x269.jpg\",\"url\":\"/cms/media/bench-1-640x269.jpg\"},\"w1080\":{\"width\":1080,\"height\":454,\"mimeType\":\"image/jpeg\",\"filesize\":22816,\"filename\":\"bench-1-1080x454.jpg\",\"url\":\"/cms/media/bench-1-1080x454.jpg\"},\"w1920\":{\"width\":1920,\"height\":807,\"mimeType\":\"image/jpeg\",\"filesize\":51669,\"filename\":\"bench-1-1920x807.jpg\",\"url\":\"/cms/media/bench-1-1920x807.jpg\"},\"w3840\":{\"width\":3840,\"height\":1615,\"mimeType\":\"image/jpeg\",\"filesize\":140849,\"filename\":\"bench-1-3840x1615.jpg\",\"url\":\"/cms/media/bench-1-3840x1615.jpg\"}},\"createdAt\":\"2023-12-19T19:50:36.465Z\",\"updatedAt\":\"2025-08-29T10:50:04.093Z\",\"url\":\"/cms/media/bench-1.jpg\"},\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"domainZone\":[\"ru\",\"by\"],\"isLanding\":{}},{\"id\":\"6578d7007929e66c401c7588\",\"name\":\"BOHEMIA\",\"description\":\"Чешское и богемское стекло высоко ценится. Это — красивые, практичные материалы, а изделия из них обладают особым шармом благодаря тонкой работе и совершенному дизайну.\",\"category\":[\"for_home\"],\"status\":\"published\",\"isOnBlock\":{\"isOn\":true,\"isOnSync\":false},\"subscriptionOnBlock\":{\"subscriptionOn\":false,\"subscriptionOnSync\":true},\"forMain\":true,\"sort\":2,\"createdAt\":\"2023-12-12T21:56:16.427Z\",\"updatedAt\":\"2025-03-04T03:11:48.201Z\",\"logo\":{\"id\":\"65802ffce2f304ddab7c29d1\",\"alt\":\"logo\",\"filename\":\"Bohemia.png\",\"mimeType\":\"image/png\",\"filesize\":16898,\"width\":240,\"height\":127,\"sizes\":{\"thumbnail\":{\"width\":null,\"height\":null,\"mimeType\":null,\"fil