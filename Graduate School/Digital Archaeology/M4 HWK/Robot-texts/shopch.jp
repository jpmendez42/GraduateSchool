<div id="top-scp-contents" class="scp-include-contents">
  <div class="top-scp-content">
    <div class="top-scp-title">
      <div class="top-styling-img"><img src="/images/ss/header.png"/></div>
    </div>

    <div id="top-styling-contents" v-cloak="v-cloak">
      <div class="scp-include-title">
        <div class="subtitle">スタイリング</div>
        <div class="ss-all-btn arrow-right"><a :href="allDispLink + '&il=Top_ss_styling_all&ic=ss_styling_all'">一覧を見る</a></div>
      </div>
      <div class="ss-ajax-list">
        <ul>
          <li v-for="item in itemList">
            <a :href="'/pc/product/ssstyling/detail?stylingId=' + item.stylingId + '&il=Top_ss_styling&ic=ss_styling'">
              <div class="ss-ajax-content">
                <div class="image" :class="{'ico-movie': item.hasVideoFlg === '1'}"><img :src="item.imgM" width="168px" heigh="223px"/></div>
                <div class="body">
                  <div class="thumbnail"><img :src="item.profileImgS"/></div>
                  <div class="attributes">
                    <div class="name">{{ item.profileName }}</div>
                    <div class="height">{{ item.profileHeight != '－' ? item.profileHeight + 'cm' : '－ cm' }}</div>
                  </div>
                </div>
              </div>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div id="vsm-contents">
      <div id="vsm-toppage-border"></div>
      <div class="vsm-contents-header vsm-toppage">
        <div class="subtitle"><i class="icon"></i>#ショップチャンネル</div>
        <div class="more-button margin-r45 arrow-right">
          <a href="/pc/product/vsmcontents/list?il=Top_ss_vsm_all&ic=ss_vsm_all">一覧を見る</a>
        </div>
      </div>
      <div class="vsm-caption">皆さまの素敵なInstagram投稿をご紹介！ご投稿をお待ちしております。</div>
      <div id="vsm-thumbnail" class="vsm-thumbnail-container" v-cloak="v-cloak">
        <ul class="vsm-thumbnail-list">
          <template v-for="vsmContent in vsmContents">
            <li class="vsm-thumbnail">
              <a class="vsm-tracking" :href=`${vsmContent.href}&il=Top_ss_vsm&ic=ss_vsm` onclick="vsmTracking(event)" :data-vsmuserid="vsmContent.vsmUserId" :data-username="vsmContent.userName">
                <div class="image" :class="{'ico-movie': vsmContent.mediaType == 'video'}">
                  <img :src="vsmContent.img"/>
                </div>
              </a>
            </li>
          </template>
        </ul>
      </div>
    </div>

  </div>
</div>
<script>
