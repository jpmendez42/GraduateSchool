nelId\":\"36\"},{\"id\":\"97466878\",\"start\":\"2025-10-13T23:05:00.000Z\",\"stop\":\"2025-10-13T23:35:00.000Z\",\"title\":\"Krimi\",\"description\":\"\",\"durationMin\":30,\"genre\":null,\"slug\":\"krimi-97466878\",\"channelId\":\"36\"},{\"id\":\"97466879\",\"start\":\"2025-10-13T23:35:00.000Z\",\"stop\":\"2025-10-14T00:25:00.000Z\",\"title\":\"Zprávy TV JOJ\",\"description\":\"\",\"durationMin\":50,\"genre\":null,\"slug\":\"zpravy-tv-joj-97466879\",\"channelId\":\"36\"}],\"55\":[{\"id\":\"97320212\",\"start\":\"2025-10-13T00:05:00.000Z\",\"stop\":\"2025-10-13T00:20:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Fotka. Gumball se snaží vypadat na školní fotografii co nejlépe, aby po sobě nechal ten správný odkaz.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320212\",\"channelId\":\"55\"},{\"id\":\"97320213\",\"start\":\"2025-10-13T00:20:00.000Z\",\"stop\":\"2025-10-13T00:30:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320213\",\"channelId\":\"55\"},{\"id\":\"97320214\",\"start\":\"2025-10-13T00:30:00.000Z\",\"stop\":\"2025-10-13T00:50:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Lekce. Richard zaslechne, jak si z něj Gumball s Darwinem dělají legraci, což ho raní, a tak se rozhodne obnovit svou pověst hrdiny.\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320214\",\"channelId\":\"55\"},{\"id\":\"97320215\",\"start\":\"2025-10-13T00:50:00.000Z\",\"stop\":\"2025-10-13T01:00:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Hranice. Nicole se rozzlobí na svou rodinu, když při nákupu v supermarketu děti chtějí čokoládu a ona jim ji nechce koupit.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320215\",\"channelId\":\"55\"},{\"id\":\"97320216\",\"start\":\"2025-10-13T01:00:00.000Z\",\"stop\":\"2025-10-13T01:15:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320216\",\"channelId\":\"55\"},{\"id\":\"97320217\",\"start\":\"2025-10-13T01:15:00.000Z\",\"stop\":\"2025-10-13T01:25:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Slib. Gumball a Darwin zveřejní na portálu Elmore Plus výhružnou zprávu a pak se musí všem, které znají, omluvit.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320217\",\"channelId\":\"55\"},{\"id\":\"97320218\",\"start\":\"2025-10-13T01:25:00.000Z\",\"stop\":\"2025-10-13T01:45:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Hlas. Gumball a Darwin zveřejní na portálu Elmore Plus výhružnou zprávu a pak se musí všem, které znají, omluvit.\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320218\",\"channelId\":\"55\"},{\"id\":\"97320219\",\"start\":\"2025-10-13T01:45:00.000Z\",\"stop\":\"2025-10-13T02:00:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320219\",\"channelId\":\"55\"},{\"id\":\"97320220\",\"start\":\"2025-10-13T02:00:00.000Z\",\"stop\":\"2025-10-13T02:05:00.000Z\",\"title\":\"Lamput III\",\"description\":\"Superdoktoři. Hubeňour přinese špatnou tašku prádla s obleky, které propůjčují superschopnosti. Po uspokojivém dnu si Superdoktoři uvědomí své vyšší poslání. Boj se zlem a pomoc utlačovaným? Kdepak. Chytání Lamputa.\",\"durationMin\":5,\"genre\":null,\"slug\":\"lamput-iii-97320220\",\"channelId\":\"55\"},{\"id\":\"97320221\",\"start\":\"2025-10-13T02:05:00.000Z\",\"stop\":\"2025-10-13T02:15:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320221\",\"channelId\":\"55\"},{\"id\":\"97320222\",\"start\":\"2025-10-13T02:15:00.000Z\",\"stop\":\"2025-10-13T02:30:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320222\",\"channelId\":\"55\"},{\"id\":\"97320223\",\"start\":\"2025-10-13T02:30:00.000Z\",\"stop\":\"2025-10-13T02:40:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320223\",\"channelId\":\"55\"},{\"id\":\"97320224\",\"start\":\"2025-10-13T02:40:00.000Z\",\"stop\":\"2025-10-13T02:55:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320224\",\"channelId\":\"55\"},{\"id\":\"97320225\",\"start\":\"2025-10-13T02:55:00.000Z\",\"stop\":\"2025-10-13T03:05:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320225\",\"channelId\":\"55\"},{\"id\":\"97320226\",\"start\":\"2025-10-13T03:05:00.000Z\",\"stop\":\"2025-10-13T03:25:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320226\",\"channelId\":\"55\"},{\"id\":\"97320227\",\"start\":\"2025-10-13T03:25:00.000Z\",\"stop\":\"2025-10-13T03:36:00.000Z\",\"title\":\"Gumballův úžasný svět IV\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":11,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-iv-97320227\",\"channelId\":\"55\"},{\"id\":\"97320228\",\"start\":\"2025-10-13T03:36:00.000Z\",\"stop\":\"2025-10-13T03:40:00.000Z\",\"title\":\"Lamput III\",\"description\":\"Hubená příšera. Hubeňour nemůže spát kvůli škytavce a jde se v polospánku napít. Brýlák ale zapomněl na první pravidlo spolubydlení: NENECHÁVEJ POKUSY Z LABORATOŘE V KUCHYNI. Hubeňour se teď s každým škytnutím promění v příšeru.\",\"durationMin\":4,\"genre\":null,\"slug\":\"lamput-iii-97320228\",\"channelId\":\"55\"},{\"id\":\"97320229\",\"start\":\"2025-10-13T03:40:00.000Z\",\"stop\":\"2025-10-13T04:00:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97320229\",\"channelId\":\"55\"},{\"id\":\"97320230\",\"start\":\"2025-10-13T04:00:00.000Z\",\"stop\":\"2025-10-13T04:10:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Věc. Večeře s babičkou Jojo hrozí katastrofou, pokud si Richard nevzpomene na „tu věc“, o které s Nicole mluvili.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320230\",\"channelId\":\"55\"},{\"id\":\"97320231\",\"start\":\"2025-10-13T04:10:00.000Z\",\"stop\":\"2025-10-13T04:30:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Samá pozadí. Gumball musí pomoci řediteli Brownovi získat sebevědomí, aby mohl na recitálu poezie zazpívat svou báseň Samá pozadí.\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320231\",\"channelId\":\"55\"},{\"id\":\"97320232\",\"start\":\"2025-10-13T04:30:00.000Z\",\"stop\":\"2025-10-13T04:40:00.000Z\",\"title\":\"Gumballův úžasný svět VI\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-vi-97320232\",\"channelId\":\"55\"},{\"id\":\"97320233\",\"start\":\"2025-10-13T04:40:00.000Z\",\"stop\":\"2025-10-13T04:55:00.000Z\",\"title\":\"Gumballův úžasný svět VI\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-vi-97320233\",\"channelId\":\"55\"},{\"id\":\"97320234\",\"start\":\"2025-10-13T04:55:00.000Z\",\"stop\":\"2025-10-13T05:05:00.000Z\",\"title\":\"Gumballův úžasný svět VI\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-vi-97320234\",\"channelId\":\"55\"},{\"id\":\"97320235\",\"start\":\"2025-10-13T05:05:00.000Z\",\"stop\":\"2025-10-13T05:25:00.000Z\",\"title\":\"Gumballův úžasný svět VI\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-vi-97320235\",\"channelId\":\"55\"},{\"id\":\"97320236\",\"start\":\"2025-10-13T05:25:00.000Z\",\"stop\":\"2025-10-13T05:35:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Dopravní zácpa. Wattersonovi se musí dostat s Anais do Daisylandu dřív, než zábavní park definitivně uzavřou.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320236\",\"channelId\":\"55\"},{\"id\":\"97320237\",\"start\":\"2025-10-13T05:35:00.000Z\",\"stop\":\"2025-10-13T05:50:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320237\",\"channelId\":\"55\"},{\"id\":\"97320238\",\"start\":\"2025-10-13T05:50:00.000Z\",\"stop\":\"2025-10-13T06:05:00.000Z\",\"title\":\"Gumballův úžasný svět VI\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-vi-97320238\",\"channelId\":\"55\"},{\"id\":\"97320239\",\"start\":\"2025-10-13T06:05:00.000Z\",\"stop\":\"2025-10-13T06:25:00.000Z\",\"title\":\"Gumballův úžasný svět VI\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-vi-97320239\",\"channelId\":\"55\"},{\"id\":\"97320240\",\"start\":\"2025-10-13T06:25:00.000Z\",\"stop\":\"2025-10-13T06:35:00.000Z\",\"title\":\"Craig od potoka\",\"description\":\"Seriál Craig od potoka pojednává o Craigovi a jeho dvou nejlepších kamarádech, Kelsey a JP. Děti se vydávají na různá dobrodružství do nepokořené předměstské divočiny, která se rozléhá kolem místního potoka. V této dětské utopii různé dětské kmeny vládnou pevnostem či cyklo rampám a vytvářejí osobitou dětskou společnost.\",\"durationMin\":10,\"genre\":null,\"slug\":\"craig-od-potoka-97320240\",\"channelId\":\"55\"},{\"id\":\"97320241\",\"start\":\"2025-10-13T06:35:00.000Z\",\"stop\":\"2025-10-13T06:50:00.000Z\",\"title\":\"Craig od potoka\",\"description\":\"Seriál Craig od potoka pojednává o Craigovi a jeho dvou nejlepších kamarádech, Kelsey a JP. Děti se vydávají na různá dobrodružství do nepokořené předměstské divočiny, která se rozléhá kolem místního potoka. V této dětské utopii různé dětské kmeny vládnou pevnostem či cyklo rampám a vytvářejí osobitou dětskou společnost.\",\"durationMin\":15,\"genre\":null,\"slug\":\"craig-od-potoka-97320241\",\"channelId\":\"55\"},{\"id\":\"97320242\",\"start\":\"2025-10-13T06:50:00.000Z\",\"stop\":\"2025-10-13T07:00:00.000Z\",\"title\":\"Craig od potoka\",\"description\":\"Seriál Craig od potoka pojednává o Craigovi a jeho dvou nejlepších kamarádech, Kelsey a JP. Děti se vydávají na různá dobrodružství do nepokořené předměstské divočiny, která se rozléhá kolem místního potoka. V této dětské utopii různé dětské kmeny vládnou pevnostem či cyklo rampám a vytvářejí osobitou dětskou společnost.\",\"durationMin\":10,\"genre\":null,\"slug\":\"craig-od-potoka-97320242\",\"channelId\":\"55\"},{\"id\":\"97320243\",\"start\":\"2025-10-13T07:00:00.000Z\",\"stop\":\"2025-10-13T07:20:00.000Z\",\"title\":\"Craig od potoka\",\"description\":\"Seriál Craig od potoka pojednává o Craigovi a jeho dvou nejlepších kamarádech, Kelsey a JP. Děti se vydávají na různá dobrodružství do nepokořené předměstské divočiny, která se rozléhá kolem místního potoka. V této dětské utopii různé dětské kmeny vládnou pevnostem či cyklo rampám a vytvářejí osobitou dětskou společnost.\",\"durationMin\":20,\"genre\":null,\"slug\":\"craig-od-potoka-97320243\",\"channelId\":\"55\"},{\"id\":\"97320244\",\"start\":\"2025-10-13T07:20:00.000Z\",\"stop\":\"2025-10-13T07:30:00.000Z\",\"title\":\"Mladí Titáni do toho! VII\",\"description\":\"Mladí Titáni do toho! je komediální pohled na život superhrdinů. Diváci dostanou možnost sledovat, jaký život má super mládež.\",\"durationMin\":10,\"genre\":null,\"slug\":\"mladi-titani-do-toho-vii-97320244\",\"channelId\":\"55\"},{\"id\":\"97320245\",\"start\":\"2025-10-13T07:30:00.000Z\",\"stop\":\"2025-10-13T07:45:00.000Z\",\"title\":\"Mladí Titáni do toho! VII\",\"description\":\"Podomní piráti. Ve snaze získat zpátky ukradený balíček se Titáni musí připojit k posádce podomních pirátů.\",\"durationMin\":15,\"genre\":null,\"slug\":\"mladi-titani-do-toho-vii-97320245\",\"channelId\":\"55\"},{\"id\":\"97320246\",\"start\":\"2025-10-13T07:45:00.000Z\",\"stop\":\"2025-10-13T07:55:00.000Z\",\"title\":\"Mladí Titáni do toho! VII\",\"description\":\"Kyle. Titáni cestují zpátky v čase do 90. let, aby navštívili videopůjčovnu, kde narazí na starého známého.\",\"durationMin\":10,\"genre\":null,\"slug\":\"mladi-titani-do-toho-vii-97320246\",\"channelId\":\"55\"},{\"id\":\"97320247\",\"start\":\"2025-10-13T07:55:00.000Z\",\"stop\":\"2025-10-13T08:15:00.000Z\",\"title\":\"Mladí Titáni do toho! II\",\"description\":\"Příběhy od táboráku. Titáni zažívají příšerný výlet pod širák, a tak se Robin nabídne, že ho okoření strašidelným vyprávěním.\",\"durationMin\":20,\"genre\":null,\"slug\":\"mladi-titani-do-toho-ii-97320247\",\"channelId\":\"55\"},{\"id\":\"97528893\",\"start\":\"2025-10-13T08:15:00.000Z\",\"stop\":\"2025-10-13T08:25:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97528893\",\"channelId\":\"55\"},{\"id\":\"97528894\",\"start\":\"2025-10-13T08:25:00.000Z\",\"stop\":\"2025-10-13T08:45:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97528894\",\"channelId\":\"55\"},{\"id\":\"97320250\",\"start\":\"2025-10-13T08:45:00.000Z\",\"stop\":\"2025-10-13T08:55:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Věc. Večeře s babičkou Jojo hrozí katastrofou, pokud si Richard nevzpomene na „tu věc“, o které s Nicole mluvili.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320250\",\"channelId\":\"55\"},{\"id\":\"97320251\",\"start\":\"2025-10-13T08:55:00.000Z\",\"stop\":\"2025-10-13T09:10:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Samá pozadí. Gumball musí pomoci řediteli Brownovi získat sebevědomí, aby mohl na recitálu poezie zazpívat svou báseň Samá pozadí.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320251\",\"channelId\":\"55\"},{\"id\":\"97320252\",\"start\":\"2025-10-13T09:10:00.000Z\",\"stop\":\"2025-10-13T09:20:00.000Z\",\"title\":\"Totální Dramarama II\",\"description\":\"Pekelně pálivá paprička. Duncan uvaří nukleární pálivou omáčku, aby doběhl Šéfa. Ale místo toho omylem vyvolá Teryho Spice, krále podsvětí!\",\"durationMin\":10,\"genre\":null,\"slug\":\"totalni-dramarama-ii-97320252\",\"channelId\":\"55\"},{\"id\":\"97320253\",\"start\":\"2025-10-13T09:20:00.000Z\",\"stop\":\"2025-10-13T09:30:00.000Z\",\"title\":\"Totální Dramarama II\",\"description\":\"Trubka netrubka. Třída pomůže Šéfovi splnit sen: Zahrát si v kapele Tubalicious. Ale to ještě netuší, jak moc jim bude chybět.\",\"durationMin\":10,\"genre\":null,\"slug\":\"totalni-dramarama-ii-97320253\",\"channelId\":\"55\"},{\"id\":\"97320254\",\"start\":\"2025-10-13T09:30:00.000Z\",\"stop\":\"2025-10-13T09:50:00.000Z\",\"title\":\"Totální Dramarama II\",\"description\":\"Kámo, kde mám papoucha? Šéf se snaží udržet si status elitního hráče, ovšem díky cheatům přivede do reality nebezpečnou postavičku.\",\"durationMin\":20,\"genre\":null,\"slug\":\"totalni-dramarama-ii-97320254\",\"channelId\":\"55\"},{\"id\":\"97320255\",\"start\":\"2025-10-13T09:50:00.000Z\",\"stop\":\"2025-10-13T09:55:00.000Z\",\"title\":\"Totální Dramarama II\",\"description\":\"Zpátečník Wendel. Courntey musí úmyslně v něčem prohrát, nebo se celý svět bude muset vrátit v čase. Bude to těžká volba...\",\"durationMin\":5,\"genre\":null,\"slug\":\"totalni-dramarama-ii-97320255\",\"channelId\":\"55\"},{\"id\":\"97320256\",\"start\":\"2025-10-13T09:55:00.000Z\",\"stop\":\"2025-10-13T10:05:00.000Z\",\"title\":\"Totální Dramarama II\",\"description\":\"Bodání v dešti. Šéf se omylem zamkne venku během bouře a děcka, která ho považují za lupiče, budou bránit školku ať to stojí co to stojí.\",\"durationMin\":10,\"genre\":null,\"slug\":\"totalni-dramarama-ii-97320256\",\"channelId\":\"55\"},{\"id\":\"97320257\",\"start\":\"2025-10-13T10:05:00.000Z\",\"stop\":\"2025-10-13T10:25:00.000Z\",\"title\":\"Totální Dramarama II\",\"description\":\"Realismus animáků. Gwen je frustrovaná Bethiným dětinským přesvědčením, že animáky jsou skutečné. Během návštěvy animačního studia však zjistí, že má Beth pravdu.\",\"durationMin\":20,\"genre\":null,\"slug\":\"totalni-dramarama-ii-97320257\",\"channelId\":\"55\"},{\"id\":\"97320258\",\"start\":\"2025-10-13T10:25:00.000Z\",\"stop\":\"2025-10-13T10:50:00.000Z\",\"title\":\"Ninjago: Dračí povstání III\",\"description\":\"Poté, co živelná pohroma navždy změní svět, noví a staří ninjové se musí spojit na záchranu říší před technologickými zlouny směřujícími k nadvládě.\",\"durationMin\":25,\"genre\":null,\"slug\":\"ninjago-draci-povstani-iii-97320258\",\"channelId\":\"55\"},{\"id\":\"97320259\",\"start\":\"2025-10-13T10:50:00.000Z\",\"stop\":\"2025-10-13T11:00:00.000Z\",\"title\":\"Craig od potoka\",\"description\":\"Motokáry od potoka. Motokárové závody u potoka jsou dravé a nelítostné a pro Craiga a jeho kamarády možná představují příliš velké sousto.\",\"durationMin\":10,\"genre\":null,\"slug\":\"craig-od-potoka-97320259\",\"channelId\":\"55\"},{\"id\":\"97320260\",\"start\":\"2025-10-13T11:00:00.000Z\",\"stop\":\"2025-10-13T11:20:00.000Z\",\"title\":\"Craig od potoka\",\"description\":\"Tajný knižní klub. Kelsey založí super tajný čtenářský klub, aby zasvětila Craiga a JPho do tajů radosti ze čtení.\",\"durationMin\":20,\"genre\":null,\"slug\":\"craig-od-potoka-97320260\",\"channelId\":\"55\"},{\"id\":\"97320261\",\"start\":\"2025-10-13T11:20:00.000Z\",\"stop\":\"2025-10-13T11:30:00.000Z\",\"title\":\"Králíčkula\",\"description\":\"Pískací zhouba. Duch zlého vikingského válečníka obživne a vtělí se do pískací psí hračky. Pak se chce ze všeho nejdřív pomstít králíkovi, který ho uvěznil.\",\"durationMin\":10,\"genre\":null,\"slug\":\"kralickula-97320261\",\"channelId\":\"55\"},{\"id\":\"97320262\",\"start\":\"2025-10-13T11:30:00.000Z\",\"stop\":\"2025-10-13T11:50:00.000Z\",\"title\":\"Králíčkula\",\"description\":\"Králíčkulův syn. Chester si myslí, že když Králíčkula vysaje lilek, snese vejce. A tak se králík rozhodne, že si z něj vystřelí a převlékne se za své vlastní dítě.\",\"durationMin\":20,\"genre\":null,\"slug\":\"kralickula-97320262\",\"channelId\":\"55\"},{\"id\":\"97320263\",\"start\":\"2025-10-13T11:50:00.000Z\",\"stop\":\"2025-10-13T12:00:00.000Z\",\"title\":\"Clarence III\",\"description\":\"Cloris. Clarence se seznámí s postarší paní v místním domově důchodců. Dojde k závěru, že jí musí připomenout, jaká byla dřív, aby ze staré nabručené babičky zase udělal veselou bytost.\",\"durationMin\":10,\"genre\":null,\"slug\":\"clarence-iii-97320263\",\"channelId\":\"55\"},{\"id\":\"97320264\",\"start\":\"2025-10-13T12:00:00.000Z\",\"stop\":\"2025-10-13T12:15:00.000Z\",\"title\":\"Clarence III\",\"description\":\"Vítejte v Clarencově světě! Možná vypadá obyčejně, ale při pohledu Clarencovýma očima je najednou plný zázraků a možností. Veselý, upřímný, svérázný a neochvějně pozitivní Clarence dokáže objevovat zábavu, která většině lidí uniká.\",\"durationMin\":15,\"genre\":null,\"slug\":\"clarence-iii-97320264\",\"channelId\":\"55\"},{\"id\":\"97320265\",\"start\":\"2025-10-13T12:15:00.000Z\",\"stop\":\"2025-10-13T12:30:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Dopravní zácpa. Wattersonovi se musí dostat s Anais do Daisylandu dřív, než zábavní park definitivně uzavřou.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320265\",\"channelId\":\"55\"},{\"id\":\"97320266\",\"start\":\"2025-10-13T12:30:00.000Z\",\"stop\":\"2025-10-13T12:45:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320266\",\"channelId\":\"55\"},{\"id\":\"97320267\",\"start\":\"2025-10-13T12:45:00.000Z\",\"stop\":\"2025-10-13T12:55:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97320267\",\"channelId\":\"55\"},{\"id\":\"97320268\",\"start\":\"2025-10-13T12:55:00.000Z\",\"stop\":\"2025-10-13T13:15:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97320268\",\"channelId\":\"55\"},{\"id\":\"97320269\",\"start\":\"2025-10-13T13:15:00.000Z\",\"stop\":\"2025-10-13T13:25:00.000Z\",\"title\":\"Totální Dramarama III\",\"description\":\"Vymaž si hlavu. Gwen si do školky objedná balíček s blasterem, který dokáže změnit povahu člověka. Než ho namíří na své rodiče, kteří jsou správní mileniálové, rozhodne se ho vyzkoušet na svých spolužácích ze školky.\",\"durationMin\":10,\"genre\":null,\"slug\":\"totalni-dramarama-iii-97320269\",\"channelId\":\"55\"},{\"id\":\"97320270\",\"start\":\"2025-10-13T13:25:00.000Z\",\"stop\":\"2025-10-13T13:30:00.000Z\",\"title\":\"Totální Dramarama III\",\"description\":\"Učitel, voják, šéf, špión. Šéf vyvine VR hru, ve které chrání školku před vetřelci. Vše se zvrtne, když děti rozbijí jeho brýle.\",\"durationMin\":5,\"genre\":null,\"slug\":\"totalni-dramarama-iii-97320270\",\"channelId\":\"55\"},{\"id\":\"97320271\",\"start\":\"2025-10-13T13:30:00.000Z\",\"stop\":\"2025-10-13T13:40:00.000Z\",\"title\":\"Totální Dramarama III\",\"description\":\"Sloněcokan. Šéf zapomněl připravit děti na sportovní testování. Pro zvýšení motivace si děti vytvoří maskota, který začne ohrožovat světovou rovnováhu školního ducha.\",\"durationMin\":10,\"genre\":null,\"slug\":\"totalni-dramarama-iii-97320271\",\"channelId\":\"55\"},{\"id\":\"97320272\",\"start\":\"2025-10-13T13:40:00.000Z\",\"stop\":\"2025-10-13T14:00:00.000Z\",\"title\":\"Totální Dramarama III\",\"description\":\"KoudE.T. Cody se rozbije během hry Kačer, kačer, husa. Courtney si myslí, že jí to budou klást mimozemšťani za vinu, a tak se veškerými silami snaží zabránit tomu, aby Harold kontaktoval Codyho domovskou planetu.\",\"durationMin\":20,\"genre\":null,\"slug\":\"totalni-dramarama-iii-97320272\",\"channelId\":\"55\"},{\"id\":\"97320273\",\"start\":\"2025-10-13T14:00:00.000Z\",\"stop\":\"2025-10-13T14:10:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320273\",\"channelId\":\"55\"},{\"id\":\"97320274\",\"start\":\"2025-10-13T14:10:00.000Z\",\"stop\":\"2025-10-13T14:25:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Samá pozadí. Gumball musí pomoci řediteli Brownovi získat sebevědomí, aby mohl na recitálu poezie zazpívat svou báseň Samá pozadí.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320274\",\"channelId\":\"55\"},{\"id\":\"97320275\",\"start\":\"2025-10-13T14:25:00.000Z\",\"stop\":\"2025-10-13T14:40:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320275\",\"channelId\":\"55\"},{\"id\":\"97320276\",\"start\":\"2025-10-13T14:40:00.000Z\",\"stop\":\"2025-10-13T14:55:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Odloučení. Gumball musí najít způsob, jak zachránit vztah, který má s Darwinem, když jsou přinuceni mít každý svůj pokoj.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320276\",\"channelId\":\"55\"},{\"id\":\"97320277\",\"start\":\"2025-10-13T14:55:00.000Z\",\"stop\":\"2025-10-13T15:05:00.000Z\",\"title\":\"Craig od potoka II\",\"description\":\"V tónině potoka. Craig musí kvůli dešti zůstat doma, a tak si pomocí hraček a představivosti vytvoří vlastní dobrodružství v prvním hudebním díle Craiga od potoka!\",\"durationMin\":10,\"genre\":null,\"slug\":\"craig-od-potoka-ii-97320277\",\"channelId\":\"55\"},{\"id\":\"97320278\",\"start\":\"2025-10-13T15:05:00.000Z\",\"stop\":\"2025-10-13T15:25:00.000Z\",\"title\":\"Craig od potoka III\",\"description\":\"Země je láva! Když vypukne hra Země je láva!, Craig musí opatrně překonat údolí potoka a zachránit svou sestru.\",\"durationMin\":20,\"genre\":null,\"slug\":\"craig-od-potoka-iii-97320278\",\"channelId\":\"55\"},{\"id\":\"97320279\",\"start\":\"2025-10-13T15:25:00.000Z\",\"stop\":\"2025-10-13T15:35:00.000Z\",\"title\":\"Craig od potoka III\",\"description\":\"Rada od potoka: Operace Včelí roj. Včelí roj - Když včely ovládnou Výměnný strom, musí Craig svolat Radu od potoka, aby zabránila katastrofě.\",\"durationMin\":10,\"genre\":null,\"slug\":\"craig-od-potoka-iii-97320279\",\"channelId\":\"55\"},{\"id\":\"97320280\",\"start\":\"2025-10-13T15:35:00.000Z\",\"stop\":\"2025-10-13T15:55:00.000Z\",\"title\":\"Craig od potoka III\",\"description\":\"Seriál Craig od potoka pojednává o Craigovi a jeho dvou nejlepších kamarádech, Kelsey a JP. Děti se vydávají na různá dobrodružství do nepokořené předměstské divočiny, která se rozléhá kolem místního potoka. V této dětské utopii různé dětské kmeny vládnou pevnostem či cyklo rampám a vytvářejí osobitou dětskou společnost.\",\"durationMin\":20,\"genre\":null,\"slug\":\"craig-od-potoka-iii-97320280\",\"channelId\":\"55\"},{\"id\":\"97320281\",\"start\":\"2025-10-13T15:55:00.000Z\",\"stop\":\"2025-10-13T16:05:00.000Z\",\"title\":\"Clarence\",\"description\":\"Tajemství půdy. Clarence je nucený jít s mámou na upjatou společenskou večeři. A musí tak vymyslet, jak vnést do situace alespoň trochu zábavy, aby se to dalo přežít.\",\"durationMin\":10,\"genre\":null,\"slug\":\"clarence-97320281\",\"channelId\":\"55\"},{\"id\":\"97320282\",\"start\":\"2025-10-13T16:05:00.000Z\",\"stop\":\"2025-10-13T16:20:00.000Z\",\"title\":\"Clarence\",\"description\":\"Vítejte v Clarencově světě! Možná vypadá obyčejně, ale při pohledu Clarencovýma očima je najednou plný zázraků a možností. Veselý, upřímný, svérázný a neochvějně pozitivní Clarence dokáže objevovat zábavu, která většině lidí uniká.\",\"durationMin\":15,\"genre\":null,\"slug\":\"clarence-97320282\",\"channelId\":\"55\"},{\"id\":\"97320283\",\"start\":\"2025-10-13T16:20:00.000Z\",\"stop\":\"2025-10-13T16:35:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320283\",\"channelId\":\"55\"},{\"id\":\"97320284\",\"start\":\"2025-10-13T16:35:00.000Z\",\"stop\":\"2025-10-13T16:50:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Samá pozadí. Gumball musí pomoci řediteli Brownovi získat sebevědomí, aby mohl na recitálu poezie zazpívat svou báseň Samá pozadí.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320284\",\"channelId\":\"55\"},{\"id\":\"97320285\",\"start\":\"2025-10-13T16:50:00.000Z\",\"stop\":\"2025-10-13T17:00:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97320285\",\"channelId\":\"55\"},{\"id\":\"97320286\",\"start\":\"2025-10-13T17:00:00.000Z\",\"stop\":\"2025-10-13T17:20:00.000Z\",\"title\":\"Gumballův úžasný svět V\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-v-97320286\",\"channelId\":\"55\"},{\"id\":\"97320287\",\"start\":\"2025-10-13T17:20:00.000Z\",\"stop\":\"2025-10-13T17:30:00.000Z\",\"title\":\"Mladí Titáni do toho! VIII\",\"description\":\"Mladí Titáni do toho! je komediální pohled na život superhrdinů. Diváci dostanou možnost sledovat, jaký život má super mládež.\",\"durationMin\":10,\"genre\":null,\"slug\":\"mladi-titani-do-toho-viii-97320287\",\"channelId\":\"55\"},{\"id\":\"97320288\",\"start\":\"2025-10-13T17:30:00.000Z\",\"stop\":\"2025-10-13T17:45:00.000Z\",\"title\":\"Mladí Titáni do toho! VII\",\"description\":\"Podomní piráti. Ve snaze získat zpátky ukradený balíček se Titáni musí připojit k posádce podomních pirátů.\",\"durationMin\":15,\"genre\":null,\"slug\":\"mladi-titani-do-toho-vii-97320288\",\"channelId\":\"55\"},{\"id\":\"97320289\",\"start\":\"2025-10-13T17:45:00.000Z\",\"stop\":\"2025-10-13T17:55:00.000Z\",\"title\":\"Mladí Titáni do toho! VI\",\"description\":\"Duch s velkým D. Když dojde k únosu ducha Halloweenu, musí Titáni spojit síly s Beetlejuicem, aby zachránili svátky.\",\"durationMin\":10,\"genre\":null,\"slug\":\"mladi-titani-do-toho-vi-97320289\",\"channelId\":\"55\"},{\"id\":\"97320290\",\"start\":\"2025-10-13T17:55:00.000Z\",\"stop\":\"2025-10-13T18:10:00.000Z\",\"title\":\"Mladí Titáni do toho! VII\",\"description\":\"Kyle. Titáni cestují zpátky v čase do 90. let, aby navštívili videopůjčovnu, kde narazí na starého známého.\",\"durationMin\":15,\"genre\":null,\"slug\":\"mladi-titani-do-toho-vii-97320290\",\"channelId\":\"55\"},{\"id\":\"97320291\",\"start\":\"2025-10-13T18:10:00.000Z\",\"stop\":\"2025-10-13T18:25:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320291\",\"channelId\":\"55\"},{\"id\":\"97320292\",\"start\":\"2025-10-13T18:25:00.000Z\",\"stop\":\"2025-10-13T18:40:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320292\",\"channelId\":\"55\"},{\"id\":\"97320293\",\"start\":\"2025-10-13T18:40:00.000Z\",\"stop\":\"2025-10-13T18:50:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Poklad. Anais odhalí tajemství, o kterém je přesvědčena, že ji dovede ke skrytému rodinnému pokladu Wattersonových.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320293\",\"channelId\":\"55\"},{\"id\":\"97320294\",\"start\":\"2025-10-13T18:50:00.000Z\",\"stop\":\"2025-10-13T19:05:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320294\",\"channelId\":\"55\"},{\"id\":\"97320295\",\"start\":\"2025-10-13T19:05:00.000Z\",\"stop\":\"2025-10-13T19:25:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320295\",\"channelId\":\"55\"},{\"id\":\"97320296\",\"start\":\"2025-10-13T19:25:00.000Z\",\"stop\":\"2025-10-13T19:35:00.000Z\",\"title\":\"Čas na dobrodružství V\",\"description\":\"Seznamte se s klukem Finnem a kouzelným psem Jakem kteří žijí v Zemi Óóó a prožívají nesčetná dobrodružství při nichž zachraňují princezny bojují se zlými příšerami a hatí plány různým zloduchům!\",\"durationMin\":10,\"genre\":null,\"slug\":\"cas-na-dobrodruzstvi-v-97320296\",\"channelId\":\"55\"},{\"id\":\"97320297\",\"start\":\"2025-10-13T19:35:00.000Z\",\"stop\":\"2025-10-13T19:50:00.000Z\",\"title\":\"Čas na dobrodružství V\",\"description\":\"Příliš stará. Finn, Jake a princezna Žvýkačka na Slavnosti mutantů objeví talentovaného mutanta jménem Citronaděj. Nyní musejí najít způsob, jak ho osvobodit od citrochňapů.\",\"durationMin\":15,\"genre\":null,\"slug\":\"cas-na-dobrodruzstvi-v-97320297\",\"channelId\":\"55\"},{\"id\":\"97320298\",\"start\":\"2025-10-13T19:50:00.000Z\",\"stop\":\"2025-10-13T20:00:00.000Z\",\"title\":\"Čas na dobrodružství V\",\"description\":\"Časový sendvič. Jake vyrábí ten nejchutnější sendvič všech dob, ale když ho Mystický mág ukradne, Finn musí vzdorovat zákonům prostoru a času, aby Jakeův výtvor získal zpátky.\",\"durationMin\":10,\"genre\":null,\"slug\":\"cas-na-dobrodruzstvi-v-97320298\",\"channelId\":\"55\"},{\"id\":\"97320299\",\"start\":\"2025-10-13T20:00:00.000Z\",\"stop\":\"2025-10-13T20:20:00.000Z\",\"title\":\"Čas na dobrodružství V\",\"description\":\"Země a voda. Princezna Žvýkačka provede s Plamennou princeznou sérii testů, aby změřila její ohnivý potenciál.\",\"durationMin\":20,\"genre\":null,\"slug\":\"cas-na-dobrodruzstvi-v-97320299\",\"channelId\":\"55\"},{\"id\":\"97320300\",\"start\":\"2025-10-13T20:20:00.000Z\",\"stop\":\"2025-10-13T20:30:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Vítejte zpět v Elmóru! Čekají vás překvapivé zvraty, bizarní humor, neobyčejný rodinný život. To je teď nový Gumballův báječně potrhlý svět!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320300\",\"channelId\":\"55\"},{\"id\":\"97320301\",\"start\":\"2025-10-13T20:30:00.000Z\",\"stop\":\"2025-10-13T20:45:00.000Z\",\"title\":\"Gumballův báječně potrhlý svět\",\"description\":\"Samá pozadí. Gumball musí pomoci řediteli Brownovi získat sebevědomí, aby mohl na recitálu poezie zazpívat svou báseň Samá pozadí.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-bajecne-potrhly-svet-97320301\",\"channelId\":\"55\"},{\"id\":\"97320302\",\"start\":\"2025-10-13T20:45:00.000Z\",\"stop\":\"2025-10-13T20:55:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Zrádci. Když Darwin dopustí, aby Gumball dostal výprask od Tiny, Gumball se rozhodne dát Darwinovi lekci.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320302\",\"channelId\":\"55\"},{\"id\":\"97320303\",\"start\":\"2025-10-13T20:55:00.000Z\",\"stop\":\"2025-10-13T21:15:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320303\",\"channelId\":\"55\"},{\"id\":\"97320304\",\"start\":\"2025-10-13T21:15:00.000Z\",\"stop\":\"2025-10-13T21:25:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320304\",\"channelId\":\"55\"},{\"id\":\"97320305\",\"start\":\"2025-10-13T21:25:00.000Z\",\"stop\":\"2025-10-13T21:40:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Poník. Gumball a Darwin si vypůjčí film s názvem Poníkův ocas, na který se chtějí s Anais podívat. Cestou domů je však pořád něco zdražuje.\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320305\",\"channelId\":\"55\"},{\"id\":\"97320306\",\"start\":\"2025-10-13T21:40:00.000Z\",\"stop\":\"2025-10-13T21:50:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320306\",\"channelId\":\"55\"},{\"id\":\"97320307\",\"start\":\"2025-10-13T21:50:00.000Z\",\"stop\":\"2025-10-13T22:05:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320307\",\"channelId\":\"55\"},{\"id\":\"97320308\",\"start\":\"2025-10-13T22:05:00.000Z\",\"stop\":\"2025-10-13T22:20:00.000Z\",\"title\":\"Gumballův úžasný svět II\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":15,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-ii-97320308\",\"channelId\":\"55\"},{\"id\":\"97320309\",\"start\":\"2025-10-13T22:20:00.000Z\",\"stop\":\"2025-10-13T22:30:00.000Z\",\"title\":\"Gumballův úžasný svět\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-97320309\",\"channelId\":\"55\"},{\"id\":\"97320310\",\"start\":\"2025-10-13T22:30:00.000Z\",\"stop\":\"2025-10-13T22:50:00.000Z\",\"title\":\"Gumballův úžasný svět\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":20,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-97320310\",\"channelId\":\"55\"},{\"id\":\"97320311\",\"start\":\"2025-10-13T22:50:00.000Z\",\"stop\":\"2025-10-13T23:00:00.000Z\",\"title\":\"Gumballův úžasný svět\",\"description\":\"Seznamte se s Wattersonovými: mámou, tátou, Anais, Darwinem a samozřejmě také Gumballem, dvanáctiletým kocourkem se sklonem k nejrůznějším nehodám!\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-97320311\",\"channelId\":\"55\"},{\"id\":\"97320312\",\"start\":\"2025-10-13T23:00:00.000Z\",\"stop\":\"2025-10-13T23:10:00.000Z\",\"title\":\"Gumballův úžasný svět\",\"description\":\"Ponožka. Gumballovi a Darwinovi se od školního poradce dostává velmi matoucích lekcí čestného chování.\",\"durationMin\":10,\"genre\":null,\"slug\":\"gumballuv-uzasny-svet-97320312\",\"channelId\":\"55\"},{\"id\":\"97320313\",\"start\":\"2025-10-13T23:10:00.000Z\",\"stop\":\"2025-10-13T23: