<script type="text/javascript">
	//「すべてのエリア」が選択された場合、他エリアの選択を外す
	jQuery('#area-00').on('click', function() {
		if (jQuery(this).prop('checked') === true) {
			jQuery('[name="reg[]"]:checked').each(function(){
				if (jQuery(this).val() === 'all-area') { return true; }
			    jQuery(this).prop('checked', false);
			 });
		}
	});
	//「すべてのエリア」が選択された状態で他エリアの選択した場合、「すべてのエリア」の選択を外す
	jQuery('[name="reg[]"]').on('click', function () {
		if ((jQuery(this).val() !== 'all-area') && (jQuery('#area-00').prop('checked') === true)) {
			jQuery('#area-00').prop('checked', false);
		}
	});

	jQuery('.search-form__submit').on('click', function() {
		var params = "";
		//検索ページ（/search）以外のページから検索した場合、現在の地域を検索条件に含める
		if ((!params) && (location.href.indexOf('/search') === -1)) {
			var current_region = "";
			var current_region_id = "";
			if (current_region !== null && current_region_id !== null) {
				var target_id = jQuery('.'+current_region).prop('for');
				jQuery('.search-form__submit').after('<input type="hidden" name="reg[]" value="' + current_region_id + '" />');
			}
		//虫眼鏡ボタン（キーワード検索）で検索した場合、「絞り込み」の条件を引き継ぐ
		}else{
			var reg = JSON.parse('null');
			if (reg.length !== 0) { set_conditions(reg, 'reg'); }
			var cat = JSON.parse('null');
			if (cat.length !== 0) { set_conditions(cat, 'cat'); }
			var area_reporter = JSON.parse('""');
			if (area_reporter.length !== 0) { set_conditions(area_reporter, 'area_reporter'); }
		}
	});

	function set_conditions(condition, condition_name) {
		jQuery(condition).each(function(index, val){
			jQuery('.search-form__submit').after('<input type="hidden" name="'+condition_name+'[]" value="' + val + '" />');
		});
	}

</script>	<h2 class="hd-map">エリアから探す</h2>
