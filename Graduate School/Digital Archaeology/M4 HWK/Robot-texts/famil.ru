,\"width\":64,\"height\":91,\"mimeType\":\"image/jpeg\",\"filesize\":2470,\"filename\":\"z7thhubpjss28wu7vq8g3ij-64x91.jpg\"},\"w128\":{\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij-128x182.jpg\",\"width\":128,\"height\":182,\"mimeType\":\"image/jpeg\",\"filesize\":6807,\"filename\":\"z7thhubpjss28wu7vq8g3ij-128x182.jpg\"},\"w384\":{\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij-384x543.jpg\",\"width\":384,\"height\":543,\"mimeType\":\"image/jpeg\",\"filesize\":37814,\"filename\":\"z7thhubpjss28wu7vq8g3ij-384x543.jpg\"},\"w640\":{\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij-640x906.jpg\",\"width\":640,\"height\":906,\"mimeType\":\"image/jpeg\",\"filesize\":92229,\"filename\":\"z7thhubpjss28wu7vq8g3ij-640x906.jpg\"},\"w1080\":{\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij-1080x1529.jpg\",\"width\":1080,\"height\":1529,\"mimeType\":\"image/jpeg\",\"filesize\":246716,\"filename\":\"z7thhubpjss28wu7vq8g3ij-1080x1529.jpg\"},\"w1920\":{\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij-1920x2717.jpg\",\"width\":1920,\"height\":2717,\"mimeType\":\"image/jpeg\",\"filesize\":686825,\"filename\":\"z7thhubpjss28wu7vq8g3ij-1920x2717.jpg\"},\"w3840\":{\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij-3840x5435.jpg\",\"width\":3840,\"height\":5435,\"mimeType\":\"image/jpeg\",\"filesize\":1910643,\"filename\":\"z7thhubpjss28wu7vq8g3ij-3840x5435.jpg\"}},\"createdAt\":\"2025-08-19T12:46:10.467Z\",\"updatedAt\":\"2025-08-29T07:04:58.638Z\",\"url\":\"/cms/media/z7thhubpjss28wu7vq8g3ij.jpg\"},\"id\":\"68a47204e44f22b64b74491c\"}],\"status\":\"published\",\"isVisible\":true,\"startDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"19\",\"customCalendarMonth\":\"08\",\"customCalendarYear\":\"2025\"}},\"beginDate\":\"2025-08-19T00:00:00.001Z\",\"endDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"31\",\"customCalendarMonth\":\"12\",\"customCalendarYear\":\"2035\"}},\"endDate\":\"2035-12-31T00:00:00.001Z\",\"blockContent\":[{\"type\":\"text\",\"text\":[{\"children\":[{\"text\":\"Приглашаем вас 23 августа на праздничное открытие нового магазина по адресу: Калининградская область, г. Калининград, ТЦ «Вестер», ул. Интернациональная, д. 76, 2 этаж.\"}]},{\"children\":[{\"text\":\"В честь открытия вас ждёт скидка -10% по карте лояльности весь день, ведущий, розыгрыш сертификатов каждый час и вкусный комплимент при покупке от 2000 рублей. \"}]},{\"children\":[{\"text\":\"Праздничная программа будет проходить с 10:00 до 20:00 — ждём вас!\"}]},{\"children\":[{\"text\":\"Для участников программы лояльности — ещё больше акций и спецпредложений:\"}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"68a47277e44f22b64b74491d\"},{\"type\":\"button\",\"buttonText\":\"Программа лояльности\",\"buttonLink\":\"https://www.famil.ru/cabinet/\",\"buttonColor\":{\"color\":\"#662c83\"},\"buttonFrame\":{\"color\":\"#662c83\"},\"buttonTextColor\":{\"color\":\"#FFFFFF\"},\"id\":\"68a4727de44f22b64b74491e\"},{\"type\":\"text\",\"text\":[{\"children\":[{\"text\":\"*При применении скидки -10% в день открытия баллы карты лояльности не списываются.\",\"italic\":true}]},{\"children\":[{\"text\":\"*Скидка -10% в день открытия не суммируется с другими акциями и спецпредложениями Familia.\",\"italic\":true}]},{\"children\":[{\"text\":\"*Количество подарков ограничено.\",\"italic\":true}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"68a47296e44f22b64b74491f\"}],\"startPromoDateBlock\":{\"castomCalendarBlock\":{}},\"beginPromoDate\":null,\"endPromoDateBlock\":{\"castomCalendarBlock\":{}},\"endPromoDate\":null,\"sort\":1,\"URLname\":\"otkryvayem-novuyu-famillia-v-kaliningrade\",\"publicationLocale\":\"locale_all\",\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"meta\":{},\"createdAt\":\"2025-08-19T12:48:46.765Z\",\"updatedAt\":\"2025-08-19T12:48:47.527Z\"},{\"id\":\"689de58e8083db6a48ce4308\",\"title\":\"Открываем новую Familia в Коломне!\",\"generalSort\":1001755129600,\"typeName\":\"news\",\"isWebShow\":true,\"isMobileSho