<div class="modal fade" id="signupModalToggle" aria-hidden="true" aria-labelledby="signupModalToggleLabel"
     tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-signup-form">
        <div class="modal-content signup-form">

            <div class="modal-header">
                <h2 class="modal-title">Registrieren</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form>

                    <div class="card user-data mb-30">
                        <h5 class="card-header">Nutzerdaten</h5>
                        <div class="card-body">
                            <div class="mb-8">
                                <label for="firstname" class="form-label required">Vorname</label><input type="text" class="form-control" id="firstname" name="firstname" placeholder="Vorname eingeben" required>
                                <div data-error="firstname" class="form-error"></div>
                            </div>                            
                            <div class="mb-8">
                                <label for="lastname" class="form-label required">Nachname</label><input type="text" class="form-control" id="lastname" name="lastname" placeholder="Nachname eingeben" required>
                                <div data-error="lastname" class="form-error"></div>
                            </div>
                            <div class="mb-8">
                                <label for="username" class="form-label required">Nutzername</label><input type="text" class="form-control" id="username" name="username" placeholder="Nutzernamen eingeben" required>
                                <div data-error="username" class="form-error"></div>
                            </div>
                            <div class="mb-8">
                                <label for="email" class="form-label required">E-mail</label><input type="email" class="form-control" id="email" name="email" placeholder="E-Mail eingeben" required>
                                <div data-error="email" class="form-error"></div>
                            </div>
                            <div class="mb-8">
                                <label for="password" class="form-label required">Kennwort</label><input type="password" class="form-control" id="password" name="password" placeholder="Kennwort eingeben" required>
                                <div data-error="password" class="form-error"></div>
                            </div>
                            <div class="mb-8">
                                <label for="confirmPassword" class="form-label required">Kennwort Best&#xE4;tigen</label><input type="password" class="form-control" id="confirmPassword" name="passwordconfirm" placeholder="Kennwort best&#xE4;tigen" required>
                                <div data-error="passwordconfirm" class="form-error"></div>
                            </div>
                            <div class="mb-8">
                                <label for="birthday" class="form-label required">Geburtstag</label><input type="date" class="form-control" id="birthday" name="birthday" placeholder="Geburtstag eingeben" required>
                                <div data-error="birthday" class="form-error"></div>
                            </div>
                        </div>
                    </div>

                    <div class="card account-details mb-30">
