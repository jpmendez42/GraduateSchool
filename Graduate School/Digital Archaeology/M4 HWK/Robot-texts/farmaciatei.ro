}

$('.brand-logos-slider').each(function() {
    $(this).owlCarousel({
        loop: false,
        dots: true,
        margin: 3,
        responsiveClass: true,
        responsive: {
            // breakpoint from 0 up
            0: {
                items: 2
            },
