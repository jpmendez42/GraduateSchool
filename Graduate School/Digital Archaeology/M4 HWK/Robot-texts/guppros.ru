2\u043e\u0440\u0430\u044f \u0434\u0430\u0440\u0438\u0442 \u0434\u0435\u0442\u044f\u043c \u043b\u0435\u0442\u043e, \u0443\u043b\u044b\u0431\u043a\u0438 \u0438 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u0435\u043d\u0438\u0435!<\/b><\/span><br>","~DETAIL_TEXT":"<br>\r\n<br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n&nbsp;\u0421\u043a\u043e\u0440\u043e \u0432 \u041f\u0440\u043e\u0441\u0432\u0435\u0442\u0435 \u043f\u043e\u0434 \u044d\u0433\u0438\u0434\u043e\u0439 <\/span><a href=\"https:\/\/vk.com\/minprosvet\" title=\"https:\/\/vk.com\/minprosvet\" target=\"_blank\"><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\u041c\u0438\u043d\u043f\u0440\u043e\u0441\u0432\u0435\u0449\u0435\u043d\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438<\/b><\/span><\/a><span style=\"font-family: Georgia, serif; font-size: 14pt;\">&nbsp;\u0441\u0442\u0430\u0440\u0442\u0443\u0435\u0442 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0430 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f \u043f\u043e \u0432\u043e\u0441\u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u043d\u043e\u0439 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u00ab\u0412\u043e\u0436\u0430\u0442\u044b\u0439\u00bb!<br>\r\n<\/span><br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0417\u0430 \u0432\u0440\u0435\u043c\u044f \u043a\u0443\u0440\u0441\u0430 \u0432\u044b \u0441\u043c\u043e\u0436\u0435\u0442\u0435:<\/span><br>\r\n<ul>\r\n\t<li><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\t&nbsp;\u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0435 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u043e \u043e \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u0438;<\/span><\/li>\r\n\t<li><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\t&nbsp;\u0443\u0437\u043d\u0430\u0442\u044c, \u043a\u0430\u043a \u0441\u0442\u0430\u0442\u044c \u0447\u0430\u0441\u0442\u044c\u044e \u043a\u043e\u043c\u0430\u043d\u0434\u044b \u043b\u0443\u0447\u0448\u0438\u0445 \u043b\u0430\u0433\u0435\u0440\u0435\u0439 \u0420\u043e\u0441\u0441\u0438\u0438;<\/span><\/li>\r\n\t<li><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\t&nbsp;\u043f\u043e\u0440\u0430\u0431\u043e\u0442\u0430\u0442\u044c \u0441 \u043e\u043f\u044b\u0442\u043d\u044b\u043c\u0438 \u0441\u043f\u0438\u043a\u0435\u0440\u0430\u043c\u0438 \u2014 \u043f\u0440\u0430\u043a\u0442\u0438\u043a\u0430\u043c\u0438 \u0432 \u0441\u0444\u0435\u0440\u0435 \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u043d\u0438\u044f \u0438 \u043f\u0435\u0434\u0430\u0433\u043e\u0433\u0438\u043a\u0438;<\/span><\/li>\r\n\t<li><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\t&nbsp;\u0440\u0430\u0437\u0432\u0438\u0442\u044c \u043d\u0430\u0432\u044b\u043a\u0438 \u043a\u043e\u043c\u043c\u0443\u043d\u0438\u043a\u0430\u0446\u0438\u0438, \u043b\u0438\u0434\u0435\u0440\u0441\u0442\u0432\u0430 \u0438 \u043a\u043e\u043c\u0430\u043d\u0434\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u044b;<\/span><\/li>\r\n\t<li><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\t&nbsp;\u043e\u043a\u0443\u043d\u0443\u0442\u044c\u0441\u044f \u0432 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0443\u044e \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443 \u0432\u043e\u0436\u0430\u0442\u0441\u043a\u043e\u0433\u043e \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f.<\/span><\/li>\r\n\t<li><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><br>\r\n\t<\/span><\/li>\r\n<\/ul>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n&nbsp;\u0417\u0430\u043d\u044f\u0442\u0438\u044f \u0431\u0443\u0434\u0443\u0442 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442\u044c \u043f\u043e \u0441\u0443\u0431\u0431\u043e\u0442\u0430\u043c \u0441&nbsp;<b>18 \u043e\u043a\u0442\u044f\u0431\u0440\u044f<\/b> \u043f\u043e <b>20 \u0434\u0435\u043a\u0430\u0431\u0440\u044f<\/b>. <\/span><br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n\u0416\u0434\u0435\u043c \u0432\u0430\u0441:<\/span><br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n&nbsp;\u0433.\u041c\u043e\u0441\u043a\u0432\u0430, \u0443\u043b. \u0420\u0430\u0434\u0438\u043e, 10\u0410\u04411.<br>\r\n<\/span><br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0417\u0430\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f \u043c\u043e\u0436\u043d\u043e \u0434\u043e 14 \u043e\u043a\u0442\u044f\u0431\u0440\u044f, \u0441\u043e\u043e\u0431\u0449\u0438\u0432 \u043e \u0441\u0432\u043e\u0451\u043c \u0443\u0447\u0430\u0441\u0442\u0438\u0438 \u0437\u0430\u043c\u0435\u0441\u0442\u0438\u0442\u0435\u043b\u044e \u0434\u0435\u043a\u0430\u043d\u0430 \u043f\u043e \u0432\u043e\u0441\u043f\u0438\u0442\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u0435.<br>\r\n<\/span><br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\u041d\u0435 \u0443\u043f\u0443\u0441\u0442\u0438\u0442\u0435 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0441\u0442\u0430\u0442\u044c \u0447\u0430\u0441\u0442\u044c\u044e \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u0432\u043e\u0436\u0430\u0442\u0441\u043a\u043e\u0439 \u0441\u0435\u043c\u044c\u0438 \u2014 \u043a\u043e\u043c\u0430\u043d\u0434\u044b, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0434\u0430\u0440\u0438\u0442 \u0434\u0435\u0442\u044f\u043c \u043b\u0435\u0442\u043e, \u0443\u043b\u044b\u0431\u043a\u0438 \u0438 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u0435\u043d\u0438\u0435!<\/b><\/span><br>","DETAIL_TEXT_TYPE":"html","~DETAIL_TEXT_TYPE":"html","PREVIEW_TEXT":"","~PREVIEW_TEXT":"","PREVIEW_TEXT_TYPE":"text","~PREVIEW_TEXT_TYPE":"text","PREVIEW_PICTURE":{"ID":"6636","TIMESTAMP_X":"13.10.2025 17:41:01","MODULE_I