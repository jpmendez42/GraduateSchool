<script>
$(document).ready(function () {
    $('#carousel-home-mim').on('slid.bs.carousel', function (event) {
        var $activeSlide = $(this).find('.carousel-inner .item.active');
        var newIndex = $activeSlide.index();

        // Aggiorna gli indicatori
        $('.carousel-indicators li').attr('aria-selected', 'false').find('button').attr('tabindex','-1');
        $('.carousel-indicators li').eq(newIndex).attr('aria-selected', 'true').find('button').attr('tabindex','0');
    });


    // Gestisce il focus e la navigazione tra gli indicatori del carousel
    $('.carousel-indicators li button').on('keydown', function (e) {
        var $currentIndicator = $(this).parent();
        var currentIndex = $currentIndicator.index();

        if (e.keyCode === 37) { // Freccia sinistra
            console.log('Click Freccia Sinistra');
            e.preventDefault();
            if (currentIndex > 0) {
                $currentIndicator.prev().find('button').focus().click();
            } else {
                $('.carousel-indicators li').last().find('button').focus().click();
            }
        }

        if (e.keyCode === 39) { // Freccia destra
            console.log('Click Freccia Destra');
            e.preventDefault();
            if (currentIndex < $('.carousel-indicators li').length - 1) {
                $currentIndicator.next().find('button').focus().click();
            } else {
                $('.carousel-indicators li').first().find('button').focus().click();
            }
        }

        if (e.keyCode === 13) { // Tasto Enter
            console.log('Click Tasto Enter');
            e.preventDefault();
            var $targetSlide = $('.carousel-inner .item').eq(currentIndex);
            $targetSlide.attr('tabindex', '0').focus();
        }
    });

    var $carousel = $('#carousel-home-mim');
    var startX, endX;

    $carousel.on('touchstart', function(event) {
        startX = event.originalEvent.touches[0].clientX;
    });

    $carousel.on('touchmove', function(event) {
        endX = event.originalEvent.touches[0].clientX;
    });

    $carousel.on('touchend', function(event) {
        var distance = startX - endX;
        if (distance > 50) { // swipe sinistra
            $carousel.carousel('next');
        } else if (distance < -50) { // swipe destra
            $carousel.carousel('prev');
        }
    });


});

</script>

	
	
	








	
	
					
				
			
		
	
	


