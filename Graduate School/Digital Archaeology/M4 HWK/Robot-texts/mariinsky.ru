<script type="text/javascript">
	$(document).ready(function(){
		if('ru'=='ru'){
			intervalID=setInterval(function(){vhodnoy_za_chas()}, 1000);
		}
	});


	$(document).ready(function() {
		var owl_ex=$('#virt_ex');
		owl_ex.owlCarousel({
			loop:true,
			items:4,
			margin:10,
			nav:false,
			dots: false,
			autoWidth:false,
			responsiveClass:true,
			responsive:{
				0:{
					items:1
				},
				400:{
					items:2
				},
				600:{
					items:3
				},
				1000:{
					items:4
				}
			}
		});
	$('.owl-next-img').click(function() {
		owl_ex.trigger('next.owl.carousel');
	});
	$('.owl-prev-img').click(function() {
		owl_ex.trigger('prev.owl.carousel');
	});


	var owl=$('.banner_carousel');
		owl.owlCarousel({
			items:1,
			loop:true,
			margin:0,
			dots: true,
			nav:false,
			autoplayTimeout:3500,
			autoplaySpeed:700,
			autoplay:true,
			autoplayHoverPause:true,
			onInitialized : rrr/*,
			URLhashListener:false,
			startPosition: 'URLHash'*/
		});
		function rrr(){
			id=$('.banner_carousel .owl-item.active div').attr('pid');
			id=$('.banner_carousel .owl-item.active div').attr('pid');
			$('.banner_preview .item').css('border','2px solid transparent');
			//$('.banner_preview .item').css('margin-top','2px');
			//$('.banner_preview .item.'+id).css('margin-top','0px');
			$('.banner_preview .item.'+id).css('border','2px solid #ee7a0b');
			update_banner(id);

				$( ".banner_preview" ).fadeOut( "slow", function() {});
				$( ".banner_pause" ).fadeOut( "slow", function() {});
				$( ".banner_prev" ).fadeOut( "slow", function() {});
				$( ".banner_next" ).fadeOut( "slow", function() {});
				$( ".banner_preview_cont" ).css( "background", 'none');
			
		
		}
		var owl2 = $('.banner_preview_slider');
		owl2.owlCarousel({
			loop:false,
			margin:1,
			nav:false,
			dots: false,
			autoWidth:true
		});
		
$('.owl-carousel-u').owlCarousel({
    loop:false,
    margin:10,
    responsiveClass:true,
            items:3,
    responsive:{
        0:{
            items:2,
            nav:false
        },
        768:{
            items:3,
            nav:false
        },
        1000:{
            items:4,
            nav:true,
            loop:false
        }
    }
})
		
		owl.on('translated.owl.carousel', function(event) {
			id=$('.banner_carousel .owl-item.active div').attr('pid');
			$('.banner_preview .item').css('border','2px solid transparent');
			//$('.banner_preview .item').css('margin-top','2px');
			//$('.banner_preview .item.'+id).css('margin-top','0px');
			$('.banner_preview .item.'+id).css('border','2px solid #ee7a0b');
			update_banner(id);
		});
		$('.banner_pause').on('click',function(){
			if($(this).hasClass('active')){
				$(this).removeClass('active');
				owl.trigger('stop.owl.autoplay');
			}else{
				$(this).addClass('active');
				owl.trigger('play.owl.autoplay',[3500])
			}
		});
		
$( ".banner_preview_menu img" ).mouseenter(
  function() {
		//$( ".banner_preview_menu img" ).trigger( "click" );
		
		if($('.banner_preview:visible').length==0){
				$( ".banner_preview" ).fadeIn( "slow", function() {});
				$( ".banner_pause" ).fadeIn( "slow", function() {});
				$( ".banner_prev" ).fadeIn( "slow", function() {});
				$( ".banner_next" ).fadeIn( "slow", function() {});
				$( ".banner_preview_cont" ).css( "background", 'url(/images/banner_preview_bg.png)');
		}
  }
);

		$('.banner_preview .item').on('click',function(){
			owl.trigger('stop.owl.autoplay');
			update_banner($(this).attr('data'));
			owl.trigger('to.owl.carousel', [$(this).attr('rel'), 200]);
			
			owl.trigger('play.owl.autoplay', [3500, 700]);
		});

		$('.banner_preview_menu img').on('click',function(){
			if($('.banner_preview:visible').length>=1){
				$( ".banner_preview" ).fadeOut( "slow", function() {});
				$( ".banner_pause" ).fadeOut( "slow", function() {});
				$( ".banner_prev" ).fadeOut( "slow", function() {});
				$( ".banner_next" ).fadeOut( "slow", function() {});
				$( ".banner_preview_cont" ).css( "background", 'none');

			}else{
				$( ".banner_preview" ).fadeIn( "slow", function() {});
				$( ".banner_pause" ).fadeIn( "slow", function() {});
				$( ".banner_prev" ).fadeIn( "slow", function() {});
				$( ".banner_next" ).fadeIn( "slow", function() {});
				$( ".banner_preview_cont" ).css( "background", 'url(/images/banner_preview_bg.png)');
			}
		});
		$('.owl-next img').click(function() {
			owl2.trigger('next.owl.carousel');
		});
		$('.owl-prev img').click(function() {
			owl2.trigger('prev.owl.carousel');
		});	

		
	function update_banner(banner_pid){
			
		banner_cont_h=$('#banner_cont').height();
		$("#BannerDescr").animate({'height': banner_cont_h}, 500, function(){});	
			banners_data=bdata[banner_pid];
			
			target_blank=' ';
			if(banners_data['target_blank']=='1') target_blank=' target="blank" ';

			a_class='';
			button='';
			button_color='#'+banners_data['place_color'];
			
			if(banners_data['vhodnoy_za_chas_flag']=='1' && banners_data['spec_id']==''){ a_class='vhodnoy_za_chas no '; button_color=' none ';}

			if(banners_data['spec_id']!='' || banners_data['vhodnoy_za_chas_flag']=='1') button='<div id="ticket_cont" class="t_button"><a class="'+a_class+'" style="background-color:'+button_color+';" href="//tickets.mariinsky.ru/'+lang+'/performance/'+banners_data['spec_id']+'/">'+banners_data['ticket_txt']+'</a></div>';
			
			if(banners_data['is_out_link']=='1' && banners_data['show_out_button']=='1') button='<div id="ticket_cont" class="t_button"><a class="'+a_class+'" style="background-color:'+banners_data['out_button_color']+'; font-weight:normal; font-size:14px; padding:5px 10px; color:'+banners_data['out_button_text_color']+';" href="'+banners_data['link']+'">'+banners_data['out_button_text']+'</a></div>';
			
			descr='<div class="b_descr"><div class="perf_date">'+banners_data['perf_date']+' </div><div class="perf_place" style="color:#'+banners_data['place_color']+';">'+banners_data['place']+'</div><div class="perf_name"><a '+target_blank+' href="'+banners_data['link']+'">'+banners_data['perf_name']+'</a></div><div class="perf_descr">'+banners_data['banner_text']+'</div>'+button+'</div>';
			$('#BannerDescr').html(descr);
			$("#BannerDescr").attr('href', banners_data['link']);
		}
	});

	var bdata = banner_JSON_data;


 </script>
<style>


