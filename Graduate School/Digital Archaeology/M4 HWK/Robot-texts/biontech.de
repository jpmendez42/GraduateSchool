e-and-products/pipeline.html&#34;,&#34;description&#34;:&#34;Explore BioNTech&#39;s unique pipeline of innovative therapies and vaccines, including mRNA cancer immunotherapies, next-generation immunomodulators, targeted therapies and infectious disease vaccines.&#34;,&#34;children&#34;:[],&#34;level&#34;:1,&#34;title&#34;:&#34;Pipeline&#34;,&#34;overviewLinkTitle&#34;:&#34;Pipeline&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Platforms&#34;,&#34;href&#34;:&#34;/int/en/home/pipeline-and-products/platforms.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/pipeline-and-products/platforms.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/pipeline-and-products/platforms.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/pipeline-and-products/platforms.html&#34;,&#34;description&#34;:null,&#34;children&#34;:[{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Platforms&#34;,&#34;href&#34;:&#34;/int/en/home/pipeline-and-products/platforms/platforms.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/pipeline-and-products/platforms/platforms.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/pipeline-and-products/platforms/platforms.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/pipeline-and-products/platforms/platforms.html&#34;,&#34;description&#34;:null,&#34;children&#34;:[],&#34;level&#34;:2,&#34;title&#34;:&#34;Platforms&#34;,&#34;overviewLinkTitle&#34;:&#34;Platforms&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;mRNA platforms&#34;,&#34;href&#34;:&#34;/int/en/home/pipeline-and-products/platforms/mrna-platforms.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/pipeline-and-products/platforms/mrna-platforms.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/pipeline-and-products/platforms/mrna-platforms.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/pipeline-and-products/platforms/mrna-platforms.html&#34;,&#34;description&#34;:&#34;Discover BioNTech’s mRNA platforms, designed to revolutionize treatments in oncology and infectious diseases. Leveraging advanced mRNA technology, BioNTech develops personalized treatment approaches and vaccines that harness the potential of the immune system to fight disease.&#34;,&#34;children&#34;:[],&#34;level&#34;:2,&#34;title&#34;:&#34;mRNA platforms&#34;,&#34;overviewLinkTitle&#34;:&#34;mRNA platforms&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Protein-based platforms&#34;,&#34;href&#34;:&#34;/int/en/home/pipeline-and-products/platforms/protein-based-platforms.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/pipeline-and-products/platforms/protein-based-platforms.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/pipeline-and-products/platforms/protein-based-platforms.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/pipeline-and-products/platforms/protein-based-platforms.html&#34;,&#34;description&#34;:&#34;BioNTech’s protein-based platforms include antibodies, antibody-drug conjugates (ADCs) and synthetic lysins, designed to broaden therapeutic options in oncology and infectious diseases.&#34;,&#34;children&#34;:[],&#34;level&#34;:2,&#34;title&#34;:&#34;Protein-based platforms&#34;,&#34;overviewLinkTitle&#34;:&#34;Protein-based platforms&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Cell therapy platforms&#34;,&#34;href&#34;:&#34;/int/en/home/pipeline-and-products/platforms/cell-therapy-platforms.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/pipeline-and-products/platforms/cell-therapy-platforms.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/pipeline-and-products/platforms/cell-therapy-platforms.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/pipeline-and-products/platforms/cell-therapy-platforms.html&#34;,&#34;description&#34;:&#34;BioNTech’s cell therapy platforms leverage TCR approches and CAR-T approaches, enhanced by mRNA technology (CARVac), to develop next-generation engineered T cell therapies that target solid tumors and help advance the future of personalized immunotherapy.&#34;,&#34;children&#34;:[],&#34;level&#34;:2,&#34;title&#34;:&#34;Cell therapy platforms&#34;,&#34;overviewLinkTitle&#34;:&#34;Cell therapy platforms&#34;,&#34;enableOverviewInNavigation&#34;:false}],&#34;level&#34;:1,&#34;title&#34;:&#34;Platforms&#34;,&#34;overviewLinkTitle&#34;:&#34;Platforms&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Clinical trials&#34;,&#34;href&#34;:&#34;/int/en/home/pipeline-and-products/clinical-trials.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/pipeline-and-products/clinical-trials.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/pipeline-and-products/clinical-trials.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/pipeline-and-products/clinical-trials.html&#34;,&#34;description&#34;:&#34;BioNTech provides an interactive portal to search and explore clinical trials in oncology and infectious diseases, with transparent information on participation, ethics, and trial options.&#34;,&#34;children&#34;:[],&#34;level&#34;:1,&#34;title&#34;:&#34;Clinical trials&#34;,&#34;overviewLinkTitle&#34;:&#34;Clinical trials&#34;,&#34;enableOverviewInNavigation&#34;:false}],&#34;level&#34;:0,&#34;title&#34;:&#34;Pipeline &amp; products&#34;,&#34;overviewLinkTitle&#34;:&#34;Pipeline &amp; products&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Careers&#34;,&#34;href&#34;:&#34;/int/en/home/careers.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/careers.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/careers.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/careers.html&#34;,&#34;description&#34;:null,&#34;children&#34;:[{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Careers&#34;,&#34;href&#34;:&#34;/int/en/home/careers/careers.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/careers/careers.html&#34;,&#34;hrefvps&#34;:&#34;/int/en/home/careers/careers.html&#34;,&#34;role&#34;:null,&#34;rel&#34;:&#34;&#34;,&#34;active&#34;:false,&#34;asset&#34;:false,&#34;pdfinnerAsset&#34;:false,&#34;absolute&#34;:false},&#34;active&#34;:false,&#34;data&#34;:null,&#34;url&#34;:&#34;/int/en/home/careers/careers.html&#34;,&#34;description&#34;:null,&#34;children&#34;:[],&#34;level&#34;:1,&#34;title&#34;:&#34;Careers&#34;,&#34;overviewLinkTitle&#34;:&#34;Careers&#34;,&#34;enableOverviewInNavigation&#34;:false},{&#34;link&#34;:{&#34;target&#34;:null,&#34;text&#34;:&#34;Entry level roles&#34;,&#34;href&#34;:&#34;/int/en/home/careers/entry-level-roles.html&#34;,&#34;hrefvpm&#34;:&#34;/int/en/home/careers/entry-level-roles.html&#34;,&#34;hrefvps&#34;:&#34;/in