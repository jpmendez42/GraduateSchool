    function OptanonWrapper() {
      if (isMobile() && document.getElementById('onetrust-banner-sdk')) {
        var acceptBtn = document.getElementById("onetrust-accept-btn-handler");
        var declineBtn = document.getElementById("onetrust-reject-all-handler");
        declineBtn.style.backgroundColor='white'
        declineBtn.style.color = '#346E4A'
        var cookieSettingsBtn = document.getElementById("onetrust-pc-btn-handler");
        var btnContainer = document.getElementById("onetrust-button-group");
        // Set the order you want below...
        btnContainer.append(acceptBtn, declineBtn, cookieSettingsBtn)
      }
      window.dispatchEvent(new CustomEvent('CookieProConsentChanged'));
   }
   const closePcBtnHandler = document.getElementById('close-pc-btn-handler');
   if(closePcBtnHandler) {
    closePcBtnHandler.addEventListener("click", ()=>{
      const onetrustPcDarkFilter = document.getElementById('onetrust-pc-dark-filter');
      if(onetrustPcDarkFilter){
        onetrustPcDarkFilter.style.display='none';
      }
   })
   }
