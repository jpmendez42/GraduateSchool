		<style>
    .it908-video-item{ display: flex; width: 100%; max-width: 1200px; background: var(--pic-color-grey-5); border-radius: 10px;}
    .it908-video-item .it908-video-play{ position: relative; width: 320px; max-height: 478px; height: 100%;}
    .it908-video-item .it908-video-play .it908-video-mask{ position: absolute; left: 0; top: 0; display: block; width: 100%; height: 100%; background-size: cover;}
    .it908-video-item .it908-video-play .it908-video-mask::before{ position: absolute; left: 50%; margin-left: -33px; top: 50%; margin-top: -33px; display: block; content: ''; width: 66px; height: 66px; background: url(css/images/pic/pic-icon-play.svg) center no-repeat; background-size:100%;}
    .it908-video-item .it908-video-play iframe{ width: 100%; height: 478px;}
    .it908-video-item .it908-video-describe{ width: calc(100% - 320px); padding: 30px 20px;}
    .it908-video-item .it908-video-describe > h2,
    .it908-video-item .it908-video-describe > h2 a,
    .it908-video-item .it908-video-describe > h2 a:hover{ font-size: 22px; line-height: 28px; font-weight: 600; color: var(--pic-color-grey-100); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;}
    .it908-video-item .it908-video-describe div.it908-video-info{ font-size: 14px; line-height: 20px; font-weight: normal; color: var(--pic-color-grey-100); overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical;}
    .it908-video-item .it908-video-describe div.it908-video-pdbox{ width: 100%; margin-top: 30px;}
    .it908-video-item .it908-video-describe div.it908-video-pdbox > ul{ display: flex; justify-content: space-between;}
    .it908-video-item .it908-video-describe div.it908-video-pdbox > ul > li{ padding: 0 5px; margin-bottom: 15px;}
    .it908-default .it908-video-item .owl-carousel .owl-nav .owl-next { right: -45px;}
    .it908-default .it908-video-item .owl-carousel .owl-nav .owl-prev { left: -45px;}
    .it908-default .pic-pds-default01 .pic-pds-btn .pic-pds-prodlink{ position: absolute; width: 100%; height: 100%; z-index: -1;}
    .it908-default .pic-pds-default01 .pic-pds-btn .pic-pds-prodlink a{ display: block; width: 100%; height: 100%; border: 0; border-radius: 0;}

    @media screen and (max-width:960px) {
        .it908-default .iopen-mall-item-title h3{ margin-left: 10px;}
        .it908-video-item{ display: block; max-width: 100%;}
        .it908-video-item .it908-video-describe{ width: 100%;}
        .it908-video-item .it908-video-play{ width: 100%;}
        .it908-video-item .it908-video-describe div.it908-video-pdbox{ margin-top:15px;}
    }
    @media screen and (max-width:640px) {
        .it908-video-item{ max-width: 100%; overflow: hidden;}
        .it908-video-item .it908-video-play{ max-height: 478px;}
        .it908-video-item .it908-video-play iframe{ height: 478px;}
        .it908-video-item .it908-video-describe{ padding: 10px;}
        .it908-video-item .it908-video-describe h2{ font-size: 17px; line-height: 22px;}
        .it908-video-item .it908-video-describe div.it908-video-info{ font-size: 12px; line-height: 16px;}
        .it908-video-item .it908-video-describe div.it908-video-pdbox > ul{ flex-wrap: wrap;}
        .it908-video-item .it908-video-describe div.it908-video-pdbox > ul > li{ width: 50%;}
    }

</style>


