jQuery(document).ready(function($) {
			
        var excerptLength = 20;
			
        jQuery('.post-excerpt').each(function() {
            var originalText = jQuery(this).text().split(' ');
            var truncatedText = originalText.slice(0, excerptLength).join(' ');

