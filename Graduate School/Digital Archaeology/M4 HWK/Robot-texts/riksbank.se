<style>
	.header-section.js-preload-style {
		max-height: 107px;
		overflow:hidden;
	}

	.js-preload-style .hero-block,
	.js-preload-style .bannerV2 {
		position: relative;
	}

	.js-preload-style .hero-block__image,
	.js-preload-style .bannerV2__image  {
		object-fit: cover;
	}

	.js-preload-style .hero-block__content,
	.js-preload-style .bannerV2 {
		flex-basis: 50%;
	}

	.js-preload-style .hero-block__link-list{
		flex-basis: 50%;
	}

	.js-preload-style .hero-block__wrapper,
	.js-preload-style .bannerV2__wrapper {
		position: relative;
		overflow: hidden;
		z-index: 1;
	}

	.js-preload-style .block-section__blocks {
		display: flex;
	}

	@media (min-width: 768px) {
		.js-preload-style .content-area--selected {
			display: flex;
			overflow-x: hidden;
			flex-wrap: wrap;
		}

		.js-preload-style .content-area--selected .block-size-3 {
			width: 25%;
		}

		.js-preload-style .content-area--selected .block-size-4 {
			width: 33%
		}
	}

	.logo.js-preload-style {
		transform: translateY(-34px);
	}

	@media (min-width: 768px) {
		.logo.js-preload-style {
			transform: translateY(-41px);
		}
	}
</style>
