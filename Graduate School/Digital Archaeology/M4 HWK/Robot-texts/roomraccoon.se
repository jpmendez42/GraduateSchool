/* FAQ */

.faq .question:after {
    content: "";
    width: 60px;
    height: 100%;
    background: #EEF5F5;
    position: absolute;
    left: 0;
    top: 0;
    z-index: 1;
}

.faq .question:before {
    content: "";
    width: 60px;
    height: 100%;
    border-width: 0 1px 0 0;
    border-style: solid;
    border-color: rgb(0 0 0 / 0%);
    position: absolute;
    left: 0;
    top: 0;
    background-color: #EEF5F5 !important;
    z-index: 1;
}

.faq .question > .title > .acc-icon-plus, .faq .question .title > .acc-icon-minus {
    font-size: 24px;
	line-height: 24px;
    color: #20817c !important;
}

.faq .question {
    margin-bottom: 0;
    overflow: hidden;
    position: relative;
    background: rgba(0,0,0,.02);
    border-bottom: 1px solid #CCCCCC;
}

.faq .question > .title > .acc-icon-plus:before {
    margin: 0!important;
    content: '\e869' !important;
}

 .faq .question .title > .acc-icon-minus:before {
	 content: '\e947' !important;
}

/* ACCORDION */

.accordion .question {
    margin-bottom: 5px;
    -webkit-border-radius: 5px;
    border-radius: 5px;
    overflow: hidden;
    border-width: 0;
    border-style: solid;
}

.mcb-section .mcb-wrap .mcb-item-zkt9r99f .accordion .question .title {
    padding-left: 0;
}

.accordion .question > .title:before {
    content: "";
    width: 49px;
    height: 100%;
    border-width: 0;
    border-style: solid;
    position: absolute;
    left: 0;
    top: 0;
    z-index: 1;
}

.accordion .question > .title > .acc-icon-plus, .accordion .question .title > .acc-icon-minus {
    font-size: 27px;
    left: 85%;
    color: #20827c;
}

.accordion .question > .title > .acc-icon-plus:before {
    margin: 0!important;
    content: '\e869' !important;
}

 .accordion .question .title > .acc-icon-minus:before {
	 content: '\e947' !important;
}

