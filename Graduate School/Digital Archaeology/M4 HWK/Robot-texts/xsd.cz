.471H155.936Z\",\"fill\":\"#2B3872\"}]]}],[\"$\",\"defs\",null,{\"children\":[\"$\",\"clipPath\",null,{\"id\":\"clip0_988_4309\",\"children\":[\"$\",\"rect\",null,{\"width\":\"389\",\"height\":\"316\",\"fill\":\"white\"}]}]}]]}],[\"$\",\"h1\",null,{\"className\":\"mb-0 text-4xl font-bold\",\"children\":\"Stránka se nenašla\"}],[\"$\",\"$L1a\",null,{\"href\":\"/\",\"className\":\"hover:underline border border-transparent font-semibold gap-[10px] relative inline-flex h-11 items-center rounded-full bg-secondary px-7 text-white !no-underline\",\"aria-disabled\":false,\"data-testid\":\"$undefined\",\"prefetch\":false,\"target\":\"$undefined\",\"rel\":\"$undefined\",\"children\":\"Zpět domů\"}]]}],\"notFoundStyles\":[]}]}]}],[\"$\",\"$L1b\",null,{}]]}],[\"$\",\"$L1c\",null,{}]]}]}]]}]}]}],[\"$\",\"$L7\",null,{\"src\":\"https://cse.google.com/cse.js?cx=936dbab897179455d\"}],[\"$\",\"$L1d\",null,{}]]}]]}]}]}]]}]],null],null],\"couldBeIntercepted\":false,\"initialHead\":[null,\"$L1e\"],\"globalErrorComponent\":\"$1f\",\"missingSlots\":\"$W20\"}]\n"])</script><script>self.__next_f.push([1,"21:I[40348,[\"1724\",\"static/chunks/5f9909de-c2de8935f3af3c68.js\",\"7667\",\"static/chunks/d384f6f5-7da9e1522ab98c4d.js\",\"9600\",\"static/chunks/cc40c94c-135db538781da5a4.js\",\"4125\",\"static/chunks/f35cabfc-c9c73daa983fb80f.js\",\"7588\",\"static/chunks/c7a7ea33-13c87b379f8013d4.js\",\"397\",\"static/chunks/8db15f2a-983929376c87ba25.js\",\"9485\",\"static/chunks/9485-9b6aff374ddac9cb.js\",\"1638\",\"static/chunks/1638-513ebb67e83f145b.js\",\"5563\",\"static/chunks/5563-dec899eb630908cd.js\",\"7767\",\"static/chunks/7767-a79e24835a7d010e.js\",\"8371\",\"static/chunks/8371-1e7ba3a228c1c90a.js\",\"3784\",\"static/chunks/3784-87d6e5dc628c8a77.js\",\"7565\",\"static/chunks/7565-77b3036f7a43dbdb.js\",\"5912\",\"static/chunks/5912-c732c5b4dcbeda37.js\",\"8289\",\"static/chunks/8289-ef08601fe0c61447.js\",\"1931\",\"static/chunks/app/page-5208f7f508681fbf.js\"],\"HydrationBoundary\"]\n9b:I[91482,[\"1724\",\"static/chunks/5f9909de-c2de8935f3af3c68.js\",\"7667\",\"static/chunks/d384f6f5-7da9e1522ab98c4d.js\",\"9600\",\"static/chunks/cc40c94c-135db538781da5a4.js\",\"4125\",\"static/chunks/f35cabfc-c9c73daa983fb80f.js\",\"7588\",\"static/chunks/c7a7ea33-13c87b379f8013d4.js\",\"397\",\"static/chunks/8db15f2a-983929376c87ba25.js\",\"9485\",\"static/chunks/9485-9b6aff374ddac9cb.js\",\"1638\",\"static/chunks/1638-513ebb67e83f145b.js\",\"5563\",\"static/chunks/5563-dec899eb630908cd.js\",\"7767\",\"static/chunks/7767-a79e24835a7d010e.js\",\"8371\",\"static/chunks/8371-1e7ba3a228c1c90a.js\",\"3784\",\"static/chunks/3784-87d6e5dc628c8a77.js\",\"7565\",\"static/chunks/7565-77b3036f7a43dbdb.js\",\"5912\",\"static/chunks/5912-c732c5b4dcbeda37.js\",\"8289\",\"static/chunks/8289-ef08601fe0c61447.js\",\"1931\",\"static/chunks/app/page-5208f7f508681fbf.js\"],\"HomePage\"]\n22:T1578,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cstrong\u003eVelký test másla přinesl překvapivé výsledky, které mohou změnit vaše nákupní zvyklosti. Zatímco bio máslo značky Milko uspělo nejvíce, tradiční výrobci jako Madeta nebo drahé italské Parmareggio spíše zklamali. Podívejte se, které máslo skutečně stojí za vaše peníze, jaké parametry určují jeho kvalitu a proč se vyplatí přemýšlet nejen nad cenou, ale i nad způsobem výroby.\u003c/strong\u003e\u003c/p\u003e \u003ch2\u003eTest másla: Metodika a podmínky hodnocení\u003c/h2\u003e \u003cp\u003eHodnocení probíhalo ve dvou situacích, které dobře známe z vlastní kuchyně, když máslo vytáhnete z lednice úplně studené a když už má chvíli pokojovou teplotu. Porotci se soustředili na to nejdůležitější, jak se máslo chová na noži, jak chutná a jestli jde snadno namazat na čerstvý chléb. Šlo tedy o to zjistit, jak si másla poradí v běžném provozu, kdy na mazání prostě nemáte čas čekat.\u003c/p\u003e \u003cp\u003eDo testu se dostaly výrobky od levnějších českých značek, přes bio varianty až po drahé dovozové máslo z Itálie. Smyslem ale nebylo jen vyhlásit vítěze, cílem bylo ukázat, že i máslo za rozumnou cenu může překvapit a v chuti se vyrovnat těm nejdražším.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eČtěte také\u003c/strong\u003e: \u003ca href=\"https://byznysdenik.cz/finance/manzelska-smlouva-rozvod/martinaweber/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eMarcela se chtěla rozvést, ale zjistila, že nedostane vůbec nic. Právník poradil manželovi geniální trik\u003c/a\u003e\u003c/p\u003e \u003ch2\u003eVítěz testu: Milko Bio máslo překvapilo odborníky\u003c/h2\u003e \u003cp\u003eNejvětším překvapením se stalo Milko Bio máslo s 82 % obsahem tuku, které předčilo veškerou konkurenci. Porotu zaujala jemná, smetanová chuť v kombinaci s vynikající konzistencí i při nižší teplotě. Máslo nabídlo ideální rovnováhu mezi krémovostí a pevností, díky čemuž se snadno roztírá bez trhání chleba.\u003c/p\u003e \u003cp\u003eNa druhém místě skončilo Tatra Farmářské máslo s 84 % obsahem tuku. Chuťově bylo o něco méně výrazné než vítěz, přesto nabídlo velmi příjemnou a vyváženou chuť bez nežádoucích příměsí. Ukázalo se tak, že i klasické české značky dokáží držet krok s bio produkty, pokud jde o kvalitu a celkový chuťový zážitek.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eČtěte také\u003c/strong\u003e: \u003ca href=\"https://byznysdenik.cz/cesko/nejvetsi-lakomec-horoskop/michaelapisanova/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eVědma varuje: Tohle znamení smrdí korunou a nikdy to nebude lepší. Utečte od něj, dokud je čas\u003c/a\u003e\u003c/p\u003e \u003ch2\u003eZklamání tradičních značek: Madeta a italské Parmareggio\u003c/h2\u003e \u003cp\u003eMadeta Jihočeské máslo s 82 % obsahem tuku patřilo mezi největší zklamání testu. Působilo příliš mastně a tuze, roztíratelnost nebyla na očekávané úrovni a postrádalo charakteristickou mléčnou chuť, kterou si spotřebitelé se značkou spojují. Přestože jde o dlouholetého lídra českého trhu, ukázalo se, že tradice nemusí vždy zaručovat i nejlepší kvalitu.\u003c/p\u003e \u003cp\u003eJeště hůře dopadlo italské Parmareggio Burro s 83 % obsahem tuku. Navzdory vysoké ceně chutnalo mdle a navíc mělo nežádoucí sýrové aroma, které kazilo celkový dojem. Tento výsledek jasně ukazuje, že prémiová cenovka není zárukou prémiového produktu. Pro českého spotřebitele tak podobný nákup může znamenat spíše zklamání než kulinářský zážitek.\u003c/p\u003e \u003ch2\u003eKvalita másla: Co skutečně rozhoduje o chuti\u003c/h2\u003e \u003cp\u003ePrávě fermentace je přitom tajemstvím toho, proč některá másla chutnají tak lahodně. Dodává jim jemnou smetanovou chuť, která se rozvine hned při prvním soustu. Rozdíl mezi máslem s fermentací a bez ní poznáte okamžitě, nejen na krajíci chleba, ale i při pečení nebo vaření. Fermentované máslo dodá pokrmům plnější a kulatější chuť.\u003c/p\u003e \u003cp\u003eEvropská pravidla navíc určují, že máslo musí obsahovat alespoň 82 % tuku. Možná to zní jako detail, ale právě tento rozdíl je znát. Máslo s vyšším obsahem tuku se při pečení chová lépe, dodá těstu pružnější konzistenci a krémům hladší texturu. A navíc, výsledná chuť je sytější a výraznější, takže i obyčejný koláč nebo omáčka chutnají o stupeň lépe.\u003c/p\u003e \u003ch2\u003eSvětové trendy: Nejlepší másla za hranicemi České republiky\u003c/h2\u003e \u003cp\u003eZajímá vás, jaké máslo boduje ve světě? Podle mezinárodních hodnocení se mezi nejlepší řadí nesolené fermentované máslo Vermont Creamery z USA. Evropa ale rozhodně nezaostává. Francie i Dánsko jsou na svá másla právem hrdé a jejich produkty patří mezi vyhledávané delikatesy.\u003c/p\u003e \u003cp\u003eVe Francii například najdete tradiční AOP máslo z oblasti Charentes-Poitou s chráněným označením původu. Pyšní se jemnou chutí a krémovou konzistencí. Nevýhodou je však vysoká cena a omezená dostupnost na českém trhu. Podobně dánská másla, známá svou kvalitou a stabilní chutí, patří k tomu nejlepšímu, co evropský trh nabízí.\u003c/p\u003e \u003cp\u003eNaštěstí i v českých supermarketech najdete cenově dostupné alternativy, které zvládnou nabídnout vysokou kvalitu bez přemrštěné ceny. Spotřebitelé tak nemusí sahat po zahraničních delikatesách, aby si dopřáli dobré máslo, stačí vybírat chytře a sledovat nejen cenu, ale i složení a původ výrobku.\u003c/p\u003e \u003cp\u003eZdroje: \u003ca href=\"https://www.arecenze.cz/clanky/test-10-masel-2025/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eArecenze.cz\u003c/a\u003e\u003c/p\u003e"])</script><script>self.__next_f.push([1,"23:T1578,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cstrong\u003eVelký test másla přinesl překvapivé výsledky, které mohou změnit vaše nákupní zvyklosti. Zatímco bio máslo značky Milko uspělo nejvíce, tradiční výrobci jako Madeta nebo drahé italské Parmareggio spíše zklamali. Podívejte se, které máslo skutečně stojí za vaše peníze, jaké parametry určují jeho kvalitu a proč se vyplatí přemýšlet nejen nad cenou, ale i nad způsobem výroby.\u003c/strong\u003e\u003c/p\u003e \u003ch2\u003eTest másla: Metodika a podmínky hodnocení\u003c/h2\u003e \u003cp\u003eHodnocení probíhalo ve dvou situacích, které dobře známe z vlastní kuchyně, když máslo vytáhnete z lednice úplně studené a když už má chvíli pokojovou teplotu. Porotci se soustředili na to nejdůležitější, jak se máslo chová na noži, jak chutná a jestli jde snadno namazat na čerstvý chléb. Šlo tedy o to zjistit, jak si másla poradí v běžném provozu, kdy na mazání prostě nemáte čas čekat.\u003c/p\u003e \u003cp\u003eDo testu se dostaly výrobky od levnějších českých značek, přes bio varianty až po drahé dovozové máslo z Itálie. Smyslem ale nebylo jen vyhlásit vítěze, cílem bylo ukázat, že i máslo za rozumnou cenu může překvapit a v chuti se vyrovnat těm nejdražším.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eČtěte také\u003c/strong\u003e: \u003ca href=\"https://byznysdenik.cz/finance/manzelska-smlouva-rozvod/martinaweber/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eMarcela se chtěla rozvést, ale zjistila, že nedostane vůbec nic. Právník poradil manželovi geniální trik\u003c/a\u003e\u003c/p\u003e \u003ch2\u003eVítěz testu: Milko Bio máslo překvapilo odborníky\u003c/h2\u003e \u003cp\u003eNejvětším překvapením se stalo Milko Bio máslo s 82 % obsahem tuku, které předčilo veškerou konkurenci. Porotu zaujala jemná, smetanová chuť v kombinaci s vynikající konzistencí i při nižší teplotě. Máslo nabídlo ideální rovnováhu mezi krémovostí a pevností, díky čemuž se snadno roztírá bez trhání chleba.\u003c/p\u003e \u003cp\u003eNa druhém místě skončilo Tatra Farmářské máslo s 84 % obsahem tuku. Chuťově bylo o něco méně výrazné než vítěz, přesto nabídlo velmi příjemnou a vyváženou chuť bez nežádoucích příměsí. Ukázalo se tak, že i klasické české značky dokáží držet krok s bio produkty, pokud jde o kvalitu a celkový chuťový zážitek.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eČtěte také\u003c/strong\u003e: \u003ca href=\"https://byznysdenik.cz/cesko/nejvetsi-lakomec-horoskop/michaelapisanova/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eVědma varuje: Tohle znamení smrdí korunou a nikdy to nebude lepší. Utečte od něj, dokud je čas\u003c/a\u003e\u003c/p\u003e \u003ch2\u003eZklamání tradičních značek: Madeta a italské Parmareggio\u003c/h2\u003e \u003cp\u003eMadeta Jihočeské máslo s 82 % obsahem tuku patřilo mezi největší zklamání testu. Působilo příliš mastně a tuze, roztíratelnost nebyla na očekávané úrovni a postrádalo charakteristickou mléčnou chuť, kterou si spotřebitelé se značkou spojují. Přestože jde o dlouholetého lídra českého trhu, ukázalo se, že tradice nemusí vždy zaručovat i nejlepší kvalitu.\u003c/p\u003e \u003cp\u003eJeště hůře dopadlo italské Parmareggio Burro s 83 % obsahem tuku. Navzdory vysoké ceně chutnalo mdle a navíc mělo nežádoucí sýrové aroma, které kazilo celkový dojem. Tento výsledek jasně ukazuje, že prémiová cenovka není zárukou prémiového produktu. Pro českého spotřebitele tak podobný nákup může znamenat spíše zklamání než kulinářský zážitek.\u003c/p\u003e \u003ch2\u003eKvalita másla: Co skutečně rozhoduje o chuti\u003c/h2\u003e \u003cp\u003ePrávě fermentace je přitom tajemstvím toho, proč některá másla chutnají tak lahodně. Dodává jim jemnou smetanovou chuť, která se rozvine hned při prvním soustu. Rozdíl mezi máslem s fermentací a bez ní poznáte okamžitě, nejen na krajíci chleba, ale i při pečení nebo vaření. Fermentované máslo dodá pokrmům plnější a kulatější chuť.\u003c/p\u003e \u003cp\u003eEvropská pravidla navíc určují, že máslo musí obsahovat alespoň 82 % tuku. Možná to zní jako detail, ale právě tento rozdíl je znát. Máslo s vyšším obsahem tuku se při pečení chová lépe, dodá těstu pružnější konzistenci a krémům hladší texturu. A navíc, výsledná chuť je sytější a výraznější, takže i obyčejný koláč nebo omáčka chutnají o stupeň lépe.\u003c/p\u003e \u003ch2\u003eSvětové trendy: Nejlepší másla za hranicemi České republiky\u003c/h2\u003e \u003cp\u003eZajímá vás, jaké máslo boduje ve světě? Podle mezinárodních hodnocení se mezi nejlepší řadí nesolené fermentované máslo Vermont Creamery z USA. Evropa ale rozhodně nezaostává. Francie i Dánsko jsou na svá másla právem hrdé a jejich produkty patří mezi vyhledávané delikatesy.\u003c/p\u003e \u003cp\u003eVe Francii například najdete tradiční AOP máslo z oblasti Charentes-Poitou s chráněným označením původu. Pyšní se jemnou chutí a krémovou konzistencí. Nevýhodou je však vysoká cena a omezená dostupnost na českém trhu. Podobně dánská másla, známá svou kvalitou a stabilní chutí, patří k tomu nejlepšímu, co evropský trh nabízí.\u003c/p\u003e \u003cp\u003eNaštěstí i v českých supermarketech najdete cenově dostupné alternativy, které zvládnou nabídnout vysokou kvalitu bez přemrštěné ceny. Spotřebitelé tak nemusí sahat po zahraničních delikatesách, aby si dopřáli dobré máslo, stačí vybírat chytře a sledovat nejen cenu, ale i složení a původ výrobku.\u003c/p\u003e \u003cp\u003eZdroje: \u003ca href=\"https://www.arecenze.cz/clanky/test-10-masel-2025/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eArecenze.cz\u003c/a\u003e\u003c/p\u003e"])</script><script>self.__next_f.push([1,"24:T52f,Články z TechZprávy.cz nabízejí pohled na svět moderních technologií. Sledují dění v oblasti IT, mobilních zařízení, chytré domácnosti, vědy, vesmíru i digitálních trendů, které ovlivňují každodenní život. Obsah je určen čtenářům, kteří chtějí být v obraze, rozumět novinkám a vědět, co se děje na technologické scéně – bez nutnosti odborných znalostí.\n\nTexty kombinují aktuální zpravodajství s vysvětlujícím kontextem. Nechybí články o nových produktech, umělé inteligenci, kyberbezpečnosti, elektromobilitě nebo moderním přístupu ke vzdělávání. Důraz je kladen na to, jak se technologie promítají do praxe a co mohou znamenat pro běžné uživatele.\n\nTechZprávy.cz osloví čtenáře, kteří se zajímají o budoucnost, sledují digitální vývoj nebo jen hledají srozumitelný přehled toho, co se právě děje v technologiích kolem nás. Články se vyznačují přehledností, čtivostí a snahou přiblížit složitá témata způsobem, který je praktický i inspirativní.\n\nObsah přináší rovnováhu mezi novinkami, analýzou i populárně-naučným přístupem. Vhodný je pro všechny, kdo chtějí držet krok s dobou – ať už z profesního zájmu, zvědavosti nebo potřeby porozumět světu, který se mění stále rychleji.25:Ta6a,"])</script><script>self.__next_f.push([1,"\u003ch2\u003e\u003ca href=\"https://www.techzpravy.cz/kviz-vedomostni-ostuda-ceka-nebo-to-zvladnete-bez-ztraty-bodu/?utm_source=eco\u0026amp;utm_medium=newsfeed#sqq-quiz-2111\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/5eb02f82-3575-45d7-c628-628a99120500/public\" width=\"211\" height=\"55\" alt=\"Spustit kvíz\" /\u003e\u003c/a\u003e\u003c/h2\u003e\u003cbr /\u003e \u003cp\u003e\u003cstrong\u003eInternet, posléze také vyhledávače a nejnověji i umělá inteligence. Informace máme dnes už na dosah ruky. A díky chytrým telefonům se přístup k vědění skrývá doslova v každé kapse. S použitím stále více sofistikovaných překladačů nás nebrzdí dokonce ani jazyková bariéra.\u003c/strong\u003e\u003c/p\u003e \u003chr class=\"wp-block-separator has-alpha-channel-opacity\" /\u003e \u003cp\u003eTo stále více mění i pohled na vzdělávání. Potřebujeme vůbec ještě určitou sumu vědomostí, kterou každý z nás získává zcela samozřejmě už na základní škole? Tímto vzděláváním získáváme tzv. všeobecný přehled. Tímto termínem se označuje souhrn znalostí z různých oblastí lidského vědění, jako jsou dějiny, zeměpis, politika, kultura, umění, psychologie, ekonomie nebo i matematika.\u003c/p\u003e \u003cp\u003eNejde přitom jen o „nabiflované“ vědomosti. K takovému rozhledu by měly určitě patřit i analytické myšlení a schopnost úsudku. Široké znalosti tak mají vliv i na řadu dalších oblastí včetně uplatnění na trhu práce nebo sociálních dovedností. Myslíte si, že některé znalosti máte ukotveny naprosto spolehlivě? Zkuste náš kvíz.\u003c/p\u003e \u003ch2\u003e\u003ca href=\"https://www.techzpravy.cz/kviz-vedomostni-ostuda-ceka-nebo-to-zvladnete-bez-ztraty-bodu/?utm_source=eco\u0026amp;utm_medium=newsfeed#sqq-quiz-2111\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/51e7b471-5469-48cf-b9fa-027631f3e400/public\" width=\"211\" height=\"55\" alt=\"Spustit kvíz\" /\u003e\u003c/a\u003e\u003c/h2\u003e\u003cbr /\u003e\u003ch2\u003eMohlo by vás zajímat: \u003ca href=\"https://www.techzpravy.cz/kviz-co-vsechno-vam-dnes-plete-hlavu-overte-si-jestli-za-to-muze-jen-vek/?utm_source=eco\u0026amp;utm_medium=newsfeed\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eKVÍZ: Co všechno vám dnes plete hlavu? Ověřte si, jestli za to může jen věk\u003c/a\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/03ad07f3-e612-41b7-f33f-c1f35c281d00/public\" alt=\"KVÍZ: Co všechno vám dnes plete hlavu? Ověřte si, jestli za to může jen věk\" /\u003e\u003c/h2\u003e\u003cbr /\u003e\u003cdiv\u003e\u003cstrong\u003eZdroje článku:\u003c/strong\u003e Autorský text, \u003ca href=\"https://www.techzpravy.cz/kviz-vedomostni-ostuda-ceka-nebo-to-zvladnete-bez-ztraty-bodu/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003ewww.techzpravy.cz\u003c/a\u003e\u003c/div\u003e"])</script><script>self.__next_f.push([1,"26:Ta5c,"])</script><script>self.__next_f.push([1,"\u003ch2\u003e\u003ca href=\"https://www.techzpravy.cz/kviz-vedomostni-ostuda-ceka-nebo-to-zvladnete-bez-ztraty-bodu/?utm_source=eco\u0026amp;utm_medium=newsfeed#sqq-quiz-2111\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/5eb02f82-3575-45d7-c628-628a99120500/public\" width=\"211\" height=\"55\" alt=\"Spustit kvíz\"\u003e\u003c/a\u003e\u003c/h2\u003e\u003cbr\u003e \u003cp\u003e\u003cstrong\u003eInternet, posléze také vyhledávače a nejnověji i umělá inteligence. Informace máme dnes už na dosah ruky. A díky chytrým telefonům se přístup k vědění skrývá doslova v každé kapse. S použitím stále více sofistikovaných překladačů nás nebrzdí dokonce ani jazyková bariéra.\u003c/strong\u003e\u003c/p\u003e \u003chr class=\"wp-block-separator has-alpha-channel-opacity\"\u003e \u003cp\u003eTo stále více mění i pohled na vzdělávání. Potřebujeme vůbec ještě určitou sumu vědomostí, kterou každý z nás získává zcela samozřejmě už na základní škole? Tímto vzděláváním získáváme tzv. všeobecný přehled. Tímto termínem se označuje souhrn znalostí z různých oblastí lidského vědění, jako jsou dějiny, zeměpis, politika, kultura, umění, psychologie, ekonomie nebo i matematika.\u003c/p\u003e \u003cp\u003eNejde přitom jen o „nabiflované“ vědomosti. K takovému rozhledu by měly určitě patřit i analytické myšlení a schopnost úsudku. Široké znalosti tak mají vliv i na řadu dalších oblastí včetně uplatnění na trhu práce nebo sociálních dovedností. Myslíte si, že některé znalosti máte ukotveny naprosto spolehlivě? Zkuste náš kvíz.\u003c/p\u003e \u003ch2\u003e\u003ca href=\"https://www.techzpravy.cz/kviz-vedomostni-ostuda-ceka-nebo-to-zvladnete-bez-ztraty-bodu/?utm_source=eco\u0026amp;utm_medium=newsfeed#sqq-quiz-2111\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/51e7b471-5469-48cf-b9fa-027631f3e400/public\" width=\"211\" height=\"55\" alt=\"Spustit kvíz\"\u003e\u003c/a\u003e\u003c/h2\u003e\u003cbr\u003e\u003ch2\u003eMohlo by vás zajímat: \u003ca href=\"https://www.techzpravy.cz/kviz-co-vsechno-vam-dnes-plete-hlavu-overte-si-jestli-za-to-muze-jen-vek/?utm_source=eco\u0026amp;utm_medium=newsfeed\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eKVÍZ: Co všechno vám dnes plete hlavu? Ověřte si, jestli za to může jen věk\u003c/a\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/03ad07f3-e612-41b7-f33f-c1f35c281d00/public\" alt=\"KVÍZ: Co všechno vám dnes plete hlavu? Ověřte si, jestli za to může jen věk\"\u003e\u003c/h2\u003e\u003cbr\u003e\u003cdiv\u003e\u003cstrong\u003eZdroje článku:\u003c/strong\u003e Autorský text, \u003ca href=\"https://www.techzpravy.cz/kviz-vedomostni-ostuda-ceka-nebo-to-zvladnete-bez-ztraty-bodu/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003ewww.techzpravy.cz\u003c/a\u003e\u003c/div\u003e"])</script><script>self.__next_f.push([1,"27:T16d0,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cstrong\u003eČekání celé hodiny, někdy i přes noc, na dnes běžné zboží bylo za socialismu časté. Kdo chtěl banány, maso nebo toaletní papír, musel mít pevné nervy nebo známou prodavačku. Nakupování tehdy připomínalo spíš loterii, v níž hlavní výhrou byla obyčejná krabička kakaa.\u003c/strong\u003e\u003c/p\u003e \u003ch2\u003eKdyž fronta byla životní styl\u003c/h2\u003e \u003cp\u003eVidět frontu před obchodem znamenalo jediné, že něco „přivezli“. Pamětníci dodnes vyprávějí, jak se lidé řadili, aniž by věděli, na co vlastně čekají. \u003cem\u003e„Jakmile ji člověk viděl, buď přiběhl a hned to zjišťoval, nebo si do ní rovnou preventivně stoupl,“\u003c/em\u003e vzpomínala paní Helena z Prahy pro Aktuálně.cz.\u003c/p\u003e \u003cp\u003eFronty se tvořily téměř na všechno, od masa, mléka, elektroniky až po dámské vložky. Nedostatkové zboží se označovalo jako „úzkoprofilové“ a lidé, kteří ho chtěli, si říkali „frontoví bojovníci“. V zimě, v dešti, s dětmi i bez nich, často i několik hodin.\u003c/p\u003e \u003cp\u003ePodle průzkumu STEM/MARK z posledních let až 40 procent lidí starších šedesáti let přiznalo, že před rokem 1989 stálo frontu na potraviny, další čtvrtina pak na elektroniku nebo textil. Dnes, kdy žijeme v naprostém přebytku všeho, něco nepředstavitelného.\u003c/p\u003e \u003ch2\u003eBanány jako symbol socialismu\u003c/h2\u003e \u003cp\u003eKdyž se před Vánocemi objevily v obchodech banány, spustila se doslova hysterie. Lidé prchali dřív z práce, aby stihli koupit alespoň jeden svazek. \u003cem\u003e„Odběhla jsem v pracovní době do fronty. Když jsem se vrátila, šla zase kolegyně, protože víc než jeden sáček mandarinek vám neprodali,“\u003c/em\u003e popsala pro Deník.cz paní Jana z Karlových Varů.\u003c/p\u003e \u003cp\u003eBanány se staly symbolem nefunkčního zásobování. Československo totiž nakupovalo převážně v zemích východního bloku, a exotické ovoce z Afriky či Jižní Ameriky mířilo spíš na Západ. Jednoduše proto, že západní země platily víc.\u003c/p\u003e \u003cp\u003eEkonom Lukáš Kovanda k tomu uvedl: \u003cem\u003e„V tehdejším Československu nefungoval cenový mechanismus. Ceny určovala centrální komise, a protože nebylo možné pružně reagovat na poptávku, zboží prostě chybělo.“\u003c/em\u003e\u003c/p\u003e \u003cfigure class=\"wp-caption aligncenter\"\u003e\u003cimg loading=\"lazy\" class=\"size-full wp-image-29024\" src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/498de86e-2144-4d55-8a85-d1091d7c4500/public\" alt=\"\" width=\"1024\" height=\"577\" /\u003e\u003cfigcaption class=\"wp-caption-text\"\u003eInstalace socialistické maloprodejny v Muzeu komunismu. FOTO: \u003ca href=\"https://commons.wikimedia.org/wiki/File:Museum_of_Communism_Shop_1.jpg\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eChemical Engineer\u003c/a\u003e, \u003ca href=\"https://creativecommons.org/licenses/by-sa/4.0\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCC BY-SA 4.0\u003c/a\u003e, via Wikimedia Commons\u003c/figcaption\u003e\u003c/figure\u003e \u003ch2\u003eTuzex, podpultovky a výměnný obchod\u003c/h2\u003e \u003cp\u003eNedostatek zboží zrodil zvláštní systémy, a to podpultový prodej a černý trh. Kdo měl známou prodavačku, byl král. Zboží se schovávalo tzv. „pod pultem“ a vydávalo jen vyvoleným. Ne však jen tak, obvykle to bylo za protislužbu, cigarety, nebo láhev rumu.\u003c/p\u003e \u003cp\u003eA pak tu byl Tuzex, obchody se západním zbožím, kam se chodilo s tuzexovými bony. Ty se nedaly koupit oficiálně, ale veksláci je nabízeli za čtyřnásobek ceny. \u003cem\u003e„Bony brali i esenbáci,“\u003c/em\u003e připomněl Kovanda.\u003c/p\u003e \u003cp\u003ePodpultový systém byl vlastně přirozenou reakcí na neefektivní plánované hospodářství. Ačkoli se „pětiletky“ vždy plnily a výroba papírově rostla, regály v obchodech zely prázdnotou. Výrobky, které se u nás vyráběly, se často vyvážely do Sovětského svazu, zatímco lidé doma stáli fronty na toaletní papír nebo kola Favorit.\u003c/p\u003e \u003ch2\u003eErvéháčko a mechem místo papíru\u003c/h2\u003e \u003cp\u003eS nedostatkem se lidé naučili vyrovnávat po svém a humor byl často jedinou obranou. Po celé republice kolovaly vtipy a narážky na tehdejší situaci. Typickým symbolem se stala kostkovaná taška na kolečkách, přezdívaná ervéháčko podle zkratky RVHP (Rada vzájemné hospodářské pomoci). Lidé ji spojovali s ironickým rčením o prázdných nákupech, které vystihovalo realitu doby. \u003cem\u003e„Ráno vyjedu, hov*o přivezu,“\u003c/em\u003e vzpomínají pamětníci.\u003c/p\u003e \u003cp\u003eS nedostatkem toaletního papíru se Češi potýkali opakovaně. Podle Paměti národa studenti při majálesu v roce 1963 skandovali:\u003cem\u003e „Chceš-li býti dobrým Čechem, vytírej si p**el mechem.“\u003c/em\u003e Cynismus tehdejší doby vystihuje lépe než jakákoli statistika.\u003c/p\u003e \u003ch2\u003eCo zůstalo v lidech dodnes\u003c/h2\u003e \u003cp\u003eI po téměř čtyřiceti letech od pádu komunismu zůstávají vzpomínky na fronty a prázdné regály živé. Mnozí starší lidé dnes s nadsázkou říkají, že je fronty „vycvičily v trpělivosti“. Ale realita byla mnohem tvrdší. Nedostatek zboží ovlivnil i způsob myšlení celé generace. Lidé si zvykli „dělat zásoby“, nakupovat do foroty a brát zboží, když zrovna bylo dostupné. Tento zvyk přetrval i po roce 1989, jen se zvedl strop možností.\u003c/p\u003e \u003cp\u003eV mnoha domácnostech se totiž dodnes najdou věci nakoupené „pro jistotu“. A i když už fronty na banány dnes působí jako něco nepředstavitelného, zůstal v lidech hluboko zakořeněný reflex, že co je k mání dnes, zítra být nemusí. Možná i proto mají Češi zvláštní slabost pro slevy, výprodeje a akce.\u003c/p\u003e \u003cp\u003e\u003cem\u003eZdroje: autorský text, \u003ca href=\"https://www.denik.cz/spolecnost/banany-socialismus-nedostatkove-zbozi.html\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eDeník\u003c/a\u003e, \u003ca href=\"https://zpravy.aktualne.cz/finance/fronty-a-nakupovani-za-socialismu/r~f1bd30c009ec11ea926e0cc47ab5f122/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eAktuálně\u003c/a\u003e\u003c/em\u003e\u003c/p\u003e"])</script><script>self.__next_f.push([1,"28:T16ce,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cstrong\u003eČekání celé hodiny, někdy i přes noc, na dnes běžné zboží bylo za socialismu časté. Kdo chtěl banány, maso nebo toaletní papír, musel mít pevné nervy nebo známou prodavačku. Nakupování tehdy připomínalo spíš loterii, v níž hlavní výhrou byla obyčejná krabička kakaa.\u003c/strong\u003e\u003c/p\u003e \u003ch2\u003eKdyž fronta byla životní styl\u003c/h2\u003e \u003cp\u003eVidět frontu před obchodem znamenalo jediné, že něco „přivezli“. Pamětníci dodnes vyprávějí, jak se lidé řadili, aniž by věděli, na co vlastně čekají. \u003cem\u003e„Jakmile ji člověk viděl, buď přiběhl a hned to zjišťoval, nebo si do ní rovnou preventivně stoupl,“\u003c/em\u003e vzpomínala paní Helena z Prahy pro Aktuálně.cz.\u003c/p\u003e \u003cp\u003eFronty se tvořily téměř na všechno, od masa, mléka, elektroniky až po dámské vložky. Nedostatkové zboží se označovalo jako „úzkoprofilové“ a lidé, kteří ho chtěli, si říkali „frontoví bojovníci“. V zimě, v dešti, s dětmi i bez nich, často i několik hodin.\u003c/p\u003e \u003cp\u003ePodle průzkumu STEM/MARK z posledních let až 40 procent lidí starších šedesáti let přiznalo, že před rokem 1989 stálo frontu na potraviny, další čtvrtina pak na elektroniku nebo textil. Dnes, kdy žijeme v naprostém přebytku všeho, něco nepředstavitelného.\u003c/p\u003e \u003ch2\u003eBanány jako symbol socialismu\u003c/h2\u003e \u003cp\u003eKdyž se před Vánocemi objevily v obchodech banány, spustila se doslova hysterie. Lidé prchali dřív z práce, aby stihli koupit alespoň jeden svazek. \u003cem\u003e„Odběhla jsem v pracovní době do fronty. Když jsem se vrátila, šla zase kolegyně, protože víc než jeden sáček mandarinek vám neprodali,“\u003c/em\u003e popsala pro Deník.cz paní Jana z Karlových Varů.\u003c/p\u003e \u003cp\u003eBanány se staly symbolem nefunkčního zásobování. Československo totiž nakupovalo převážně v zemích východního bloku, a exotické ovoce z Afriky či Jižní Ameriky mířilo spíš na Západ. Jednoduše proto, že západní země platily víc.\u003c/p\u003e \u003cp\u003eEkonom Lukáš Kovanda k tomu uvedl: \u003cem\u003e„V tehdejším Československu nefungoval cenový mechanismus. Ceny určovala centrální komise, a protože nebylo možné pružně reagovat na poptávku, zboží prostě chybělo.“\u003c/em\u003e\u003c/p\u003e \u003cfigure class=\"wp-caption aligncenter\"\u003e\u003cimg loading=\"lazy\" class=\"size-full wp-image-29024\" src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/498de86e-2144-4d55-8a85-d1091d7c4500/public\" alt=\"\" width=\"1024\" height=\"577\"\u003e\u003cfigcaption class=\"wp-caption-text\"\u003eInstalace socialistické maloprodejny v Muzeu komunismu. FOTO: \u003ca href=\"https://commons.wikimedia.org/wiki/File:Museum_of_Communism_Shop_1.jpg\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eChemical Engineer\u003c/a\u003e, \u003ca href=\"https://creativecommons.org/licenses/by-sa/4.0\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCC BY-SA 4.0\u003c/a\u003e, via Wikimedia Commons\u003c/figcaption\u003e\u003c/figure\u003e \u003ch2\u003eTuzex, podpultovky a výměnný obchod\u003c/h2\u003e \u003cp\u003eNedostatek zboží zrodil zvláštní systémy, a to podpultový prodej a černý trh. Kdo měl známou prodavačku, byl král. Zboží se schovávalo tzv. „pod pultem“ a vydávalo jen vyvoleným. Ne však jen tak, obvykle to bylo za protislužbu, cigarety, nebo láhev rumu.\u003c/p\u003e \u003cp\u003eA pak tu byl Tuzex, obchody se západním zbožím, kam se chodilo s tuzexovými bony. Ty se nedaly koupit oficiálně, ale veksláci je nabízeli za čtyřnásobek ceny. \u003cem\u003e„Bony brali i esenbáci,“\u003c/em\u003e připomněl Kovanda.\u003c/p\u003e \u003cp\u003ePodpultový systém byl vlastně přirozenou reakcí na neefektivní plánované hospodářství. Ačkoli se „pětiletky“ vždy plnily a výroba papírově rostla, regály v obchodech zely prázdnotou. Výrobky, které se u nás vyráběly, se často vyvážely do Sovětského svazu, zatímco lidé doma stáli fronty na toaletní papír nebo kola Favorit.\u003c/p\u003e \u003ch2\u003eErvéháčko a mechem místo papíru\u003c/h2\u003e \u003cp\u003eS nedostatkem se lidé naučili vyrovnávat po svém a humor byl často jedinou obranou. Po celé republice kolovaly vtipy a narážky na tehdejší situaci. Typickým symbolem se stala kostkovaná taška na kolečkách, přezdívaná ervéháčko podle zkratky RVHP (Rada vzájemné hospodářské pomoci). Lidé ji spojovali s ironickým rčením o prázdných nákupech, které vystihovalo realitu doby. \u003cem\u003e„Ráno vyjedu, hov*o přivezu,“\u003c/em\u003e vzpomínají pamětníci.\u003c/p\u003e \u003cp\u003eS nedostatkem toaletního papíru se Češi potýkali opakovaně. Podle Paměti národa studenti při majálesu v roce 1963 skandovali:\u003cem\u003e „Chceš-li býti dobrým Čechem, vytírej si p**el mechem.“\u003c/em\u003e Cynismus tehdejší doby vystihuje lépe než jakákoli statistika.\u003c/p\u003e \u003ch2\u003eCo zůstalo v lidech dodnes\u003c/h2\u003e \u003cp\u003eI po téměř čtyřiceti letech od pádu komunismu zůstávají vzpomínky na fronty a prázdné regály živé. Mnozí starší lidé dnes s nadsázkou říkají, že je fronty „vycvičily v trpělivosti“. Ale realita byla mnohem tvrdší. Nedostatek zboží ovlivnil i způsob myšlení celé generace. Lidé si zvykli „dělat zásoby“, nakupovat do foroty a brát zboží, když zrovna bylo dostupné. Tento zvyk přetrval i po roce 1989, jen se zvedl strop možností.\u003c/p\u003e \u003cp\u003eV mnoha domácnostech se totiž dodnes najdou věci nakoupené „pro jistotu“. A i když už fronty na banány dnes působí jako něco nepředstavitelného, zůstal v lidech hluboko zakořeněný reflex, že co je k mání dnes, zítra být nemusí. Možná i proto mají Češi zvláštní slabost pro slevy, výprodeje a akce.\u003c/p\u003e \u003cp\u003e\u003cem\u003eZdroje: autorský text, \u003ca href=\"https://www.denik.cz/spolecnost/banany-socialismus-nedostatkove-zbozi.html\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eDeník\u003c/a\u003e, \u003ca href=\"https://zpravy.aktualne.cz/finance/fronty-a-nakupovani-za-socialismu/r~f1bd30c009ec11ea926e0cc47ab5f122/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eAktuálně\u003c/a\u003e\u003c/em\u003e\u003c/p\u003e"])</script><script>self.__next_f.push([1,"29:T1255,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cstrong\u003eVzácná bankovka z rané fáze československého státu vám může přinést nečekané bohatství v řádech miliónů.\u003c/strong\u003e\u003c/p\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cp\u003eKrabice z půdy nebo ze sklepa často skrývají poklady, které nemusí na první pohled působit jako cennosti. Možná o tom ani nevíte, a uschováváte po svých předcích „svatý grál“, který vám může změnit život a udělat z vás boháče. Někdy stačí zdánlivě obyčejný kus papíru.\u003c/p\u003e \u003ch2\u003ePořádně se podívejte, než něco vyhodíte\u003c/h2\u003e \u003cp\u003ePokud se na ten nepořádek ve sklepě nebo na půdě už nemůžete dívat a rozhodli jste se pro takzvanou debordelizaci věcí, musíme vás upozornit, abyste si dali velký pozor, než něco vyhodíte. \u003cstrong\u003eVe starých krabicích se totiž může skrývat poklad\u003c/strong\u003e, o němž nemáte ani tušení. Objevíte-li staré bankovky, s nimiž v dnešní době už nelze platit, neodsuzujte je k zániku. Možná mají větší hodnotu než kdy dříve.\u003c/p\u003e \u003ch2\u003eStará pětitisícikoruna\u003c/h2\u003e \u003cp\u003eNapříklad nejvzácnější československá pětitisícikoruna z roku 1919. Je to až k nevíře, ale tento zdánlivě bezcenný kus papíru může dosahovat hodnoty až 25 miliónů korun. A proč je tak cenná? Vznikla ve Vídni a bylo jí vytištěno necelých 600 tisíc kusů, ovšem \u003cstrong\u003edo dnešní doby se podle expertů dochoval jen zlomek\u003c/strong\u003e. „\u003cem\u003eJe zajímavá tím, že byla v oběhu 20 měsíců, od 7. srpna 1919 do 15. dubna 1921. Právě ta krátká doba oběhu stojí za tím, že bankovek, které se musely naráz vyměnit a nebyly dlouho v oběhu, je poměrně málo. Dnes evidujeme ve veřejných a soukromých sbírkách asi 36 pravých kusů této státovky,\u003c/em\u003e“ uvedl dle ČT24 Filip Hradil z Vlastivědného muzea v Olomouci.\u003c/p\u003e \u003cdiv\u003e\u003c/div\u003e \u003ca href=\"https://svetkreativity.cz/vzacne-ceske-desetikoruny-se-prodavaji-za-statisice-korun/\" class=\"inside-post-link\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e \u003cdiv class=\"i_i\"\u003e \u003cimg width=\"250\" height=\"131\" src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/ee3e22fc-98c0-40cc-67da-f91af7c2e100/public\" class=\"attachment-250x180 size-250x180\" alt=\"\" /\u003e \u003c/div\u003e \u003cdiv class=\"i_l\"\u003e \u003ch3 class=\"hed\"\u003eTato desetikoruna se prodala za 160 tisíc Kč. Podle odborníků jsou další kusy stále v oběhu\u003c/h3\u003e \u003c/div\u003e \u003c/a\u003e \u003cblockquote class=\"instagram-media\"\u003e \u003cdiv\u003e \u003cp\u003e \u003c/p\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003eZobrazit příspěvek na Instagramu\u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003cp\u003e \u003c/p\u003e \u003cp\u003e\u003ca class=\"external\" href=\"https://www.instagram.com/p/DC6h6Ado1ga/?utm_source=ig_embed\u0026amp;utm_campaign=loading\" target=\"_blank\" rel=\"noopener noreferrer\"\u003ePříspěvek sdílený Národná Pokladnica (@narodna.pokladnica)\u003c/a\u003e\u003c/p\u003e \u003c/div\u003e \u003c/blockquote\u003e \u003cp\u003e\u003c/p\u003e \u003cdiv\u003e\u003c/div\u003e \u003cp\u003eBankovce se říká státovka, protože byla vydaná státem v počátcích fungování Československa. Má tedy vysokou nejen peněžní hodnotu, ale i historickou. \u003cstrong\u003eV roce 2024 se v Praze jeden exemplář vydražil za neuvěřitelných 25 680 000 korun\u003c/strong\u003e. O 4 roky dříve se podobný kus prodal za 12,1 miliónu korun. Přestože vám zřejmě žádná jiná bankovka nepřinese tak vysoké jmění, existují i jiná platidla, která vám mohou dopřát nečekaně velké bohatství. O některých \u003ca href=\"https://svetkreativity.cz/vzacne-mince-a-bankovky-jak-je-rozpoznat-oznaceni/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003evzácných bankovkách\u003c/a\u003e jsme již psali na SvětěKreativity.\u003c/p\u003e \u003cp\u003eZdroj: \u003ca class=\"external\" href=\"https://www.idnes.cz/finance/banky-a-sporeni/ceska-mena-koruna-100-let-pribehy-historie-rarity.A190403_123639_sporeni_sov\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eiDNES\u003c/a\u003e, \u003ca class=\"external\" href=\"https://ct24.ceskatelevize.cz/clanek/regiony/bankovka-statovka-zachycena-na-internetove-aukci-je-prava-ma-hodnotu-milionu-korun-96589\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eČT24\u003c/a\u003e, \u003ca class=\"external\" href=\"https://www.instagram.com/narodna.pokladnica/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eInstagram Národná pokladnica\u003c/a\u003e\u003c/p\u003e \u003cp\u003e \u003c/p\u003e \u003cp\u003eThe post \u003ca href=\"https://svetkreativity.cz/vzacna-bankovka-z-rane-faze-csr-ma-hodnotu-milionu/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eKdo si nenechal vyměnit tuto starou bankovku, ten má doma poklad v hodnotě 25 000 000 Kč\u003c/a\u003e appeared first on \u003ca href=\"https://svetkreativity.cz\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eSvětkreativity\u003c/a\u003e.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"2a:T1253,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003cstrong\u003eVzácná bankovka z rané fáze československého státu vám může přinést nečekané bohatství v řádech miliónů.\u003c/strong\u003e\u003c/p\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cp\u003eKrabice z půdy nebo ze sklepa často skrývají poklady, které nemusí na první pohled působit jako cennosti. Možná o tom ani nevíte, a uschováváte po svých předcích „svatý grál“, který vám může změnit život a udělat z vás boháče. Někdy stačí zdánlivě obyčejný kus papíru.\u003c/p\u003e \u003ch2\u003ePořádně se podívejte, než něco vyhodíte\u003c/h2\u003e \u003cp\u003ePokud se na ten nepořádek ve sklepě nebo na půdě už nemůžete dívat a rozhodli jste se pro takzvanou debordelizaci věcí, musíme vás upozornit, abyste si dali velký pozor, než něco vyhodíte. \u003cstrong\u003eVe starých krabicích se totiž může skrývat poklad\u003c/strong\u003e, o němž nemáte ani tušení. Objevíte-li staré bankovky, s nimiž v dnešní době už nelze platit, neodsuzujte je k zániku. Možná mají větší hodnotu než kdy dříve.\u003c/p\u003e \u003ch2\u003eStará pětitisícikoruna\u003c/h2\u003e \u003cp\u003eNapříklad nejvzácnější československá pětitisícikoruna z roku 1919. Je to až k nevíře, ale tento zdánlivě bezcenný kus papíru může dosahovat hodnoty až 25 miliónů korun. A proč je tak cenná? Vznikla ve Vídni a bylo jí vytištěno necelých 600 tisíc kusů, ovšem \u003cstrong\u003edo dnešní doby se podle expertů dochoval jen zlomek\u003c/strong\u003e. „\u003cem\u003eJe zajímavá tím, že byla v oběhu 20 měsíců, od 7. srpna 1919 do 15. dubna 1921. Právě ta krátká doba oběhu stojí za tím, že bankovek, které se musely naráz vyměnit a nebyly dlouho v oběhu, je poměrně málo. Dnes evidujeme ve veřejných a soukromých sbírkách asi 36 pravých kusů této státovky,\u003c/em\u003e“ uvedl dle ČT24 Filip Hradil z Vlastivědného muzea v Olomouci.\u003c/p\u003e \u003cdiv\u003e\u003c/div\u003e \u003ca href=\"https://svetkreativity.cz/vzacne-ceske-desetikoruny-se-prodavaji-za-statisice-korun/\" class=\"inside-post-link\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e \u003cdiv class=\"i_i\"\u003e \u003cimg width=\"250\" height=\"131\" src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/ee3e22fc-98c0-40cc-67da-f91af7c2e100/public\" class=\"attachment-250x180 size-250x180\" alt=\"\"\u003e \u003c/div\u003e \u003cdiv class=\"i_l\"\u003e \u003ch3 class=\"hed\"\u003eTato desetikoruna se prodala za 160 tisíc Kč. Podle odborníků jsou další kusy stále v oběhu\u003c/h3\u003e \u003c/div\u003e \u003c/a\u003e \u003cblockquote class=\"instagram-media\"\u003e \u003cdiv\u003e \u003cp\u003e \u003c/p\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003eZobrazit příspěvek na Instagramu\u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cdiv\u003e \u003cdiv\u003e\u003c/div\u003e \u003cdiv\u003e\u003c/div\u003e \u003c/div\u003e \u003cp\u003e \u003c/p\u003e \u003cp\u003e\u003ca class=\"external\" href=\"https://www.instagram.com/p/DC6h6Ado1ga/?utm_source=ig_embed\u0026amp;utm_campaign=loading\" target=\"_blank\" rel=\"noopener noreferrer\"\u003ePříspěvek sdílený Národná Pokladnica (@narodna.pokladnica)\u003c/a\u003e\u003c/p\u003e \u003c/div\u003e \u003c/blockquote\u003e \u003cp\u003e\u003c/p\u003e \u003cdiv\u003e\u003c/div\u003e \u003cp\u003eBankovce se říká státovka, protože byla vydaná státem v počátcích fungování Československa. Má tedy vysokou nejen peněžní hodnotu, ale i historickou. \u003cstrong\u003eV roce 2024 se v Praze jeden exemplář vydražil za neuvěřitelných 25 680 000 korun\u003c/strong\u003e. O 4 roky dříve se podobný kus prodal za 12,1 miliónu korun. Přestože vám zřejmě žádná jiná bankovka nepřinese tak vysoké jmění, existují i jiná platidla, která vám mohou dopřát nečekaně velké bohatství. O některých \u003ca href=\"https://svetkreativity.cz/vzacne-mince-a-bankovky-jak-je-rozpoznat-oznaceni/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003evzácných bankovkách\u003c/a\u003e jsme již psali na SvětěKreativity.\u003c/p\u003e \u003cp\u003eZdroj: \u003ca class=\"external\" href=\"https://www.idnes.cz/finance/banky-a-sporeni/ceska-mena-koruna-100-let-pribehy-historie-rarity.A190403_123639_sporeni_sov\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eiDNES\u003c/a\u003e, \u003ca class=\"external\" href=\"https://ct24.ceskatelevize.cz/clanek/regiony/bankovka-statovka-zachycena-na-internetove-aukci-je-prava-ma-hodnotu-milionu-korun-96589\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eČT24\u003c/a\u003e, \u003ca class=\"external\" href=\"https://www.instagram.com/narodna.pokladnica/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eInstagram Národná pokladnica\u003c/a\u003e\u003c/p\u003e \u003cp\u003e \u003c/p\u003e \u003cp\u003eThe post \u003ca href=\"https://svetkreativity.cz/vzacna-bankovka-z-rane-faze-csr-ma-hodnotu-milionu/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eKdo si nenechal vyměnit tuto starou bankovku, ten má doma poklad v hodnotě 25 000 000 Kč\u003c/a\u003e appeared first on \u003ca href=\"https://svetkreativity.cz\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eSvětkreativity\u003c/a\u003e.\u003c/p\u003e"])</script><script>self.__next_f.push([1,"2b:T50c,Články ze Žena-in.cz přinášejí osobitý, často velmi otevřený pohled na ženský svět v celé jeho šíři – od vztahů, rodiny a domácnosti až po aktuální společenská témata nebo osobní zkušenosti. Jejich silnou stránkou je autenticita, blízkost a schopnost otevřít i citlivá témata s lidskostí, empatií a často i nadhledem.\n\nČtenářky zde najdou inspiraci pro každodenní život i únik do světa příběhů, ve kterých se snadno poznají. Texty kombinují praktické rady s emocemi, humor s reflexí, a často vycházejí přímo z reálných životních situací. Nejde jen o univerzální návody nebo trendy, ale o skutečný dialog se ženami, které řeší podobné věci jako ony samy.\n\nObsah oslovuje široké spektrum čtenářek, od mladších žen až po zkušené čtenářky, které ocení kombinaci srozumitelnosti, sdílení a ženské solidarity. Vedle lehčích témat, jako je vaření nebo móda, se objevují i hlubší texty o vztazích, sebevědomí, zdraví či životních křižovatkách.\n\nČlánky ze Žena-in.cz jsou blízké, přístupné a psané s respektem ke každodennímu životu. Nabízejí prostor pro zasmání, zamyšlení i inspiraci – a právě proto si snadno nacházejí své čtenářky napříč generacemi.2c:T50c,Články ze Žena-in.cz přinášejí osobitý, často velmi otevřený pohled na ženský svět v celé jeho šíři – od vztahů, rodiny a domácnosti až po aktuální společenská témata nebo osobní zkušenosti. Jejich silnou stránkou je autenticita, blízkost a schopnost otevřít i citlivá témata s lidskostí, empatií a často i nadhledem.\n\nČtenářky zde najdou inspiraci pro každodenní život i únik do světa příběhů, ve kterých se snadno poznají. Texty kombinují praktické rady s emocemi, humor s reflexí, a často vycházejí přímo z reálných životních situací. Nejde jen o univerzální návody nebo trendy, ale o skutečný dialog se ženami, které řeší podobné věci jako ony samy.\n\nObsah o"])</script><script>self.__next_f.push([1,"slovuje široké spektrum čtenářek, od mladších žen až po zkušené čtenářky, které ocení kombinaci srozumitelnosti, sdílení a ženské solidarity. Vedle lehčích témat, jako je vaření nebo móda, se objevují i hlubší texty o vztazích, sebevědomí, zdraví či životních křižovatkách.\n\nČlánky ze Žena-in.cz jsou blízké, přístupné a psané s respektem ke každodennímu životu. Nabízejí prostor pro zasmání, zamyšlení i inspiraci – a právě proto si snadno nacházejí své čtenářky napříč generacemi.2d:T2357,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003ci\u003e„Samozřejmě mi bylo jasné, že bydlet s někým je zásadní krok a že teprve po sestěhování se ukážou některé zlozvyky toho druhého, o kterých jsme do té doby neměli tušení. Nepředstavovala jsem si žádnou procházku růžovou zahradou, ale realita mě tedy opravdu šokovala,“\u003c/i\u003e popisuje Petra.\u003c/p\u003e \u003cdiv\u003e \u003cdiv\u003e \u003cdiv\u003eMOHLO BY SE VÁM LÍBIT:\u003c/div\u003e \u003cdiv\u003e\u003ca href=\"https://zena-in.cz/clanek/nejjasnejsi-dukaz-ze-je-vas-vztah-u-konce-co-rika-veda-i-praxe\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e Nejjasnější důkaz, že je váš vztah u konce: Co říká věda i praxe\u003c/a\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cp\u003eTa tvrdí, že pokaždé, když přišla k Dominikovi během předchozího roku \u003ca href=\"https://zena-in.cz/clanky/podobne/rande\" target=\"_blank\" rel=\"noopener noreferrer\"\u003erandění\u003c/a\u003e na návštěvu, měl doma perfektně uklizeno a tvářil se jako někdo, kdo si na pořádek opravdu potrpí. Vždy byl také velmi galantní, pravý gentleman, kterého by nenapadlo se před Petrou posadit v trenýrkách na gauč, drbat se v rozkroku a popíjet u toho lahváče. Jenže po tom, co se k němu Petra \u003ca href=\"https://zena-in.cz/clanky/podobne/stehovani\" target=\"_blank\" rel=\"noopener noreferrer\"\u003enastěhovala\u003c/a\u003e, se všechno tohle stalo realitou.\u003c/p\u003e \u003cp\u003e\u003ci\u003e„Proměna Dominikova chování jako kdyby nastala z minuty na minutu. Hned potom, co jsem si k němu přesunula všechny svoje věci. Postupně jsem zjistila, že co neuklidím já, to nikdo jiný neuklidí a z Dominika dokonce vypadlo, že před stěhováním měl doma dvakrát týdně uklízečku, kterou ale odřekl, když jsme se domluvili na společném bydlení. Myslel si prý, že uklízet budu chtít jako paní domácnosti jenom já,“\u003c/i\u003e říká Petra, která se ale k Dominikovi rozhodně nestěhovala s představou, že mu bude dělat hospodyni a \u003ca href=\"https://zena-in.cz/clanky/podobne/uklizecka\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eslužeb uklízečky\u003c/a\u003e by klidně ráda využívala dál. Zvlášť když se ukázalo, že Dominik je ve skutečnosti opravdu velký bordelář.\u003c/p\u003e \u003cdiv\u003e \u003cdiv\u003e \u003cdiv\u003eMOHLO BY SE VÁM LÍBIT:\u003c/div\u003e \u003cdiv\u003e\u003ca href=\"https://zena-in.cz/clanek/myslela-jsem-ze-randim-se-samymi-hnupy-ale-nakonec-jsem-zjistila-ze-je-chyba-ve-mne-rika-denisa\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e Myslela jsem, že randím se samými hňupy, ale nakonec jsem zjistila, že je chyba ve mně, říká Denisa\u003c/a\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cp\u003ePetřino prozření se navíc netýkalo jen nepořádku, ale i Dominikova dalšího chování. \u003ca href=\"https://zena-in.cz/clanky/podobne/gentleman\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eZ gentlemana\u003c/a\u003e, co by si před ní dřív v životě neuprdnul se prý stal přesně ten typický obraz Čecha ležícího na gauči a škrábajícího si varlata.\u003c/p\u003e \u003cp\u003e\u003ci\u003e„Vypadá to, že se na mě celý rok jen snažil zapůsobit, vydával se za někoho, kým není a teprve po nastěhování se ukázala jeho pravá tvář. Teď vlastně ani nevím, jestli jsem se zamilovala opravdu do něj nebo jen do nějakého obrazu a představy,“\u003c/i\u003e uzavírá Petra.\u003c/p\u003e \u003cp\u003e\u003cb\u003eK příběhu se vyjádřila životní a vztahová koučka Mgr. Janette Šimková:\u003c/b\u003e\u003c/p\u003e \u003cp\u003ePetra zažila klamavý dojem ve vztahu – nesoulad mezi tím, co partner prezentoval, a tím, jak se ve skutečnosti choval. Dominikův záměr nemusel být vědomé klamání, ale velmi si dával záležet na tom, aby se ve fázi randění ukázal v co nejlepším světle. Až společné bydlení odhalilo jeho skutečné návyky, představy o vztahu a postoje k odpovědnosti. Petra má oprávněnou pochybnost, zda je tento muž schopný partnerské rovnosti a respektu.\u003c/p\u003e \u003cp\u003eZ hlediska řešení takové situace bývá potřeba série otevřených, upřímných rozhovorů o očekáváních, rozdělení povinností a stanovení hranic. Petra se potřebuje ujistit, zda je Dominik ochoten převzít odpovědnost za rozdělení rolí v domácnosti i za své chování.\u003c/p\u003e \u003cp\u003ePři těchto debatách bývá nápomocná párová terapie, vztahový poradce nebo kouč, kteří vytvářejí bezpečný a konstruktivní prostor pro společné hledání funkčního modelu soužití, se kterým budou spokojeni oba partneři. Každý vztah potřebuje vzájemnost, kde kompromis nevzniká ze strachu, viny ani z potřeby být dokonalý/dokonalá, ale z dobré vůle a rovnocennosti. Když musí jeden z partnerů trvale ustupovat, děje se tak na jeho úkor a na úkor zdraví vztahu.\u003c/p\u003e \u003cp\u003ePokud by Dominik nebyl otevřený sebereflexi a nezměnil svůj postoj, je zcela legitimní, pokud by se Petra rozhodla ze vztahu odejít. Vztah, který se rozpadne pod tíhou předstíraného ideálu, není selháním, ale příležitostí k vědomější volbě při výběru kompatibilnějšího partnera.\u003c/p\u003e \u003ctable cellpadding=\"5\"\u003e \u003ctbody\u003e \u003ctr\u003e \u003ctd\u003e \u003cp\u003e\u003cb\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/9d3bd769-a4ef-4587-beaa-6798563fb600/public\" width=\"236\" height=\"284\" alt=\"a04e39708c301-Vystrizek.jpg.webp\" /\u003eMgr. Janette Šimková\u003c/b\u003e je životní a vztahová koučka.\u003cbr /\u003e\u003cbr /\u003eOsobnímu rozvoji se věnuje od roku 2008. Je certifikovanou koučkou RCS, absolvovala intenzivní tréninkový program Results Coaching System akreditovaný ICF (International Coach Federation). Model koučování párů a rodin studovala u jedné z nejlepších současných kouček na světě – Dr. Marilyn Atkinson, PhD., mezinárodně uznávané školitelky koučů. Absolvovala certifikovaný trénink Family and Couples Coaching od Erickson College International.\u003c/p\u003e \u003cul\u003e \u003cli\u003ePrvní zkušenosti získala ve 108hodinovém sociálně-psychologickém výcviku.\u003c/li\u003e \u003cli\u003eJe absolventkou dvouletého psychologického výcviku Integrativní práce s motivací a změnou v komplexních systémech, rodinách a párech v Coachingplus pod vedením odborného garanta prof. Antona Heretika.\u003c/li\u003e \u003cli\u003eVyužívání principů a technik Motivačních rozhovorů, které jsou komunikačním přístupem zaměřeným na podporu klientů při hledání a rozvíjení vnitřní motivace ke změně, studovala v 60hodinovém výcviku u Dr. Jana Soukupa.\u003c/li\u003e \u003cli\u003eZvládání stresu pomocí všímavosti (mindfulness) trénovala v kurzu u Andreje Jeleníka. Absolvovala 250hodinový supervizní výcvik pod vedením mezinárodně akreditovaných supervizorů z Coachingplus. Má licenci supervizora zapsanou na MPSVR SR.\u003c/li\u003e \u003cli\u003eJe aktivní členkou Evropské rady pro koučování a mentorování EMCC Czechia \u0026amp; Slovakia\u003c/li\u003e \u003cli\u003eMá evropskou koučovací akreditaci „senior practitioner“ EIA EMCC Global.\u003cb\u003e\u003cbr /\u003e\u003c/b\u003e\u003c/li\u003e \u003c/ul\u003e \u003cp\u003eVíce informací najdete na lifekoucing.sk.\u003c/p\u003e \u003c/td\u003e \u003c/tr\u003e \u003c/tbody\u003e \u003c/table\u003e \u003cp\u003e\u003cspan\u003eZdroj info: Text byl zpracován na základě příběhu ženy, kterou redakce zná a která jej předala redakci se svolením k uveřejnění. Fotografie je pouze ilustrační a jména osob byla na žádost této konkrétní ženy pozměněna, stejně tak jako její jméno. Pokud máte příběh, který by se mohl objevit na našich stránkách, napište nám na redakce@zena-in.cz.\u003c/span\u003e\u003c/p\u003e \u003ch3\u003eSouvisející články\u003c/h3\u003e\u003cul\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/tetin-dar-me-pripravil-o-rodinu-kazdy-z-neho-chce-kousek-na-spravedlnost-nehledi-rika-tamara\" title=\"Tetin dar mě připravil o rodinu. Každý z něho chce kousek, na spravedlnost nehledí, říká Tamara\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eTetin dar mě připravil o rodinu. Každý z něho chce kousek, na spravedlnost nehledí, říká Tamara\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/bud-za-sebe-poslal-nekoho-jineho-nebo-me-podvedl-stezuje-si-petra\" title=\"Buď za sebe poslal někoho jiného, nebo mě podvedl, stěžuje si Petra\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eBuď za sebe poslal někoho jiného, nebo mě podvedl, stěžuje si Petra\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/kouzlo-zralosti-proc-mladsi-muzi-stale-casteji-voli-starsi-partnerky\" title=\"Kouzlo zralosti: proč mladší muži stále častěji volí starší partnerky\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eKouzlo zralosti: proč mladší muži stále častěji volí starší partnerky\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/nejlepsi-kamaradka-me-nechala-bez-strechy-nad-hlavou-jen-kvuli-sve-hloupe-zasade-sveruje-se-nastvana-petra\" title=\"Nejlepší kamarádka mě nechala bez střechy nad hlavou jen kvůli své hloupé zásadě, svěřuje se naštvaná Petra\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eNejlepší kamarádka mě nechala bez střechy nad hlavou jen kvůli své hloupé zásadě, svěřuje se naštvaná Petra\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/co-laska-dela-s-zenskym-telem-vedci-odhalili-ze-zamilovanost-meni-imunitni-system\" title=\"Co láska dělá s ženským tělem? Vědci odhalili, že zamilovanost mění imunitní systém\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCo láska dělá s ženským tělem? Vědci odhalili, že zamilovanost mění imunitní systém\u003c/a\u003e\u003c/li\u003e \u003c/ul\u003e"])</script><script>self.__next_f.push([1,"2e:T234f,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u003ci\u003e„Samozřejmě mi bylo jasné, že bydlet s někým je zásadní krok a že teprve po sestěhování se ukážou některé zlozvyky toho druhého, o kterých jsme do té doby neměli tušení. Nepředstavovala jsem si žádnou procházku růžovou zahradou, ale realita mě tedy opravdu šokovala,“\u003c/i\u003e popisuje Petra.\u003c/p\u003e \u003cdiv\u003e \u003cdiv\u003e \u003cdiv\u003eMOHLO BY SE VÁM LÍBIT:\u003c/div\u003e \u003cdiv\u003e\u003ca href=\"https://zena-in.cz/clanek/nejjasnejsi-dukaz-ze-je-vas-vztah-u-konce-co-rika-veda-i-praxe\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e Nejjasnější důkaz, že je váš vztah u konce: Co říká věda i praxe\u003c/a\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cp\u003eTa tvrdí, že pokaždé, když přišla k Dominikovi během předchozího roku \u003ca href=\"https://zena-in.cz/clanky/podobne/rande\" target=\"_blank\" rel=\"noopener noreferrer\"\u003erandění\u003c/a\u003e na návštěvu, měl doma perfektně uklizeno a tvářil se jako někdo, kdo si na pořádek opravdu potrpí. Vždy byl také velmi galantní, pravý gentleman, kterého by nenapadlo se před Petrou posadit v trenýrkách na gauč, drbat se v rozkroku a popíjet u toho lahváče. Jenže po tom, co se k němu Petra \u003ca href=\"https://zena-in.cz/clanky/podobne/stehovani\" target=\"_blank\" rel=\"noopener noreferrer\"\u003enastěhovala\u003c/a\u003e, se všechno tohle stalo realitou.\u003c/p\u003e \u003cp\u003e\u003ci\u003e„Proměna Dominikova chování jako kdyby nastala z minuty na minutu. Hned potom, co jsem si k němu přesunula všechny svoje věci. Postupně jsem zjistila, že co neuklidím já, to nikdo jiný neuklidí a z Dominika dokonce vypadlo, že před stěhováním měl doma dvakrát týdně uklízečku, kterou ale odřekl, když jsme se domluvili na společném bydlení. Myslel si prý, že uklízet budu chtít jako paní domácnosti jenom já,“\u003c/i\u003e říká Petra, která se ale k Dominikovi rozhodně nestěhovala s představou, že mu bude dělat hospodyni a \u003ca href=\"https://zena-in.cz/clanky/podobne/uklizecka\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eslužeb uklízečky\u003c/a\u003e by klidně ráda využívala dál. Zvlášť když se ukázalo, že Dominik je ve skutečnosti opravdu velký bordelář.\u003c/p\u003e \u003cdiv\u003e \u003cdiv\u003e \u003cdiv\u003eMOHLO BY SE VÁM LÍBIT:\u003c/div\u003e \u003cdiv\u003e\u003ca href=\"https://zena-in.cz/clanek/myslela-jsem-ze-randim-se-samymi-hnupy-ale-nakonec-jsem-zjistila-ze-je-chyba-ve-mne-rika-denisa\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e Myslela jsem, že randím se samými hňupy, ale nakonec jsem zjistila, že je chyba ve mně, říká Denisa\u003c/a\u003e\u003c/div\u003e \u003c/div\u003e \u003c/div\u003e \u003cp\u003ePetřino prozření se navíc netýkalo jen nepořádku, ale i Dominikova dalšího chování. \u003ca href=\"https://zena-in.cz/clanky/podobne/gentleman\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eZ gentlemana\u003c/a\u003e, co by si před ní dřív v životě neuprdnul se prý stal přesně ten typický obraz Čecha ležícího na gauči a škrábajícího si varlata.\u003c/p\u003e \u003cp\u003e\u003ci\u003e„Vypadá to, že se na mě celý rok jen snažil zapůsobit, vydával se za někoho, kým není a teprve po nastěhování se ukázala jeho pravá tvář. Teď vlastně ani nevím, jestli jsem se zamilovala opravdu do něj nebo jen do nějakého obrazu a představy,“\u003c/i\u003e uzavírá Petra.\u003c/p\u003e \u003cp\u003e\u003cb\u003eK příběhu se vyjádřila životní a vztahová koučka Mgr. Janette Šimková:\u003c/b\u003e\u003c/p\u003e \u003cp\u003ePetra zažila klamavý dojem ve vztahu – nesoulad mezi tím, co partner prezentoval, a tím, jak se ve skutečnosti choval. Dominikův záměr nemusel být vědomé klamání, ale velmi si dával záležet na tom, aby se ve fázi randění ukázal v co nejlepším světle. Až společné bydlení odhalilo jeho skutečné návyky, představy o vztahu a postoje k odpovědnosti. Petra má oprávněnou pochybnost, zda je tento muž schopný partnerské rovnosti a respektu.\u003c/p\u003e \u003cp\u003eZ hlediska řešení takové situace bývá potřeba série otevřených, upřímných rozhovorů o očekáváních, rozdělení povinností a stanovení hranic. Petra se potřebuje ujistit, zda je Dominik ochoten převzít odpovědnost za rozdělení rolí v domácnosti i za své chování.\u003c/p\u003e \u003cp\u003ePři těchto debatách bývá nápomocná párová terapie, vztahový poradce nebo kouč, kteří vytvářejí bezpečný a konstruktivní prostor pro společné hledání funkčního modelu soužití, se kterým budou spokojeni oba partneři. Každý vztah potřebuje vzájemnost, kde kompromis nevzniká ze strachu, viny ani z potřeby být dokonalý/dokonalá, ale z dobré vůle a rovnocennosti. Když musí jeden z partnerů trvale ustupovat, děje se tak na jeho úkor a na úkor zdraví vztahu.\u003c/p\u003e \u003cp\u003ePokud by Dominik nebyl otevřený sebereflexi a nezměnil svůj postoj, je zcela legitimní, pokud by se Petra rozhodla ze vztahu odejít. Vztah, který se rozpadne pod tíhou předstíraného ideálu, není selháním, ale příležitostí k vědomější volbě při výběru kompatibilnějšího partnera.\u003c/p\u003e \u003ctable cellpadding=\"5\"\u003e \u003ctbody\u003e \u003ctr\u003e \u003ctd\u003e \u003cp\u003e\u003cb\u003e\u003cimg src=\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/9d3bd769-a4ef-4587-beaa-6798563fb600/public\" width=\"236\" height=\"284\" alt=\"a04e39708c301-Vystrizek.jpg.webp\"\u003eMgr. Janette Šimková\u003c/b\u003e je životní a vztahová koučka.\u003cbr\u003e\u003cbr\u003eOsobnímu rozvoji se věnuje od roku 2008. Je certifikovanou koučkou RCS, absolvovala intenzivní tréninkový program Results Coaching System akreditovaný ICF (International Coach Federation). Model koučování párů a rodin studovala u jedné z nejlepších současných kouček na světě – Dr. Marilyn Atkinson, PhD., mezinárodně uznávané školitelky koučů. Absolvovala certifikovaný trénink Family and Couples Coaching od Erickson College International.\u003c/p\u003e \u003cul\u003e \u003cli\u003ePrvní zkušenosti získala ve 108hodinovém sociálně-psychologickém výcviku.\u003c/li\u003e \u003cli\u003eJe absolventkou dvouletého psychologického výcviku Integrativní práce s motivací a změnou v komplexních systémech, rodinách a párech v Coachingplus pod vedením odborného garanta prof. Antona Heretika.\u003c/li\u003e \u003cli\u003eVyužívání principů a technik Motivačních rozhovorů, které jsou komunikačním přístupem zaměřeným na podporu klientů při hledání a rozvíjení vnitřní motivace ke změně, studovala v 60hodinovém výcviku u Dr. Jana Soukupa.\u003c/li\u003e \u003cli\u003eZvládání stresu pomocí všímavosti (mindfulness) trénovala v kurzu u Andreje Jeleníka. Absolvovala 250hodinový supervizní výcvik pod vedením mezinárodně akreditovaných supervizorů z Coachingplus. Má licenci supervizora zapsanou na MPSVR SR.\u003c/li\u003e \u003cli\u003eJe aktivní členkou Evropské rady pro koučování a mentorování EMCC Czechia \u0026amp; Slovakia\u003c/li\u003e \u003cli\u003eMá evropskou koučovací akreditaci „senior practitioner“ EIA EMCC Global.\u003cb\u003e\u003cbr\u003e\u003c/b\u003e\u003c/li\u003e \u003c/ul\u003e \u003cp\u003eVíce informací najdete na lifekoucing.sk.\u003c/p\u003e \u003c/td\u003e \u003c/tr\u003e \u003c/tbody\u003e \u003c/table\u003e \u003cp\u003e\u003cspan\u003eZdroj info: Text byl zpracován na základě příběhu ženy, kterou redakce zná a která jej předala redakci se svolením k uveřejnění. Fotografie je pouze ilustrační a jména osob byla na žádost této konkrétní ženy pozměněna, stejně tak jako její jméno. Pokud máte příběh, který by se mohl objevit na našich stránkách, napište nám na redakce@zena-in.cz.\u003c/span\u003e\u003c/p\u003e \u003ch3\u003eSouvisející články\u003c/h3\u003e\u003cul\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/tetin-dar-me-pripravil-o-rodinu-kazdy-z-neho-chce-kousek-na-spravedlnost-nehledi-rika-tamara\" title=\"Tetin dar mě připravil o rodinu. Každý z něho chce kousek, na spravedlnost nehledí, říká Tamara\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eTetin dar mě připravil o rodinu. Každý z něho chce kousek, na spravedlnost nehledí, říká Tamara\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/bud-za-sebe-poslal-nekoho-jineho-nebo-me-podvedl-stezuje-si-petra\" title=\"Buď za sebe poslal někoho jiného, nebo mě podvedl, stěžuje si Petra\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eBuď za sebe poslal někoho jiného, nebo mě podvedl, stěžuje si Petra\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/kouzlo-zralosti-proc-mladsi-muzi-stale-casteji-voli-starsi-partnerky\" title=\"Kouzlo zralosti: proč mladší muži stále častěji volí starší partnerky\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eKouzlo zralosti: proč mladší muži stále častěji volí starší partnerky\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/nejlepsi-kamaradka-me-nechala-bez-strechy-nad-hlavou-jen-kvuli-sve-hloupe-zasade-sveruje-se-nastvana-petra\" title=\"Nejlepší kamarádka mě nechala bez střechy nad hlavou jen kvůli své hloupé zásadě, svěřuje se naštvaná Petra\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eNejlepší kamarádka mě nechala bez střechy nad hlavou jen kvůli své hloupé zásadě, svěřuje se naštvaná Petra\u003c/a\u003e\u003c/li\u003e \u003cli\u003e\u003ca href=\"https://zena-in.cz/clanek/co-laska-dela-s-zenskym-telem-vedci-odhalili-ze-zamilovanost-meni-imunitni-system\" title=\"Co láska dělá s ženským tělem? Vědci odhalili, že zamilovanost mění imunitní systém\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCo láska dělá s ženským tělem? Vědci odhalili, že zamilovanost mění imunitní systém\u003c/a\u003e\u003c/li\u003e \u003c/ul\u003e"])</script><script>self.__next_f.push([1,"2f:T878,"])</script><script>self.__next_f.push([1,"Údolí řeky Ni-čou v Číně je hluboké 565 metrů, proto se mu také říká trhlina v Zemi. Tato obrovská rokle po staletí od sebe odděluje místní komunity. Americká architektka Wendy Foková se vydala do této odlehlé oblasti, aby si prohlédla stavební dílo, které posunulo hranice lidských možností. Kaňony jsou nádherně dramatické, je tu krásná krajina. Rozhodla se podniknout nebezpečnou cestu na druhou stranu údolí. Silnice jsou hodně hrbolaté a jediný způsob, jak se dostat z jedné strany údolí na druhou do jiné provincie, je po této silnici. Je to strašně únavné, protože cesta trvá pět hodin. Dlouhá jízda po příkrých svazích dolů a zase nahoru je dost napínavá. Silnice je skutečně nebezpečná, protože na ni leží spousta ostrých kamenů, a kolem jsou příkré srázy. Také jsou tu občas sesuvy půdy, takže po stranách silnice jsou hromady kamení. Tato přírodní překážka měla na místní obyvatele velmi negativní dopad. V provincii Kuej-čou žije přes 35 milionů lidí. Pro místní zemědělce je velmi obtížné po klikatých silničkách přes strmá údolí odvézt svou produkci, aby ji prodali. Takže není divu, že jde o jednu z nejchudších provincií v Číně. Proto bylo nezbytně nutné tuto situaci vyřešit. Ale ještě nikdy nebyla mostem překlenuta tak hluboká rokle. Na dno údolí je to více než půl kilometru. Překonávání kaňonů bylo vždy velkým problémem. Ve druhém století před naším letopočtem bylo na takzvané himálajské hedvábné stezce, která se klikatila dolů do údolí, více než sto ostrých zatáček. Dnes to z ní dělá velmi nebezpečnou cestu. V roce 1936 navrhl James Curran první sedačkovou lanovku inspirovanou zvedacím mechanismem pro vykládání banánů z lodí. Byla skvělá, ale jen pro lyžaře. V roce 1974 Evel Knievel se pokoušel překročit kaňon Snake River pomocí rakety, ale to se nepovedlo. Řešení, s nímž přišli čínští inženýři, bylo ohromující. Most Pej-Pchan-Ťiang, jehož mostovka vede 565 metrů nade dnem údolí, díky čemuž jde o nejvyšší most na světě."])</script><script>self.__next_f.push([1,"30:T4b8,Sytě zelená, široká údolí a pusté, drsné hory. To je Skotská vysočina. Prastará krajina, kterou si lidé po celá staletí chtěli podmanit, kultivovat ji a přizpůsobit svým potřebám. Fauna při tom stála kdesi v pozadí, ale to už teď tak docela neplatí. Příroda si pozvolna získává Skotskou vysočinu zpět, a i člověk se poučil a pochopil, jak nezastupitelnou roli tyto ekosystémy hrají. Přičinil se o vznik národních parků a rezervací a zachránil tak některé druhy před vyhynutím či vyhubením. V srdci Vysočiny leží národní park Cairngorms. Na těchto chladných náhorních plošinách je velmi obtížné přežít, přesto se tu někteří tvorové cítí jako doma. Sobi. V těchto horách se pohybovali po tisíce let, ale ve třináctém století jejich populace postupně vymizela. Po dlouhé době se tu však znovu objevili – v polovině dvacátého století se sem vrátilo malé sobí stádo. I mláďata kulíka hnědého jsou extrémně důležitá pro celou populaci těchto ptáků, protože ta se v posledních letech zmenšila o více než polovinu. A kvůli odlesňování a dalším faktorům měla namále třeba také veverka obecná31:Tb58,"])</script><script>self.__next_f.push([1,"U pobřeží Alžírska kotvila velká francouzská flotila, a po kapitulaci Francie bylo jen otázkou času, kdy se jí zmocní Hitler. Churchill proto nařídil Královskému loďstvu, aby francouzské lodě vyprovodilo ven ze Středozemního moře. Francouzi však takovou možnost odmítli, proto se Britové rozhodli jejich flotilu potopit přímo v přístavu. Krátce poté překročily libyjsko–egyptské hranice stovky tisíc italských vojáků. Britské síly, doplněné o rekruty z celého svého impéria, je však zatlačily zpět do hloubi libyjského území. Hitler při pohledu na neúspěch svého italského spojence zasáhl a v březnu 1941 vyslal do severní Afriky nepočetnou, ale zkušenou tankovou jednotku pod vedením německého taktického génia, generála Erwina Rommela. Ten obrátil Brity na okamžitý ústup a v té chvíli mu již zdánlivě nic nebránilo v postupu přímo na Suez. Jenže německý postup zastavili odhodlaní obránci přístavního města Tobruk, které se téměř rok bránilo dobytí. Rommelovi se však podařilo Brity odvážným manévrem obklíčit a přístav dobýt. Němce tak od Suezu dělila pouze britská obranná linie u El Alameinu nedaleko Káhiry. Churchill v této kritické situaci požádal o pomoc svého nového spojence, Spojené státy, a Roosevelt souhlasil s invazí amerických sil do severní Afriky. Ty si zároveň měly odbýt křest ohněm v boji proti Němcům. Nový velitel britských vojsk, generál Montgomery, však u El Alameinu využil nejenom čerstvých posil, ale i nových amerických tanků a zatlačil Rommela zpět na tuniské území. Ve francouzské severoafrické kolonii se mezitím vylodily obrovské americké invazní síly, která byly odhodlané zapojit se do boje proti Afrikakorpsu. Francouzi, kteří dosud nedokázali strávit britský útok na svou flotilu, však zpočátku zasypávali vyloďující se Američany krupobitím kulek. Nakonec však s nimi, po několika dnech tvrdých bojů, uzavřeli příměří. Nezkušeným americkým vojákům se ale mělo zanedlouho dostat mnohem tvrdší lekce. Rommel na ně totiž v Tunisku zaútočil, nezkušení američtí velitelé nedokázali na německý útok správně zareagovat a byli v bitvě u Kasserinského průsmyku zmasakrováni. Po tomto neúspěchu byl vedením amerického kontingentu pověřen známý bouřlivák, generál George Patton, který se nakonec ukázal být stejně dobrým tankovým velitelem, jako Rommel. Afrikakorps se zanedlouho dostal do kleští britských sil, postupujících z východu a amerických sil blížících se k němu ze západu. Vyčerpaný a zlomený Rommel si uvědomil, že hra skončila, a vrátil se do Německa. Desetitisíce vojáků Osy v Tunisku byly vzápětí nuceny kapitulovat. Spojenci tím dosáhli svého prvního důležitého vítězství nad nacistickým Německem."])</script><script>self.__next_f.push([1,"32:T652,Klášterní zahrady byly vždy místy tak trochu odlehlými a skrytými, kam řeholníci a řeholnice chodili hledat odpočinek a klid pro modlitbu. Někdy byly dokonce jediným místem, kam mimo klášter mohli vstoupit. Zahrady ale měly zároveň i ryze praktický význam. Ovocem a zeleninou zásobovaly klášterní kuchyni, léčivými bylinami zase klášterní lékárny. Řada zahrad postupně zanikla, dnes jsou ale opět obnovovány, ať už samotnými řeholníky, městy nebo jednotlivci. Postupně navštívíme rozlehlou zahradu bratří kapucínů na Hradčanech, kde v minulosti stávala i poustevna nebo zahradu bývalého kapucínského kláštera v Opočně, která byla ještě donedávna veřejnosti nepřístupná. Dnes je z ní komunitní zahrada, ve které se postupně podařilo obnovit původní sad se starými odrůdami, vytvořit místa k odpočinku a do budoucna je v plánu i kavárna. Léčebnou oázu pro pacienty Nemocnice sester sv. Karla Boromejského se zase podařilo vybudovat sestrám boromejkám pod Petřínem. A v práci neustávají. Další část zahrady upravují na terapeutický park. Bratr Rafael z komunity trapistů v Novém dvoře nás zavede na místa, kam člověk běžně nemá přístup. Do zahrady, ve které ročně vyprodukují několik tun potravin, a díky které jsou téměř soběstační. A nakonec zavítáme do vyhlášené bylinkové zahrady na Kuksu, ve které si v minulosti pěstovali zdejší Milosrdní bratři bylinky na výrobu léčiv. Dnes zahradu spravuje Národní památkový ústav a slouží především k osvětě a vzdělávání33:T4c8,Turbovrtulové motory jsou v menších výškách účinnější, mají nižší spotřebu. Jetstream je vysloveně určený pro lety na krátké vzdálenosti. Let 33-79 vzlétl v 18 hodin z Greensboro v Severní Karolíně, cesta do Releigh–Durham měla trvat 35 minut. Na palubě bylo ten večer 18 cestujících. Šestnáct kilometrů od cílového letiště dostal let povolení začít klesat, posádka sní"])</script><script>self.__next_f.push([1,"žila výkon motorů. U turbovrtulových letounů se výkon motoru a otáčky vrtule ovládají odděleně. Jetstream 32 nemá autopilota, celou dobu je řízen ručně. Patří k letadlům, která vyžadují nejvíc pilotního umu. Během klesání do výšky tisíc metrů posádka sledovala počasí. Námraza může letadlo vážně ohrozit. Kromě toho, že zvyšuje jeho hmotnost, narušuje také aerodynamiku křídla. To ovšem nebylo jediné riziko, se kterým museli piloti počítat. Před letem 33-79 přistával Boeing 727, který mohl Jetstream potenciálně ohrozit. V důsledku obtékání vzduchem vznikají u těžkých letadel na koncích křídel velmi silné vodorovné víry. Pokud zasáhnou menší letoun turbulence v úplavu, mohou být tak prudké, že je pilot nedokáže zvládnout.34:T5c3,Liška obecná má ze všech volně žijících šelem planety největší zeměpisný areál. Tento divoký příbuzný domestikovaných psů je schopen osídlit téměř každé prostředí: od měst a tropických klimatických oblastí až po zamrzlou tundru na severu, kde žije jeho blízký příbuzný, liška polární. Jako oportunistický všežravec je inteligentní a je velmi přizpůsobivá. Obvykle se živí vším, co má vysoký obsah energie a co je snadno dostupné nebo se dá snadno ulovit. Její strava se proto místně a sezónně mění a sahá od polních myší a králíků přes tučné a na bílkoviny bohaté žížaly, husy a ryby až po bobule a spadané ovoce na podzim. Lišky jsou považovány za šelmy, které se ze všech psovitých nejvíce podobají kočkám. Vzhledem k podobnému loveckému chování a společné specializaci na drobné hlodavce coby kořist prošly lišky a jejich kočkovité protějšky v průběhu evoluce konvergentním vývojem. Lišky jsou také lepšími lezci než ostatní psovité šelmy, což je schopnost, která se hodí zejména ve skalnatém terénu, jako je pobřeží Newfoundlandu. Tento příběh sleduje tři mláďata, která se tam narodila, jak"])</script><script>self.__next_f.push([1," se pod vedením a ochranou své matky rychle učí a přizpůsobují drsné realitě života šelem. Čelí však mnoha potížím, od prvních vrávoravých krůčků a tahanic o pozici až po ztráty a prohry a hledání vlastního teritoria.35:T5fe,Janek sehnal Jakubovy jiné prášky, ale nezabírají. Jakub přizná, že už má velké bolesti. Chce to skončit a prosí, aby nic neříkal Týně. Chystá se oslava Jakubových narozenin, Julie sehnala fotbálek, všichni jsou nadšení. Jen Janek ví, že Jakub chce na svoje narozeniny vypít lektvar od šamana. Ale nesmí nic prozradit. Oslava se vyvíjí dobře, všichni se baví, ale Týna si najednou všimne, že Jakub tam není. Vyběhne ven a na Popelkově lavičce sedí Jakub s prázdnou lahvičkou od šamana. Rozloučí se a Jakub ji i Janka posílá pryč. Anna a Linhart se stále hádají, i když Anna dělá svoji práci dobře. Filip dává Johnovi najevo, že s ním nebude kámoš. Když na večeři John zjistí, že mu sebral peněženku i s kartou, tak se vlastně pobaví. Vrátí se do Solange a uzavře s Filipem dohodu, že na jeho mámu nebude křičet. Je mu Filip sympatický, protože se ho nebojí. Sylva odmítne Vildu, který si s ní chce promluvit o jejich vztahu. Dává mu jasně najevo, že miluje Jirku. Běta i Hana se tomu diví, je jim jasné, že Sylva miluje Vildu. Jenže Sylva vysvětluje, že Karolína s Vildou čeká dítě, takže jí nechce zničit vztah. Běta se jen usměje, a řekne, že Karolína těhotná není. Sylvě docvakne, že udělala blbost. Valentýna slibuje Lídě pomstu kvůli tomu, že podvedla Frantu s Kratinou. Kratinová ji prosí, ať toho nechá. Valentýna nakuká Řehákové, že o ní Franta pěkně mluvil. A Řeháková mu začne nadbíhat.36:T4c0,V 9. století se sešli mocní druidové, aby přivítali hvězdu přicházející ze souhvězdí Draka. Jeden z nich, Brude, velice touží po moci a také po boji s jižní stranou Británie. Ostatní s ním ale nesouhlasí, a tak je povraždí. Jedin"])</script><script>self.__next_f.push([1,"ý, kdo unikne, je druidský učeň Lorne. Na jižní straně valu se Gareth a skupina mladých vojáků chystá na závěrečnou zkoušku, pokud ji splní, budou pasováni na rytíře. Gareth je sice nejlepší v boji, ale při výběru daní není dost důrazný, nechce prosté lidi připravit o to poslední, co ještě mají. Jeho velitel ho odmítá pasovat na rytíře a nařídí mu přinést 100 zlatých, jinak ať se nevrací. Té noci zahlédne Gareth padat meteorit do severních lesů, který podle pověsti může obsahovat bohatství. Jde ho hledat, ale místo meteoru najde draka s devíti vejci. V tu chvíli na něj zaútočí Brudovi lidé. Gareth je smrtelně zraněn, ale i přesto zachrání jedno z vajec, které by se mohlo rozbít. Drak ocení jeho snahu o záchranu vejce, a tak s ním sdílí své srdce, čímž mu zachrání život. Vznikne mezi nimi pevné pouto, které jim může pomoci porazit Bruda a zastavit jeho hrůzovládu.37:T5a7,Jedné noci dochází v městečku Bomont k tragédii, cestou z taneční zábavy umírá při autonehodě pět středoškoláků, mezi nimi i syn místního reverenda. Krátce poté vyhlásí zastupitelé města nová nařízení - nezletilí mají zákaz nočního vycházení, požívání alkoholu, poslechu hudby a také veřejného provozování tance. O tři roky později přijíždí do Bomontu Ren MacCormack. Po smrti matk