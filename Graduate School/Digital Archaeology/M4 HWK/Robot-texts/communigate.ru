/* Стили для блоков с горизонтальной прокруткой */
.t396__artboard { 
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;           /* Скрывает скроллбар в Firefox */
    -ms-overflow-style: none;        /* Скрывает скроллбар в IE и Edge */
