3 21.3668 26.1953 20.5858 25.4142L16.5858 21.4142C15.8047 20.6332 15.8047 19.3668 16.5858 18.5858C17.3668 17.8047 18.6332 17.8047 19.4142 18.5858L22 21.1716L28.5858 14.5858C29.3668 13.8047 30.6332 13.8047 31.4142 14.5858Z" fill="#DC6655"></path><defs><linearGradient id="paint0_linear_2683_6970" x1="23.9999" y1="4" x2="23.9999" y2="44.0091" gradientUnits="userSpaceOnUse"><stop stop-color="#DC6655"></stop><stop offset="1" stop-color="#DC6655" stop-opacity="0.5"></stop></linearGradient></defs></svg></div> <div class="text-container" data-v-ce2b2678><h3 class="card-title mt-[12px] md:mt-[16px]" data-v-ce2b2678>Поддержка 24/7</h3> <p class="card-description" data-v-ce2b2678>Отвечаем в любое время дня и ночи — <br>без выходных, праздников и перерывов <br>на обед</p></div> <!----></div><div class="card-wrapper" data-v-ce2b2678><div class="ui-svg-icon icon w-40px h-40px" style="height:40px;width:40px;cursor:inherit" data-v-ce2b2678><svg width="40px" height="40px" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path opacity="0.3" d="M44 24C44 35.0457 35.0457 44 24 44C12.9543 44 4 35.0457 4 24C4 12.9543 12.9543 4 24 4C35.0457 4 44 12.9543 44 24Z" fill="url(#paint0_linear_2683_6978)"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M24 12C25.1046 12 26 12.8954 26 14V24C26 24.5304 25.7893 25.0391 25.4142 25.4142L21.4142 29.4142C20.6332 30.1953 19.3668 30.1953 18.5858 29.4142C17.8047 28.6332 17.8047 27.3668 18.5858 26.5858L22 23.1716V14C22 12.8954 22.8954 12 24 12Z" fill="#DC6655"></path><defs><linearGradient id="paint0_linear_2683_6978" x1="24" y1="4" x2="24" y2="44" gradientUnits="userSpaceOnUse"><stop stop-color="#DC6655"></stop><stop offset="1" stop-color="#DC6655" stop-opacity="0.5"></stop></linearGradient></defs></svg></div> <div class="text-container" data-v-ce2b2678><h3 class="card-title mt-[12px] md:mt-[16px]" data-v-ce2b2678>Бесперебойная работа</h3> <p class="card-description" data-v-ce2b2678>Гарантируем доступность сайтов <br>на уровне 99,98% по SLA.</p></div> <!----></div><div class="card-wrapper" data-v-ce2b2678><div class="ui-svg-icon icon w-40px h-40px" style="height:40px;width:40px;cursor:inherit" data-v-ce2b2678><svg width="40px" height="40px" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path opacity="0.3" d="M24 4C14.0589 4 6 12.0589 6 22C6 28.0528 9.61953 33.1835 13.7901 36.798L20.673 42.7631C22.5823 44.4179 25.4177 44.4179 27.327 42.7631L34.2099 36.798C38.3805 33.1835 42 28.0528 42 22C42 12.0589 33.9411 4 24 4Z" fill="url(#paint0_linear_2683_6964)"></path><path d="M28 22C28 24.2091 26.2091 26 24 26C21.7909 26 20 24.2091 20 22C20 19.7909 21.7909 18 24 18C26.2091 18 28 19.7909 28 22Z" fill="#DC6655"></path><defs><linearGradient id="paint0_linear_2683_6964" x1="24" y1="4" x2="24" y2="44.0042" gradientUnits="userSpaceOnUse"><stop stop-color="#DC6655"></stop><stop offset="1" stop-color="#DC6655" stop-opacity="0.5"></stop></linearGradient></defs></svg></div> <div class="text-container" data-v-ce2b2678><h3 class="card-title mt-[12px] md:mt-[16px]" data-v-ce2b2678>Надежные дата-центры</h3> <p class="card-description" data-v-ce2b2678>Дата-центры в России и Казахстане <br>отвечают международным стандартам безопасности</p></div> <!----></div><div class="card-wrapper" data-v-ce2b2678><div class="ui-svg-icon icon w-40px h-40px" style="height:40px;width:40px;cursor:inherit" data-v-ce2b2678><svg width="40px" height="40px" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path opacity="0.3" d="M14 40C14 38.8954 14.8954 38 16 38H32C33.1046 38 34 38.8954 34 40C34 41.1046 33.1046 42 32 42H16C14.8954 42 14 41.1046 14 40Z" fill="currentColor"></path><path opacity="0.3" d="M15.6 34C12.2397 34 10.5595 34 9.27606 33.346C8.14709 32.7708 7.2292 31.8529 6.65396 30.7239C6 29.4405 6 27.7603 6 24.4L6 15.6C6 12.2397 6 10.5595 6.65396 9.27606C7.2292 8.14709 8.14708 7.2292 9.27606 6.65396C10.5595 6 12.2397 6 15.6 6L32.4 6C35.7603 6 37.4405 6 38.7239 6.65396C39.8529 7.2292 40.7708 8.14