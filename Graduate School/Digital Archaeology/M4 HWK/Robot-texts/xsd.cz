d\":false,\"canonical\":true,\"redirectOnly\":true,\"paywall\":false,\"readingTime\":null,\"publishedAt\":\"2025-10-13T06:37:00.000Z\"},{\"guid\":\"d71ba35e-b238-583f-bbcc-6fbb2fb26a7a\",\"feed\":{\"guid\":\"zG96-BrZSSwxr_5q8SkFy\",\"name\":\"Zprávy - Aktuálně.cz\",\"logo\":\"https://asset.stdout.cz/fe/aktualne/img/acz-desktop-logo-dark.png\"},\"title\":\"Znásilnil pacientku po celkové anestezii, soud potvrdil sanitáři trest vězení\",\"description\":\"Sanitář se odvolal k nejvyššímu soudu. Ten ovšem rozsudek soudu nižší instance potvrdil.\",\"url\":\"https://zpravy.aktualne.cz/domaci/nejvyssi-soud-potvrdil-byvalemu-sanitari-sestilety-trest-za/r~c4ba6a86a84011f0a26cac1f6b220ee8/?utm_source=centrumHP\u0026utm_medium=zpravodajstvi\u0026utm_campaign=zpravy.aktualne.cz\u0026utm_content=zpravodajstvi\",\"slug\":\"znasilnil-pacientku-po-celkove-anestezii-soud-potvrdil-sanitari-trest-vezeni-d71ba35e-b238-583f-bbcc-6fbb2fb26a7a\",\"categories\":[\"Domácí\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/eaa7a534-0563-4c99-0814-32df4f09a600/public\",\"type\":\"image\",\"credit\":\"Zprávy - Aktuálně.cz\",\"title\":\"Znásilnil pacientku po celkové anestezii, soud potvrdil sanitáři trest vězení\",\"text\":\"Znásilnil pacientku po celkové anestezii, soud potvrdil sanitáři trest vězení\"}],\"blockGuid\":\"s_do3OoSq3pNjAVJrbZU6\",\"order\":8,\"verified\":false,\"canonical\":true,\"redirectOnly\":true,\"paywall\":false,\"readingTime\":null,\"publishedAt\":\"2025-10-13T14:48:44.000Z\"},{\"guid\":\"3d8ad108-2ae9-50ed-9ebd-9532b84fbcea\",\"feed\":{\"guid\":\"L0nemJNYKpkBNBqWxZWon\",\"name\":\"HlídacíPes.org\",\"logo\":\"https://hlidacipes.org/src/themes/template/build/hlidacipes-logo.png?7eb0b2a72d8857b844c8\"},\"title\":\"Ministr mezinárodní izolace. Turkův „humor“ by narazil hned za hranicemi\",\"description\":\"KOMENTÁŘ. Možný adept na post ministra zahraničí Filip Turek už déle než rok bagatelizuje svou nápadnou náklonnost k nacistické symbolice, kterou nejnověji dokládá archiv jeho smazaných facebookových příspěvků zveřejněný Deníkem N. S takovým životopisem by coby ministr měl ale problém absolvovat standardní jednání třeba v sousedním Německu. A zdaleka nejen tam. Bojkot ministrů blízkých krajní\",\"url\":\"https://hlidacipes.org/ministr-mezinarodni-izolace-turkuv-humor-by-narazil-hned-za-hranicemi/?utm_source=centrumHP\u0026utm_medium=zpravodajstvi\u0026utm_campaign=hlidacipes.org\u0026utm_content=zpravodajstvi\",\"slug\":\"ministr-mezinarodni-izolace-turkuv-humor-by-narazil-hned-za-hranicemi-3d8ad108-2ae9-50ed-9ebd-9532b84fbcea\",\"categories\":[\"Nezařazené\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/4877abc4-98cc-4a99-2f32-b6564b669100/public\",\"type\":\"image\",\"credit\":\"Filip Turek. Foto: PETR TOPIČ / MAFRA / Profimedia\",\"title\":\"profimedia-1030234022\",\"text\":\"Filip Turek. Foto: PETR TOPIČ / MAFRA / Profimedia\"}],\"blockGuid\":\"s_do3OoSq3pNjAVJrbZU6\",\"order\":9,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"alternativeTitle\":\"Komentář: Ministr mezinárodní izolace. Turkův „humor“ by narazil hned za hranicemi\",\"readingTime\":6,\"publishedAt\":\"2025-10-13T13:20:19.000Z\"},{\"guid\":\"291d1015-7219-5078-80a1-2d0592fa7361\",\"feed\":{\"guid\":\"zG96-BrZSSwxr_5q8SkFy\",\"name\":\"Zprávy - Aktuálně.cz\",\"logo\":\"https://asset.stdout.cz/fe/aktualne/img/acz-desktop-logo-dark.png\"},\"title\":\"\\\"Spíš hon na nejbližšího mechanika.\\\" Šéf NATO si střílí z Rusů a jejich ponorky\",\"description\":\"Ruské ministerstvo obrany popřelo informace o tom, že se u břehů Francie kvůli poruše nouzově vynořila ruská ponorka.\",\"url\":\"https://zpravy.aktualne.cz/zahranici/hon-na-nejblizsiho-mechanika-sef-nato-si-strili-z-rusu-a-jej/r~c4cf7040a82a11f0bb77ac1f6b220ee8/?utm_source=centrumHP\u0026utm_medium=zpravodajstvi\u0026utm_campaign=zpravy.aktualne.cz\u0026utm_content=zpravodajstvi\",\"slug\":\"hon-na-nejblizsiho-mechanika-sef-nato-si-strili-z-rusu-a-jejich-ponorky-291d1015-7219-5078-80a1-2d0592fa7361\",\"categories\":[\"Zahraničí\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/a3de0945-ef6b-457d-9795-cfb1176c9d00/public\",\"type\":\"image\",\"credit\":\"Zprávy - Aktuálně.cz\",\"title\":\"\\\"Hon na nejbližšího mechanika.\\\" Šéf NATO si střílí z Rusů a jejich ponorky\",\"text\":\"\\\"Hon na nejbližšího mechanika.\\\" Šéf NATO si střílí z Rusů a jejich ponorky\"}],\"blockGuid\":\"s_do3OoSq3pNjAVJrbZU6\",\"order\":10,\"verified\":false,\"canonical\":true,\"redirectOnly\":true,\"paywall\":false,\"readingTime\":null,\"publishedAt\":\"2025-10-13T11:50:08.000Z\"}]},{\"guid\":\"nMP1igvxfek7jHredLTPE\",\"name\":\"magazines\",\"type\":\"magazines\",\"order\":0,\"limit\":50,\"articles\":[]},{\"guid\":\"kgUVY-QKIkxnncytmW43f\",\"name\":\"Magazín\",\"type\":\"magazineList\",\"order\":4,\"limit\":30,\"articles\":[{\"guid\":\"3120b8c2-6375-58b1-9d77-88ac0b416f19\",\"feed\":{\"guid\":\"zG96-BrZSSwxr_5q8SkFy\",\"name\":\"Zprávy - Aktuálně.cz\",\"logo\":\"https://asset.stdout.cz/fe/aktualne/img/acz-desktop-logo-dark.png\"},\"title\":\"Vrah Aničky neprošel detektorem lži, zůstal ale na svobodě. Usvědčili ho až po smrti\",\"description\":\"Týden od zmizení školačky měla policie podezřelého. Byl jím recidivista Otakar Tomek. K soudu ale případ nedorazil.\",\"url\":\"https://zpravy.aktualne.cz/domaci/zmizenix/r~5c9198e4a83611f0a065ac1f6b220ee8/?utm_source=centrumHP\u0026utm_medium=custom_block\u0026utm_campaign=zpravy.aktualne.cz\u0026utm_content=magazineList\",\"slug\":\"vrah-neprosel-detektorem-lzi-zatkli-ho-ale-po-mesicich-anicka-zmizela-pred-15-lety-3120b8c2-6375-58b1-9d77-88ac0b416f19\",\"categories\":[\"Domácí\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/fcc6b3e4-2399-4b40-95a0-447514681b00/public\",\"type\":\"image\",\"credit\":\"Zprávy - Aktuálně.cz\",\"title\":\"Vrah neprošel detektorem lži, zatkli ho ale po měsících. Anička zmizela před 15 lety\",\"text\":\"Vrah neprošel detektorem lži, zatkli ho ale po měsících. Anička zmizela před 15 lety\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":1,\"verified\":false,\"canonical\":true,\"redirectOnly\":true,\"paywall\":false,\"readingTime\":null,\"publishedAt\":\"2025-10-13T16:55:13.000Z\"},{\"guid\":\"b778ab62-c26f-5bf8-ab39-7498d501433c\",\"feed\":{\"guid\":\"VvesDNx4fCt5uckk_aXEg\",\"name\":\"Vaření.cz\",\"logo\":\"https://vareni-production-cdn.xsd.cz/static/images/logo/rsslogo.gif\"},\"title\":\"Pozvánka na hody: Začíná podzimní festival restaurací, zajistěte si tříchodové menu za jednotnou cenu\",\"description\":\"Z čeho se dělá coulis? A jaký je rozdíl mezi mochi a matcha? Teď to můžete ochutnat a zjistit na vlastní chuťové buňky. Podzimní festival Restaurant Week začíná!\",\"url\":\"https://www.vareni.cz/magazin/pozvanka-na-hody-zacina-podzimni-festival-restauraci-zajistete-si-trichodove-menu-za-jednotnou-cenu?utm_source=centrumHP\u0026utm_medium=custom_block\u0026utm_campaign=www.vareni.cz\u0026utm_content=magazineList\",\"slug\":\"pozvanka-na-hody-zacina-podzimni-festival-restauraci-zajistete-si-trichodove-menu-za-jednotnou-cenu-b778ab62-c26f-5bf8-ab39-7498d501433c\",\"categories\":[],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/4f9a037d-90fd-4705-93d0-aa47fb299900/public\",\"type\":\"image\",\"credit\":\"Vaření.cz - HPx články\",\"title\":\"Pozvánka na hody: Začíná podzimní festival restaurací, zajistěte si tříchodové menu za jednotnou cenu\",\"text\":\"Pozvánka na hody: Začíná podzimní festival restaurací, zajistěte si tříchodové menu za jednotnou cenu\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":2,\"verified\":false,\"canonical\":true,\"redirectOnly\":true,\"paywall\":false,\"readingTime\":null,\"publishedAt\":\"2025-10-13T18:36:51.000Z\"},{\"guid\":\"b567b696-638d-51c8-89a7-4f0a2c9c0c78\",\"feed\":{\"guid\":\"Rs4O0DPiSLtIGvMWrwcu8\",\"name\":\"VIP show\",\"logo\":\"https://vipshow.cz/wp-content/uploads/2020/04/vipshow-logo.png\"},\"title\":\"Jak dnes vypadá Zlatovláska Jorga Kotrbová. Už ji neznáte, ale bohatá je tak, že se vám zatají dech\",\"description\":\"Kdysi ji miloval celý národ. Princezna se zlatými vlasy okouzlila krále i srdce diváků. Dnes už o Jorze Kotrbové téměř neslyšíme, přesto žije život. Vyměnila svět kamer za klid u koní, reflektory za ticho hor a pozornost publika za svobodu, kterou si vybudovala sama.\",\"url\":\"https://vipshow.cz/nejnovejsi-zpravy/jorga-kotrbova-zlatovlaska/alexandrakrizova/?utm_source=centrumHP\u0026utm_medium=custom_block\u0026utm_campaign=vipshow.cz\u0026utm_content=magazineList\",\"slug\":\"jak-dnes-vypada-zlatovlaska-jorga-kotrbova-uz-ji-neznate-ale-bohata-je-tak-ze-se-vam-zataji-dech-b567b696-638d-51c8-89a7-4f0a2c9c0c78\",\"categories\":[\"Česko\",\"Film a seriál\",\"Nejnovější zprávy\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/67861dc0-040e-40bc-5918-a8403d27e100/public\",\"type\":\"image\",\"credit\":\"VIPshow\",\"title\":\"Princezna, která učarovala divákům\",\"text\":\"Princezna, která učarovala divákům\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":3,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":4,\"publishedAt\":\"2025-10-13T15:48:19.000Z\"},{\"guid\":\"17c9601e-a460-58b0-a4bb-8907df10a634\",\"feed\":{\"guid\":\"sKtFx69mjcVOW9j12wefJ\",\"name\":\"Techzpravy.cz\",\"logo\":\"https://techzpravy.cz/techzpravy-logo-32-32.png\"},\"title\":\"AI může být váš nejlepší pomocník. Nebo taky nenápadný sabotér\",\"description\":\"Nová studie společnosti Anthropic ve spolupráci s britskými výzkumníky odhalila znepokojivý fakt: k manipulaci chování velkých jazykových modelů stačí pouhých 250 škodlivých dokumentů. Tato technika, známá jako data poisoning, otevírá zadní vrátka i těm největším AI systémům – a bez důsledné kontroly trénovacích dat může zůstat zcela neodhalená.\",\"url\":\"https://www.techzpravy.cz/ai-muze-byt-vas-nejlepsi-pomocnik-nebo-taky-nenapadny-saboter/?utm_source=centrumHP\u0026utm_medium=custom_block\u0026utm_campaign=www.techzpravy.cz\u0026utm_content=magazineList\",\"slug\":\"ai-muze-byt-vas-nejlepsi-pomocnik-nebo-taky-nenapadny-saboter-17c9601e-a460-58b0-a4bb-8907df10a634\",\"categories\":[\"Technologie\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/a2f0e3c8-7eb4-4b03-8dd9-8bdb2c677a00/public\",\"type\":\"image\",\"credit\":\"DragosCondreaW / Depositphotos\",\"title\":\"AI může být váš nejlepší pomocník. Nebo taky nenápadný sabotér\",\"text\":\"AI asisstant artificial intelligence chatbot\"}],\"blockGuid\":\"kgUVY-QKIkxnncytmW43f\",\"order\":4,\"verified\":false,\"canonical\":true,\"redirectOnly\":false,\"paywall\":false,\"readingTime\":4,\"publishedAt\":\"2025-10-13T18:05:00.000Z\"},{\"guid\":\"a60309a6-3151-5446-9209-fe4676f1943a\",\"feed\":{\"guid\":\"FkC-D7ar7Zyxf32SXF-8e\",\"name\":\"Žena.cz\",\"logo\":\"https://asset.stdout.cz/fe/zena/img/logo.png\"},\"title\":\"Dědictví po Bartoškovi uzavřeno. Milionovou firmu převzala manželka\",\"description\":\"Pět měsíců poté, co zemřel prezident karlovarského filmového festivalu Jiří Bartoška, bylo uzavřeno dědictví. Žádné hádky o miliony ale neproběhly.\",\"url\":\"https://zena.aktualne.cz/celebrity/dedictvi-po-bartoskovi-uzavreno-milionovou-firmu-prevzala-manzelka?utm_source=centrumHP\u0026utm_medium=custom_block\u0026utm_campaign=zena.aktualne.cz\u0026utm_content=magazineList\",\"slug\":\"dedictvi-po-bartoskovi-uzavreno-milionovou-firmu-prevzala-manzelka-a60309a6-3151-5446-9209-fe4676f1943a\",\"categories\":[\"Celebrity\"],\"mediaContent\":[{\"url\":\"https://imagedelivery.net/k-X15uEmlF-8_1kEFgAMbg/f2d41cde-7e35-48e6-d423-d40680126200/public\",\"type\":\"image\",\"credit\":\"Žena.cz\",\"title\":\"Dědictví po Bartoškovi uzavřeno. Milionovou firmu převzala manželka\",\"text\":\"Dědictví po Bartoškovi uzavřeno. Milionovou firmu převzala manželka\"},{\"url\":\"https://imagedelivery.ne