<script>
document.addEventListener('DOMContentLoaded', function() {
    // URLからクエリパラメータを取得
    const params = new URLSearchParams(window.location.search);

    // UTMパラメータを取得（utm_source, utm_medium, utm_campaign）
    const utmParams = ['utm_source', 'utm_medium', 'utm_campaign'].reduce((acc, param) => {
        if (params.has(param)) {
            acc[param] = params.get(param);
        }
        return acc;
    }, {});

    // UTMパラメータを含むクエリストリングを構築
    const utmQueryString = new URLSearchParams(utmParams).toString();

    // ページ内のすべてのdynamic-linkクラスのリンクを取得
    const dynamicLinks = document.querySelectorAll('.dynamic-link');

    // 各リンクにUTMパラメータを追加
    dynamicLinks.forEach(link => {
        const originalUrl = link.href;
        link.href = originalUrl.includes('?') ? `${originalUrl}&${utmQueryString}` : `${originalUrl}?${utmQueryString}`;
    });
});
</script>

        
      
