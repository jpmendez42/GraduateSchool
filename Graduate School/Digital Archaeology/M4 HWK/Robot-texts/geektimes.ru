    <script>window.i18nFetch = new Promise((res, rej) => {
            const xhr = new XMLHttpRequest();
            xhr.open('GET', '/js/i18n/en-compiled.4a79129489bb4c1c0df564e19c13cb33.json');
            xhr.responseType = 'json';
            xhr.onload = function(e) {
              if (this.status === 200) {
                res({en: xhr.response});
              } else {
                rej(e);
              }
            };
            xhr.send();
          });</script>
