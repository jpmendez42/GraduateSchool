        function () {
            var self = this;
            hovertimer = setTimeout(function(){
                $(self).addClass('active');
            }, 250);
        },
        function () {
            clearTimeout(hovertimer);
            $li.removeClass('active');
        }
    );
</script>	</div>
                       
