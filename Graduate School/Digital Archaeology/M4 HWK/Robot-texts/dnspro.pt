				<span class="et_pb_image_wrap "><img decoding="async" src="/files/2017/07/Enhanced-accessibility.svg" alt="Enhanced accessibility" title="Enhanced accessibility" class="wp-image-306" /></span>
			</div>
			</div><div class="et_pb_column et_pb_column_1_2 et_pb_column_12  et_pb_css_mix_blend_mode_passthrough et-last-child">
				
				
				
				
				<div class="et_pb_module et_pb_text et_pb_text_7 learn-more  et_pb_text_align_left et_pb_bg_layout_light">
				
				
				
				
				<div class="et_pb_text_inner"><h3>Enhanced accessibility</h3>
<p>Configure your Symbian, Android, iOS or Windows phone or tablet to access your collaborative business mailbox on the go. <a href="/enterprise-email/"><span class="more">L</span>Learn more</a></p></div>
			</div>
