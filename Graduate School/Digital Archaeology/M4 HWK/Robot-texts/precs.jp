} 
                 
main .kv .center > li:nth-of-type(2) .prise02 img {
    width: 80%;
    margin-bottom: 8px;
}                 
  
main .kv .center > li:nth-of-type(1) .title, main .kv .center > li:nth-of-type(1) .title2 {
    background: linear-gradient(-90deg, #006400, #00CA00) ;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
                 
