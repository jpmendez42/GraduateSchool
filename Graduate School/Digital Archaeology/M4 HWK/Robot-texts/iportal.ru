body.theme-sholding {
  /** colors */
  --color-black: #000000;
  --color-white: #FFFFFF;
  --color-yellow: #FFD500;
  --color-pink: #EEBCFF;
  --color-green: #87D538;
  --color-lime: #D4FB38;
  --color-purple: #8045FF;
  --color-blue: #45B1FE;
  --color-crimson: #FF459E;
  --color-orange: #FF3B00;
  --color-mint: #79F5BA;
  --color-blue-dark: #294CA6;
  --color-blue-medium: #AFC6FF;
  --color-blue-light: #F5F7FF;
  --color-gray-dark: #334054;
  --color-gray-deep: #9CA5B5;
  --color-gray-medium: #D0D5DD;
  --color-gray-medium-2: #E5E7EB;
  --color-gray-light: #F2F4F7;
  --color-orange-accent: #FF522D;
  --color-red-error: #F04438;
  /** fonts family */
  --font-family: "Mabry Pro", sans-serif;
  /** headers */
  --h-N-light-font-weight: 300;
  --h-N-standard-font-weight: 400;
  --h-N-medium-font-weight: 500;
  --h-N-bold-font-weight: 700;
  --h-1-font-size-value: 80;
  --h-1-line-height-value: 80;
