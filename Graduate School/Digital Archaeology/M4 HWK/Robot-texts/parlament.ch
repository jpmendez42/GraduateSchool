					<li data-ng-repeat="item in categories | orderBy: 'RefinementValue': false">
						<a href="#!" data-ng-click="Pd.Shared.Dropdown.HandleDropDownAnchorClick($event);getBlogsByCategory(item.RefinementToken);">
