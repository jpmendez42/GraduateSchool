            $j().ready(function()
            {
                var hlRegexp = new RegExp('[\?\&]search-keywords=([^\?\&#;]+)', 'i');
                var result = hlRegexp.exec(location.search);
                if (result != null && result.length > 1)
                {
                    var keywords = result[1].split(',');
                    for (var x = 0; x < keywords.length; x++)
                    {
                        if (keywords[x] != '')
                        {
                        
                            $j('#ametys-cms-zone-carrousel').highlight($j.trim(keywords[x]));
                        
                            $j('#ametys-cms-zone-theme-content').highlight($j.trim(keywords[x]));
                        
                            $j('#ametys-cms-zone-articles').highlight($j.trim(keywords[x]));
                         
                        }
                    }
                }
            });
        
