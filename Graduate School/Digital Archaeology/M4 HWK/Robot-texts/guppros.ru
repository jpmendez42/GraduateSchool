439<\/b> \u2014 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u043e\u0440\u0430 \u043d\u0430\u0448\u0435\u0433\u043e \u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0430 \u0432 \u0432\u0443\u0437\u0435 \u0441 1949 \u043f\u043e 2021 \u0433\u043e\u0434.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0412 \u0447\u0435\u0441\u0442\u044c \u044e\u0431\u0438\u043b\u0435\u044f \u0431\u0443\u0434\u0435\u0442 \u0442\u043e\u0440\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u043e\u0442\u043a\u0440\u044b\u0442\u0430 \u0438\u043c\u0435\u043d\u043d\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f, \u043f\u043e\u0441\u0432\u044f\u0449\u0451\u043d\u043d\u0430\u044f \u043f\u0430\u043c\u044f\u0442\u0438 \u0440\u043e\u043c\u0430\u043d\u0438\u0441\u0442\u0430, \u0434\u043e\u043a\u0442\u043e\u0440\u0430 \u0444\u0438\u043b\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043d\u0430\u0443\u043a, \u0430\u043a\u0430\u0434\u0435\u043c\u0438\u043a\u0430 \u041c\u041f\u0410 \u0438 \u0437\u0430\u0441\u043b\u0443\u0436\u0435\u043d\u043d\u043e\u0433\u043e \u0434\u0435\u044f\u0442\u0435\u043b\u044f \u043d\u0430\u0443\u043a\u0438 \u0420\u0424.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0412 \u0440\u0430\u043c\u043a\u0430\u0445 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044f \u043f\u0440\u043e\u0439\u0434\u0451\u0442 \u041c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u0430\u044f \u043d\u0430\u0443\u0447\u043d\u0430\u044f \u043a\u043e\u043d\u0444\u0435\u0440\u0435\u043d\u0446\u0438\u044f \u00ab\u0410\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e-\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u043d\u043e\u0433\u043e \u0441\u0438\u043d\u0442\u0430\u043a\u0441\u0438\u0441\u0430 \u0438\u043d\u0434\u043e\u0435\u0432\u0440\u043e\u043f\u0435\u0439\u0441\u043a\u0438\u0445 \u044f\u0437\u044b\u043a\u043e\u0432 (\u0444\u0440\u0430\u043d\u0446\u0443\u0437\u0441\u043a\u0438\u0439, \u0438\u0441\u043f\u0430\u043d\u0441\u043a\u0438\u0439, \u0438\u0442\u0430\u043b\u044c\u044f\u043d\u0441\u043a\u0438\u0439)\u00bb.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0416\u0434\u0451\u043c \u0432\u0430\u0441:<\/span><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n<ul>\r\n\t<li><span style=\"font-size: 14pt;\">29 \u043e\u043a\u0442\u044f\u0431\u0440\u044f,10:00;<\/span><\/li>\r\n\t<li>\u041c\u043e\u0441\u043a\u0432\u0430, \u041f\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043d\u043e\u0432\u0441\u043a\u0438\u0439 \u043f\u0435\u0440\u0435\u0443\u043b\u043e\u043a, 5.<\/li>\r\n<\/ul>\r\n<\/span><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><br>\r\n<\/span><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\u041f\u0440\u043e\u0441\u0432\u0435\u0442 \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0430\u0435\u0442 \u0432\u0430\u0441 \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u0437\u043d\u0430\u043c\u0435\u043d\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u043c \u0441\u043e\u0431\u044b\u0442\u0438\u0438!<\/b><\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"> <b><br>\r\n<\/b><\/span><br>\r\n<span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\u0423\u0437\u043d\u0430\u0439\u0442\u0435 \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0435 \u043f\u043e \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u043e\u0439 \u043f\u043e\u0447\u0442\u0435:<\/b><\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"> <a href=\"mailto:nv.polyakova@eduprosvet.ru\">nv.polyakova@eduprosvet.ru<\/a><\/span>","~DETAIL_TEXT":"<span style=\"font-family: Georgia, serif; font-size: 14pt;\">&nbsp;\u0412 \u044d\u0442\u043e\u043c \u0433\u043e\u0434\u0443 \u043c\u044b \u043e\u0442\u043c\u0435\u0447\u0430\u0435\u043c 100-\u043b\u0435\u0442\u043d\u0438\u0439 \u044e\u0431\u0438\u043b\u0435\u0439<b> \u041d\u0430\u0442\u0430\u043b\u0438\u0438 \u041c\u0438\u0445\u0430\u0439\u043b\u043e\u0432\u043d\u044b \u0412\u0430\u0441\u0438\u043b\u044c\u0435\u0432\u043e\u0439<\/b> \u2014 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u043e\u0440\u0430 \u043d\u0430\u0448\u0435\u0433\u043e \u0423\u043d\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0430 \u0432 \u0432\u0443\u0437\u0435 \u0441 1949 \u043f\u043e 2021 \u0433\u043e\u0434.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0412 \u0447\u0435\u0441\u0442\u044c \u044e\u0431\u0438\u043b\u0435\u044f \u0431\u0443\u0434\u0435\u0442 \u0442\u043e\u0440\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u043e\u0442\u043a\u0440\u044b\u0442\u0430 \u0438\u043c\u0435\u043d\u043d\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f, \u043f\u043e\u0441\u0432\u044f\u0449\u0451\u043d\u043d\u0430\u044f \u043f\u0430\u043c\u044f\u0442\u0438 \u0440\u043e\u043c\u0430\u043d\u0438\u0441\u0442\u0430, \u0434\u043e\u043a\u0442\u043e\u0440\u0430 \u0444\u0438\u043b\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u043d\u0430\u0443\u043a, \u0430\u043a\u0430\u0434\u0435\u043c\u0438\u043a\u0430 \u041c\u041f\u0410 \u0438 \u0437\u0430\u0441\u043b\u0443\u0436\u0435\u043d\u043d\u043e\u0433\u043e \u0434\u0435\u044f\u0442\u0435\u043b\u044f \u043d\u0430\u0443\u043a\u0438 \u0420\u0424.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0412 \u0440\u0430\u043c\u043a\u0430\u0445 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044f \u043f\u0440\u043e\u0439\u0434\u0451\u0442 \u041c\u0435\u0436\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u0430\u044f \u043d\u0430\u0443\u0447\u043d\u0430\u044f \u043a\u043e\u043d\u0444\u0435\u0440\u0435\u043d\u0446\u0438\u044f \u00ab\u0410\u043a\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e-\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u043d\u043e\u0433\u043e \u0441\u0438\u043d\u0442\u0430\u043a\u0441\u0438\u0441\u0430 \u0438\u043d\u0434\u043e\u0435\u0432\u0440\u043e\u043f\u0435\u0439\u0441\u043a\u0438\u0445 \u044f\u0437\u044b\u043a\u043e\u0432 (\u0444\u0440\u0430\u043d\u0446\u0443\u0437\u0441\u043a\u0438\u0439, \u0438\u0441\u043f\u0430\u043d\u0441\u043a\u0438\u0439, \u0438\u0442\u0430\u043b\u044c\u044f\u043d\u0441\u043a\u0438\u0439)\u00bb.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0416\u0434\u0451\u043c \u0432\u0430\u0441:<\/span><span style=\"font-family: Georgia, serif; font-size: 14pt;\">\r\n<ul>\r\n\t<li><span style=\"font-size: 14pt;\">29 \u043e\u043a\u0442\u044f\u0431\u0440\u044f,10:00;<\/span><\/li>\r\n\t<li>\u041c\u043e\u0441\u043a\u0432\u0430, \u041f\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043d\u043e\u0432\u0441\u043a\u0438\u0439 \u043f\u0435\u0440\u0435\u0443\u043b\u043e\u043a, 5.<\/li>\r\n<\/ul>\r\n<\/span><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><br>\r\n<\/span><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\u041f\u0440\u043e\u0441\u0432\u0435\u0442 \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0430\u0435\u0442 \u0432\u0430\u0441 \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u0437\u043d\u0430\u043c\u0435\u043d\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u043c \u0441\u043e\u0431\u044b\u0442\u0438\u0438!<\/b><\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\"> <b><br>\r\n<\/b><\/span><br>\r\n<