ntentFormatName":"Text","baseMarketingSpotActivityName":"HomeTuMarca_Header_Spot","contentClickAction":"None","contentId":"716174606","baseMarketingSpotActivityID":"716174606","contentName":"HomeTuMarca_Header_Spot","baseMarketingSpotDataType":"MarketingContent","activityIdentifierID":"0","MarketingContentDescription":[{}],"marketingContentDescription":[{"marketingText":"  \u003cdp-catalog-entry-carousel-header  href=\"/marcas-dportenis\"\n  title=\"Tu marca, Tu poder\" \n  buttons=\"[{'name': 'adidas', 'carouselId': 'DPV2_Adidas_Spot'},\n  {'name': 'Under Armour','carouselId': 'DPV2_Under_Armour_Spot'},\n  {'name': 'Puma','carouselId': 'DPV2_Puma_Spot'},\n  {'name': 'Nike', 'carouselId': 'DPV2_Nike_Spot'}]\" \u003e\n\u003c/dp-catalog-entry-carousel-header\u003e  \n\n\u003cdp-catalog-entry-carousel-see-more  id=\"DPV2_Adidas_Spot\"  href=\"{'pathname': 'buscar', 'query': {'searchTerm':'todo adidas'}}\" \u003e\u003c/dp-catalog-entry-carousel-see-more\u003e \n\u003cdp-catalog-entry-carousel-see-more  id=\"DPV2_Under_Armour_Spot\"  href=\"{'pathname': 'buscar', 'query': {'searchTerm':'todo ua'}}\" \u003e\u003c/dp-catalog-entry-carousel-see-more\u003e\n\u003cdp-catalog-entry-carousel-see-more  id=\"DPV2_Puma_Spot\"  href=\"{'pathname': 'buscar', 'query': {'searchTerm':'todo puma'}}\"\u003e\u003c/dp-catalog-entry-carousel-see-more\u003e\n\u003cdp-catalog-entry-carousel-see-more  id=\"DPV2_Nike_Spot\"  href=\"/nike-marcas-dportenis\"\u003e\u003c/dp-catalog-entry-carousel-see-more\u003e","language":"-5"}],"contentFormatId":"2","activityPriority":"1","properties":[{"baseMarketingKey":"mktActivityDescription"},{"baseMarketingValue":"1.0","baseMarketingKey":"displaySequence"}],"contentStoreId":"1"}]}],"resourceId":"https://dpprodlivets-app:5443/wcs/resources/store/1/espot/HomeTuMarca_Header_Spot?catalogId=3074457345616677668\u0026DM_ReturnCatalogGroupId=true\u0026DM_FilterResults=false\u0026langId=-5\u0026DM_ReqCmd=TopCategoriesDisplay","resourceName":"espot"},"@#query:#_s:\"-5\",_n:true,_m:\"TopCategoriesDisplay\",_l:false,_a:\"3074457345616677668\",,_o:\"DPV2_Adidas_Spot\",_C:\"1\",,\"ESpotDataFromName\",":{"MarketingSpotData":[{"nextTimeLimit":"-1","marketingSpotIdentifier":"716157545","behavior":"2","eSpotName":"DPV2_Adidas_Spot","baseMarketingSpotActivityData":[{"baseMarketingSpotActivityName":"Tenis adidas Dropset 3 Mujer","productId":"3074457345618021246","description":[{"longDescription":" \u003cdiv class='container-description'\u003e\u003ch4\u003e\u003cstrong\u003eEmpieza tu rutina con los nuevos tenis para entrenamiento adidas Dropset 3.\u0026nbsp;\u003c/strong\u003e\u003c/h4\u003e\u003cp\u003eNo importa cual sea tu entrenamiento, si exige fuerza o resistencia, con los nuevos Dropset 3 podrás agregar soporte y resistencia. Cuentan con una mediasuela de doble densidad para mantener tus pies estables. La tecnología HEAT.RDY y el exterior de malla te brindan transpirabilidad para vencer el calor. Es de horma ancha, ideal para cuando los pies están más agotados, y la suela Adiwear se adhiere al suelo para impulsar el rendimiento.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eCaracterísticas:\u003c/strong\u003e\u003c/p\u003e\u003cul\u003e\u003cli\u003eSuela Adiwear 6 con talón Traxion\u003c/li\u003e\u003cli\u003eMediasuela de doble densidad\u003c/li\u003e\u003cli\u003eSistema de amarre regulable\u003c/li\u003e\u003c/ul\u003e\u003c/div\u003e","thumbnail":"images/catalog/default/1035718-1004V1.jpg","language":"-5","shortDescription":" Empieza tu rutina con los nuevos tenis para entrenamiento adidas Dropset 3.\u0026nbsp;No impor","fullImage":"images/catalog/default/1035718-1004V1.jpg","productName":"Tenis adidas Dropset 3 Mujer"}],"activityFormat":"web","ownerID":"7000000000000001001","activityIdentifierName":"DPV2_Adidas_Activities","baseMarketingSpotActivityID":"3074457345618021246","baseMarketingSpotDataType":"CatalogEntry","productPartNumber":"001035718-1004","activityIdentifierID":"716121551","contractPrice":[{"minorVersionNumber":