<script src="/js/webflow.js?v=1683264947"
        type="text/javascript"></script>
<script>
    $(".email-form , #wf-form-Contact-Form").submit(function (e) {

        e.preventDefault();
        $(this).siblings('.error-message').hide();
        $(this).siblings('.w-form-fail').hide();

        let isValid = false;
        let validPhone = false;
        let validEmail = false;
        let validSig = false;

        $(this).find(':input').not(':input[type=button], :input[type=submit], :input[type=reset]').each(function (input, elem) {
            if ($(elem).attr("name") === 'checkbox-sig') {
                if ($(elem).is(":checked") === true) {
                    validSig = true;
                    $(elem).siblings('.w-checkbox-input').css('border-color', '');
                } else if ($(elem).is(":checked") === false) {
                    $(elem).siblings('.w-checkbox-input').css('border-color', '#ff2c2c');
                }
            }

            if ($(elem).attr("name") === 'phone') {
                if ($(elem).val() !== '') {
                    validPhone = true;
                    $(elem).css('border-color', '');
                } else if ($(elem).val() === '') {
                    $(elem).css('border-color', '#ff2c2c');
                }
            }

            if ($(elem).attr("name") === 'email') {
                if ($(elem).val() !== '') {
                    validEmail = true;
                    $(elem).css('border-color', '');
                } else if ($(elem).val() === '') {
                    $(elem).css('border-color', '#ff2c2c');
                }
            }
        });

        let textError = '';
        if (validPhone && validEmail && validSig) {
            isValid = true;
        } else if (validPhone && validEmail && !validSig) {
            textError = `Необходимо дать согласие на обработку данных`;
        } else if (validPhone && !validEmail && validSig) {
            textError = `Не заполнено поле почты`;
        } else if (validPhone && !validEmail && !validSig) {
            textError = `Необходимо дать согласие на обработку данных и заполнить поле почты`;
        } else if (!validPhone && validEmail && validSig) {
            textError = `Не заполнено поле телефона`;
        } else if (!validPhone && validEmail && !validSig) {
            textError = `Необходимо дать согласие на обработку данных и заполнить поле телефона`;
        } else if (!validPhone && !validEmail && validSig) {
            textError = `Не заполнены поля телефона и почты`;
        } else if (!validPhone && !validEmail && !validSig) {
            textError = `Необходимо заполнить поля почты и телефона, а также дать согласие на обработку данных`;
        }

        if (!isValid) {
            $(this).siblings('.error-message').html(`<div>${textError}</div>`);
            $(this).siblings('.w-form-fail').html(`<div>${textError}</div>`);
            $(this).siblings('.error-message').show();
            $(this).siblings('.w-form-fail').show();
            return;
        } else {
            textError = `Ой! Что-то пошло не так`;
            $(this).siblings('.error-message').html(`<div>${textError}</div>`);
            $(this).siblings('.w-form-fail').html(`<div>${textError}</div>`);
        }

        $(this).hide();
        var form = $(this);

        $.ajax({
            type: "POST",
            url: "form",
            data: form.serialize(), // serializes the form's elements.
            success: function (data) {
                form.siblings('.success-message').show();
                form.siblings('.w-form-done').show();
                console.log('success', data); // show response from the php script.
            },
            error: function (data) {
                form.siblings('.error-message').show();
                form.siblings('.w-form-fail').show();
                console.log('error', data)
            }
        });
        return false;
    });
</script>
