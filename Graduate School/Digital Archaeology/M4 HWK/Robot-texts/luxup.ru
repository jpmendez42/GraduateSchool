    .v-header { position: fixed; height: 64px; width: 100%; background-color: rgba(14,11,4, 0.95); z-index: 9999999999; border-bottom: 1px solid #8f96a3; font-family: 'Raleway',Arial,sans-serif; -webkit-user-select: none; -khtml-user-select: none; -moz-user-select: none; -ms-user-select: none; user-select: none; }
    .v-header-inner { position: relative; max-width: 1200px; margin: auto; }
