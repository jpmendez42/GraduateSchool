<script>
$(function () {
    $(document).ready(function () {
        $('.banner-close').click(function() {
            $(this).parent().hide();
            Cookies.set("floating_banner", "close", {expires: 1});
        });
    });
    $(window).on("scroll", function() {
        if (Cookies.get("floating_banner") !== "close") {
            if ($(this).scrollTop() > 100) {
                $(".banner").fadeIn(300);
            }
        }
    });
});
</script>

