},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Vent og prøv senere.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"3XlgY75wWQDz1Gfn4Ayh5J","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 452 4.5.0 policy based rcpt([email-address]) rate limited","title":"452 4.5.0 policy based rcpt([email-address]) rate limited","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Der er forsøgt sendt mails til for mange modtagere med samme afsender mailadresse/bruger-id indenfor den sidste time.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"1. Fjern mails fra udbakken, som ikke er sendt.\n2. Luk dit postprogram.\n3. Vent 60 minutter.\n4. Prøv at sende din mail igen.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSpørgsmål vedr. denne fejlmeddelelse kan rettes til postmaster@abuse.mail.dk","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"DpGvBEwLLAjhCW5r7B6bW","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 452 4.5.0 policy based rcpt([ip-address]) rate limited","title":"452 4.5.0 policy based rcpt([ip-address]) rate limited","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Der er forsøgt sendt mails til for mange modtagere fra samme ip-adresse indenfor den sidste time.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"1. Fjern mails fra udbakken, som ikke er sendt.\n2. Luk dit postprogram.\n3. Vent 60 minutter.\n4. Prøv at sende din mail igen.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"3VmsTsmoPa14yXpZV2StUn","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 452 4.5.0 policy based throttling ([ip-address])","title":"452 4.5.0 policy based throttling ([ip-address])","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Hvis en ip-adresse sender mails som adskillige gange fanges af spam filteret, så afbrydes kommunikationen og der opretholdes en blokering i en time for den pågældende ip-adresse.\nDette er for at forhindre at spammere belaster systemet unødigt.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"A. Kontroller og rens dine enheder for virus, som evt. udsender mails via din konto.\nB. Kontroller hvad du har liggende i udbakken (på alle dine enheder) og som endnu ikke er afsendt. Fjern den/disse mails og vent minimum 60 min, før du prøver at sende igen.\nC. Skift din adgangskode til mail for en sikkerhedsskyld (efter punkt A).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"1E3XAqNDtusHYmZ74T8TvH","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.0 service not allowed","title":"550 5.1.0 service not allowed","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Hvis en ip-adresse sender mails som adskillige gange fanges af spam filteret, så afbrydes kommunikationen og der opretholdes en blokering i en time for den pågældende ip-adresse.\nDette er for at forhindre at spammere belaster systemet unødigt.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"A. Kontroller og rens dine enheder for virus, som evt. udsender mails via din konto.\nB. Kontroller hvad du har liggende i udbakken (på alle dine enheder) og som endnu ikke er afsendt. Fjern den/disse mails og vent minimum 60 min, før du prøver at sende igen.\nC. Skift din adgangskode til mail for en sikkerhedsskyld (efter punkt A).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Mere information om mailinglister ","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"https://postmaster.tdc.dk/mailingister"},"content":[{"nodeType":"text","value":"her","marks":[],"data":{}}]},{"nodeType":"text","value":".","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"45xaLDG8vHg2G5NgMP9DWH","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.1 user: [email-address] unknown","title":"550 5.1.1 user: [email-address] unknown","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailadressen, du forsøger at skrive til, findes ikke.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Kontroller mailadressen for stavefejl og prøv igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Forsøger du at svare på en mail, kan fejlen skyldes, at afsender benytter en forkert afsender-mailadresse.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Typiske fejl:\n- hotmail.dk i stedet for hotmail.com\n- gmail.dk i stedet for gmail.com\n- domænet webspeed.dk bliver stavet forkert, for eksempel wepspeed.dk\n- punktum før snabel-a, for eksempel post.@yousee.dk\n- mailadressen indeholder mellemrum eller usynlige tegn.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"3l5N1D7K7rv8434ZWKZJ7m","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.2 rcptto domain ([domain]) not valid","title":"550 5.1.2 rcptto domain ([domain]) not valid","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Domænet (delen efter snabel-a) i mailadressen er ikke et gyldigt posthus.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Teknisk:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Der er ikke nogen MX-record som peger på en IPv4 A-record.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Kontroller mailadressen for stavefejl og prøv igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejlen kan også skyldes, at vejviseren til modtagers posthus er opsat forkert.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"2MVikEJsjMa9LemRlA1RbO","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.2 rcptto domain ([domain]) not valid, rfc1918","title":"550 5.1.2 rcptto domain ([domain]) not valid, rfc1918","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Domænet (delen efter snabel-a) i mailadressen er ikke et gyldigt posthus.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Teknisk:","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"\nMX-record peger på en A-record, som er en privat ip (f.eks. 127.0.0.1).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Kontroller mailadressen for stavefejl og prøv igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejlen kan også skyldes, at vejviseren til modtagers posthus er opsat forkert.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"2Bq5v0X1hz1Pq7JFZPiqQU","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.8 rcptto domain ([domain]) not found in dns","title":"550 5.1.8 rcptto domain ([domain]) not found in dns","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"a) Domænet (delen efter snabel-a) i mailadressen findes ikke.\neller\nb) Fejl ved DNS opslag.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"a) Kontroller mailadressen for stavefejl og prøv igen (mailadressen som fejlede, finder du i fejlmeddelelsen som henviste dig til denne webside).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"b) Ved du at delen efter snabel-a er stavet korrekt og findes, skyldes fejlen måske at et DNS opslag er fejlet. Denne fejl skyldes ofte at det register (navneserver) som kender domænet er flyttet. Vent 1-24 timer og prøv igen.\nSpørgsmål vedrørende b) skal typisk rettes til det sted domænet hører hjemme (dem som hoster domænet).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"iO3Z7JQyNFj3XiKtNBNB8","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.8 [customer-id] not allowed to send as [email-address]","title":"550 5.1.8 [customer-id] not allowed to send as [email-address]","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Det brugernavn du benytter til login på asmtp.yousee.dk (for udgående post) hører ikke til samme postkasse som mailadressen du benytter.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"I fejlmeddelelsen som henviste dig til denne webside, finder du det brugernavn og den mailadresse som TDC ser at du benytter.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Skift dit \"brugernavn\" for udgående post, til det brugernavn som hører til postkassen du benytter (fremfor at sende med et brugernavn tilhørende en anden postkassen).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hvis brugernavn i fejlmeddelelsen er korrekt, så kontroller om mailadressen er stavet korrekt.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Hvis du, som de fleste, anvender Windows og for eksempel Outlook Express, anbefaler vi, du bruger det automatiske værktøj.\n","marks":[],"data":{}},{"nodeType":"hyperlink","data":{"uri":"http://yousee.dk/4444"},"content":[{"nodeType":"text","value":"http://yousee.dk/4444","marks":[],"data":{}}]},{"nodeType":"text","value":"","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"53esQAYkXegoCLJtKegPH2","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.1.8 sending non-local domain not allowed [domain]","title":"550 5.1.8 sending non-local domain not allowed [domain]","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:","nodeType":"text"},{"data":{},"marks":[],"value":"\nDu forsøger at sende mail via TDCs mailserver med et afsender domænet, som ikke tilhører TDC.\n\n","nodeType":"text"},{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:","nodeType":"text"},{"data":{},"marks":[],"value":"\nTDC har lukket af for muligheden, for at sende med eget domæne via TDCs mailserver. Du skal i stedet sende dine mails via den mailserver som din mailadresse tilhører.\n\nDu kan vælge mellem to løsninger. Den ene er at skifte, så du fremover benytter en TDC mailadresse som afsender (se løsning 1) eller du kan vælge at benytte samme afsender som du gør idag (se løsning 2).\n\n","nodeType":"text"},{"data":{},"marks":[{"type":"bold"}],"value":"Løsning 1:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSkift afsender mailadresse til den mailadresse som tilhører din TDC postkasse og opret evt. en videresendelse fra din gamle postkasse til din TDC postkasse.\n\n","nodeType":"text"},{"data":{},"marks":[{"type":"bold"}],"value":"Løsning 2:","nodeType":"text"},{"data":{},"marks":[],"value":"\nBemærk at TDC yder IKKE hjælp til denne opsætning. Din mailadresse tilhører en anden leverandør (hvor du sandsynligvis har købt og betalt for denne tjeneste) og det er dem som skal hjælpe dig med denne opsætning.\n\nKontakt den person eller virksomhed som domænet i din mailadresse tilhører og spørg  hvordan du sender via deres service.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[],"value":"","nodeType":"text"},{"data":{"uri":"https://postmaster.tdc.dk/fejlmeddelser/asmtp/550-5-1-8-domain-not-allowed/Mail-server-with-another-provider"},"content":[{"data":{},"marks":[],"value":"Vejledninger fra andre leverandører.","nodeType":"text"}],"nodeType":"hyperlink"},{"data":{},"marks":[],"value":"","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[],"value":"Fungerer afsendelse ikke med den nye opsætning skal du kontakte denne leverandør (TDC kan ikke hjælpe med tredie parts opsætning).","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSpørgsmål vedr. denne fejlmeddelelse kan rettes til postmaster@abuse.mail.dk","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"zApCpTsaPYfr2KBa1U1mC","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.2.1 user: [email-address] is inactive or suspended","title":"550 5.2.1 user: [email-address] is inactive or suspended","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailadressen du forsøger at skrive til, er ikke aktiv.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Det er uvist, hvorfor kontoen ikke er aktiv. Kunden kan have opsagt sit abonnement.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Vi ikke kan oplyse årsag og ej heller ny mailadresse.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"31EN3kXDy6xcwq5qIkawqP","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.4.0 No route to destination host: [domain]","title":"550 5.4.0 No route to destination host: [domain]","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Modtagers posthus findes ikke.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du har sendt en mail til et domæne som ikke tager imod post. Kontroller mailadressen for fejl. Se delen efter snabel-a.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Typiske fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du har måske skrevet gmail.dk i stedet for gmail.com eller msn.dk i stedet for msn.com","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"5h2TpeqtTLKcWtL3eNYbZY","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.4.0 [domain] is not a mail domain (or you did not define recipient...","title":"550 5.4.0 [domain] is not a mail domain (or you did not define recipient...","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Domænet asmtp.yousee.dk / asmtp.mail.dk kan ikke benyttes som afsender/modtager domæne.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du har enten forsøgt at benytte asmtp.yousee.dk / asmtp.mail.dk som afsender/modtager domæne eller også har du glemt at specificere et domæne i afsender/modtager mailadressen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"3R22tqONWmE4DO9XBHqPBD","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.6.0 Lone CR or LF in headers (see RFC2822 section 2.2)","title":"550 5.6.0 Lone CR or LF in headers (see RFC2822 section 2.2)","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Du forsøger at sende/videresende en mail som ikke er korrekt formatteret.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Slet mailen i udbakken.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[],"value":"For tekniske detaljer, se https://tools.ietf.org/html/rfc2822#section-2.2","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Spørgsmål vedr. denne fejlmeddelelse kan rettes til postmaster@abuse.mail.dk","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"5iyXLbyjqh1HcKhzNr4k94","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.6.0 message considered spam","title":"550 5.6.0 message considered spam","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailen anses for at være spam og vil ikke blive sendt.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du bedes kontrollere/afprøve følgende:","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"1. Kontroller om der ligger mails i udbakken. Typisk er det den ældste mail i udbakken som blokerer. Prøv at fjern denne og se om resten evt. kan sendes.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"2. Er det et svar på en mail, du ikke kan sende, så prøv at slette modpartens tekst i dit svar (altså teksten under din signatur). Du kan/skal ikke svare på spam/uønsket post.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"3. Forsøger du at videresende en mail, kan det skyldes at spamfilteret har skiftet mening siden du modtog mailen og derfor kan mailen ikke videresendes.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"4. Indeholder din mail (eller vedhæftede filer) henvisninger til hjemmesider (f.eks. \"http://...\"), så prøv at fjerne disse henvisning (dette gælder også mailadresser).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"5. Indeholder din mail billeder, som du har fundet på nettet (gælder også smileys og baggrunds-tapet), kan et billede godt anses for at være spam, fordi en spammer har brugt netop dette billede i en større spam udsendelse. Det samme gælder for firma logoer m.v.\nBemærk også at nogle post programmer sætter et baggrunds billeder på alle mails som sendes.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"6. Fodnoter kan også være et problem, nogle post programmer indsætter en fodnote, f.eks. \"Sendt via min X enhed\", Scannet med X antivirus\" og lignende. Prøv at fjern denne signatur.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"7. Endelig som en mere sjælden mulighed, kan det skyldes at dit postprogram er opsat til at svare på alle mails du modtager (modtager kvittering og læse kvittering). Vi tilråder at du de-aktiverer disse kvitteringer, da de kan være til stor gene. De fleste Microsoft produkter sender sådanne kvitteringer. Mail-kvitteringen er en skjult mail som du derfor ikke kan slette, men mailen kan stadig blokere.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"5E9tgTUEPYOziZFrV0RhhY","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.6.0 message considered virus","title":"550 5.6.0 message considered virus","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailen indeholder virus og vil derfor ikke blive sendt.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Kontroller din computer for virus og prøv igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"4MfDC35ptHE8eJoS2Ey4pe","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 550 5.7.1 authentication needed, relaying denied","title":"550 5.7.1 authentication needed, relaying denied","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Du forsøger at bruge en tjeneste, som kræver login.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Opsæt dit postprogram til at benytte brugernavn og adgangskode.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Dit brugernavn er dit kundenummer eller din mailadresse, og adgangskoden er typisk den samme adgangskode, du bruger, når du henter post.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Se korrekt opsætning på YouSee's hjemmeside.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"4ueAi2TRProYN2NsIn2Yb2","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion 552 5.3.4 Message size exceeds maximum message size: [bytes]","title":"552 5.3.4 Message size exceeds maximum message size: [bytes]","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailen er for stor.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Reducer størrelsen på din mail og prøv igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Typiske fejl:\n- der er vedhæftet et dokument, som fylder for meget .\n- der er vedhæftet et eller flere fotos, som fylder for meget.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"6HDWyhrn6bmdT36EB2UM8v","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion ASMTP: Fejl til de utålmodige","title":"ASMTP: Fejl til de utålmodige","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Der findes regler for kommunikation via mail.\n\n","nodeType":"text"},{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Benyt standard mail software, som opfylder RFC2821 eller læs RFC2821 for korrekt mail-kommunikation.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSpørgsmål vedr. denne fejlmeddelelse kan rettes til postmaster@mail.dk","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"eiJ2bKPjcpnXLUPCZCRbM","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion ASMTP: For mange ukendte brugere","title":"ASMTP: For mange ukendte brugere","body":{"d