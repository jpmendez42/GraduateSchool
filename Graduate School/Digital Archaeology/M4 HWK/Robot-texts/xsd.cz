tionMin\":8,\"genre\":8,\"slug\":\"vecernicek-97468498\",\"channelId\":\"180\"},{\"id\":\"97468499\",\"start\":\"2025-10-13T16:35:00.000Z\",\"stop\":\"2025-10-13T16:40:00.000Z\",\"title\":\"Bluey II\",\"description\":\"\",\"durationMin\":7,\"genre\":4,\"slug\":\"bluey-ii-97468499\",\"channelId\":\"180\"},{\"id\":\"97468500\",\"start\":\"2025-10-13T16:40:00.000Z\",\"stop\":\"2025-10-13T16:50:00.000Z\",\"title\":\"Medvedík Pompon\",\"description\":\"\",\"durationMin\":7,\"genre\":4,\"slug\":\"medvedik-pompon-97468500\",\"channelId\":\"180\"},{\"id\":\"97468501\",\"start\":\"2025-10-13T16:50:00.000Z\",\"stop\":\"2025-10-13T16:55:00.000Z\",\"title\":\"Fidlibumove pokusy\",\"description\":\"\",\"durationMin\":6,\"genre\":4,\"slug\":\"fidlibumove-pokusy-97468501\",\"channelId\":\"180\"},{\"id\":\"97468502\",\"start\":\"2025-10-13T16:55:00.000Z\",\"stop\":\"2025-10-13T17:05:00.000Z\",\"title\":\"Šmolkovia - nové príbehy II\",\"description\":\"\",\"durationMin\":12,\"genre\":4,\"slug\":\"smolkovia-nove-pribehy-ii-97468502\",\"channelId\":\"180\"},{\"id\":\"97468503\",\"start\":\"2025-10-13T17:05:00.000Z\",\"stop\":\"2025-10-13T17:30:00.000Z\",\"title\":\"Heidi\",\"description\":\"\",\"durationMin\":22,\"genre\":4,\"slug\":\"heidi-97468503\",\"channelId\":\"180\"},{\"id\":\"97468504\",\"start\":\"2025-10-13T17:30:00.000Z\",\"stop\":\"2025-10-13T17:40:00.000Z\",\"title\":\"Vstúpte do sveta tanca\",\"description\":\"\",\"durationMin\":14,\"genre\":8,\"slug\":\"vstupte-do-sveta-tanca-97468504\",\"channelId\":\"180\"},{\"id\":\"97468505\",\"start\":\"2025-10-13T17:40:00.000Z\",\"stop\":\"2025-10-13T18:00:00.000Z\",\"title\":\"Zázračný miniateliér\",\"description\":\"\",\"durationMin\":8,\"genre\":1,\"slug\":\"zazracny-miniatelier-97468505\",\"channelId\":\"180\"},{\"id\":\"97468506\",\"start\":\"2025-10-13T18:00:00.000Z\",\"stop\":\"2025-10-13T18:07:00.000Z\",\"title\":\"Správy v slovenskom posunkovom jazyku\",\"description\":\"\",\"durationMin\":7,\"genre\":9,\"slug\":\"spravy-v-slovenskom-posunkovom-jazyku-97468506\",\"channelId\":\"180\"},{\"id\":\"97468507\",\"start\":\"2025-10-13T18:07:00.000Z\",\"stop\":\"2025-10-13T18:10:00.000Z\",\"title\":\"Informácia pre tipujúcich: KENO 10, KENO Joker, Extra výplata, Všetko alebo nič\",\"description\":\"\",\"durationMin\":3,\"genre\":null,\"slug\":\"informacia-pre-tipujucich-keno-10-keno-joker-extra-vyplata-vsetko-alebo-nic-97468507\",\"channelId\":\"180\"},{\"id\":\"97468508\",\"start\":\"2025-10-13T18:10:00.000Z\",\"stop\":\"2025-10-13T18:35:00.000Z\",\"title\":\"Lov slov\",\"description\":\"\",\"durationMin\":27,\"genre\":1,\"slug\":\"lov-slov-97468508\",\"channelId\":\"180\"},{\"id\":\"97468509\",\"start\":\"2025-10-13T18:35:00.000Z\",\"stop\":\"2025-10-13T19:30:00.000Z\",\"title\":\"Ako sa rodila Zem\",\"description\":\"Objavte históriu našej rodnej Zeme - štyri a pol miliardy rokov vývoja modrej planéty, vyrozprávanej v piatich pútavých príbehoch. Od prvých kvapiek, z ktorých vznikol svet vody, až po príchod neuveriteľných obyvateľov - nás ľudí. Tvorcovia spolupracovali s dvoma stovkami popredných odborníkov (paleontológovia, geológovia, klimatológovia), ktorí prispeli najnovšími vedeckými poznatkami. Pôsobivé vizuálne zábery kombinujú s CGI rekonštrukciami, aby diváka preniesli do stredobodu udalostí, ktoré formovali planétu. Seriál z produkcie BBC zobrazuje Zem nielen ako kulisu ľudských dejín, ale ako živý, meniaci sa organizmus.\",\"durationMin\":53,\"genre\":5,\"slug\":\"ako-sa-rodila-zem-97468509\",\"channelId\":\"180\"},{\"id\":\"97468510\",\"start\":\"2025-10-13T19:30:00.000Z\",\"stop\":\"2025-10-13T20:05:00.000Z\",\"title\":\"Experiment\",\"description\":\"\",\"durationMin\":30,\"genre\":1,\"slug\":\"experiment-97468510\",\"channelId\":\"180\"},{\"id\":\"97468511\",\"start\":\"2025-10-13T20:05:00.000Z\",\"stop\":\"2025-10-13T22:42:00.000Z\",\"title\":\"Ty si tiež nič nevidel\",\"description\":\"Claire a Thomas majú šťastnú rodinu s dvomi deťmi. Ich spokojný život sa ocitne v troskách, keď polícia v blízkosti ich domu nájde novorodenca, ktorého matkou je zrejme Claire. Claire tvrdí, že nevedela o tom, že je tehotná, ale ako je možné, že ani nikto iný nič nevidel?\",\"durationMin\":92,\"genre\":3,\"slug\":\"ty-si-tiez-nic-nevidel-97468511\",\"channelId\":\"180\"},{\"id\":\"97468512\",\"start\":\"2025-10-13T22:42:00.000Z\",\"stop\":\"2025-10-13T22:44:00.000Z\",\"title\":\"Hymna SR\",\"description\":\"\",\"durationMin\":2,\"genre\":null,\"slug\":\"hymna-sr-97468512\",\"channelId\":\"180\"},{\"id\":\"97468513\",\"start\":\"2025-10-13T22:44:00.000Z\",\"stop\":\"2025-10-13T23:35:00.000Z\",\"title\":\"Správy\",\"description\":\"\",\"durationMin\":50,\"genre\":9,\"slug\":\"spravy-97468513\",\"channelId\":\"180\"},{\"id\":\"97468514\",\"start\":\"2025-10-13T23:35:00.000Z\",\"stop\":\"2025-10-13T23:50:00.000Z\",\"title\":\"Hírek\",\"description\":\"\",\"durationMin\":6,\"genre\":9,\"slug\":\"hirek-97468514\",\"channelId\":\"180\"}],\"181\":[{\"id\":\"97467824\",\"start\":\"2025-10-13T01:20:00.000Z\",\"stop\":\"2025-10-13T02:10:00.000Z\",\"title\":\"Španielske mestá - svetové dedičstvo\",\"description\":\"\",\"durationMin\":51,\"genre\":5,\"slug\":\"spanielske-mesta-svetove-dedicstvo-97467824\",\"channelId\":\"181\"},{\"id\":\"97467825\",\"start\":\"2025-10-13T02:10:00.000Z\",\"stop\":\"2025-10-13T03:05:00.000Z\",\"title\":\"Správy\",\"description\":\"\",\"durationMin\":50,\"genre\":9,\"slug\":\"spravy-97467825\",\"channelId\":\"181\"},{\"id\":\"97956939\",\"start\":\"2025-10-13T03:05:00.000Z\",\"stop\":\"2025-10-13T03:30:00.000Z\",\"title\":\"Slovensko v obrazoch\",\"description\":\"\",\"durationMin\":24,\"genre\":5,\"slug\":\"slovensko-v-obrazoch-97956939\",\"channelId\":\"181\"},{\"id\":\"97467827\",\"start\":\"2025-10-13T03:30:00.000Z\",\"stop\":\"2025-10-13T05:00:00.000Z\",\"title\":\"Dámsky klub\",\"description\":\"\",\"durationMin\":90,\"genre\":1,\"slug\":\"damsky-klub-97467827\",\"channelId\":\"181\"},{\"id\":\"97467828\",\"start\":\"2025-10-13