er justify-content-start gap-2"><span class="text-muted">13/10/2025</span><!----><app-tags ngh="17"><div role="region" class="flex-row d-flex justify-content-start align-items-center flex-wrap gap-2 tags-class text-center"><div class="d-flex flex-row"><div class="tag-wave"></div><!----><span role="status" class="tag sizeS"> Économie </span><!----></div><!----></div></app-tags><!----></div></div></div><!----><div class="px-4 pt-3 pb-3 mb-3 d-flex flex-column flex-grow-1"><app-markdown aria-live="polite" class="card-text mb-2" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p><span style="color:rgb(16,17,17);font-family:Roboto, sans-serif;">L’Allemagne, premier partenaire de l’UE en termes de PIB, est aussi l’un de ceux qui sont les plus exposés depuis quelques années aux multiples assauts d’un monde plus mouvementé.</span></p></div></app-markdown><!----><!----><!----></div><!----><!----></a><!----><!----><!----><!----><!----><!----></app-card><app-card role="article" class="align-items-stretch d-flex card-container col-sm-12 col-md-6 col-lg-3 col-xl-3 col-xxl-3 fourCardsInCardGrid" ngh="18"><a role="region" class="card card-infos w-100 link-card-info hoverBorder" href="/actualites/point-attention-faux-conseillers-bancaires" aria-label="Redirige vers Point d’attention sur les faux conseillers bancaires, ne vous faites pas piéger !"><img height="170px" loading="lazy" class="card-img-top imageObjectFitCover" src="https://bredfrmedia.blob.core.windows.net/media/assets/illu_actu_faux_conseiller_septembre_2025_2_6f5310d316.jpg" role="presentation"><!----><div class="pt-3"><div class="px-4 pb-0 mt-3"><div class="mb-2"><span role="heading" aria-level="2" class="cardTitleHorizontal">Point d’attention sur les faux conseillers bancaires, ne vous faites pas piéger ! </span></div><!----><div class="d-flex align-items-center justify-content-start gap-2"><span class="text-muted">13/10/2025</span><!----><app-tags ngh="17"><div role="region" class="flex-row d-flex justify-content-start align-items-center flex-wrap gap-2 tags-class text-center"><div class="d-flex flex-row"><div class="tag-wave"></div><!----><span role="status" class="tag sizeS"> Sécurité </span><!----></div><!----></div></app-tags><!----></div></div></div><!----><div class="px-4 pt-3 pb-3 mb-3 d-flex flex-column flex-grow-1"><app-markdown aria-live="polite" class="card-text mb-2" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p><span style="font-family:&quot;Aptos&quot;,sans-serif;">Les arnaques bancaires par <strong>usurpation d'identité</strong> sont en <strong>très forte augmentation</strong>. Que vous soyez un particulier ou un professionnel, les <strong>fraudeurs</strong> se font passer pour des conseillers bancaires afin de voler vos informations confidentielles et votre argent.&nbsp;</span></p></div></app-markdown><!----><!----><!----></div><!----><!----></a><!----><!----><!----><!----><!----><!----></app-card><app-card role="article" class="align-items-stretch d-flex card-container col-sm-12 col-md-6 col-lg-3 col-xl-3 col-xxl-3 fourCardsInCardGrid" ngh="18"><a role="region" class="card card-infos w-100 link-card-info hoverBorder" href="actualites/envie-de-decouvrir-des-courts-metrages-passionnants" aria-label="Redirige vers Envie de découvrir des courts-métrages passionnants ? "><img height="170px" loading="lazy" class="card-img-top imageObjectFitCover" src="https://bredfrmedia.blob.core.windows.net/media/assets/12courtsdeminuit_vignette_bf15ed9be8.jpg" role="presentation"><!----><div class="pt-3"><div class="px-4 pb-0 mt-3"><div class="mb-2"><span role="heading" aria-level="2" class="cardTitleHorizontal">Envie de découvrir des courts-métrages passionnants ?  </span></div><!----><div class="d-flex align-items-center justify-content-start gap-2"><span class="text-muted">10/10/2025</span><!----><app-tags ngh="17"><div role="region" class="flex-row d-flex justify-content-start align-items-center flex-wrap gap-2 tags-class text-center"><div class="d-flex flex-row"><div class="tag-wave"></div><!----><span role="status" class="tag sizeS"> Sociétariat </span><!----></div><!----></div></app-tags><!----></div></div></div><!----><div class="px-4 pt-3 pb-3 mb-3 d-flex flex-column flex-grow-1"><app-markdown aria-live="polite" class="card-text mb-2" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p><span style="color:rgb(79,79,79);font-family:Aptos, sans-serif;font-size:16px;">Rendez-vous du 13 au 15 octobre 2025 avec les 12 Courts de Minuit&nbsp;!&nbsp;</span></p></div></app-markdown><!----><!----><!----></div><!----><!----></a><!----><!----><!----><!----><!----><!----></app-card><app-card role="article" class="align-items-stretch d-flex card-container col-sm-12 col-md-6 col-lg-3 col-xl-3 col-xxl-3 fourCardsInCardGrid" ngh="19"><a role="region" class="card card-infos w-100 link-card-info hoverBorder" href="/actualites/envie-de-vous-lancer-dans-lentrepreneuriat" aria-label="Redirige vers Envie de vous lancer dans l’entrepreneuriat ? "><img height="170px" loading="lazy" class="card-img-top imageObjectFitCover" src="https://bredfrmedia.blob.core.windows.net/media/assets/illu_actu_semaine_entreprendre_adie_octobre_2025_a3fda5855b.jpg" role="presentation"><!----><div class="pt-3"><div class="px-4 pb-0 mt-3"><div class="mb-2"><span role="heading" aria-level="2" class="cardTitleHorizontal">Envie de vous lancer dans l’entrepreneuriat ?  </span></div><!----><div class="d-flex align-items-center justify-content-start gap-2"><span class="text-muted">06/10/2025</span><!----><!----></div></div></div><!----><div class="px-4 pt-3 pb-3 mb-3 d-flex flex-column flex-grow-1"><app-markdown aria-live="polite" class="card-text mb-2" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p style="margin-left:0px;"><strong>Rendez-vous du 13 au 17 octobre pour faire avancer votre projet.</strong></p><p><span style="font-family:Aptos, sans-serif;">Plus de 500 événements d’information seront accessibles pour tous, en ligne et en présentiel, en français et en plusieurs langues.</span></p></div></app-markdown><!----><!----><!----></div><!----><!----></a><!----><!----><!----><!----><!----><!----></app-card><!----><!----></div><!----><!----><!----><!----><!----><!----><!----><div class="flex-column d-flex gap-4"><!----><app-button class="d-flex justify-content-center justify-content-md-end" ngh="15"><!----><a href="/actualites" type="button" target="_self" aria-label="Voir toutes les actualités" class="btn mw-100 h-100 align-content-center justify-content-center align-self-center px-4 py-2 btn-outline-primary"><div class="align-items-center justify-content-center d-flex"><!----><span class="hyphens buttonTextClass button-text">Voir toutes les actualités</span><!----><!----><!----></div></a><!----><!----><!----><!----></app-button><!----><!----></div><!----></div><!----><!----><!----></div><!----></app-grid-cards><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><app-custom-section id="" ngh="9"><div role="region" class=""></div><!----></app-custom-section><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><app-grid-cards id="" ngh="22"><div role="region" aria-label="Grid cards" class="container-fluid p-0 pt-5" style="background-color: #FFFFFF;"><div role="region" aria-label="grid-cards-list" class="container gap-02 d-flex flex-column"><app-markdown ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><h2>Construisons une relation dans la confiance</h2></div></app-markdown><!----><!----><!----><!----><div class="card-icon-container"><div class="d-flex flex-sm-column flex-md-row card-desk gap-sm-4 gap-md-0"><app-card-icons role="article" class="align-items-stretch d-flex card-container col-sm-12 col-md-4 col-lg-4 col-xl-4 col-xxl-4" ngh="21"><div></div><!----><!----><div id="card-icons-content" role="region" aria-label="Card icon with content" class="card p-4 card-icons w-100" style="background-color: white;"><div class="d-flex align-items-center justify-content-center mb-3 card-icon"><div class="d-flex flex-row gap-1"><i aria-hidden="true" style="height: 56px; width: 56px;" class="d-flex fa fa-4x fa-duotone fa-people-group fa-solid justify-content-center"></i><!----></div></div><!----><!----><app-markdown aria-live="polite" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p style="text-align:center;"><span style="color:hsl( 0, 0%, 82% );">__________</span><span style="color:hsl(0,0%,82%);">__________</span></p><p style="text-align:center;">La BRED est une Banque Populaire coopérative. Elle appartient à ses clients sociétaires qui participent au développement et au financement de l’économie réelle.</p></div></app-markdown><!----><!----><!----><!----><!----><!----></div><!----><!----></app-card-icons><app-card-icons role="article" class="align-items-stretch d-flex card-container col-sm-12 col-md-4 col-lg-4 col-xl-4 col-xxl-4" ngh="21"><div></div><!----><!----><div id="card-icons-content" role="region" aria-label="Card icon with content" class="card p-4 card-icons w-100" style="background-color: white;"><div class="d-flex align-items-center justify-content-center mb-3 card-icon"><div class="d-flex flex-row gap-1"><i aria-hidden="true" style="height: 56px; width: 56px;" class="d-flex fa fa-4x fa-duotone fa-solid fa-user-check justify-content-center"></i><!----></div></div><!----><!----><app-markdown aria-live="polite" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p style="text-align:center;"><span style="color:hsl( 0, 0%, 82% );">__________</span><span style="color:hsl(0,0%,82%);">__________</span></p><p style="text-align:center;">A la BRED, votre conseiller dédié vous connait et comprend vos besoins. Quels que soient vos projets de vie, grands ou petits, il vous conseille et vous propose les meilleures solutions pour un accompagnement sur mesure.</p></div></app-markdown><!----><!----><!----><!----><!----><!----></div><!----><!----></app-card-icons><app-card-icons role="article" class="align-items-stretch d-flex card-container col-sm-12 col-md-4 col-lg-4 col-xl-4 col-xxl-4" ngh="21"><div></div><!----><!----><div id="card-icons-content" role="region" aria-label="Card icon with content" class="card p-4 card-icons w-100" style="background-color: white;"><div class="d-flex align-items-center justify-content-center mb-3 card-icon"><div class="d-flex flex-row gap-1"><i aria-hidden="true" style="height: 56px; width: 56px;" class="d-flex fa fa-4x fa-building-circle-check fa-duotone fa-solid justify-content-center"></i><!----></div></div><!----><!----><app-markdown aria-live="polite" ngh="10"><div id="markdown-container" samesizeimg="" changelinkcolor="" changelistmarkercolor="" class="black d-flex flex-column markdownclass" style="--table-bg-color: white;"><p style="text-align:center;"><span style="color:hsl( 0, 0%, 82% );">__________</span><span style="color:hsl(0,0%,82%);">__________</span></p><p style="text-align:center;">Plus de 300 agences pour vous accueillir et des espaces en libre-service pour vos opérations bancaires, des téléconseillers disponibles jusqu'à 22h (horaires en Métropole) et une application mobile dédiée pour la gestion de vos comptes en toute autonomie.</p></div></app-markdown><!----><!----><!----><!----><!----><!----></div><!----><!----></app-card-icons><!----></div></div><!----><!----><!----><!----><div class="flex-column d-flex gap-4"><span role="heading" aria-level="2" id="secondaryTitle" class="secondaryTitle text-center">Vous aussi devenez un client satisfait : rejoignez-nous !</span><!----><app-button class="d-flex justify-content-center" ngh="15"><!----><a href="/particuliers/ouvrir-un-compte" type="button" target="_self" aria-label="J'ouvre un compte" class="btn mw-100 h-100 align-content-center justify-content-center align-self-center px-4 py-2 btn-primary"><div class="align-items-center justify-content-center d-flex"><!----><span class="hyphens buttonTextClass button-text">J'ouvre un compte</span><!----><!----><!----></div></a><!----><!----><!----><!----></app-button><!----><!----></div><!----></div><!----><!----><!----></div><!----></app-grid-cards><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><app-grid-cards id="" ngh="26"><div role="region" aria-label="Grid cards" class="container-fluid p-0 pt-5 pb-5" style="background-color: white;"><div role="region" aria-label="grid-cards-list" class="container gap-02 d-flex flex-column"><!----><!----><!----><!----><div class="card-icon-container"><div class="d-flex flex-sm-c