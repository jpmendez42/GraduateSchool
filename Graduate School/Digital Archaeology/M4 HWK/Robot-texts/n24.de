="(min-width: 910px) calc(970px / 3), (min-width: 600px) 50vw, 100vw"/><img src="https://images.welt.de/68ecba23ff70575ab37a2153/04ea3c13efb1d6e5a798a07aa6fe654d/ci23x11-w200/f1-grand-prix-of-miami" class="c-picture__image" alt="#31 Esteban Ocon (FRA, BWT Alpine F1 Team), F1 Grand Prix of Miami at Miami International Autodrome on May 7, 2022 in Miami, United States of America. (Photo by HOCH ZWEI)" loading="lazy" decoding="async"/></picture></div></header></div><div class="c-teaser__container is-full-height-flex"><div class="c-teaser__overline"><div class="c-teaser__ellipsis-container"><span class="c-teaser__badge " data-external="Teaser.Badge"><a class="is-link c-teaser__badge-link is-teaser-link" href="/sport/formel1/" title="Formel 1" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;link&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/sport/formel1/&quot;,&quot;trackingName&quot;:&quot;Formel 1&quot;,&quot;trackingLabel&quot;:&quot;Formel 1&quot;}}" tabindex="-1"><span class="u-visually-hidden">Ressort<!-- -->:</span>Formel 1</a></span><span class="c-teaser__topic" data-external="Teaser.Topic">Esteban Ocon</span></div></div><div class="c-teaser__body" data-external="Teaser.Body"><h4 class="c-teaser__headline" data-external="Teaser.Title"><a class="is-link c-teaser__headline-link is-teaser-link" href="/sport/formel1/article68ecba23ff70575ab37a2153/formel-1-esteban-ocon-am-naechsten-morgen-bin-ich-zusammengebrochen.html" title="„Am nächsten Morgen bin ich in der Dusche zusammengebrochen“" data-external="Teaser.Link" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;panorama_a_free&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/sport/formel1/article68ecba23ff70575ab37a2153/formel-1-esteban-ocon-am-naechsten-morgen-bin-ich-zusammengebrochen.html&quot;,&quot;trackingName&quot;:&quot;„Am nächsten Morgen bin ich in der Dusche zusammengebrochen“&quot;,&quot;trackingLabel&quot;:&quot;„Am nächsten Morgen bin ich in der Dusche zusammengebrochen“&quot;}}" aria-label="Formel 1 - Esteban Ocon: „Am nächsten Morgen bin ich in der Dusche zusammengebrochen“">„Am nächsten Morgen bin ich in der Dusche zusammengebrochen“</a></h4><p class="c-teaser__intro" data-external="Teaser.Intro">Die Formel 1 ist über die Jahre immer sicherer geworden. Meist steigen die Fahrer unverletzt aus. Folgen gibt es dennoch, wie Esteban Ocon berichtet. Die schlimmen Nachwehen spürte er in einem Fall am nächsten Tag sehr deutlich.</p></div><script type="application/hydration-data" data-internal-ref="TeaserFooter-7de1bf2d-8560-4b18-75dd-6c4f55b49b67">{"teaserId":"68ecba23ff70575ab37a2153","showCommentCount":true}</script><div data-component="TeaserFooter" data-internal-id="TeaserFooter-7de1bf2d-8560-4b18-75dd-6c4f55b49b67" class="is-teaser-footer-hydrated"></div></div></article></div><div data-external="Stage.Item" class="u-grid-item is-grid-col-mobile-s-12 is-grid-col-mobile-l-6 is-grid-col-tablet-l-4"><article class="c-teaser c-teaser--default" data-external="Teaser" data-external-id="68eb78f40bda2290ccea8886"><div class="c-teaser__container"><header class="c-teaser__header" data-external="Teaser.Header"><div class="c-picture has-placeholder-image is-aspect-ratio-mobile-s-23x11  c-picture--default" data-external="Teaser.PictureElement.Placeholder"><picture class="c-picture__image-container is-aspect-ratio-mobile-s-23x11 "><source media="(min-width:0px)" srcSet="https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w200/britain-prisoner-slain 200w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w400/britain-prisoner-slain 400w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w600/britain-prisoner-slain 600w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w800/britain-prisoner-slain 800w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w1000/britain-prisoner-slain 1000w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w1200/britain-prisoner-slain 1200w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w1400/britain-prisoner-slain 1400w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w1600/britain-prisoner-slain 1600w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w1800/britain-prisoner-slain 1800w, https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w2000/britain-prisoner-slain 2000w" sizes="(min-width: 910px) calc(970px / 3), (min-width: 600px) 50vw, 100vw"/><img src="https://images.welt.de/68eb78f40bda2290ccea8886/bbd44f6bca53f68a407e244f53432269-master/ci23x11-w200/britain-prisoner-slain" class="c-picture__image" alt="Lostprophets-Sänger Ian Watkins im Jahr 2011. Zum Höhepunkt seiner Taten" loading="lazy" decoding="async"/></picture></div></header></div><div class="c-teaser__container is-full-height-flex"><div class="c-teaser__overline"><div class="c-teaser__ellipsis-container"><span class="c-teaser__badge " data-external="Teaser.Badge"><a class="is-link c-teaser__badge-link is-teaser-link" href="/kultur/pop/" title="Pop" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;link&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/kultur/pop/&quot;,&quot;trackingName&quot;:&quot;Pop&quot;,&quot;trackingLabel&quot;:&quot;Pop&quot;}}" tabindex="-1"><span class="u-visually-hidden">Ressort<!-- -->:</span>Pop</a></span><span class="c-teaser__topic" data-external="Teaser.Topic">Getöteter Ian Watkins</span></div></div><div class="c-teaser__body" data-external="Teaser.Body"><h4 class="c-teaser__headline" data-external="Teaser.Title"><a class="is-link c-teaser__headline-link is-teaser-link" href="/kultur/pop/article68eb78f40bda2290ccea8886/getoeteter-ian-watkins-der-gefallene-rockstar-der-ein-baby-zeugen-wollte-um-es-zu-missbrauchen.html" title="Der gefallene Rockstar, der ein Baby zeugen wollte, um es zu missbrauchen" data-external="Teaser.Link" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;panorama_a_free&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/kultur/pop/article68eb78f40bda2290ccea8886/getoeteter-ian-watkins-der-gefallene-rockstar-der-ein-baby-zeugen-wollte-um-es-zu-missbrauchen.html&quot;,&quot;trackingName&quot;:&quot;Der gefallene Rockstar, der ein Baby zeugen wollte, um es zu missbrauchen&quot;,&quot;trackingLabel&quot;:&quot;Der gefallene Rockstar, der ein Baby zeugen wollte, um es zu missbrauchen&quot;}}" aria-label="Pop - Getöteter Ian Watkins: Der gefallene Rockstar, der ein Baby zeugen wollte, um es zu missbrauchen">Der gefallene Rockstar, der ein Baby zeugen wollte, um es zu missbrauchen</a></h4><p class="c-teaser__intro" data-external="Teaser.Intro">Die Lostprophets waren eine der größten Bands Großbritanniens. Dann wurde ihr Sänger Ian Watkins wegen pädophiler Übergriffe verhaftet und verurteilt. Er hatte Kinder missbraucht und versucht, einen Säugling zu vergewaltigen. Jetzt wurde er im Gefängnis getötet. Eine Rekonstruktion.</p></div><script type="application/hydration-data" data-internal-ref="TeaserFooter-9e1c3500-9cfa-4c17-7b45-87a33ce4339e">{"teaserId":"68eb78f40bda2290ccea8886","showCommentCount":true,"autho