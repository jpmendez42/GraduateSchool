<script>
   $(document).ready(function() {
   // Выбираем все блоки со слайдерами
   $('.custom-margin-top-products').each(function() {
       // Находим количество слайдов в текущем блоке
       var slideCount = $(this).find('.swiper-slide').length;
   
       // Находим соответствующий блок .swiper-custom-arrows__wrapper
       var arrowsWrapper = $(this).siblings('.swiper-custom-arrows__wrapper');
   
$(window).on('resize', function() {
    if ($(window).width() <= 1024) {
        if (slideCount > 2) {
            arrowsWrapper.show();
        } else {
            arrowsWrapper.hide();
        }
    } else {
        if (slideCount > 3) {
            arrowsWrapper.show();
        } else {
            arrowsWrapper.hide();
        }
    }
});
   });
   });
   
</script>
