<script type="text/javascript">
$(document).ready(function () {
    if (Object.values(jsonMember?.pc || {}).filter($v => !$v).length > 0) {
        var pcFancyboxOptions = {
            width: 840,
            maxWidth: "95%",
            height: 526,
            closeBtn: false,
            closeClick: false, 
            helpers: {
                overlay: {
                    closeClick: false,  // 禁止點擊 overlay 關閉
                    css: { cursor: 'default' }  // 移除點擊手型
                }
            },
            modal: true,
            buttons: []
        };
        
        $(document).on("click", ".modal_footer .privacy_consent_close", function () {
            var is_agree = $(this).data("consent") == 1;
            if (is_agree && $(".modal_footer input[type='checkbox'].privacy_consent_checkbox:checked").length != $(".modal_footer input[type='checkbox'].privacy_consent_checkbox").length) {
                alert("請看到最後並勾選同意條款!");
                return;
            }
            $.ajax({
                url: "https://mall.iopenmall.tw/iopen/api/api.member_privacy_consent.php",
                type: "POST",
                dataType: "json",
                data: {
                    mem_agree: is_agree,
                    privacy_version: "2024-11-21",
                    [csrf_key]: csrf_val
                },
                beforeSend: function () {
                    $(".modal_footer input[type='button'].privacy_consent_close").prop("disabled", true);
                },
                error: function (e) {
                    console.log(e);
                },
                complete: function () {
                    parent.$.fancybox.close();
                    $(".modal_footer input[type='button'].privacy_consent_close").prop("disabled", false);
                }
            });
        });
        
        // 建立 observer 實例
        const pc_observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    $(".modal_footer input[type='checkbox'].privacy_consent_checkbox").prop("disabled", false)
                    // 停止觀察
                    pc_observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.69 });

                // 要求同意隱私權條款
        setTimeout(async () => {
            if (mem_uid && (!mem_privacy_overdue || Math.floor(Date.now()/1000) > mem_privacy_overdue)) {
                $("#privacy_consent_open").fancybox(pcFancyboxOptions).trigger("click");
            }
        }, 200);
        
        pc_observer.observe(document.querySelector(".membership .privacy_content_done"));
    }
});
</script>    
