  <body>
    <div class="layout">
      <header class="header js-header">
        <div class="section__inner header__inner">
          <div class="header__logo"><a class="header__logo__link" href="/"><img
                src="https://a-static.sber.ru/assets/images/logo-sberads-color.svg" alt="SberAds"></a></div>
          <div class="header__buttons js-header-buttons"><a class="btn btn-md btn-default header-button-reg"
              href="https://ads.sber.ru/api/v1.0/user/keycloak_register?backUrl=https://ads.sber.ru/td/&amp;reg_from=registr_header_button"
              target="_blank" data-sberads="reg"
              data-cv-name="registr_header_button"><span>Зарегистрироваться</span></a><a
              class="btn btn-md btn-dashed header-button-login" href="https://ads.sber.ru/td" target="_blank"
              data-sberads="login" data-cv-name="join_TD"><span>Войти</span></a>
            <div class="header__help dropdown js-dropdown">
              <div class="btn btn-md btn-secondary dropdown__button js-dropdown-button">Поддержка<img
                  src="https://a-static.sber.ru/assets/images/icon-arrow-down.svg" alt=""></div>
              <div class="dropdown__content js-dropdown-content">
                <ul class="dropdown__list">
                  <li class="dropdown__list__item"><a class="dropdown__list__item__title"
                      href="https://ads.sber.ru/help" data-cv-name="spravka_header"><img
                        class="dropdown__list__item__icon" src="https://a-static.sber.ru/assets/images/icon-book.svg"
                        alt="">Справка</a></li>
                  <li class="dropdown__list__item"><a class="dropdown__list__item__title" href="#feedback"
                      data-cv-name="zadat_vopros_header"><img class="dropdown__list__item__icon"
                        src="https://a-static.sber.ru/assets/images/icon-question.svg" alt="">Задать вопрос</a></li>
                  <li class="dropdown__list__item"><a class="dropdown__list__item__title" href="mailto:help@ads.sber.ru"
                      rel="noopener noreferrer" data-cv-name="send_email"><img class="dropdown__list__item__icon"
                        src="https://a-static.sber.ru/assets/images/icon-mail.svg" alt="">Написать нам</a></li>
                </ul>
              </div>
            </div>
          </div>
          <div class="header-menu-mobile" id="js-header-menu-mobile"><button class="header-menu-mobile__button-burger"
              id="js-header-menu-mobile-button"></button>
            <div class="header-menu-mobile-container">
              <div class="header-menu-mobile-inner">
                <ul class="header-menu-mobile__list">
                  <li><a class="js-header-menu-mobile-link" href="#benifits" data-cv-name="advantages">Преимущества</a>
                  </li>
                  <li><a class="js-header-menu-mobile-link" href="#benifits"
