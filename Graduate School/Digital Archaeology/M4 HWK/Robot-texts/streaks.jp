        d="M10.9864 1.5967C11.3286 1.66468 11.9607 1.97963 12.7538 2.37842C13.173 2.58915 13.6896 2.9177 14.2379 3.26664C15.6586 4.17072 17.2651 5.19488 18.7878 5.25833C18.5974 9.0831 17.8429 12.1737 16.4834 14.7024C15.2009 17.0907 13.3995 18.9283 10.9819 20.3172C8.56194 18.9237 6.7606 17.0884 5.48039 14.7024C4.12087 12.1737 3.3686 9.08537 3.17826 5.25833C4.70319 5.19488 6.30967 4.17071 7.7281 3.2689C8.27644 2.91996 8.79307 2.59141 9.21225 2.38069C10.0098 1.9819 10.642 1.66467 10.9841 1.59896M10.9841 0.663162C10.9343 0.663162 10.8867 0.667698 10.8369 0.674496C10.3656 0.756067 9.7402 1.06875 8.7908 1.54459C7.25455 2.31498 4.92977 4.27948 3.09216 4.32706C2.97434 4.33159 2.85651 4.35878 2.75001 4.40863C2.64352 4.45848 2.54835 4.53099 2.46905 4.61936C2.30591 4.8029 2.22433 5.04307 2.23566 5.28779C2.62992 13.3089 5.50755 18.2734 10.5559 21.1601C10.6873 21.2349 10.8324 21.2734 10.9774 21.2734C11.1224 21.2734 11.2674 21.2349 11.3988 21.1601C16.4471 18.2757 19.3248 13.3112 19.719 5.28779C19.7326 5.04307 19.6488 4.8029 19.4879 4.61936C19.4109 4.53099 19.3135 4.45848 19.207 4.40863C19.1005 4.35878 18.9826 4.33159 18.8648 4.32706C17.0272 4.27948 14.7047 2.31498 13.1662 1.54459C12.2168 1.07102 11.5914 0.756067 11.1201 0.674496C11.0725 0.667698 11.0249 0.663162 10.9796 0.663162H10.9841Z"
