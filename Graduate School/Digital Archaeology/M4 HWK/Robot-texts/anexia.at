<div id="t3_content"><!--TYPO3SEARCH_begin--><div class="wrapper-row content teaser 0">
		<div class="container borderTop">
			<div class="row"><div></div></div>
		</div>
		<div class="container three-cols">
			<div class="row">

				<div class="col-md-4 col-sm-4">
					<div class="content">
						<div class="circle">
							<img class="icon three-col-icons" alt="icon"  width="93" src='/fileadmin/img/icons/035-Cloud.svg'>
						</div>
						
									<div class="text">
										<h2>Digitale Souveränität</h2>
										<hr class="small" />
										<p>Europäische Cloud-Infrastrukturen, die digitale Souveränität durch Datenschutz, Transparenz und Kontrolle gewährleisten.</p>
										
												<div class="link">
													<span><a href="/de/unternehmen/ueber-anexia/engagement-und-auszeichnungen/digitale-souveraenitaet">Mehr<span class="icon-arrow green right big"></span></a></span>
												</div>
											
									</div>
							

					</div>
				</div>

				<div class="col-md-4 col-sm-4">
