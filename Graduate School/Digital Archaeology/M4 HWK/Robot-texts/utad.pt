}

.selectBox select {
  width: 100%;
}

.form-select {
  padding-left: 45px;
}

.overSelect {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

#mySelectOptions {
  display: none;
  border: 0.5px #7c7c7c solid;
  background-color: white;
  color: #0f253e;
  max-height: 250px;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid #1c344b;
}

#mySelectOptions label {
  font-weight: normal;
  display: block;
  white-space: nowrap;
  min-height: 0.75em;
  background-color: #ffffff;
  padding: 0px 10px 0px 10px;
}

#mySelectInner {
  height: 250px;
  overflow-y: scroll;
}

#mySelectOptions label:hover {
  background-color: #cccccc;
  border: none;
}

/* SELECTHOVER */
.form-select {
  overflow: hidden;
}

select {
  width: 100%;
  font-size: 1em;
  padding: 0.73em;
  background-color: #fff;
  border-radius: 10px;
}

select:focus {
  border-radius: 10px;
  border-color: #7c7c7c;
  background: #fff;
  outline: none;
}

#grau.select-wrap {
  width: 100%;
  position: absolute;
}

.select-wrap:focus-within select {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
  padding-left: 10px;
  border: 1px solid #1c344b;
}

option:hover {
  background-color: #cccccc;
  color: #0f253e;
}

option:checked {
  box-shadow: 0 0 1em 100px #ce0007 inset;
}

.input-icon {
  position: absolute;
  left: 30px;
  top: calc(50% - 0.4em); /* Keep icon in center of input, regardless of the input height */
  color: #ce0007;
}

@media screen and (-webkit-min-device-pixel-ratio:0) {
    select {
        -webkit-appearance: none !important;
    }
}

.form-group:after {
    content:"\f107";
    font-family: FontAwesome;
    color: #000;
    padding: 12px 8px;
    position: absolute; 
	right: 1em; 
	top: 0;
    z-index: 1;
    text-align: center;
