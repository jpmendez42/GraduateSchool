<script>
    function runCount() {
        var counted = 0;
        if (!counted) {
            jQuery('.number').each(function () {
                const tthis = jQuery(this),
                    countTo = tthis.attr('data-count');
                jQuery({
                    countNum: tthis.text()
                }).animate({
                        countNum: countTo
                    },
                    {
                        duration: 2000,
                        easing: 'swing',
                        step: function () {
                            tthis.text(Math.floor(this.countNum));
                        },
                        complete: function () {
                            tthis.text(this.countNum);
                        }
                    });
            });
        }
        counted = 1;
    }

    setTimeout(runCount, 1000);
</script>
