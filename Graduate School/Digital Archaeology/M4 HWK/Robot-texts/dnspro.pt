    font-size: 14px;
}
#top-menu .menu-item-has-children > a:first-child::after {
    top: 21px;
}
#before-menu-widgets {
    display: none;    
}
#menu-menu-right, #menu-menu-right-br, #menu-menu-right-pt {
    display: flex;
    padding-top: 20px;
}
.container.et_menu_container {
    display: flex;
}
.et_header_style_left .logo_container {
    flex: 0 1 150px;
    position: static;
}
.et_header_style_left #et-top-navigation {
    flex: 1 0 auto;
    padding: 20px 0 25px 20px !important;
    display: flex;
    align-items: center;
    justify-content: space-between;
