</script><script>
    (function ($) {
        $(document).ready(function () {
            var ratesLoad = function () {
                $.ajax({
                    url: "/ajax/currencies2.php",
                    cache: false,
                    dataType: 'json',
                    success: function (json) {
                        if (json.OFFICE) {
                            $('.jsRatesOfficeLine').remove();
                            $.each(json.OFFICE, function (code, values) {
                                $('.jsRatesOffice').append('<div class="jsRatesOfficeLine">' +
                                    '<div class="name">' + code + '</div>' +
                                    '<div>' + values.BUY + '</div>' +
                                    '<div>' + values.SALE + '</div>' +
                                    '</div>');
                            });
                        }

                        if (json.CB) {
                            $.each(json.CB, function (code, value) {
                                $('.jsRatesCb' + code).text(value);
                            });
                        }

                        if (json.MIB) {
                            $.each(json.MIB, function (code, value) {
                                $('.jsRatesMib' + code).text(value);
                            });
                        }

                        setTimeout(function () {
                            ratesLoad();
                        }, 30000);
                    }
                });
            }

            ratesLoad();
        }).on('click', '.js-active-currencies-folder', function (ev) {
            ev.preventDefault();

            if ($(this).hasClass('opened')) {
                $(this).removeClass('opened')
                $(this).next().slideUp()
            } else {
                $(this).addClass('opened');
                $(this).next().slideDown()
            }
        }).on('click', '.js-currencies-select-button', function (ev) {
            ev.preventDefault();

            let index = $(this).data('folder');

            $(this).parent().siblings().removeClass('active');
            $(this).parent().addClass('active');

            $('.index-currencies-inner__folders .folder-item').each(function (key, item) {
                $(item).removeClass('active');
                if ($(item).data('folder') === index) {
                    $(item).addClass('active');
                }
            })
            $('.js-active-currencies-folder').html($(this).html());
            $('.js-active-currencies-folder').removeClass('opened');
            $('.js-active-currencies-folder').next().slideUp();
        });
    }(jQuery));
</script>


<script>
    (function ($) {
        $(document).ready(function () {
            $.ajax({
                url: '/ajax/cookies/check.php',
                method: 'get',
                success: function (data) {
                    data=JSON.parse(data);

                    if (!data.checked) {
                        $('.cookies-window').fadeIn();
                    }
                }
            });
        });

        $(document).on('click', '.cookies-window .js-cookies-close', function (e) {
            e.preventDefault();
            let element=$(this);
            $.ajax({
                url: '/ajax/cookies/set.php',
                method: 'get',
                success: function () {
                    element.closest('.cookies-window').fadeOut();
                }
            });
        })
    }(jQuery));
</script>
<script src="https://pay.best2pay.net/webapi/js/best2pay.js"></script>
<script src="https://pay.best2pay.net/webapi/js/best2pay-p2p.js"></script>
<script>
    var payment = new Best2Pay();

    function pay(amount, description, reference) {
        payment.pay({
            sector: 1084,
            code: 643
        });
    }

    var p2p = new Best2PayP2P();

    function payP2P() {
        p2p.pay({
            sector: 545,
            code: 643,
            fullScreen: true
        });
    }

    var dons = new Best2Pay();

    function donate(amount, description, reference) {
        dons.pay({
            sector: 2156,
            code: 643
        });
    }
</script>
