ority="auto" width="363" height="410" class="Img uy-size-full uy-object-cover"> </div> <div class="uy-align-center uy-m-auto uy-flex uy-max-w-[496px] uy-flex-col uy-items-center uy-gap-300"> <span class="Tag theme-bg-lighter theme-border theme-text-darker uy-inline-flex uy-items-center uy-justify-center uy-gap-50 uy-rounded-100 uy-border uy-transition-all tagFont uy-font-body uy-font-medium uy-text-75 uy-leading-150 uy-bg-theme-blue-lighter uy-border-theme-blue uy-text-theme-blue-darker uy-py-25 uy-px-125"> +10 integraciones </span> <div class="uy-flex uy-flex-col uy-gap-100"> <h2 class="uy-text-content-heading title2Font uy-font-title uy-font-semibold uy-text-1000 md:uy-text-1200 uy-leading-125"> Conecta PayFit con tus herramientas favoritas </h2> <p>Nos integramos con las soluciones líderes  para una gestión 360º</p> </div> <a href="/es/asociaciones-e-integraciones/" class="ButtonLink uy-cursor-pointer uy-transition-all uy-duration-200 uy-items-center uy-justify-center uy-gap-100 disabled:uy-cursor-default buttonFont uy-font-body uy-font-medium uy-text-100 uy-leading-150 secondary uy-flex uy-rounded-150 uy-px-200 uy-border uy-text-center uy-bg-surface-button-secondary uy-border-border-button-secondary uy-text-content-button-secondary uy-shadow-raising hover:uy-bg-surface-button-secondary-hover hover:uy-border-border-button-secondary-hover hover:uy-shadow-floating active:uy-bg-surface-button-secondary-pressed active:uy-border-border-button-secondary-pressed disabled:uy-bg-surface-button-secondary-disabled disabled:uy-border-border-button-secondary-disabled disabled:uy-text-content-button-secondary-disabled uy-py-[11.54px] Link uy-w-fit" class="ButtonLink uy-cursor-pointer uy-transition-all uy-duration-200 uy-items-center uy-justify-center uy-gap-100 disabled:uy-cursor-default buttonFont uy-font-body uy-font-medium uy-text-100 uy-leading-150 secondary uy-flex uy-rounded-150 uy-px-200 uy-border uy-text-center uy-bg-surface-button-secondary uy-border-border-button-secondary uy-text-content-button-secondary uy-shadow-raising hover:uy-bg-surface-button-secondary-hover hover:uy-border-border-button-secondary-hover hover:uy-shadow-floating active:uy-bg-surface-button-secondary-pressed active:uy-border-border-button-secondary-pressed disabled:uy-bg-surface-button-secondary-disabled disabled:uy-border-border-button-secondary-disabled disabled:uy-text-content-button-secondary-disabled uy-py-[11.54px] Link uy-w-fit"> <span class="uy-flex-1">Ver integraciones disponibles</span>  </a> <div class="uy-mt-300 md:uy-hidden"> <img src="https://www.datocms-assets.com/50397/1723123245-phone.svg" alt="Logos de empresas integradas con PayFit" loading="lazy" decoding="async" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="374" height="172" class="Img uy-size-full uy-object-cover"> </div> </div> <div class="uy-lg-300 -uy-mr-500 uy-hidden uy-object-cover md:uy-block"> <img src="https://www.datocms-assets.com/50397/1723123558-group-15516.svg" alt="Logos de empresas integradas con PayFit (Qonto, Rzilient, Ravio, Payflow)" loading="lazy" decoding="async" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="363" height="410" class="Img uy-size-full uy-object-cover"> </div> </div>  </section> </div><div data-section="FeaturesListRecord"> <section class="Section uy-max-w-screen">  <div class="FeaturesListRecord"> <div class="uy-flex uy-flex-col uy-items-center uy-gap-300"> <div class="BlockHeader uy-flex uy-max-w-[819px] uy-flex-col uy-gap-100 uy-mx-auto uy-text-center"><h2 class="title2Font uy-font-title uy-font-semibold uy-text-1000 md:uy-text-1200 uy-leading-125 uy-text-content-heading">Nóminas, gestión de vacaciones y ausencias, fichaje, gastos  y evaluaciones de desempeño. ¡Nos encargamos de todo ! </h2><p class="uy-text-content-text">Somos una asesoría laboral 360<sup>º</sup>. ¿Por qué no centralizar también tus procesos administrativos y de RRHH ? </p></div>  </div> <div class="uy-mt-600 uy-grid uy-grid-cols-12 uy-gap-250"> <div class="uy-col-span-12 md:uy-col-span-7 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Automatización de la nómina</h3> <p>Ausencias y vacaciones, bonificaciones, gastos profesionales : todas las variables impactan en tiempo real las nóminas de tus empleados.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png" alt="Ilustración de una nómina generada con el software de nóminas" sizes="(min-width: 1360px) 720px, (min-width: 780px) 53.75vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1723041034-automatizacion-nomina.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="2034" height="1500" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-5 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Vacaciones y ausencias</h3> <p>Los managers podrán aprobar las ausencias y vacaciones de su equipo en un solo clic, e impactarán en la nómina en tiempo real.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png" alt="Ilustración de la application de gestión de vacaciones y ausencias del software de nóminas" sizes="(min-width: 1360px) 508px, (min-width: 780px) 38.39vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1723040953-vacaciones-y-ausencias.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="1512" height="1500" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-5 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Control horario y fichaje</h3> <p>Registra fácilmente la jornada laboral de tus trabajadores, garantizando el cumplimiento de las obligaciones legales. </p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1723449331-tracking-2x.png" alt="Ilustración de la funcionalidad de control horario y de fichaje del software de nóminas" sizes="(min-width: 1360px) 508px, (min-width: 780px) 38.39vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1723449331-tracking-2x.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1723449331-tracking-2x.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1723449331-tracking-2x.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1723449331-tracking-2x.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1723449331-tracking-2x.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1723449331-tracking-2x.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="2016" height="2000" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-7 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Onboarding</h3> <p>Configura tu cuenta fácilmente completando la información necesaria sobre tu empresa, asegurando el cumplimiento de las normativas de manera rápida y eficiente.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png" alt sizes="(min-width: 1360px) 720px, (min-width: 780px) 53.75vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1746609981-language-es-background-false-1.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="606" height="500" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-7 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Gastos profesionales</h3> <p>Con PayFit, tus empleados suben los tickets directamente en la plataforma y tú los gestionas eficientemente, reflejando los cambios en la nómina en tiempo real.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png" alt sizes="(min-width: 1360px) 720px, (min-width: 780px) 53.75vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1734626630-gastos-profesionales.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="2034" height="1410" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-5 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">PayFit Copilot, tu asistente virtual</h3> <p>Nuestro asistente está diseñado para proporcionarte respuestas rápidas y precisas, ayudándote a resolver todas las dudas que te surjan.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1734626652-copilotes.png" alt sizes="(min-width: 1360px) 508px, (min-width: 780px) 38.39vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1734626652-copilotes.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1734626652-copilotes.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1734626652-copilotes.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1734626652-copilotes.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1734626652-copilotes.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1734626652-copilotes.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="1512" height="1410" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-5 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Evaluación y seguimiento</h3> <p>Refuerza la comunicación y la cohesión de tus equipos de trabajo con el módulo 1 : 1 y de seguimiento de objetivos, creados para fortalecer la comunicación con tus empleados, incentivar su motivación y mejorar su productividad.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png" alt sizes="(min-width: 1360px) 508px, (min-width: 780px) 38.39vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1734626556-evaluacion-y-seguimiento.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="3606" height="2040" class="Img"> </div> </div><div class="uy-col-span-12 md:uy-col-span-7 uy-rounded-300 uy-bg-surface-background-grayLight uy-flex uy-w-full uy-flex-col uy-justify-between"> <div class="uy-p-400 md:uy-p-600"> <h3 class="uy-text-content-heading title3Font uy-font-title uy-font-semibold uy-text-600 md:uy-text-800 uy-leading-125">Generación automática de documentos</h3> <p>¿No tienes tiempo para solicitar un documento ? ¿Tu gestoría tarda mucho ? Con nuestra biblioteca, genera los documentos legales y de recursos humanos que necesites y envíalos a firmar en menos de cinco minutos.</p> </div> <div class="uy-aspect-spotMedium uy-w-full uy-relative uy-overflow-hidden uy-rounded-b-[28px]"> <img src="https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png" alt sizes="(min-width: 1360px) 720px, (min-width: 780px) 53.75vw, calc(100vw - 32px)" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1747059728-language-es-background-false-2.png?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="605" height="500" class="Img"> </div> </div> </div> </div>  </section> </div><div data-section="VideoModuleRecord"> <section class="Section uy-max-w-screen">  <div class="VideoModuleRecord uy-flex uy-flex-col uy-gap-[40px] [&_.VideoModalOverlay]:uy-hidden"> <div class="uy-mx-auto uy-flex uy-max-w-[800px] uy-flex-col uy-gap-100"> <h2 class="title2Font uy-font-title uy-font-semibold uy-text-1000 md:uy-text-1200 uy-leading-125 uy-text-center uy-text-content-heading"> PayFit vs. Gestorías: ¿Qué opción impulsa mejor tu PYME? </h2> <p class="uy-text-center">Con PayFit, gestionar nóminas y RRHH en PYMEs es más fácil y eficiente. Automatiza procesos, elimina dependencias y mejora el control con actualizaciones en tiempo real. ¡Apuesta por la digitalización con PayFit y lleva tu PYME al siguiente nivel!</p> </div> <astro-island uid="bAhco" prefix="r541" component-url="/_astro/Modal.DtnGlonB.js" component-export="Modal" renderer-url="/_astro/client.6yfSuQ0T.js" props="{&quot;tabIndex&quot;:[0,0],&quot;className&quot;:[0,&quot;uy-w-full uy-rounded-200&quot;],&quot;locale&quot;:[0,&quot;es&quot;]}" ssr client="visible" opts="{&quot;name&quot;:&quot;Modal&quot;,&quot;value&quot;:true}" await-children><div class="Modal uy-h-full uy-cursor-pointer uy-w-full uy-rounded-200" role="button" tabindex="0"><astro-slot name="button"><div role="button" tabindex="0" class="VideoModalWrapper uy-relative uy-overflow-hidden uy-rounded-200 uy-group uy-flex uy-items-center uy-justify-center uy-h-full uy-cursor-pointer uy-w-full"> <img src="https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp" alt sizes="(min-width: 1360px) 1250px, calc(100vw - 34px)" slot="thumbnail" loading="lazy" decoding="async" srcset="https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp?w=328&dpr=1&q=90&auto=format&fit=max 328w, https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp?w=768&dpr=1&q=90&auto=format&fit=max 768w, https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp?w=1024&dpr=1&q=90&auto=format&fit=max 1024w, https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp?w=1248&dpr=1&q=90&auto=format&fit=max 1248w, https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp?w=1970&dpr=1&q=90&auto=format&fit=max 1970w, https://www.datocms-assets.com/50397/1738684871-maxresdefault-14.webp?w=2496&dpr=1&q=90&auto=format&fit=max 2496w" onerror="this.classList.add('uy-invisible')" fetchpriority="auto" width="1280" height="720" class="Img uy-h-full uy-w-full uy-object-cover"> <div class="VideoModalOverlay uy-absolute uy-h-full uy-w-full uy-bg-grayscale-L12/50"></div>  <div class="uy-a