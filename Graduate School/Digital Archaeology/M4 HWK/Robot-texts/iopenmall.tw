<script>
    function scart_num_refresh()
    {
        var data;
        if (csrf_key && csrf_val) {
            data = {
                myAct:"getCartNumber",
                [csrf_key]: csrf_val
            };
        } else {
            data = {
                myAct:"getCartNumber",
                '_token': 'c38c38683a5920244950ae500497242c78fe9691383000e21090b28e555ba617b02649081aafdf559b3a182c04b1ca399f6637109bf303863cba4c75f29e31f0'
            };
        }

        $.ajax({
            url: "/iopen/api/api.shopping_cart.php",
            type: "POST",
            dataType: "json",
            data: data,
            success: function(Jdata){
                if( Jdata.error == 'C00' ){
                    var count = 0;
                    $.each(Jdata.content, function(key, value) {
                        count = count + parseInt(value['scar_count']);
                    });
                    if (count > 0) {
                        $('#Cart_Total').text(count);
                        $('#Car_Count').text(count).show();
                    } else {
                        $('#Cart_Total').text(0);
                        $('#Car_Count').text(count).hide();
                    }
                }
            }
        });
    }
    if ('' == '' || '' == 'index') {
        scart_num_refresh();
    }

    function removeScarByWeb(web_byeurl) {
        $.ajax({
            url: "/iopen/api/api.shopping_cart.php",
            type: "POST",
            dataType: "json",
            data: {
                myAct:"removeScarByWeb",
                web_byeurl:web_byeurl,
                [csrf_key]: csrf_val
            },
			success: function(Jdata){
				if( Jdata.error == 'C00' ){
                    if (typeof(it340_scart_refresh) == 'function') {
                        it340_scart_refresh();
                    } else {
                        top_refresh();
                    }
				}
			}
        });
    }

    //追蹤愛心
    function setProdTrace() {
        if (mem_uid) {
            var strProdUid = '';
            $(".taisuan_btn_like").each(function(){
                var prod_uid = $(this).attr("prod_uid");
                if (prod_uid) {
                    if (strProdUid)
                        strProdUid += ',';
                    strProdUid += prod_uid;
                }
            });

            if (csrf_key && csrf_val) {
                var data = {
                    strProdUid: strProdUid,
                    myAct: "get_trace",
                    mem_uid: mem_uid,
                    [csrf_key]: csrf_val
                };
            } else {
                var data = {
                    strProdUid: strProdUid,
                    myAct: "get_trace",
                    mem_uid: mem_uid,
                    '_token': 'c38c38683a5920244950ae500497242c78fe9691383000e21090b28e555ba617b02649081aafdf559b3a182c04b1ca399f6637109bf303863cba4c75f29e31f0'
                };
            }
            $.ajax({
                url: "https://mall.iopenmall.tw/iopen/api/api.product_trace_list.php",
                type: "POST",
                dataType: "json",
                data: data,
                success: function(r){
                    // console.log(r)
                    if (r.trace.length > 0) {
                        for (var i = 0; i < r.trace.length; i++) {
                            var trace = r.trace[i];
                            $(".trace_"+trace.prod_uid).addClass('active');
                        }
                    }
                }
            });
        }
    }
    if ('' != '1' && '0' != '1') setProdTrace();
</script>

