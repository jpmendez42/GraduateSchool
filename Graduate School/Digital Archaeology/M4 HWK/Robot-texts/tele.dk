e":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion ASMTP: Mailen blev afvist","title":"ASMTP: Mailen blev afvist","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Mailen blev afvist af en filterregel. ","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSpørgsmål vedr. denne fejlmeddelelse kan rettes til postmaster@mail.dk","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Server:\n","nodeType":"text"},{"data":{},"marks":[],"value":"asmtp","nodeType":"text"}],"nodeType":"paragraph"}],"nodeType":"document"}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"7dqRFvGMXuZvpcM6fEhT2O","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion ASMTP: Mailen har rejst lang vej","title":"ASMTP: Mailen har rejst lang vej","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailen har rejst lang vej uden at være kommet frem, og mailserveren har givet op.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Prøv at sende mailen igen (vent eventuelt 1-2 dage).","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Typiske fejl:","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"- mailen kører i ring, måske fordi modtager videresender sine mail fra en postkasse og tilbage igen.\n- mailen har stået i kø, og mailen har været forsøgt flere gange.\n- modtagers posthuset er opsat forkert og kan ikke modtage post.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"4wCIPmXwYMEOj7Mpi2NM7H","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion - ASMTP: Mailen kører i ring","title":"ASMTP: Mailen kører i ring","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Mailen kører i ring.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Det er ikke muligt at levere mailen, da modtager sandsynligvis videresender sine mails til en anden postkasse og derfra videresender mailen tilbage igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Forsøg at kontakt modtager på anden vis.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"WzmGEDCMYyCYlDIYElbMr","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion - ASMTP: Midlertidig begrænsning (mail/ip)","title":"ASMTP: Midlertidig begrænsning (mail/ip)","body":{"nodeType":"document","data":{},"content":[{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Fejl:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"Der er forsøgt afsendt for mange mails fra din ip-adresse indenfor de sidste time.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Løsning:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"1. Fjern mails fra udbakken, som ikke er sendt.\n2. Luk dit postprogram.\n3. Vent 60 minutter.\n4. Prøv at sende din mail igen.","marks":[],"data":{}}]},{"nodeType":"paragraph","data":{},"content":[{"nodeType":"text","value":"Server:\n","marks":[{"type":"bold"}],"data":{}},{"nodeType":"text","value":"asmtp","marks":[],"data":{}}]}]}}}},"content":[]},{"nodeType":"embedded-entry-block","data":{"target":{"metadata":null,"sys":{"id":"6C9oR071CX0SgAgNxzM7co","contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"componentAccordion"}}},"fields":{"internalName":"Mail - Basic Page - Accordion - ASMTP: Midlertidig begrænsning (mail/mf)","title":"ASMTP: Midlertidig begrænsning (mail/mf)","body":{"data":{},"content":[{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Fejl:\n","nodeType":"text"},{"data":{},"marks":[],"value":"Der er forsøgt afsendt for mange mails med samme afsender mailadresse/bruger-id indenfor den sidste time.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Løsning:\n","nodeType":"text"},{"data":{},"marks":[],"value":"1. Fjern mails fra udbakken, som ikke er sendt.\n2. Luk dit postprogram.\n3. Vent 60 minutter.\n4. Prøv at sende din mail igen.","nodeType":"text"}],"nodeType":"paragraph"},{"data":{},"content":[{"data":{},"marks":[{"type":"bold"}],"value":"Spørgsmål:","nodeType":"text"},{"data":{},"marks":[],"value":"\nSpørgsmål vedr. denne fejlmeddelelse kan rettes til ","nodeType":"text"},{"data":{"uri":"mailto:postmaster@abuse.mail.dk"},"conten