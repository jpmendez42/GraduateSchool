  <script type="rocketlazyloadscript">
    const fluxFrame = document.querySelector('.quixoticFluxFrame');
const zestTrack = document.querySelector('.zestfulTrack');
const leftArrow = document.querySelector('.lucidArrow--left');
const rightArrow = document.querySelector('.lucidArrow--right');
let isDragging = false;
let startPos = 0;
let currentTranslate = 0;
let prevTranslate = 0;
let animationID = 0;
let currentIndex = 0;

const cardElements = document.querySelectorAll('.whimsicalCard');
const cardWidth = cardElements[0].offsetWidth + 20; // Including gap
const totalCards = cardElements.length;
const visibleCards = window.innerWidth <= 768 ? 2 : 4;
const maxIndex = totalCards - visibleCards;

const images = document.querySelectorAll('.vividImagery');
let loadedImages = 0;

function preloadImages() {
  images.forEach((img) => {
    const image = new Image();
    image.src = img.src;
    image.onload = () => {
      loadedImages++;
      if (loadedImages === images.length) {
        // Enable slider functionality only after all images are loaded
        fluxFrame.addEventListener('mousedown', startDrag);
        fluxFrame.addEventListener('touchstart', startDrag);
        fluxFrame.addEventListener('mousemove', drag);
        fluxFrame.addEventListener('touchmove', drag);
        fluxFrame.addEventListener('mouseup', endDrag);
        fluxFrame.addEventListener('touchend', endDrag);
        fluxFrame.addEventListener('mouseleave', endDrag);
        leftArrow.addEventListener('click', scrollLeft);
        rightArrow.addEventListener('click', scrollRight);
        window.addEventListener('resize', handleResize);
        updateArrows();
      }
    };
  });
}

function updateArrows() {
  leftArrow.disabled = currentIndex === 0;
  rightArrow.disabled = currentIndex >= maxIndex;
}

function setSliderPosition() {
  zestTrack.style.transform = `translateX(${currentTranslate}px)`;
  updateArrows();
}

function animation() {
  setSliderPosition();
  if (isDragging) requestAnimationFrame(animation);
}

function startDrag(event) {
  isDragging = true;
  startPos = (event.type === 'touchstart') ? event.touches[0].clientX : event.clientX;
  animationID = requestAnimationFrame(animation);
  zestTrack.style.transition = 'none';
}

function drag(event) {
  if (isDragging) {
    const currentPosition = (event.type === 'touchmove') ? event.touches[0].clientX : event.clientX;
    const diff = currentPosition - startPos;
    currentTranslate = prevTranslate + diff;
  }
}

function endDrag() {
  isDragging = false;
  cancelAnimationFrame(animationID);

  const movedBy = currentTranslate - prevTranslate;
  currentIndex -= Math.round(movedBy / cardWidth);
  currentIndex = Math.max(0, Math.min(currentIndex, maxIndex));

  currentTranslate = -currentIndex * cardWidth;
  prevTranslate = currentTranslate;
  zestTrack.style.transition = 'transform 0.5s ease';
  setSliderPosition();
}

function scrollLeft() {
  if (currentIndex > 0) {
    currentIndex--;
    currentTranslate = -currentIndex * cardWidth;
    prevTranslate = currentTranslate;
    zestTrack.style.transition = 'transform 0.5s ease';
    setSliderPosition();
  }
}

function scrollRight() {
  if (currentIndex < maxIndex) {
    currentIndex++;
    currentTranslate = -currentIndex * cardWidth;
    prevTranslate = currentTranslate;
    zestTrack.style.transition = 'transform 0.5s ease';
    setSliderPosition();
  }
}

function handleResize() {
  const newVisibleCards = window.innerWidth <= 768 ? 2 : 4;
  if (newVisibleCards !== visibleCards) {
    location.reload(); // Simple way to reset layout
  }
}

// Call preloadImages to start loading images
preloadImages();
  </script>


