<script>
function chatDialogOpen(_input = null) {
    //  chat-widget__button--has-unread
    const chatContainer = document.querySelector('#chatContainer');
    const chatClose = document.querySelector('#chatClose');
    if (chatContainer.classList.contains("chat-widget__container--open")) {
        
    } else {
        chatContainer.classList.add("chat-widget__container--open");
        chatClose.style.display = 'block';
    }
    
    const chatWidgetIframe = document.getElementById("chatWidgetIframe");
    chatWidgetIframe.sandbox.remove('allow-presentation');
    chatWidgetIframe.style.display = 'block';

    // 2. 創建一個 form 元素
    const form = document.createElement('form');

    // 3. 設置 form 元素的屬性
    form.method = 'post';
    form.action = '/iopen/api/api.bbc_instant_messaging.php';
    form.target = 'chatWidgetIframe'; // 使用 iframe 的 id 作為 target
    /**/
    // 4. 將 FormData 中的數據添加到 form 中
    if ((chatDialogOpen?.isProxy && chatDialogOpen?.params instanceof FormData) || 
        (!chatDialogOpen?.isProxy && _input instanceof FormData)) {
        for (const [key, value] of (chatDialogOpen?.isProxy ? chatDialogOpen?.params : _input).entries()) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = value;
            form.appendChild(input);
        }
    }
    
    // 5. 將 form 元素添加到文檔中
    chatContainer.appendChild(form);

    // 6. 提交 form 元素
    form.submit();
    
    // 7. （可選）移除 form 元素
    chatContainer.removeChild(form);

    // 8. 添加 allow-downloads 到 iframe 的 sandbox 屬性
    if (chatWidgetIframe.sandbox.value.includes('allow-scripts')) {
        chatWidgetIframe.sandbox.add('allow-downloads');
    }
}

function chatDialogClose() {
    const chatContainer = document.querySelector('#chatContainer');
    const chatClose = document.querySelector('#chatClose');
    const chatWidgetIframe = document.getElementById("chatWidgetIframe");
    chatContainer.classList.remove("chat-widget__container--open");
    chatClose.style.display = 'none';
    chatWidgetIframe.sandbox.remove('allow-downloads');
    chatWidgetIframe.src = 'about:blank';
    chatWidgetIframe.removeAttribute('src');
}

function chatWidgetLoginGuidanceShow() {
    const chatWidgetLoginGuidance = document.getElementById("chatWidgetLoginGuidance");
    const chatWidgetIframe = document.getElementById("chatWidgetIframe");
    chatWidgetIframe.sandbox.remove('allow-downloads');
    chatWidgetIframe.style.display = 'none';
    chatWidgetIframe.src = 'about:blank';
    chatWidgetLoginGuidance.style.display = 'block';
    chatWidgetIframe.removeAttribute('src');
}

function chatDialogCloseFromIframe(message) {
    alert(message);
    chatDialogClose();
}
/**/
/**/
window.addEventListener('message', function (event) {
    console.log(event);
    if (event.origin !== 'https://chat.iopenmall.tw') {
        return;
    }
    const data = event.data;
    if (data && data.type === 'pic-open-url' && data.url) {
        window.open(data.url, '_blank');
    }
});
