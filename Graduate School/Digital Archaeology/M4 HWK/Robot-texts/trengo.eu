Weglot.on('initialized', () => {
  	if (window.location.href.indexOf("/hi/") === -1) {
    let currentLang = Weglot.getAvailableLanguages();
        if (currentLang === 'nl') {
            setTimeout(function() {
                loadWidget('r36XOOrBO7oDvbX');
