  class DraftModeToggler extends HTMLElement {
    constructor() {
      super();

      const exitButton = this.querySelector('.exit-button');
      if (exitButton) {
        exitButton.addEventListener('click', () => this.handleClick());
      }
    }

    async handleClick() {
      // In dev environment, just hide the banner because draft content is always enabled
      if (ENVIRONMENT === 'dev') {
        this.remove();
        return;
      }

      const response = await fetch('/api/draft-mode/disable/');

      if (!response.ok) {
        alert('Could not exit draft mode');
        return;
      }

      document.location.reload();
    }
  }

  customElements.define('draft-mode-toggler', DraftModeToggler);
})();</script>  <script>
        window.axeptioSettings = {
