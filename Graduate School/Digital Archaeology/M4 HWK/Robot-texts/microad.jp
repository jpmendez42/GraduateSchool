bb%e5%a3%87%ef%bc%9a8%e6%9c%8823%e6%97%a5%e9%96%8b%e5%82%ac%e3%80%91ir-robotics%e4%b8%bb%e5%82%ac","type":"news","title":"\u3010IR\u30bb\u30df\u30ca\u30fc\u767b\u58c7\uff1a8\u670823\u65e5\u958b\u50ac\u3011IR Robotics\u4e3b\u50ac\uff1a\u300c\u7b2c3\u56de \u500b\u4eba\u6295\u8cc7\u5bb6\u30b5\u30df\u30c3\u30c8\u300d\u3078\u767b\u58c7","meta":{},"body":{"title_ja":"\u3010IR\u30bb\u30df\u30ca\u30fc\u767b\u58c7\uff1a8\u670823\u65e5\u958b\u50ac\u3011IR Robotics\u4e3b\u50ac\uff1a\u300c\u7b2c3\u56de \u500b\u4eba\u6295\u8cc7\u5bb6\u30b5\u30df\u30c3\u30c8\u300d\u3078\u767b\u58c7","title_en":"","type":"seminar","contents":[{"acf_fc_layout":"text","ja":"\u3000\u682a\u5f0f\u4f1a\u793e\u30de\u30a4\u30af\u30ed\u30a2\u30c9\uff08\u672c\u793e\uff1a\u6771\u4eac\u90fd\u6e0b\u8c37\u533a\u3001\u4ee3\u8868\u53d6\u7de0\u5f79 \u793e\u9577\u57f7\u884c\u5f79\u54e1\uff1a\u6e21\u8fba\u5065\u592a\u90ce\uff09\u306f\u3001\u500b\u4eba\u6295\u8cc7\u5bb6\u306e\u7686\u69d8\u306b\u5411\u3051\u305fIR\u6d3b\u52d5\u306e\u4e00\u74b0\u3068\u3057\u3066\u30012025\u5e748\u670823\u65e5\uff08\u571f\uff09\u306b\u3001\u682a\u5f0f\u4f1a\u793eIR Robotics\uff08\u672c\u793e\uff1a\u6771\u4eac\u90fd\u5343\u4ee3\u7530\u533a\u3001\u4ee3\u8868\u53d6\u7de0\u5f79\uff1a\u91d1\u6210\u67f1\uff09\u304c\u4e3b\u50ac\u3059\u308b\u3001\u500b\u4eba\u6295\u8cc7\u5bb6\u5411\u3051\u30a4\u30d9\u30f3\u30c8\u300c\u500b\u4eba\u6295\u8cc7\u5bb6\u30b5\u30df\u30c3\u30c8\u300d\u3078\u767b\u58c7\u3044\u305f\u3057\u307e\u3059\u3002","en":""},{"acf_fc_layout":"img","data":"\/media\/2025\/08\/67028c35d36e1a5c8cd1d0cea9fc66c0.jpg","caption_ja":"","caption_en":""},{"acf_fc_layout":"text","ja":"<b>\u25a0\u8a73\u7d30\u30fb\u304a\u7533\u8fbc\u307f\u306f\u3053\u3061\u3089<\/b>\uff1a\u3000<a href=\"https:\/\/www.irtv-kojintoushika-event.com\/8%E6%9C%8823%E6%97%A5%E9%96%8B%E5%82%AC\" target=\"_blank\">https:\/\/www.irtv-kojintoushika-event.com\/8%E6%9C%8823%E6%97%A5%E9%96%8B%E5%82%AC<\/a><br \/>\r\n\u203b\u4f1a\u5834: 100\u540d\/ \u30aa\u30f3\u30e9\u30a4\u30f3: 100\u540d\uff08\u6700\u5927\u4eba\u6570\uff09<br \/>\r\n<br \/>\r\n<b>\uff1c\u958b\u50ac\u6982\u8981\uff1e<\/b><br \/>\r\n<br \/>\r\n<b>\u25a0\u958b\u50ac\u65e5\u6642 <\/b>\uff1a2025\u5e74 8\u670823\u65e5(\u571f) \u200b10:00 \uff5e 19:00(\u9014\u4e2d\u5165\u9000\u5ba4\u53ef)<br \/>\r\n\u203b\u30de\u30a4\u30af\u30ed\u30a2\u30c9\u306f\u300116:30 \uff5e 17:20 \u306b\u767b\u58c7\u3057\u307e\u3059\u3002<br \/>\r\n<b>\u25a0\u4f1a\u5834\u3000\u3000 <\/b>\uff1a\u4f1a\u5834\uff08\u8d64\u5742\u30ac\u30fc\u30c7\u30f3\u30b7\u30c6\u30a3\uff09\uff06\u30aa\u30f3\u30e9\u30a4\u30f3\u914d\u4fe1(\u30cf\u30a4\u30d6\u30ea\u30c3\u30c9\u5f62\u5f0f)<br \/>\r\n\u203b\u4f1a\u5834: 100\u540d\/ \u30aa\u30f3\u30e9\u30a4\u30f3: 100\u540d\uff08\u6700\u5927\u4eba\u6570\uff09<br \/>\r\n<b>\u25a0\u53c2\u52a0\u8cbb\u3000 <\/b>\uff1a\u4e8b\u524d\u7533\u8fbc\u5236\uff0f\u7121\u6599<br \/>\r\n<b>\u25a0\u4e3b\u50ac\u3000\u3000 <\/b>\uff1a\u682a\u5f0f\u4f1a\u793eIR Robotics<br \/>\r\n<br \/>\r\n<b>\uff1c\u500b\u4eba\u6295\u8cc7\u5bb6\u30b5\u30df\u30c3\u30c8\u3068\u306f\uff1f\uff1e<\/b><br \/>\r\n<br \/>\r\n\u300c\u500b\u4eba\u6295\u8cc7\u5bb6\u30b5\u30df\u30c3\u30c8\u300d\u306f\u3001\u6295\u8cc7\u5bb6\u3068\u4e0a\u5834\u4f01\u696d\u306e\u201d\u5bfe\u8a71\u201d\u3092\u91cd\u8996\u3057\u305f\u500b\u4eba\u6295\u8cc7\u5bb6\u5411\u3051IR\u30a4\u30d9\u30f3\u30c8\u3067\u3059\u3002<br \/>\r\n\u672c\u30a4\u30d9\u30f3\u30c8\u3067\u306f\u3001\u6ce8\u76ee\u306e\u4e0a\u5834\u4f01\u696d\u306e\u7d4c\u55b6\u8005\u304c\u30d7\u30edMC\u3068\u5bfe\u8ac7\u3057\u3001\u4e8b\u696d\u306e\u6210\u9577\u6226\u7565\u3092\u8a9e\u308b\u8aac\u660e\u4f1a\u3092\u5b9f\u65bd\u3044\u305f\u3057\u307e\u3059\u3002\u6295\u8cc7\u5bb6\u304b\u3089\u306e\u8cea\u554f\u306b\u3082\u4e01\u5be7\u306b\u7b54\u3048\u3001\u4f01\u696d\u7406\u89e3\u3092\u6df1\u3081\u3066\u3044\u305f\u3060\u3051\u307e\u3059\u3002<br \/>\r\n<br \/>\r\n\u3055\u3089\u306b\u3001\u8457\u540d\u6295\u8cc7\u5bb6\u304c\u6295\u8cc7\u624b\u6cd5\u3092\u660e\u304b\u3059\u7279\u5225\u30bb\u30c3\u30b7\u30e7\u30f3\u3092\u958b\u50ac\u3002<br \/>\r\n\u30a4\u30d9\u30f3\u30c8\u5f8c\u534a\u306b\u306f\u3001\u767b\u58c7\u8005\u3084\u4ed6\u306e\u53c2\u52a0\u8005\u3068\u4ea4\u6d41\u3067\u304d\u308b\u6642\u9593\u3082\u3054\u7528\u610f\u3057\u3066\u3044\u307e\u3059\u3002<br \/>\r\n \u76f4\u63a5\u8a71\u3059\u3053\u3068\u3067\u3001\u3088\u308a\u30ea\u30a2\u30eb\u306a\u8996\u70b9\u304c\u5f97\u3089\u308c\u307e\u3059\u3002<br \/>\r\n<br \/>\r\n\u3053\u306e\u6a5f\u4f1a\u306b\u305c\u3072\u3054\u53c2\u52a0\u304f\u3060\u3055\u3044\u3002<br \/>\r\n<br \/>\r\n<b>\uff1c\u30de\u30a4\u30af\u30ed\u30a2\u30c9\uff1a\u767b\u58c7\u60c5\u5831\uff1e<\/b>\u3000<br \/>\r\n<br \/>\r\n<b>\u767b\u58c7\u8005\u3000<\/b>\uff1a\u4ee3\u8868\u53d6\u7de0\u5f79\u3000\u793e\u9577\u57f7\u884c\u5f79\u54e1\u3000\u6e21\u8fba \u5065\u592a\u90ce<br \/>\r\n<b>\u767b\u58c7\u65e5\u6642<\/b>\uff1a8\u670823\u65e5(\u571f)  \u7b2c6\u90e8\uff0f16:30\u301c17:20<br \/>\r\n<br \/>\r\n<b>\uff1c\u4e3b\u50ac\uff1a\u682a\u5f0f\u4f1a\u793eIR Robotics\u306b\u3064\u3044\u3066\uff1e<\/b><br \/>\r\n<br \/>\r\n\u682a\u5f0f\u4f1a\u793eIR Robotics\u306f\u3001\u300c\u6210\u9577\u4f01\u696d\u304c\u3088\u308a\u6210\u9577\u3059\u308b\u305f\u3081\u306e\u30d3\u30b8\u30cd\u30b9\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u306b\u306a\u308b\u300d\u3092\u30d3\u30b8\u30e7\u30f3\u306b\u63b2\u3052\u3001\u4e0a\u5834\u4f01\u696d\u3092\u5bfe\u8c61\u3068\u3057\u305fIR DX\u4e8b\u696d\u3001\u4e0a\u5834\u4f01\u696d\uff0f\u4e0a\u5834\u6e96\u5099\u4e2d\u4f01\u696d\u3092\u5bfe\u8c61\u3068\u3057\u305f\u30a8\u30c7\u30e5\u30b1\u30fc\u30b7\u30e7\u30f3\u4e8b\u696d\u3001\u30cf\u30a4\u30af\u30e9\u30b9\u4eba\u6750\u3068\u4e0a\u5834\u4f01\u696d\uff0f\u4e0a\u5834\u6e96\u5099\u4f01\u696d\u3092\u30de\u30c3\u30c1\u30f3\u30b0\u3059\u308bCxO\u4eba\u6750\u7d39\u4ecb\u4e8b\u696d\u3092\u5c55\u958b\u3057\u3066\u3044\u307e\u3059\u3002<br \/>\r\n<br \/>\r\n<a href=\"https:\/\/ir-robotics.co.jp\/\" target=\"_blank\">https:\/\/ir-robotics.co.jp\/<\/a>\t<br \/>\r\n","en":""}],"links":[{"text_ja":"\u25c6\u500b\u4eba\u6295\u8cc7\u5bb6\u30b5\u30df\u30c3\u30c8\u306b\u95a2\u3059\u308b\u554f\u3044\u5408\u308f\u305b\u3000\u682a\u5f0f\u4f1a\u793eIR Robotics\u3000\u304a\u554f\u3044\u5408\u308f\u305b\u30d5\u30a9\u30fc\u30e0","text_en":"","url_ja":"https:\/\/ir-robotics.co.jp\/contact\/","url_en":""}],"related_company":false,"contact":[{"heading_ja":"\u25c6\u5831\u9053\u95a2\u4fc2\u306b\u95a2\u3059\u308b\u304a\u554f\u3044\u5408\u308f\u305b","heading_en":"","division_ja":"","division_en":"","personnel_ja":"","personnel_en":"","tel_ja":"","tel_en":"","mail":"microad-pr@microad.co.jp"}],"post_ogp_image":false}},{"id":2674,"date":"2025-08-07T13:01:19","slug":"%e5%ad%90%e4%bc%9a%e7%a4%beuncover-truth%e3%80%81%e3%80%90%e6%9b%b8%e7%b1%8d%e8%b2%a9%e5%a3%b2%e9%96%8b%e5%a7%8b%e3%80%91cdp%e3%81%ae%e3%81%a4%e3%81%8f%e3%82%8a%e6%96%b9%ef%bc%9aga4-x-bigquery","type":"news","title":"\u5b50\u4f1a\u793eUNCOVER TRUTH\u3001\u3010\u66f8\u7c4d\u8ca9\u58f2\u958b\u59cb\u3011CDP\u306e\u3064\u304f\u308a\u65b9\uff1aGA4 \u00d7 BigQuery\u306b\u3088\u308b\u9867\u5ba2\u30c7\u30fc\u30bf\u57fa\u76e4 \u69cb\u7bc9\u30fb\u6d3b\u7528\u5b9f\u8df5\u30ac\u30a4\u30c9 \uff0f\u300c\u5c0e\u5165\u3057\u305f\u3060\u3051\u300d\u3067\u7d42\u308f\u3089\u305b\u306a\u3044\u3002\u65bd\u7b56\u306b\u6d3b\u304b\u3059 \u201c\u9867\u5ba2\u30c7\u30fc\u30bf\u57fa\u76e4\u201d \u306e\u3064\u304f\u308a\u65b9","meta":{},"body":{"title_ja":"\u5b50\u4f1a\u793eUNCOVER TRUTH\u3001\u3010\u66f8\u7c4d\u8ca9\u58f2\u958b\u59cb\u3011CDP\u306e\u3064\u304f\u308a\u65b9\uff1aGA4 \u00d7 BigQuery\u306b\u3088\u308b\u9867\u5ba2\u30c7\u30fc\u30bf\u57fa\u76e4 \u69cb\u7bc9\u30fb\u6d3b\u7528\u5b9f\u8df5\u30ac\u30a4\u30c9 \uff0f\u300c\u5c0e\u5165\u3057\u305f\u3060\u3051\u300d\u3067\u7d42\u308f\u3089\u305b\u306a\u3044\u3002\u65bd\u7b56\u306b\u6d3b\u304b\u3059 \u201c\u9867\u5ba2\u30c7\u30fc\u30bf\u57fa\u76e4\u201d \u306e\u3064\u304f\u308a\u65b9","title_en":"","type":"press","contents":[{"acf_fc_layout":"text","ja":"\u3000\u682a\u5f0f\u4f1a\u793e\u30de\u30a4\u30af\u30ed\u30a2\u30c9\uff08\u672c\u793e\uff1a\u6771\u4eac\u90fd\u6e0b\u8c37\u533a\u3001\u4ee3\u8868\u53d6\u7de0\u5f79 \u793e\u9577\u57f7\u884c\u5f79\u54e1\uff1a\u6e21\u8fba\u5065\u592a\u90ce\uff09\u306e\u5b50\u4f1a\u793e\u3001\u682a\u5f0f\u4f1a\u793eUNCOVER TRUTH\uff08\u6240\u5728\u5730\uff1a\u6771\u4eac\u90fd\u6e0b\u8c37\u533a\u3001\u4ee3\u8868\u53d6\u7de0\u5f79\uff1a\u77f3\u5ddd \u656c\u4e09\u3001\u4ee5\u4e0b UNCOVER TRUTH\uff09\u306f\u3001\u66f8\u7c4d\u300eCDP\u306e\u3064\u304f\u308a\u65b9\uff1aGA4 \u00d7 BigQuery\u306b\u3088\u308b\u9867\u5ba2\u30c7\u30fc\u30bf\u57fa\u76e4 \u69cb\u7bc9\u30fb\u6d3b\u7528\u5b9f\u8df5\u30ac\u30a4\u30c9 \u300f\u3092\u30012025\u5e748\u67087\u65e5\u306b\u30a4\u30f3\u30d7\u30ec\u30b9\u793e\u3088\u308a\u8ca9\u58f2\u3092\u958b\u59cb\u3044\u305f\u3057\u307e\u3059\u3002<br \/>\r\n<br \/>\r\n\u3000\u540c\u793eCAO\u5c0f\u5ddd\u5353\u3001COO\u5c0f\u7551\u967d\u4e00\u3001\u30a2\u30ca\u30ea\u30b9\u30c8\u30c1\u30fc\u30e0\u30ea\u30fc\u30c0\u30fc\u6e21\u908a\u4f91\u7d00\u306b\u52a0\u3048\u3001Option\u5408\u540c\u4f1a\u793e\u306e\u4ee3\u8868\u793e\u54e1\u3067\u3042\u308b\u67f3\u4e95\u9686\u9053\u6c0f\u3092\u8fce\u3048\u305f\u5171\u8457\u3068\u306a\u308a\u307e\u3059\u3002<br \/>\r\n","en":""},{"acf_fc_layout":"img","data":"\/media\/2025\/08\/bd80ca4805682578527cf80098ee18b7.jpg","caption_ja":"","caption_en":""},{"acf_fc_layout":"text","ja":"<b>\u25a0\u5185\u5bb9<\/b><br \/>\r\n\u3000\u672c\u66f8\u306f\u3001GA4\u3067\u53d6\u5f97\u3057\u305f\u30a6\u30a7\u30d6\u30fb\u30a2\u30d7\u30ea\u306e\u30c7\u30fc\u30bf\u3092BigQuery\u3067\u7d71\u5408\u30fb\u6d3b\u7528\u3059\u308b\u65b9\u6cd5\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002\u540d\u5bc4\u305b\u51e6\u7406\u3084\u884c\u52d5\u5c65\u6b74\u306e\u7d71\u5408\u3068\u3044\u3063\u305f\u6280\u8853\u7684\u306a\u30ed\u30b8\u30c3\u30af\u304b\u3089\u3001\u4e2d\u5c0f\u4f01\u696d\u3067\u3082\u5c0e\u5165\u53ef\u80fd\u306a\u30b9\u30e2\u30fc\u30eb\u30b9\u30bf\u30fc\u30c8\u306e\u624b\u6cd5\u3001\u30d1\u30fc\u30bd\u30ca\u30e9\u30a4\u30ba\u65bd\u7b56\u3001\u7d44\u7e54\u3065\u304f\u308a\u307e\u3067\u3001\u30d3\u30b8\u30cd\u30b9\u306e\u6210\u679c\u306b\u3064\u306a\u304c\u308b\u30ce\u30a6\u30cf\u30a6\u3092\u7db2\u7f85\u3057\u3066\u3044\u307e\u3059\u3002GA4\u306e\u30c7\u30fc\u30bf\u6d3b\u7528\u3084\u3001\u30af\u30e9\u30a6\u30c9CDP\u306e\u69cb\u7bc9\u3092\u76ee\u6307\u3059\u65b9\u306b\u3068\u3063\u3066\u6700\u9069\u306a\u4e00\u518a\u3067\u3059\u3002<br \/>\r\n<br \/>\r\n<b>\u25a0\u8457\u8005<\/b><br \/>\r\n\u3000UNCOVERTRUTH CAO\u306e\u5c0f\u5ddd\u5353\u3092\u306f\u3058\u3081\u3001\u53d6\u7de0\u5f79COO \u5c0f\u7551\u967d\u4e00\u3001\u30b3\u30f3\u30b5\u30eb\u30c6\u30a3\u30f3\u30b0\u30b0\u30eb\u30fc\u30d7 \u30a2\u30ca\u30ea\u30b9\u30c8\u30c1\u30fc\u30e0 \u30ea\u30fc\u30c0\u30fc \u6e21\u908a\u4f91\u7d00\u3001Option\u5408\u540c\u4f1a\u793e\u306e\u30c7\u30fc\u30bf\u6d3b\u7528\u306e\u5c02\u9580\u5bb6\u3067\u3042\u308b\u67f3\u4e95\u9686\u9053\u6c0f\u304c\u57f7\u7b46\u3057\u3066\u3044\u307e\u3059\u3002\u8c4a\u5bcc\u306a\u73fe\u5834\u7d4c\u9a13\u306b\u57fa\u3065\u304f\u77e5\u898b\u3092\u7d50\u96c6\u3057\u3001\u5b9f\u52d9\u3067\u672c\u5f53\u306b\u5f79\u7acb\u3064CDP\u69cb\u7bc9\u306e\u65b9\u6cd5\u8ad6\u3092\u4f53\u7cfb\u7684\u306b\u89e3\u8aac\u3057\u3066\u3044\u307e\u3059\u3002<br \/>\r\n<br \/>\r\n<b>\u25a0\u3053\u306e\u3088\u3046\u306a\u65b9\u306b\u304a\u85a6\u3081<\/b><br \/>\r\n\u30fbGA4\u3084BigQuery\u306e\u30c7\u30fc\u30bf\u6d3b\u7528\u306b\u624b\u3054\u305f\u3048\u3092\u611f\u3058\u3089\u308c\u3066\u3044\u306a\u3044\u65b9<br \/>\r\n\u30fbCDP\u69cb\u7bc9\u306b\u95a2\u5fc3\u306f\u3042\u308b\u304c\u3001\u6280\u8853\u7684\u30fb\u4e88\u7b97\u7684\u30cf\u30fc\u30c9\u30eb\u304c\u9ad8\u3044\u3068\u611f\u3058\u3066\u3044\u308b\u65b9<br \/>\r\n\u30fb\u9867\u5ba2\u884c\u52d5\u5c65\u6b74\u3084\u5c5e\u6027\u30c7\u30fc\u30bf\u3092\u30de\u30fc\u30b1\u30c6\u30a3\u30f3\u30b0\u65bd\u7b56\u306b\u6d3b\u304b\u3057\u305f\u3044\u65b9<br \/>\r\n\u30fbDX\u3084\u30c7\u30b8\u30bf\u30eb\u30de\u30fc\u30b1\u30c6\u30a3\u30f3\u30b0\u63a8\u9032\u3092\u62c5\u5f53\u3059\u308b\u90e8\u30fb\u8ab2\u9577\u301c\u5b9f\u52d9\u62c5\u5f53\u30ec\u30d9\u30eb\u306e\u65b9<br \/>\r\n<br \/>\r\n<b>\u25a0\u6982\u8981<\/b><br \/>\r\n<b>\u66f8\u540d<\/b>\u3000\u3000\u3000\uff1aCDP\u306e\u3064\u304f\u308a\u65b9\uff1aGA4 \u00d7 BigQuery\u306b\u3088\u308b\u9867\u5ba2\u30c7\u30fc\u30bf\u57fa\u76e4 \u69cb\u7bc9\u30fb\u6d3b\u7528\u5b9f\u8df5\u30ac\u30a4\u30c9<br \/>\r\n<b>\u51fa\u7248\u5f62\u614b<\/b>\u3000\uff1a\u5358\u884c\u672c\uff08\u30bd\u30d5\u30c8\u30ab\u30d0\u30fc\uff09416\u30da\u30fc\u30b8<br \/>\r\n<b>\u8457\u8005<\/b>\u3000\u3000\u3000\uff1a\u5c0f\u5ddd \u5353 (\u8457), \u5c0f\u7551 \u967d\u4e00 (\u8457), \u67f3\u4e95 \u9686\u9053 (\u8457), \u6e21\u908a \u4f91\u7d00 (\u8457)<br \/>\r\n<b>\u4fa1\u683c<\/b>\u3000\u3000\u3000\uff1a3,905\u5186\uff08\u7a0e\u8fbc\u307f\uff09<br \/>\r\n<b>\u51fa\u7248<\/b>\u3000\u3000\u3000\uff1a\u30a4\u30f3\u30d7\u30ec\u30b9<br \/>\r\n<b>\u767a\u58f2<\/b>\u3000\u3000\u3000\uff1a2025\u5e748\u67087\u65e5<br \/>\r\n<b>URL<\/b>\u3000\u3000\u3000\uff1a<a href=\"https:\/\/amzn.asia\/d\/bQv5Aza\" target=\"_blank\">https:\/\/amzn.asia\/d\/bQv5Aza<\/a>\t<br \/>\r\n<br \/>\r\n<br \/>\r\n\u30d7\u30ec\u30b9\u30ea\u30ea\u30fc\u30b9\u306e\u8a73\u7d30\u306f\u3053\u3061\u3089\u3092\u3054\u89a7\u304f\u3060\u3055\u3044\uff1a<br \/>\r\n<a href=\"https:\/\/www.uncovertruth.co.jp\/news\/press-release\/20250807-cdpbook\/\" target=\"_blank\">https:\/\/www.uncovertruth.co.jp\/news\/press-release\/20250807-cdpbook\/<\/a>\t<br \/>\r\n<br \/>\r\n<br \/>\r\n<br \/>\r\n<br \/>\r\n","en":""}],"links":false,"related_company":[{"name_ja":"\u682a\u5f0f\u4f1a\u793eUNCOVER TRUTH","name_en":"","location_ja":"\u6771\u4eac\u90fd\u6e0b\u8c37\u533a\u685c\u4e18\u753a20\u756a1\u53f7 \u6e0b\u8c37\u30a4\u30f3\u30d5\u30a9\u30b9\u30bf\u30ef\u30fc13\u968e","location_en":"","establishment_date":"","capital_ja":"","capital_en":"","president_ja":"\u4ee3\u8868\u53d6\u7de0\u5f79\uff1a\u77f3\u