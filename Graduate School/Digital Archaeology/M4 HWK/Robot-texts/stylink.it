		<style type="text/css" id="wp-custom-css">
			
/* give hero element min height */
.hero .x-row {
	min-height: 70vh;
}
.hero .x-row ~ .x-row {
	min-height: 0;
}
@media (orientation: landscape) {
	.hero .x-row {
		padding-top: 7vh;
		padding-bottom: 3vh;
	}
	.hero .x-row ~ .x-row {
		padding-top: 0;
	}
}

body {
	background-color: #fff;
	color: #190851;
}

.x-masthead {
	z-index: 19;
}
.x-colophon {
	z-index: 9;
}

:where( [lang="de-DE"], [lang="en-GB"] ) :is(h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6, h1 a, h2 a, h3 a, h4 a, h5 a, h6 a, .h1 a, .h2 a, .h3 a, .h4 a, .h5 a, .h6 a, blockquote) {
    color: inherit;
}

/* Top Level Menu Item for Tablet */
@media (hover: hover) {
	.tablet-only {
		display: none; 	
	}
}
@media (max-width: 978px) {
	.tablet-only {
		display: none; 	
	}
}

/* Button in comment form */
.x-comment-form-submit {
    background-color: #a890fe; /* Tropical Indigo */
    border: 0;
    border-radius: 0.35em;
    color: #fff;
    font-size: 1em;
    font-family: "DM Sans", Geneva, "Helvetica Neue", Arial, sans-serif;
    line-height: 1;
    margin: 5px 0 0 0;
    min-width: 2.5em;
    min-height: 45px;
    text-transform: capitalize;
}

/* restrain footer bg image */
@media(min-width: 768px) {
	.bigfoot .x-bg .x-bg-layer-lower-image {
		background-size: 50% !important;
	}
}

/* style links in footer */
.link_footer {
	display: inline-block;
	margin-bottom: 0.25em !important;
}

.link_footer:hover {
	color: #fff;
}

/* nav list items in footer */
.bigfoot .mh1-r.x-row,
.bigfoot .mh1-1a.x-anchor .x-anchor-text {
	margin-left: 0;
}

/* manage space in footer */
@media(max-width: 479px) {
	.footer-copyright {
		/* make room for trustpilot badge */
		padding-bottom: 4rem;
	}
	.footer-column {
		margin-top: 0 !important;
	}
	/* hide spacers @XS 
	.footer-logo-spacer {
		display: none;
	}
	*/
}

.single-post .footer-copyright {
	/* make room for sharing tools */
	padding-bottom: 4rem;
}

.esg-media-cover-wrapper .esg-content + .esg-content a {
	text-overflow: ellipsis;
	overflow: hidden;
	white-space: nowrap;
}

/* limit content width */
.bigfoot .x-anchor-text-primary {
    max-width: 15em;
}

/* limit content width and center */
@media only screen and (min-width: 310px) and (max-width: 479px) {
	.bigfoot .mh1-h.x-bar-container {
		max-width: 12em;
		margin-right: auto;
		margin-left: auto;
	}
}

@media(min-width:480px) and (max-width:767px) {
	.bigfoot .mh1-h.x-bar-container {
		max-width: 32em;
		margin-right: auto;
		margin-left: auto;
	}
}

/* google review badge in footer */
html .wp-gr {
	font-size: 1em !important;
	font-family: inherit !important;
}

html .wp-gr .wp-google-name {
 	color: #fff !important;
	font-weight: 400 !important;
	margin: 0 3em 0.5em 0 !important;
}

html .wp-gr .grw-header-inner {
	padding: 0 !important;
}

html .wp-gr .wp-google-wr a {
	background: #a890fe !important;
	border-radius: 5px !important;
	color: #190851 !important;
	font-size: 1em !important;
	letter-spacing: 1px !important;
	text-transform: uppercase !important;
	text-shadow: none !important;
	padding: 0.875em 1.20em 0.80em 1.25em !important;
}

html .wp-gr .wp-google-wr a:hover {
	color: #ffffff !important;
	background: #a890fe !important;
}

#pop-up .wp-google-wr a {
	background: #7fa7b5 !important;
}

/* Distance between blog images and text */
.post .x-image { margin-bottom: 1em; }

/* Team Person */
.card {
	position: relative;
}

.card .x-image img {
    width: 100%;
}

/* Team Foto Switch */
.onhover {
	opacity: 0;
	position: absolute;
	top: 0;
	right: 0;
	bottom: 0;
	left: 0;
	width: 100%;
	transition: opacity 0.25s ease-in-out;
}

.card:hover .onhover {
	opacity: 1;
}

/* Team Foto Switch OLD */
#onhover {
	display: none;
}

#card:hover span[id="initial"]{
	display: none;
	opacity: 0;
}

#card:hover span[id="onhover"]{
	display: block;
	opacity: 1;
}
/* END Team Foto Switch OLD */
/* END Team Foto Switch */

/* Team order */
.card  { order: 1 }

.x-grid { display: grid; }
html:lang("en-AU") .au { order: 0 }
html:lang("nl-NL") .benl { order: 0 }
html:lang("nl-NL") .five { order: 0 }
html:lang("be-FR") .benl { order: 0 }
html:lang("be-FR") .five { order: 0 }
html:lang(cz) .cz { order: 0 }
html:lang(cz) .three { order: 0 }
html:lang(de) .dach { order: 0 }
html:lang(de) .one { order: 0 }
html:lang("fr-FR") .fr { order: 0 }
html:lang("fr-FR") .four { order: 0 }
html:lang(gr) .gr { order: 0 }
html:lang(pl) .pl { order: 0 }
html:lang(pl) .three { order: 0 }
html:lang(pl) .eleven { order: 0 }
html:lang(ro) .ro { order: 0 }
html:lang(ro) .three { order: 0 }
html:lang("sv-SE") .se { order: 0 }
html:lang("en-GB") .ukie { order: 0 }
html:lang("en-GB") .two { order: 0 }
html:lang("en-US") .us { order: 0 }
/* END Team order */

/* remove image overlay in Edge */
img {
	pointer-events: none;
}

/* Teaser */
.teaser {
	border-radius: 13px;
	padding: 3rem;
	text-align: center;
}
.teaser--header {
	font-family: "Bricolage Grotesque", Lato, "Helvetica Neue", Arial, sans-serif;
}
.teaser p {
	margin-bottom: 1rem;		
}
.teaser--app-download {
	background-color:#fbf9f2;
	color: #190851;
}

.teaser--download-buttons {
	display: flex;
	justify-content: center;
	column-gap: 1em;
}
/* END Teaser */

/* Header joboffers */
.joboffers-headerwrapper {
	position: relative;
	width: 100%;
	height: 0;
	padding-bottom: 39%;
}

.joboffers-headerwrapper img {
	width: 100%;
	height: auto;
}

.joboffers-headerwrapper > * {
  position: absolute;
  top: 0;
  left: 50%;
	margin-top: 0;
	margin-left: 0;
	transform: translate(-50%, 0);
}

.button-joboffers {
  position: absolute;
  top: auto;
	bottom: 0.25rem;
	transform: translate(-50%, -100%);
}

.x-anchor-button.button-joboffers:hover {
	transform: translate(-50%, calc(-100% - 3px) );
}

.button-joboffers .x-anchor-content {
	white-space: nowrap;
}

@media(max-width: 767px) {
	.button-joboffers {
		bottom: 0;
		transform: translate(-50%, 50%);
	}
	.button-joboffers .x-anchor-content {
		font-size: 0.75em;
	}
	.x-anchor-button.button-joboffers:hover {
		transform: translate(-50%, calc(50% - 3px) );
	}
}

/* END header joboffers */

/* Language switcher */
.wpml-ls-legacy-dropdown-click {
	margin-top: 5px;
	width: auto;
	min-width: 0;
}

.wpml-ls-legacy-dropdown-click a {
	color: #190851;
	display: block;
	line-height: 1;
	padding: 5px 5px 5px 10px;
	white-space: nowrap;
}

.wpml-ls-sub-menu a {
    margin-right: 0;
    padding: 10px 10px 10px 10px;
}

.wpml-ls-sub-menu a:hover {
	color: #a890fe;
}

/* wpml dropdown */
.x-bar-top.x-bar-is-sticky .widget_icl_lang_sel_widget .wpml-ls .wpml-ls-sub-menu,
.wpml-ls-legacy-dropdown-click .wpml-ls-sub-menu {
	background-color: #fff;
	background-color: rgba(255,255,255,0.95);
	border-bottom-right-radius: 13px;
	border-bottom-left-radius: 13px;
	margin-top: 1.12em;
	min-width: 10em;
	padding-bottom: 0.5em;
	text-align: left;
}

.x-bar-top.x-bar-is-sticky .widget_icl_lang_sel_widget .wpml-ls > ul {
/*	background-color: transparent; */
	text-align: left;
}

.x-bar-is-sticky .wpml-ls-sub-menu a:hover {
	color: #a890fe;
}
/* Current language in footer */
.wpml-ls-statics-shortcode_actions .wpml-ls-current-language > a {
	color: #fbf9f2 !important;
}
/* Other languages in footer */
.wpml-ls-statics-shortcode_actions a, .wpml-ls-statics-shortcode_actions .wpml-ls-sub-menu a, .wpml-ls-statics-shortcode_actions .wpml-ls-sub-menu a:link, .wpml-ls-statics-shortcode_actions li:not(.wpml-ls-current-language) .wpml-ls-link, .wpml-ls-statics-shortcode_actions li:not(.wpml-ls-current-language) .wpml-ls-link:link {
    color: #a890fe !important;
}


/* END Language switcher */

.current-page-ancestor .x-anchor-text .x-anchor-text-primary {
    color: #a890fe;
}

@media not (prefers-reduced-motion) {
	.levitate,
	.x-anchor-button {
		transition: all 0.25s ease-out;
	}
	.levitate:hover,
	.x-anchor-button:hover {
		transform: translate(0, -3px);
	}
}

.meetings-iframe-container {
		margin-top: -65px;
		width: 95%;
}

.meetings-iframe-container iframe {
	width: 100%;	
}

@media (max-width: 978px) {
	.reverse-xs .x-row-inner {
		display: flex;
	}

	.reverse-xs .x-row-inner .x-col:first-child {
		order: 1;
	}

	.reverse-xs .x-row-inner .x-col:last-child {
		order: 0;
	}
}

/* Hide WPML development notice */
.otgs-development-site-front-end {
	display: none;
}

/* Hide Events in Blog categories list */
.widget_categories .wp-block-categories-list .cat-item-1186 {
	display: none;
}

/* CookieFox Cookie banner */
.cookiefox {
	--cookiefox--color-text-primary: #190851;
	--cookiefox--color-text-secondary: #767676;
	--cookiefox--color-button-primary: #190851;
	--cookiefox--color-button-secondary: #190851;
	--cookiefox--background: #fbf9f2;
	--cookiefox--font-family: inherit;
	--cookiefox--font-size: 1rem;
	--cookiefox--font-size-mobile: 1rem;
	--cookiefox--line-height: 1.4;
	--cookiefox__notice--box-shadow: none;
	--cookiefox__modal--border-radius: 0;
	--cookiefox__title--font-family: "bricolage-grotesque",Lato,'Helvetica Neue',Arial,sans-serif;
	--cookiefox__title--font-size: 1.2rem;
	--cookiefox__title--font-weight: bold;
	--cookiefox__text--font-size: 1rem;
	--cookiefox__text--font-weight: normal;
	--cookiefox__text--text-align: center;
	--cookiefox__button--font-size: 1rem;
	--cookiefox__button--font-weight: normal;
	--cookiefox__button--text-transform: none;
	--cookiefox__button--border-radius: 6px;
	--cookiefox__footer--background: transparent;
	--cookiefox__footer--color-border: transparent;
	--cookiefox__embed--background: #f0f0f0;
	--cookiefox__embed--border-color: #e8e8e8;
}

.cookiefox .cookiefox__spacer {
	display: none;
}

.cookiefox__title {
	text-align: center;	
}

.cookiefox--banner .cookiefox__categories, .cookiefox--banner .cookiefox__meta,
.cookiefox__title,
.cookiefox .cookiefox__footer {
	justify-content: center;
}

.cookiefox__details-category {
    display: flex;
    flex-flow: column;
    justify-content: center;
    align-items: center;
}

.cookiefox details p {
    position: static;
    padding-top: 0;
}

.open-cookie-settings a,
.open-cookie-settings span {
	color: #fff;
	cursor: pointer;
	padding: 5px;
}

.open-cookie-settings a:hover {
	color: #a890fe;
}

.cookiefox {
	background-color: rgba(255,255,255,0.98);
	border-top-right-radius: 13px;
	border-top-left-radius: 13px;	width: 43em;
	max-width: 90vw;
	display: flex;
	left: 50%;
	transform: translate(-50%,0);
}

@media (max-width: 599px) {
	.cookiefox__footer {
		flex-flow: column;
		gap: 1em;
		justify-content: center;
	}
	
	.cookiefox__footer > .cookiefox__button {
		margin-right: 0;
	}
}


/* Cookie Consent disabled temporarily */

.open-cookie-settings {
	display: none;
}








/* Make Blog Preview Images square */
.mhtu-n.x-image img {
    aspect-ratio: 1/1;
}




/* Cookie Notice Consent */
.cookie-notice-consent__button {
    display: inline-block;
    text-decoration: none;
    margin: 5px 0 0 5px;
    padding: 0 0;
    color: inherit;
    border: 0;
    cursor: pointer;
    touch-action: manipulation;
    white-space: nowrap;
    border-radius: 0;
}

.cookie-notice-consent__button:hover {
	background-color: transparent;
	box-shadow: none;
	color: #a890fe;
}


