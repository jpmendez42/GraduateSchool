	<div class="row light">
		<div class="col-md-12 spects">	<div class="row c_theatre c_ballet spec_row" style="" itemscope itemtype="http://data-vocabulary.org/Event">
		<div class="col-md-2 col-xs-2 col-sm-2 time_cnt"><div class="time"><time itemprop="startDate" datetime="2025-10-14T19:00:00+03:00">19:00</time></div></div>		
