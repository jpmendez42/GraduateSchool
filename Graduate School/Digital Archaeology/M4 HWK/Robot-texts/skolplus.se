        <script>
            SITE_URL='https://skolplus.se/';
            SITEIMAGES_URL='https://skolplus.se/images/';
			var user_langcode = 'sv';
			
            function topDiv(div_id){
                var qdiv=document.getElementById(div_id);
                document.body.appendChild(qdiv);
                qdiv.style.display = 'block';
            }
            function showDiv(div_id){
                var qdiv=document.getElementById(div_id);
                qdiv.style.display = 'block';
            }
            function hideDiv(div_id){
                var qdiv=document.getElementById(div_id);
                qdiv.style.display = 'none';
            }
            function toggleDiv(div_id) {
                var qdiv = document.getElementById(div_id);
                qdiv.style.display = qdiv.style.display == "none" ? "block" : "none";
            }
            function show_login_form(){
                if (navigator.cookieEnabled){
                    var the_form = document.getElementById('login_form');
                    the_form.style.visibility = 'visible';
                    document.getElementById('login_username').focus();
                }
                else {
                    alert('Denna webbsida behöver kakor (cookies), vänligen slå på kakor i din webbläsare!');
                }
                return false;
            }


        </script>
        <script>

            var _gaq = _gaq || [];
            _gaq.push(['_setAccount', 'UA-29349058-1']);
            _gaq.push(['_trackPageview']);

            (function() {
                var ga = document.createElement('script'); ga.type = 'text/javascript'; ga.async = true;
                ga.src = ('https:' == document.location.protocol ? 'https://ssl' : 'http://www') + '.google-analytics.com/ga.js';
                var s = document.getElementsByTagName('script')[0]; s.parentNode.insertBefore(ga, s);
            })();

            function toggleFaEye(eye)
            {
                let x = eye.parentElement.getElementsByTagName('input')[0];

                if (x.type === "password")
                {
                    x.type = "text";
                    eye.style.backgroundImage = "url(https://skolplus.se//images/open_eye.png)";
                }
                else
                {
                    x.type = "password";
                    eye.style.backgroundImage = "url(https://skolplus.se//images/closed_eye.png)";
                }
            }
        </script>
