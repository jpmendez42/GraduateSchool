<!-- AE CALENDLY LINK SCRIPt FOR NEW ACCOUNTS THANK_YOU PAGE  -->

<script type="text/plain" data-service="calendly" data-category="marketing">
        jQuery(document).ready(function ($) {
            // Step 1: Get the encoded string from the URL
            var queryString = window.location.search;
            var encodedString = "";

            // Check if the query string starts with "?data="
            if (queryString.indexOf("?data=") === 0) {
                encodedString = queryString.substring(6); // Exclude "?data="
                encodedString = decodeURIComponent(encodedString); // Decode the URL-encoded string
            }

            console.log(encodedString); // Log the value of encodedString to the console

            // Step 2: Decode the Base64-encoded string
            var decodedString = atob(encodedString);

            // Step 4: Use the Values
            var calendlySlug = "your-default-slug"; // Use a default slug
            if (decodedString.includes("&aeCalendar=")) {
                // Split on aeCalendar= and take the part after it
                var calendarPart = decodedString.split("&aeCalendar=")[1];
                // Remove anything after &leadScore= if it exists
                calendlySlug = calendarPart.split("&leadScore=")[0];
            }
            var calendlyURL = "https://calendly.com/" + calendlySlug + "?hide_gdpr_banner=1";

            // Update the data-url attribute dynamically
            $(".calendly-inline-widget").attr("data-url", calendlyURL);

            // Replace the entire HTML content of the container with a new iframe
            $(".calendly-inline-widget").html('<iframe src="' + calendlyURL + '" width="100%" height="100%" frameborder="0" title="Select a Date &amp; Time - Calendly"></iframe>');
        });
    </script>
<script data-service="calendly" data-category="marketing" type="text/plain" data-cmplz-src="https://assets.calendly.com/assets/external/widget.js" async></script>

<!-- END AE CALENDLY LINK SCRIPT -->

