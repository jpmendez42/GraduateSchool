    .v-header-login-menu-login-icon { position: absolute; width: 18px; height: 18px; top: 11px; left: 8px; background: url('https://luxupnetwork.com/img/login2.png') no-repeat; background-size: cover; }
    .v-header-login-menu-text { position: absolute; height: 40px; left: 40px; font-weight: 450; font-size: 14px; color: #fff; display: flex; align-items: center; justify-content: center; }
    
    .v-header-burger { position: absolute; width: 55px; height: 51px; top: 2px; right: 5px; display: none; }
    .v-header-burger-label { display: flex; flex-direction: column; width: 25px; cursor: pointer; padding: 15px; }
    .v-header-burger-label .v-header-burger-span { background: #fff; border-radius: 10px; height: 3px; margin: 2px 0; transition: .3s  cubic-bezier(0.68, -0.6, 0.32, 1.6); }
    .v-header-burger-span:nth-of-type(1) { width:50%; }
    .v-header-burger-span:nth-of-type(2) { width:100%; }
    .v-header-burger-span:nth-of-type(3) { width:75%; }
    .v-header-burger-input[type="checkbox"] { display:none; }
    .v-header-burger-input[type="checkbox"]:checked ~ .v-header-burger-span:nth-of-type(1) { transform-origin:bottom; transform:rotatez(45deg) translate(3px,0px) }
    .v-header-burger-input[type="checkbox"]:checked ~ .v-header-burger-span:nth-of-type(2) { transform-origin:top; transform:rotatez(-45deg) }
    .v-header-burger-input[type="checkbox"]:checked ~ .v-header-burger-span:nth-of-type(3) { transform-origin:bottom; width:50%; transform: translate(10px,-3px) rotatez(45deg); }
    
    .v-mobile-menu { position: fixed; display: none; overflow-y: auto; width: 100%; height: 100VH; background: #000; z-index: 99999; font-family: 'Raleway',Arial,sans-serif; -webkit-user-select: none; -khtml-user-select: none; -moz-user-select: none; -ms-user-select: none; user-select: none; opacity: 0; animation: v-fade-in .3s forwards; }
    .v-mobile-menu-item { position: relative; width: calc(100% - 20px); height: 56px; margin-left: 20px; border-bottom: 1px solid #8f96a3; color: #fff; font-size: 15px; font-weight: 450; display: flex; align-items: center; }
    .v-mobile-menu-ls-item { position: relative; width: calc(100% - 20px); height: 56px; margin-left: 20px; border-bottom: 1px solid #8f96a3; }
    .v-mobile-menu-top { position: relative; width: 100%; height: 80px; }
    .v-mobile-menu-signup-icon { position: absolute; width: 18px; height: 18px; top: 19px; left: 0; background: url('https://luxupnetwork.com/img/signup_mob.png') no-repeat; background-size: cover; }
    .v-mobile-menu-login-icon { position: absolute; width: 18px; height: 18px; top: 19px; left: -3px; background: url('https://luxupnetwork.com/img/login_mob.png') no-repeat; background-size: cover; }
    .v-mobile-menu-ls-text { position: absolute; height: 100%; font-weight: 700; font-size: 15px; left: 28px; color: #E2B400; display: flex; align-items: center; }
    .v-mobile-menu-social { position: relative; width: 100%; height: 35px; margin: 50px auto; }
    .v-mobile-menu-social-inner { margin: 0 auto; width: 200px; height: 35px;  }
    .v-mobile-menu-tg { width: 35px; height: 35px; float: left; background: url('https://luxupnetwork.com/img/mm_tg.svg') no-repeat; background-size: cover; }
    .v-mobile-menu-blog { width: 35px; height: 35px; margin: 0 0 0 20px; float: left; background: url('https://luxupnetwork.com/img/blog_mob.svg') no-repeat; background-size: cover; }
    .v-mobile-menu-vk { width: 35px; height: 35px; margin: 0 0 0 20px; float: left; background: url('https://luxupnetwork.com/img/mm_vk.svg') no-repeat; background-size: cover; }
    .v-mobile-menu-dzen { width: 35px; height: 35px; margin: 0 0 0 20px; float: left; background: url('https://luxupnetwork.com/img/mm_dzen.svg') no-repeat; background-size: cover; }

    .v-mobile-menu-dd { position: relative; display: block; width: calc(100% - 20px); margin-left: 20px; border-bottom: 1px solid #8f96a3; color: #fff; font-size: 15px; font-weight: 450; }
    .v-mobile-menu-dd-input[type="checkbox"] { display:none; }
    .v-mobile-menu-dd-text { position: relative; width: 100%; height: 56px; display: flex; align-items: center; }
    .v-mobile-menu-dd-text:after { content: url('https://luxupnetwork.com/img/mob-arrow-down.svg'); position: absolute; display: block; width: 15px; height: 15px; right: 20px; top: 20px; transition: transform .3s; }
    .v-mobile-menu-dd-input[type="checkbox"]:checked ~ .v-mobile-menu-dd-text:after { transform: rotate(180deg); }
    .v-mobile-menu-dd-input[type="checkbox"]:checked ~ .v-mobile-menu-dd-sub { display: block; }
    .v-mobile-menu-dd-sub { position: relative; display: none; width: calc(100% - 20px); padding: 0 0 15px 20px; }
    .v-mobile-menu-dd-sub-item { position: relative; height: 20px; font-size: 14px; padding: 10px 0; font-weight: 400; color: #dedede; }
    .v-mobile-menu-dd-sub-item-req { color: #E2B400; }

