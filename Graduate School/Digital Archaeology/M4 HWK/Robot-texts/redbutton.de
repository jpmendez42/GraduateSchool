			<div class="mk-col-1-3"><section id="custom_html-7" class="widget_text widget widget_custom_html"><div class="textwidget custom-html-widget"><div id="footer_column_3">
<p>
		<h5 class="widgettitle">
		<a href="#" id="datenschutzbestimmungen">Datenschutz</a>
	</h5>
</p>
<p>
