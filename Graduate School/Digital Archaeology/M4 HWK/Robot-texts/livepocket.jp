<script type="text/javascript">

var limit_pu = 12;
var offset_pu = 0;

var limit_ns = 3;
var offset_ns = 0;

var pref_category_select_location = '';
var timespec = '';

Common.init = function() {

    setTimeout(function(){
        get_news(limit_ns, offset_ns);
    },200);
    //get_tags();

    $('#form').submit(function(e){
        if($('#search').val() == 'アーティスト、公演名から検索'){
            $('#search').val('');
        }
        return true;
    });

    $('.timespec').bind('click', function() {
        val = $(this).val();
        if (val == timespec) {
            $(this).removeAttr('checked');
            timespec = '';
            $('.detail_date_info').removeAttr('disabled');
        } else {
            timespec = val;
            $(this).attr('checked', 'checked');
            $('.detail_date_info').attr('disabled', 'disabled');
        }
        $('#form').submit();
    });

    $('.pref_category_select_location').bind('click', function() {
        val = $(this).val();
        if (val == pref_category_select_location) {
            $(this).removeAttr('checked');
            pref_category_select_location = '';
        } else {
            pref_category_select_location = val;
            $(this).attr('checked', 'checked');
        }
    });

    $('#events-link').show();

    $('div.detail_date_info').hide();
    $('div.detail_location_info').hide();
    $('#search_options').hide();

    remove_empty_slides_link()

    $(window).load(function(){
    
        API.show_error('');
        $('header').addClass('top-header');
    });

    // バナー小エリアのエンタリングを実行する
    function centeringSmallBanner() {
        setTimeout(function() {
            $('#banner-area-small').css('display', '');
            if ($('#banner-area-small ul').children() == undefined ||
                $('#banner-area-small ul').children().length == 0 ||
                $('#banner-area-small ul').children().length > 3) {
                return;
            }
            var li_count = $('#banner-area-small ul').children().length;
            var li_width = $($('#banner-area-small ul').children()[0]).width();
            var box_width = li_width  * li_count + (20 * (li_count - 1));
            $('#banner-area-small ul').width(box_width);
        }, 0);
    }
    centeringSmallBanner();

    //リサイズされたら、センタリングをする関数を実行する
    $(window).resize(centeringSmallBanner);

    // 画像用CSSクラスセット(縦長or横長)
    setImageCssClass('.topics_item dd')

    // 3点リーダー付与
    addThreePoint('.topics_item dd')

    /**
    * 画像用CSSクラスセット(縦長or横長)
    */
    function setImageCssClass(list_name) {
        $(list_name).each(function() {
            var $target = $(this);

            var img = $target.find('img');
            var clone = img.clone();
            clone
                .css({
                    display: 'none',
                    position : 'absolute',
                    overflow : 'visible'
                })
                .width('auto')
                .height('auto');

            $(clone).bind("load",function(){
                if (this.width === this.height) {
                    // 正方形
                    $(img).addClass('square');

                } else if (this.width < this.height) {
                    // 縦長
                    $(img).addClass('vertical');

                } else {
                    // 横長
                    $(img).addClass('horizontal');
                }
                $(this).remove();
            });

            // DOMを一旦追加
            $target.after(clone);
        });
    }

    /**
    * 3点リーダー付与
    */
    function addThreePoint(list_name) {
        $(list_name).each(function() {
            var $target = $(this);
            var $target = $($target.find('span'));

            // オリジナルの文章を取得する
            var html = $target.html();

            // 対象の要素を、高さにautoを指定し非表示で複製する
            var $clone = $target.clone();
            $clone
                .css({
                    display: 'none',
                    position : 'absolute',
                    overflow : 'visible'
                })
                .width($target.width())
                .height('auto');
            $clone.css('max-height', 'none');

            // DOMを一旦追加
            $target.after($clone);

            // 指定した高さになるまで、1文字ずつ消去していく
            while((html.length > 0) && ($clone.height() > $target.height())) {
                html = html.substr(0, html.length - 1);
                $clone.html(html + '...');
            }

            // 文章を入れ替えて、複製した要素を削除する
            $target.html($clone.html());
            $clone.remove();
        });
    }
}

$(function(){
    $('a[href^=#]').click(function(){
        var speed = 500;
        var href= $(this).attr("href");
        var target = $(href == "#" || href == "" ? 'html' : href);
        var position = target.offset().top;
        $("html, body").animate({scrollTop:position}, speed, "swing");
        return false;
    });
});

