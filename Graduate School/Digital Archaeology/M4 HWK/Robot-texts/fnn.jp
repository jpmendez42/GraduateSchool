<!-- 1plusX -->
<script>
try {
  //1plusXに対してキーバリュー情報取得処理を行う際のhttpリクエストタイムアウト指定値(ms)を定義
  var TAGGER_TIMEOUT = 1000;
  var googletag = window.googletag || {};
  googletag.cmd = googletag.cmd || [];
  // 1plusXの処理を利用する、しないを定義するフラグ値
  var do1plusXTargeting = true;
  (function (url) {
    //1plusXに対してキーバリュー情報取得が必要なslotがない場合は何も実施しない
    if (!do1plusXTargeting) {
      return;
    }
    //1plusXに対してキーバリュー情報取得完了後に実行するコールバック関数
    var accessDg = function (res) {
      //googletag.cmd.push未実行時のみ実施。
      if (res) {
        googletag.cmd.push(function () {
          //ページレベルでkey-value設定実施。1plusXからのキーバリュー情報が取得できた場合のみsetTargetingを実施
          if (res !== null) {
            if (res["s"] !== null && res["s"].length > 0) {
              //1plusxのオーディエンス用（res['s']の部分）
              googletag.pubads().setTargeting("opeaud", res["s"]);
            }
            if (res["t"] !== null && res["t"].length > 0) {
              //1plusxのトピック用（res['t']の部分）
              googletag.pubads().setTargeting("opectx", res["t"]);
            }
          }
        });
      }
    };
    //1plusxに対して、キーバリュー情報の取得処理開始（HTTP Request）
    try {
      fetch(url + "?url=" + encodeURIComponent(window.location.href), {
        referrerPolicy: "no-referrer-when-downgrade",
        mode: "cors",
        credentials: "include",
        //応答コードが200の時のみ、正常完了とする。それ以外はサーバエラー扱いにする。
      })
        .then(function (response) {
          if (response.status === 200) {
            return response.json();
          } else {
            throw new Error("server error.");
          }
        })
        .then(function (res) {
          //通信正常完了時
          accessDg(res);
        });
    } catch (error) {
      //fetchエラー処理
      console.log(error);
    }
  })("https://mediaconsortium.profiles.tagger.opecloud.com/api/v1"); //1plusxのHTTP Request先
} catch (e) {}
</script>
<!-- /1plusX -->
<!-- start parts: Header_Bidding -->
<!-- Define callback function -->
<script type="text/javascript">
  window.fluxtag = {
    readyBids: {
      prebid: false,
      amazon: false,
      google: false
    },
    failSafeTimeout: 3e3, // 【注意】環境に合わせて数値をご設定してください
    isFn: function isFn(object) {
      var _t = 'Function';
      var toString = Object.prototype.toString;
      return toString.call(object) === '[object ' + _t + ']';
    },
    launchAdServer: function() {
      if (!fluxtag.readyBids.prebid || !fluxtag.readyBids.amazon) {
        return;
      }
      fluxtag.requestAdServer();
    },
    requestAdServer: function() {
      if (!fluxtag.readyBids.google) {
        fluxtag.readyBids.google = true;
        googletag.cmd.push(function () {
          if (!!(pbjs.setTargetingForGPTAsync) && fluxtag.isFn(pbjs.setTargetingForGPTAsync)) {
            pbjs.que.push(function () {
              pbjs.setTargetingForGPTAsync();
            });
          }
          apstag.setDisplayBids();
          googletag.pubads().refresh();
        });
      }
    },
    renderAds: function(lines) {
      googletag.cmd.push(function () {
        var refreshLines = [];
        var params = (function () {
          // GAMを呼び出したかを確認にするフラグ
          var readyBids = {
            amazon: false,
            google: false,
            prebid: false,
          };
          var refreshSlots = [];
          var apsSlots = [];
          var divIds = [];
          var apsDivIds = [];
          var definedSlots = [];
          var displayDivIds = [];

          googletag.pubads().getSlots().forEach(function (slot) {
            // 既にdefineSlotされていた場合
            definedSlots[slot.getSlotElementId()] = slot;
          });
          for (var i = 0; i < lines.length; i++) {
            var divId = lines[i].divId;
            var adUnitCode = lines[i].code;
            var sizes = lines[i].sizes;
            var isAps = lines[i].isAps || false;

            refreshLines.push({
              code: adUnitCode,
              size: sizes,
              id: divId
            });
            if (definedSlots[divId]) {
              refreshSlots.push(definedSlots[divId]);
            } else {
              refreshSlots.push(
                googletag.defineSlot(adUnitCode, sizes, divId).addService(googletag
                  .pubads())
              );
              displayDivIds.push(divId);
            }

            divIds.push(divId);
            // TAM並走枠の場合
            if (isAps) {
              apsSlots.push({
                slotID: divId,
                slotName: adUnitCode,
                sizes: sizes
              });
              apsDivIds.push(divId);
            }
          }
          // APSの枠がない場合
          if (apsSlots.length === 0) {
            readyBids.amazon = true;
          }
          // Prebid、APSでオークション後に起動する関数 (GAMコール、広告Display)
          var adServerSend = function () {
            if (!readyBids.amazon || !readyBids.prebid) {
              return;
            }
            if (!readyBids.google) {
              readyBids.google = true;
              for (var i = 0; i < displayDivIds.length; i++) {
                googletag.display(displayDivIds[i]);
              }
              if (!!(pbjs.setTargetingForGPTAsync) && fluxtag.isFn(pbjs.setTargetingForGPTAsync)) {
                pbjs.que.push(function () {
                  pbjs.setTargetingForGPTAsync();
                });
              }
              if (apsSlots.length > 0 && !!(window.apstag) && fluxtag.isFn(window.apstag.fetchBids)) {
                window.apstag.setDisplayBids(apsDivIds);
              }
              googletag.pubads().refresh(refreshSlots);
            }
          };
          // APSオークション後に起動する関数
          var apsCallback = function () {
            readyBids.amazon = true;
            adServerSend();
          };
          // Prebidオークション後に起動する関数
          var prebidCallback = function () {
            readyBids.prebid = true;
            adServerSend();
          };
          // もしtimeout以内にPrebidが動作できなかった場合、最終的にGAMをコール
          setTimeout(function () {
            readyBids.amazon = true;
            readyBids.prebid = true;
            adServerSend();
          }, 3000);   // 【注意】timeoutの秒数は環境に合わせて枠情報をご設定してください

          return {
            aps: {
              slots: apsSlots,
              callback: apsCallback,
            },
            prebid: {
              callback: prebidCallback,
            }
          };
        })();
        // Prebid呼び出し
        if (!!(window.pbFlux) && window.pbFlux.refresh && fluxtag.isFn(window.pbFlux.refresh)) {
          pbjs.que.push(function () {
            pbFlux.refresh({
              lines: refreshLines,
              callback: params.prebid.callback,
              timeout: 2000 // 【注意】環境に合わせて枠情報をご設定してください
            });
          });
        } else {
          params.prebid.callback();
        }
        
        if (params.aps.slots.length > 0 && !!(window.apstag) && fluxtag.isFn(window.apstag.fetchBids)) {
          // APS呼び出し
          window.apstag.fetchBids({
            slots: params.aps.slots,
            timeout: 15e2 // 【注意】環境に合わせて枠情報をご設定してください
          }, function (bids) {
            params.aps.callback();
          });
        } else {
          params.aps.callback();
        }
      });
    }
  };
</script>
<script type="text/javascript">
  setTimeout(function () {
    fluxtag.requestAdServer();
  }, fluxtag.failSafeTimeout);
</script>
