  <title>Хостинг FullSpace — хостинг PHP 8.3, хостинг Python 3.11, Django, регистрация доменов</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html,
    body {
      height: 100%;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      font-family: Arial, sans-serif;
    }

    .container {
      width: 100%;
      max-width: 980px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    main {
      display: flex;
      gap: 1em;
      padding: 40px 0;
      flex: 1;
    }

    .logo {
      flex-shrink: 0;
    }

    .logo img {
      display: block;
      width: auto;
      height: auto;
    }

    .text {
      flex: 1;
    }

    .text h1 {
      font-size: 1.5rem;
      margin-bottom: 1em;
    }

    .text p {
      margin-bottom: .8em;
      line-height: 1.4;
    }

    .text a {
      color: #4e008c;
      text-decoration: none;
    }

    .text a:hover {
      text-decoration: underline;
    }

    footer {
      background: #4e008c;
      background-image: url("/footer.jpg");
      color: #fff;
      padding: 15px 15px;
      font-size: .75rem;
    }

    .footer-inner {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
      
    }

    .footer-inner a {
      color: #fefe68;
      text-decoration: none;
    }

    .footer-inner a:hover {
      text-decoration: underline;
    }
    .footer-inner-left {
      align-self: center;
      width: 66%;
    }
  </style>
</head>

<body>

