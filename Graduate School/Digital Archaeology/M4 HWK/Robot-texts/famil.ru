:[[\"$\",\"div\",null,{\"className\":\"FAQ_intro__pjBf3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"FAQ_title__pQlOK\",\"children\":\"Часто задаваемые вопросы\"}],[\"$\",\"$L3f\",null,{\"href\":\"/ru/faq\",\"className\":\"FAQ_link__Doh1h FAQ_desktop__SrfIA\",\"children\":\"Все вопросы и ответы\"}]]}],[\"$\",\"$L40\",null,{\"data\":[{\"id\":\"67935a96f9e74ca6cdc8a1af\",\"title\":\"Как вернуть товар, купленный с сервисом Подели?\",\"description\":[{\"children\":[{\"text\":\"Если вы решили вернуть покупку, выплаченная сумма будет возвращена на банковскую карту, которая указана в сервисе Подели.\"}]}],\"categoryId\":{\"value\":{\"id\":\"65e97852978dd6583694a4a9\",\"title\":\"Подели\",\"isOn\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-03-07T08:18:26.216Z\",\"updatedAt\":\"2025-01-24T09:37:59.583Z\",\"sort\":7},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":28,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:17:10.007Z\",\"updatedAt\":\"2025-01-24T09:17:10.705Z\"},{\"id\":\"67935a70f9e74ca6cdc8a135\",\"title\":\"Нужен ли паспорт для совершения покупки с помощью сервиса Подели? \",\"description\":[{\"children\":[{\"text\":\"При совершении покупки с помощью сервиса Подели паспорт не требуется.\"}]},{\"children\":[{\"text\":\"Подели работает не только для клиентов Альфа-Банка. Использовать можно карту любого российского банка.\"}]}],\"categoryId\":{\"value\":{\"id\":\"65e97852978dd6583694a4a9\",\"title\":\"Подели\",\"isOn\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-03-07T08:18:26.216Z\",\"updatedAt\":\"2025-01-24T09:37:59.583Z\",\"sort\":7},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":27,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:16:32.898Z\",\"updatedAt\":\"2025-01-24T09:16:33.390Z\"},{\"id\":\"67935a5533caac31715eb6dc\",\"title\":\"Как оплачивать покупки с помощью сервиса Подели?\",\"description\":[{\"children\":[{\"text\":\"Сервис делит сумму покупки на четыре равные части и формирует график платежей.\"}]},{\"children\":[{\"text\":\"Первый платеж списывается в день покупки, следующие три — равными долями через каждые две недели.\"}]},{\"children\":[{\"text\":\"Внести платеж или всю сумму раньше срока, изменить данные карты или отслеживать график платежей можно в мобильном приложении сервиса Подели. Также график платежей можно запросить в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://podeli.ru/\",\"children\":[{\"text\":\"чате\"}]},{\"text\":\" на сайте сервиса.\"}]},{\"children\":[{\"text\":\"Общая сумма покупки должна быть от 300 до 30 000 рублей.\"}]}],\"categoryId\":{\"value\":{\"id\":\"65e97852978dd6583694a4a9\",\"title\":\"Подели\",\"isOn\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-03-07T08:18:26.216Z\",\"updatedAt\":\"2025-01-24T09:37:59.583Z\",\"sort\":7},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":26,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:16:05.532Z\",\"updatedAt\":\"2025-01-24T09:16:06.246Z\"},{\"id\":\"67935a3933caac31715eb678\",\"title\":\"Как воспользоваться сервисом Подели?\",\"description\":[{\"children\":[{\"text\":\"Отсканируйте QR-код с рекламного объявления или скачайте мобильное приложение сервиса Подели. Пройдите быструю регистрацию для подтверждения покупки. \"}]},{\"children\":[{\"text\":\"Покажите кассиру QR-код из приложения Подели, дождитесь обработки заявки, подтвердите оплату и забирайте покупку.\"}]}],\"categoryId\":{\"value\":{\"id\":\"65e97852978dd6583694a4a9\",\"title\":\"Подели\",\"isOn\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-03-07T08:18:26.216Z\",\"updatedAt\":\"2025-01-24T09:37:59.583Z\",\"sort\":7},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":25,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:15:37.064Z\",\"updatedAt\":\"2025-01-24T09:15:37.578Z\"},{\"id\":\"679359fcf9e74ca6cdc8a001\",\"title\":\"Ошибки в приложении\",\"description\":[{\"children\":[{\"text\":\"Если вы столкнулись с проблемами в работе приложения, пожалуйста, напишите нам в чат-бот на сайте или в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://t.me/familia_rus_bot\",\"children\":[{\"text\":\"Telegram.\"}]},{\"text\":\" Или позвоните по номеру +7 (800) 100-33-90.\"}]}],\"categoryId\":{\"value\":{\"id\":\"664c73851c1a78ff980f9f51\",\"title\":\"Мобильное приложение\",\"isOn\":true,\"sort\":6,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-05-21T10:12:21.966Z\",\"updatedAt\":\"2025-01-24T09:37:54.920Z\"},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":24,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:14:36.334Z\",\"updatedAt\":\"2025-03-04T13:53:28.156Z\"},{\"id\":\"67935968584189f10d699625\",\"title\":\"Как я могу использовать мобильное приложение?\",\"description\":[{\"children\":[{\"text\":\"В мобильном приложении Familia можно:\"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Совершать покупки в интернет-магазине: более 15 тыс. карточек товаров в онлайн-каталоге.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Находить нужные размеры и проверять наличие товаров с помощью сканера по штрих-коду или QR-коду на ценнике.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Подписываться на любимые бренды и отслеживать их поступление в выбранные магазины.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Пользоваться личным кабинетом: отслеживать историю покупок, статус онлайн-заказов, электронные чеки, доступные промокоды и не только. \"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Находить магазины поблизости с помощью карты магазинов.\"}]}]}]}],\"categoryId\":{\"value\":{\"id\":\"664c73851c1a78ff980f9f51\",\"title\":\"Мобильное приложение\",\"isOn\":true,\"sort\":6,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-05-21T10:12:21.966Z\",\"updatedAt\":\"2025-01-24T09:37:54.920Z\"},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":23,\"isHomepage\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:12:08.395Z\",\"updatedAt\":\"2025-03-04T13:52:31.708Z\"},{\"id\":\"679358bcf9e74ca6cdc89d47\",\"title\":\"Как установить мобильное приложение Familiа на телефон?\",\"description\":[{\"children\":[{\"text\":\"Скачать приложение можно в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://play.google.com/store/apps/details?id=ru.familia.app\",\"children\":[{\"text\":\"Google Play\"}]},{\"text\":\", \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://apps.apple.com/ru/app/familia-%D0%B1%D1%80%D0%B5%D0%BD%D0%B4%D1%8B-%D0%B4%D0%BE-85/id6468092253\",\"children\":[{\"text\":\"App Store\"}]},{\"text\":\" или \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.rustore.ru/catalog/app/ru.familia.app?utm_source=social\u0026utm_medium=telegram\u0026utm_campaign=app\u0026utm_content=post\u0026utm_term=2.06.2024\",\"children\":[{\"text\":\"RuStore\"}]},{\"text\":\".\"}]}],\"categoryId\":{\"value\":{\"id\":\"664c73851c1a78ff980f9f51\",\"title\":\"Мобильное приложение\",\"isOn\":true,\"sort\":6,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2024-05-21T10:12:21.966Z\",\"updatedAt\":\"2025-01-24T09:37:54.920Z\"},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":22,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:09:16.832Z\",\"updatedAt\":\"2025-01-24T09:09:17.207Z\"},{\"id\":\"67935898f9e74ca6cdc89cca\",\"title\":\"Как узнать статус интернет-заказа?\",\"description\":[{\"children\":[{\"text\":\"Отслеживайте статус интернет-заказа в личном кабинете на \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/catalog/\",\"children\":[{\"text\":\"сайте\"}]},{\"text\":\" или в мобильном приложении. После поступления заказа в пункт выдачи вы получите СМС-уведомление о том, что заказ доставлен.\"}]},{\"children\":[{\"text\":\"Также для уточнения статуса вы можете обратиться к нам одним из способов:\"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Позвоните нам по телефону +7 (800) 100-33-90.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Напишите нам в чат-бот на сайте или в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://t.me/familia_rus_bot\",\"children\":[{\"text\":\"Telegram.\"}]},{\"text\":\"\"}]}]}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":21,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:08:40.799Z\",\"updatedAt\":\"2025-01-24T09:08:41.396Z\"},{\"id\":\"6793587133caac31715eb21f\",\"title\":\"В течение какого времени можно забрать интернет-заказ?\",\"description\":[{\"children\":[{\"text\":\"Срок хранения интернет-заказа в магазине Familia составляет 14 дней с момента поступления в магазин.\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":20,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:08:01.593Z\",\"updatedAt\":\"2025-01-24T09:08:02.180Z\"},{\"id\":\"6793584c584189f10d69936b\",\"title\":\"В какие сроки доставят интернет-заказ?\",\"description\":[{\"children\":[{\"text\":\"Доставка в пункт выдачи Familia занимает от 2 до 14 дней и зависит от региона доставки. Средний срок доставки в ваш регион указывается при оформлении заказа.\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":19,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:07:24.673Z\",\"updatedAt\":\"2025-01-24T09:07:25.156Z\"},{\"id\":\"6793582bf9e74ca6cdc89ba0\",\"title\":\"Что необходимо знать о проценте выкупа?\",\"description\":[{\"children\":[{\"text\":\"Процент выкупа – это доля выкупленных товаров от общего количества товаров в заказах. В расчёте учитываются последние оформленные 10 заказов.\"}]},{\"children\":[{\"text\":\"Процент выкупа влияет на количество товаров, доступных для заказа с оплатой при получении. Если ваш процент выкупа менее 30%, оплата при получении будет недоступна.Узнать свой процент выкупа вы можете в личном кабинете на \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/catalog/\",\"children\":[{\"text\":\"сайте\"}]},{\"text\":\" или в мобильном приложении.\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":18,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:06:51.237Z\",\"updatedAt\":\"2025-01-24T09:06:51.900Z\"},{\"id\":\"6793580533caac31715eb0e7\",\"title\":\"Что необходимо знать об оплате при получении?\",\"description\":[{\"children\":[{\"text\":\"Оплата при получении доступна, если: \"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Максимальное количество невыкупленного товара не превышает 10 штук.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Процент выкупа интернет-заказов выше 30%.\"}]}]}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":17,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:06:13.812Z\",\"updatedAt\":\"2025-01-24T09:06:14.200Z\"},{\"id\":\"679357b133caac31715eafaf\",\"title\":\"Как оформить заказ в интернет-магазине?\",\"description\":[{\"children\":[{\"text\":\"Для оформления заказа в интернет-магазине:\"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Добавьте понравившиеся товары в корзину на \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/catalog/\",\"children\":[{\"text\":\"сайте\"}]},{\"text\":\" или в мобильном приложении, пройдите авторизацию, выберите удобный пункт выдачи заказов, далее выберете способ оплаты заказа. \"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Оплатите онлайн банковской картой при оформлении заказа или выберите вариант оплаты при получении заказа.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Отслеживайте статус интернет-заказа в личном кабинете на \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/catalog/\",\"children\":[{\"text\":\"сайте\"}]},{\"text\":\" или в мобильном приложении. После поступления заказа в пункт выдачи вы получите СМС-уведомление о том, что заказ доставлен.\"}]}]}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":15,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:04:49.096Z\",\"updatedAt\":\"2025-01-24T09:04:49.807Z\"},{\"id\":\"6793576033caac31715eaf08\",\"title\":\"Как попасть в интернет-магазин Familia?\",\"description\":[{\"children\":[{\"text\":\"Каталог интернет-магазина доступен на \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/catalog/\",\"children\":[{\"text\":\"сайте\"}]},{\"text\":\" и в мобильном приложении Familia. Скачать приложение можно в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://play.google.com/store/apps/details?id=ru.familia.app\",\"children\":[{\"text\":\"Google Play\"}]},{\"text\":\", \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://apps.apple.com/ru/app/familia-%D0%B1%D1%80%D0%B5%D0%BD%D0%B4%D1%8B-%D0%B4%D0%BE-85/id6468092253\",\"children\":[{\"text\":\"App Store\"}]},{\"text\":\" или \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.rustore.ru/catalog/app/ru.familia.app?utm_source=social\u0026utm_medium=telegram\u0026utm_campaign=app\u0026utm_content=post\u0026utm_term=2.06.2024\",\"children\":[{\"text\":\"RuStore\"}]},{\"text\":\".\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8afc6efb0bb79ecd900\",\"title\":\"Интернет-магазин\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:11.812Z\",\"updatedAt\":\"2024-03-12T07:13:28.016Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":5},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":14,\"isHomepage\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T09:03:28.524Z\",\"updatedAt\":\"2025-01-24T09:03:28.961Z\"},{\"id\":\"679352f9584189f10d6989de\",\"title\":\"Какие привилегии дает карта лояльности?\",\"description\":[{\"children\":[{\"text\":\"Карта лояльности дает ряд привилегий:\"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"text\":\"Промокод - 10% за заполнение профиля в \"},{\"type\":\"link\",\"linkType\":\"custom\",\"url\":\"https://www.famil.ru/ru/login\",\"newTab\":true,\"children\":[{\"text\":\"личном кабинете\"}]},{\"text\":\" и подтверждение e-mail*.\"}]},{\"children\":[{\"text\":\"Промокод -10% за подписку на Telegram-канал**.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Промокод -10% на день рождения***.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Увеличенный срок возврата товаров надлежащего качества, не бывших в употреблении, — 30 дней со дня покупки, при условии её оформления по карте лояльности. Их возврат возможен в соответствии с законодательством РФ.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Возможность отложить понравившийся товар до конца текущего дня на кассе любого магазина.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"История покупок и электронные чеки в личном кабинете.\\n\"}],\"type\":\"li\"}]},{\"children\":[{\"text\":\"*Промокод на единоразовую скидку 10% предоставляется за заполнение обязательных полей (имя, e-mail, дата рождения, пол) и подтверждение e-mail, указанного в \",\"italic\":true},{\"type\":\"link\",\"linkType\":\"custom\",\"url\":\"https://www.famil.ru/ru/login\",\"newTab\":true,\"children\":[{\"text\":\"личном кабинете\",\"italic\":true}]},{\"italic\":true,\"text\":\".\"}]},{\"children\":[{\"text\":\"** В акции могут участвовать пользователи, которые впервые подписались на канал Familia с 1 апреля 2025 г.\",\"italic\":true}]},{\"children\":[{\"italic\":true,\"text\":\"***В день рождения участнику программы лояльности присваивается подарочный промокод на единоразовую скидку -10% на покупку в сети розничных магазинов и интернет-магазине Familia. Срок действия промокода – 15 дней со дня его получения.\"}]},{\"children\":[{\"text\":\"Все промокоды действуют 15 дней с момента получения/активации.\",\"italic\":true}]},{\"children\":[{\"text\":\"Узнайте больше о \"},{\"type\":\"link\",\"linkType\":\"custom\",\"url\":\"https://www.famil.ru/ru/safari\",\"newTab\":true,\"children\":[{\"text\":\"программе лояльности Familia\"}]},{\"text\":\"\",\"underline\":true},{\"type\":\"link\",\"linkType\":\"custom\",\"url\":\"https://www.famil.ru/ru/safari\",\"newTab\":true,\"children\":[{\"text\":\"\"}]},{\"text\":\".\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8bec6efb0bb79ecd908\",\"title\":\"Программа лояльности Familia\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:26.667Z\",\"updatedAt\":\"2025-07-18T09:26:33.671Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":4},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":10,\"isHomepage\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:44:41.115Z\",\"updatedAt\":\"2025-07-18T09:30:18.865Z\"},{\"id\":\"679352ae584189f10d698928\",\"title\":\"Как оформить карту лояльности?\",\"description\":[{\"children\":[{\"text\":\"Карту лояльности Familia можно оформить несколькими способами:\"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Онлайн: на сайте или в мобильном приложении Familia, чтобы карта всегда была под рукой.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"На кассе: просто сообщите кассиру ваш номер телефона.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"По телефону: свяжитесь с нами по номеру +7 (800) 100-33-90 и оформите карту за несколько минут.\"}]}]}]}],\"categoryId\":{\"value\":{\"id\":\"6579b8bec6efb0bb79ecd908\",\"title\":\"Программа лояльности Familia\",\"isOn\":true,\"createdAt\":\"2023-12-13T13:59:26.667Z\",\"updatedAt\":\"2025-07-18T09:26:33.671Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":4},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":9,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:43:26.045Z\",\"updatedAt\":\"2025-07-18T09:28:30.025Z\"},{\"id\":\"679351ee33caac31715ea506\",\"title\":\"Где найти электронный чек?\",\"description\":[{\"children\":[{\"text\":\"Для участников программы лояльности электронный чек доступен в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/ru/cabinet\",\"children\":[{\"text\":\"«Личном кабинете»\"}]},{\"text\":\". Чтобы увидеть историю покупок и электронные чеки, в личном кабинете нажмите раздел «Покупки».\"}]},{\"children\":[{\"text\":\"\\nЭлектронные чеки в личном кабинете отображаются только на покупки, совершенные с применением карты лояльности. \"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc01c6efb0bb79ecdd70\",\"title\":\"Электронный чек\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:13:21.988Z\",\"updatedAt\":\"2024-03-12T07:13:11.746Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":3},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":8,\"isHomepage\":true,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:40:14.819Z\",\"updatedAt\":\"2025-04-01T09:25:53.270Z\"},{\"id\":\"6793508ef9e74ca6cdc88cdc\",\"title\":\"Какой срок действия у подарочной карты Familia?\",\"description\":[{\"children\":[{\"text\":\"Срок действия подарочной карты 365 дней c даты покупки.\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc1ec6efb0bb79ecdd7c\",\"title\":\"Подарочная карта\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:13:50.621Z\",\"updatedAt\":\"2024-03-12T07:13:02.381Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":2},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":7,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:34:22.617Z\",\"updatedAt\":\"2025-01-24T08:39:30.237Z\"},{\"id\":\"67935067584189f10d698518\",\"title\":\"Где можно использовать подарочную карту?\",\"description\":[{\"children\":[{\"text\":\"Подарочные карты Familia принимаются во всех наших розничных магазинах.\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc1ec6efb0bb79ecdd7c\",\"title\":\"Подарочная карта\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:13:50.621Z\",\"updatedAt\":\"2024-03-12T07:13:02.381Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":2},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":6,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:33:43.808Z\",\"updatedAt\":\"2025-01-24T08:33:44.399Z\"},{\"id\":\"6793503ef9e74ca6cdc88b97\",\"title\":\"Что делать, если подарочная карта не пришла?\",\"description\":[{\"children\":[{\"text\":\"Свяжитесь с нами одним из способов: \"}]},{\"type\":\"ul\",\"children\":[{\"children\":[{\"text\":\"Позвоните нам по телефону +7 (800) 100-33-90.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Напишите нам в чат-бот на сайте или в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://t.me/familia_rus_bot\",\"children\":[{\"text\":\"Telegram.\"}]},{\"text\":\"\"}],\"type\":\"li\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc1ec6efb0bb79ecdd7c\",\"title\":\"Подарочная карта\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:13:50.621Z\",\"updatedAt\":\"2024-03-12T07:13:02.381Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":2},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":5,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:33:02.213Z\",\"updatedAt\":\"2025-01-24T08:33:02.659Z\"},{\"id\":\"6793501b33caac31715ea132\",\"title\":\"Что делать, если при оформлении подарочной карты в электронной почте получателя допущена ошибка?\",\"description\":[{\"children\":[{\"text\":\"Свяжитесь с нами одним из способов: \"}]},{\"type\":\"ul\",\"children\":[{\"children\":[{\"text\":\"Позвоните нам по телефону +7 (800) 100-33-90.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Напишите нам в чат-бот на сайте или в \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://t.me/familia_rus_bot\",\"children\":[{\"text\":\"Telegram.\"}]},{\"text\":\"\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Напишите нам обращение через раздел, заполнив необходимые поля и указав в сообщении корректные контактные данные получателя, чтобы мы могли отправить карту еще раз.\"}],\"type\":\"li\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc1ec6efb0bb79ecdd7c\",\"title\":\"Подарочная карта\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:13:50.621Z\",\"updatedAt\":\"2024-03-12T07:13:02.381Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":2},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":4,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:32:27.421Z\",\"updatedAt\":\"2025-01-24T08:32:28.002Z\"},{\"id\":\"67934feb33caac31715ea094\",\"title\":\"Как оформить электронную подарочную карту Familia?\",\"description\":[{\"children\":[{\"text\":\"Для оформления электронной подарочной карты Familia перейдите на сайте в раздел \"},{\"type\":\"link\",\"newTab\":false,\"url\":\"https://www.famil.ru/ru/certificate\",\"children\":[{\"text\":\"«Подарочные карты»\"}]},{\"text\":\". Пройдите все шаги оформления: выберите цвет карты, дизайн, номинал. Заполните данные получателя и отправителя, выберите способ отправки подарочной карты, по желанию напишите текст поздравления, укажите дату и время отправки.\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc1ec6efb0bb79ecdd7c\",\"title\":\"Подарочная карта\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:13:50.621Z\",\"updatedAt\":\"2024-03-12T07:13:02.381Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":2},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":3,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:31:39.911Z\",\"updatedAt\":\"2025-01-24T09:25:05.198Z\",\"isHomepage\":true},{\"id\":\"67934f97f9e74ca6cdc889f7\",\"title\":\"Как происходит возврат денежных средств?\",\"description\":[{\"children\":[{\"text\":\"Возврат денежных средств можно осуществить следующими способами: \"}]},{\"type\":\"ul\",\"children\":[{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Если покупка оплачена наличными, возврат денежных средств осуществляется наличными.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Если покупка оплачена подарочной картой, возврат поступает на подарочную карту — её выдаёт кассир при осуществлении возврата.\"}]}]},{\"type\":\"li\",\"children\":[{\"children\":[{\"text\":\"Если покупка оплачена банковской картой, возврат можно осуществить одним из способов: на банковскую карту, которой была оплачена покупка (деньги поступят от трёх до десяти рабочих дней) или на подарочную карту (деньги будут доступны сразу).\"}]}]}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc2ac6efb0bb79ecdd84\",\"title\":\"Возврат товара\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:14:02.813Z\",\"updatedAt\":\"2024-03-12T07:12:54.811Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":1},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":2,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:30:15.154Z\",\"updatedAt\":\"2025-03-05T14:20:39.469Z\",\"isHomepage\":true},{\"id\":\"67934f6c584189f10d6982a7\",\"title\":\"Как оформить возврат товара?\",\"description\":[{\"children\":[{\"text\":\"Оформить возврат товара надлежащего качества можно в любом магазине сети Familia при следующих условиях:\"}]},{\"type\":\"ul\",\"children\":[{\"children\":[{\"text\":\"Товар не был в эксплуатации.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Сохранена полная комплектация товара и товарный вид.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Сохранены ярлыки, бирки, пломбы, заводская упаковка, если она влияет на товарный вид.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Срок возврата не превышает 14 дней, не считая дня покупки. Для участников программы лояльности срок возврата товара надлежащего качества составляет 30 дней со дня покупки.\"}],\"type\":\"li\"},{\"children\":[{\"text\":\"Товар входит в перечень товаров надлежащего качества, подлежащих возврату.\"}],\"type\":\"li\"}]},{\"children\":[{\"text\":\"Участникам программы лояльности для оформления возврата чек необязателен, так как все покупки сохранены в вашем \"},{\"type\":\"link\",\"linkType\":\"custom\",\"url\":\"https://www.famil.ru/ru/login\",\"newTab\":true,\"children\":[{\"text\":\"личном кабинете\"}]},{\"text\":\" (при условии, что при совершении покупки была применена карта лояльности).\"}]}],\"categoryId\":{\"value\":{\"id\":\"6579bc2ac6efb0bb79ecdd84\",\"title\":\"Возврат товара\",\"isOn\":true,\"createdAt\":\"2023-12-13T14:14:02.813Z\",\"updatedAt\":\"2024-03-12T07:12:54.811Z\",\"autoTranslatetoCn\":true,\"autoTranslatetoEn\":true,\"sort\":1},\"relationTo\":\"FAQCategories\"},\"status\":\"published\",\"domainZone\":[\"ru\"],\"isVisible\":true,\"sort\":1,\"isHomepage\":false,\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"createdAt\":\"2025-01-24T08:29:32.938Z\",\"updatedAt\":\"2025-04-01T09:27:31.101Z\"}]}],[\"$\",\"$L3f\",null,{\"href\":\"/ru/faq\",\"className\":\"FAQ_link__Doh1h FAQ_mobile__sDIdT\",\"children\":\"Все вопросы и ответы\"}]]}]}]\n"])</script><script>self.__next_f.push([1,"35:[\"$\",\"section\",null,{\"className\":\"MainOffPrice_wrapper__8iaZc\",\"children\":[\"$\",\"div\",null,{\"className\":\"container MainOffPrice_container__o6dlq\",\"children\":[[\"$\",\"div\",null,{\"className\":\"MainOffPrice_head__cl0hq\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"MainOffPrice_title__zubbL\",\"children\":\"Familia — лидер офф-прайс торговли в России\"}],[\"$\",\"$L3f\",null,{\"href\":\"/ru/aboutus/more\",\"className\":\"MainOffPrice_desktop__fBKGK\",\"children\":\"Узнать больше\"}]]}],[\"$\",\"div\",null,{\"className\":\"MainOffPrice_cards__B9Fpq\",\"style\":{\"gridTemplateColumns\":\"repeat(3, 1fr)\"},\"children\":[[\"$\",\"div\",\"65658facfdb049454888d44b\",{\"className\":\"MainOffPrice_card__UJ4K7\",\"style\":{\"background\":\"#662C83\",\"color\":\"#F3F3F3\"},\"children\":[[\"$\",\"p\",null,{\"className\":\"MainOffPrice_variable__kDozg\",\"children\":[[\"$\",\"span\",null,{\"className\":\"MainOffPrice_prefix__pYY1a\",\"children\":\"$undefined\"}],\"6500+\"]}],[\"$\",\"div\",null,{\"className\":\"MainOffPrice_content__hHEcD\",\"children\":[[\"$\",\"p\",null,{\"className\":\"MainOffPrice_title__zubbL\",\"children\":\"известных брендов\"}],[\"$\",\"p\",null,{\"className\":\"MainOffPrice_text__ZdqGr\",\"children\":\"В ассортименте Familia только оригинальные бренды, а линейка торговых марок и товарных категорий постоянно расширяется.\"}],[\"$\",\"$L3f\",null,{\"href\":\"/ru/brands\",\"className\":\"MainOffPrice_button__op3lg\",\"children\":\"Бренды\"}]]}]]}],[\"$\",\"div\",\"65658ffcfdb049454888d44c\",{\"className\":\"MainOffPrice_card__UJ4K7\",\"style\":{\"background\":\"#341F51\",\"color\":\"#F3F3F3\"},\"children\":[[\"$\",\"p\",null,{\"className\":\"MainOffPrice_variable__kDozg\",\"chil