<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="ru" lang="ru" >
  <head>
    <meta http-equiv="content-type" content="text/html" charset="utf-8" />
    <title>RiNet - Internet Service Provider</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="" >
    <link rel="stylesheet" href="style.css" />
    <style>
          @font-face {      font-family: "CoFoSansRegular";      src: url(./fonts/CoFo_Sans-Regular.woff2);      font-style: normal;      font-weight: 700;    }        @font-face {      font-family: "CoFoSansRegular-Bold";      src: url(./fonts/CoFo_Sans-Bold.woff2);      font-style: normal;      font-weight: 700;    }    * {        -webkit-appearance: none;        -webkit-font-smoothing: subpixel-antialiased;        font-family: 'CoFoSansRegular', sans-serif;        box-sizing: border-box;    } 

    </style>
  </head>
  <body>
    <div class="container" >
      <div  class="header" >
        <div  class="left_side" >
          <img  loading="lazy"  src="images/logo.svg"  class="img"  />
          
          <div class="hamburger-menu menu-left">
            <input id="menu__toggle" type="checkbox" />
            <label class="menu__btn" for="menu__toggle">
              <span></span>
            </label>

            <ul class="menu__box">
              <li><a class="menu__item" href="https://msk.dom.ru/user/login">Личный кабинет</a></li>
              <li><a class="menu__item" href="https://msk.dom.ru/payments">Оплатить</a></li>
            </ul>
          </div>

        </div>
        <div class="line_mobile"></div>
          <div class="right_side" >
            <div class="wrapper">
              
              <div  class="phone" ><a href="tel:+74959814571" target="_blank">+7 (495) 981-45-71</a> </div>
              <div class="hamburger-menu menu-right">
                  <input id="menu__toggle_right" class="menu__toggle_right" type="checkbox" />
                  <label class="menu__btn" for="menu__toggle_right">
                    <span></span>
                  </label>

                  <ul class="menu__box">
                    <li><a class="menu__item" href="https://msk.dom.ru/user/login">Личный кабинет</a></li>
                    <li><a class="menu__item" href="https://msk.dom.ru/payments">Оплатить</a></li>
                  </ul>
              </div>
              <div  class="div-6" > 
                <a href="https://msk.dom.ru/user/login"><div class="div-7" >Войти в личный кабинет</div></a>
                <a href="https://msk.dom.ru/payments"><div  class="div-8" >Оплатить</div></a> 
              </div> 
            </div>
          </div> 
          
      </div>
      
<div  class="row" ></div>
<!-- <div class="wrapper_main"> -->
<div  class="div-10" >
<div  class="div-12" >
  <div  class="div-13" >
    <div  class="column" >
      <div  class="div-14" >
        <div  class="div-15" >
          <div  class="div-16" >Частным клиентам</div>
            <div  class="div-17" >
              <div  class="div-18" >Подключайте услуги для дома на новом сайте</div>
              <a href="https://msk.dom.ru/"><div  class="div-19" >Перейти на сайт</div></a>
            </div>
        </div>
        <img  loading="lazy"  srcSet="images/image1_200.png 200w, images/image1_400.png 400w, images/image1_800.png 800w, images/image1_1200.png 1200w, images/image1_1600.png 1600w, images/image1.png"  class="img-2"  /></div></div>
        <div  class="column-2" >
          <div  class="div-20" >
          <div  class="div-21" >
            <div  class="div-22" >Корпоративным клиентам</div>
        <div  class="div-23" ><div  class="div-24" >Подключайте услуги для бизнесаи управляйте ими как привыкли</div>
            <a href="https://moscow.b2b.dom.ru/"><div  class="div-19" >Перейти на сайт</div></a>
        </div></div>
        <img  loading="lazy"  srcSet="images/image2_200.png 200w, images/image2_400.png 400w, images/image2_800.png 800w, images/image2_1200.png 1200w, images/image2_1600.png 1600w, images/image2.png"  class="img-3"  /></div></div></div></div>
      
  <!-- </div> -->
  </div>


  </body>
</html>
