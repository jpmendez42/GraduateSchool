=1284&amp;height=722&amp;smart=true 1284w, https://www.saechsische.de/resizer/v2/YBCU6ZRUPVEJRBGKDICECG6TJA.jpg?auth=fa713004fb5fe4c4f1fcc671cda8a7c7021e8d6edef2d2e40ae9d9cc6928f884&amp;quality=70&amp;width=856&amp;height=482&amp;smart=true 856w, https://www.saechsische.de/resizer/v2/YBCU6ZRUPVEJRBGKDICECG6TJA.jpg?auth=fa713004fb5fe4c4f1fcc671cda8a7c7021e8d6edef2d2e40ae9d9cc6928f884&amp;quality=70&amp;width=767&amp;height=431&amp;smart=true 767w, https://www.saechsische.de/resizer/v2/YBCU6ZRUPVEJRBGKDICECG6TJA.jpg?auth=fa713004fb5fe4c4f1fcc671cda8a7c7021e8d6edef2d2e40ae9d9cc6928f884&amp;quality=70&amp;width=603&amp;height=339&amp;smart=true 603w, https://www.saechsische.de/resizer/v2/YBCU6ZRUPVEJRBGKDICECG6TJA.jpg?auth=fa713004fb5fe4c4f1fcc671cda8a7c7021e8d6edef2d2e40ae9d9cc6928f884&amp;quality=70&amp;width=428&amp;height=241&amp;smart=true 428w"/></div></div><div class="RectangleTeaserstyled__TeaserContentContainer-sc-123berd-1 eHXWOL"><div data-is-element-rendered="true" data-testid="teaser-content" data-teaser-size="l/m/m"><div class="Overlinestyled__Overline-sc-1jsgsl-0 kmbwpz"><span>Von „Cheri, Cheri Lady" bis „Brother Louie"</span></div><div class="TeaserContentTopstyled__HeadlineAvatarContainer-sc-9i9png-0 gAfvGj"><h2 class="Headlinestyled__Headline-sc-mamptc-0 bGMxjt TeaserContentTopstyled__Headline-sc-9i9png-1 feeylJ" data-testid="headline"><span data-testid="paid-icon-container" class="TeaserContentTopstyled__PaidIconContainer-sc-9i9png-2 kSPmPM"><div class="PaidIconstyled__PaidIcon-sc-19nr71-0 CRKtH" data-testid="PaidIcon"><svg role="img" class="PaidIconstyled__Icon-sc-19nr71-2 jVVtDZ" width="1em" height="1em" aria-labelledby="paid-icon" viewBox="0 0 24 24"><title id="paid-icon">Kostenpflichtig</title><use xlink:href="/pf/resources/icons.svg?d=874#PlusFilledWhite"></use></svg></div>﻿</span><span>Dieter Bohlen in Dresden: Was den „Poptitan“ in der Ballsportarena traurig gemacht hat</span></h2></div><p class="TeaserTextstyled__TeaserText-sc-1opeq3e-0 hHcBCj">Zum Abschluss seiner Tour durch Deutschland und Österreich tritt „Poptitan” Dieter Bohlen in Dresden auf. Tausende feiern Bohlen in der Ballsportarena mit „Dieter“-Sprechchören. Dafür gibt es die großen Hits gleich doppelt auf die Ohren.</p></div></div></article></a><div id="fusion-static-exit:contentlist-f0fbYQ71o7SK1nC-5-8-0" style="display:none" data-fusion-component="contentlist-f0fbYQ71o7SK1nC-5-8-0"></div></div><div id="fusion-static-exit:f0fbYQ71o7SK1nC-5-8-0" style="display:none" data-fusion-component="f0fbYQ71o7SK1nC-5-8-0"></div><div class="Dividerstyled__DividerSpacingVisibilityWrapper-sc-1fznxc6-0 kVsyNI"><div data-testid="divider" class="Dividerstyled__Divider-sc-1fznxc6-1 eeAvvG"> </div></div></div><div><div id="fusion-static-enter:f0fQseO7o7SK198-5-8-1" style="display:none" data-fusion-component="f0fQseO7o7SK198-5-8-1"></div><div data-testid="ContentList" class="TeaserListstyled__ContentListContainer-sc-vceyn2-0 fiUBMO"><div id="fusion-static-enter:contentlist-f0fQseO7o7SK198-5-8-1" style="display:none" data-fusion-component="contentlist-f0fQseO7o7SK198-5-8-1"></div><div id="content-list-meta-f0fQseO7o7SK198-5-8-1" data-testid="content-list-meta-f0fQseO7o7SK198-5-8-1" data-offset="4" data-ids="5YQ6ZRSJJBEBNES7R2PT5YMUTA" class="ServerContentListstyled__Meta-sc-1vmrgrb-0 dVzIFK"></div><a href="/kultur/regional/krabat-als-opernfigur-premiere-in-goerlitz-begeistert-das-publikum-5YQ6ZRSJJBEBNES7R2PT5YMUTA.html" class="TeaserLinkstyled__Link-sc-170johp-0 bReGfB"><article data-is-element-rendered="true" data-testid="teaser-content" data-teaser-size="s/s/s" class="DesktopRectangleMobileSquareTeaserstyled__DesktopRectangleMobileSquareTeaser-sc-19vwpog-0 dyhYIB"><div class="TeaserVariantImagestyled__TeaserVariantImage-sc-eh0uzm-0 eousYg DesktopRectangleMobileSquareTeaserstyled__TeaserVariantImage-sc-19vwpog-1 bvKKdp"><div data-testid="image" class="Imagestyled__Container-sc-1io480m-0 hgdEFH"><picture><source media="(min-width: 768px)" srcSet="https://www.sae