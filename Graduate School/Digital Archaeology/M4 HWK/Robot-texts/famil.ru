image/jpeg\",\"filesize\":36579,\"filename\":\"cjfj8uoyp1vxmfvti49qb-384x543.jpg\"},\"w640\":{\"url\":\"/cms/media/cjfj8uoyp1vxmfvti49qb-640x906.jpg\",\"width\":640,\"height\":906,\"mimeType\":\"image/jpeg\",\"filesize\":91543,\"filename\":\"cjfj8uoyp1vxmfvti49qb-640x906.jpg\"},\"w1080\":{\"url\":\"/cms/media/cjfj8uoyp1vxmfvti49qb-1080x1529.jpg\",\"width\":1080,\"height\":1529,\"mimeType\":\"image/jpeg\",\"filesize\":248234,\"filename\":\"cjfj8uoyp1vxmfvti49qb-1080x1529.jpg\"},\"w1920\":{\"url\":\"/cms/media/cjfj8uoyp1vxmfvti49qb-1920x2717.jpg\",\"width\":1920,\"height\":2717,\"mimeType\":\"image/jpeg\",\"filesize\":732986,\"filename\":\"cjfj8uoyp1vxmfvti49qb-1920x2717.jpg\"},\"w3840\":{\"url\":\"/cms/media/cjfj8uoyp1vxmfvti49qb-3840x5435.jpg\",\"width\":3840,\"height\":5435,\"mimeType\":\"image/jpeg\",\"filesize\":2132874,\"filename\":\"cjfj8uoyp1vxmfvti49qb-3840x5435.jpg\"}},\"createdAt\":\"2025-08-14T13:27:36.092Z\",\"updatedAt\":\"2025-08-29T07:05:39.481Z\",\"url\":\"/cms/media/cjfj8uoyp1vxmfvti49qb.jpg\"},\"id\":\"689de43c5b28c06612955526\"}],\"status\":\"published\",\"isVisible\":true,\"startDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"14\",\"customCalendarMonth\":\"08\",\"customCalendarYear\":\"2025\"}},\"beginDate\":\"2025-08-14T00:00:00.001Z\",\"endDateBlock\":{\"castomCalendarBlock\":{\"customCalendarDay\":\"02\",\"customCalendarMonth\":\"02\",\"customCalendarYear\":\"2029\"}},\"endDate\":\"2029-02-02T00:00:00.001Z\",\"blockContent\":[{\"title\":\"\",\"type\":\"text\",\"text\":[{\"children\":[{\"text\":\"Приглашаем вас 16 августа на праздничное открытие нового магазина по адресу: Московская область, г. Коломна, ТЦ «РИО», ул. Октябрьской революции, д. 362, 3 этаж.\"}]},{\"children\":[{\"text\":\"В честь открытия вас ждёт скидка -10% по карте лояльности весь день, ведущий, розыгрыш сертификатов каждый час, вкусный комплимент при покупке от 2000 рублей, а также робот Филимон! Робот будет общаться, шутить и делать для вас фото, которые можно получить на электронную почту. \"}]},{\"children\":[{\"text\":\"Праздничная программа будет проходить с 10:00 до 20:00 — ждём вас!\"}]},{\"children\":[{\"text\":\"Для участников программы лояльности — ещё больше акций и спецпредложений:\"}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"689de46d5b28c06612955527\"},{\"type\":\"button\",\"buttonText\":\"Программа лояльности\",\"buttonLink\":\"https://www.famil.ru/ru/login\",\"buttonColor\":{\"color\":\"#662c83\"},\"buttonFrame\":{\"color\":\"#FFFFFF\"},\"buttonTextColor\":{\"color\":\"#FFFFFF\"},\"id\":\"689de4b15b28c06612955528\"},{\"type\":\"text\",\"text\":[{\"children\":[{\"text\":\"*При применении скидки -10% в день открытия баллы карты лояльности не списываются.\",\"italic\":true}]},{\"children\":[{\"text\":\"*Скидка -10% в день открытия не суммируется с другими акциями и спецпредложениями Familia.\",\"italic\":true}]},{\"children\":[{\"text\":\"*Количество подарков ограничено.\",\"italic\":true}]}],\"buttonColor\":{},\"buttonFrame\":{},\"buttonTextColor\":{},\"id\":\"689de4de5b28c06612955529\"}],\"startPromoDateBlock\":{\"castomCalendarBlock\":{}},\"beginPromoDate\":null,\"endPromoDateBlock\":{\"castomCalendarBlock\":{}},\"endPromoDate\":null,\"sort\":1,\"URLname\":\"kolomna\",\"publicationLocale\":\"locale_all\",\"autoTranslatetoEn\":true,\"autoTranslatetoCn\":true,\"meta\":{},\"createdAt\":\"2025-08-14T13:33:02.101Z\",\"updatedAt\":\"2025-08-14T13:34:11.927Z\"}]}]}]]}]]}],[\"$\",\"$L1c\",null,{}]]}]}]}]}]}]}]\n"])</script><script>self.__next_f.push([1,"1d:I{\"id\":92355,\"chunks\":[\"9313:static/chunks/fdfeff44-33183653e9c29060.js\",\"7728:static/chunks/7728-037425c0981966b0.js\",\"4535:static/chunks/4535-7ddc930e7d2deef9.js\",\"6548:static/chunks/6548-07f5499c27997b7d.js\",\"2139:static/chunks/2139-54e0cc021310d3f4.js\",\"2749:static/chunks/2749-6e3aaca3a7ee2a7b.js\",\"1821:static/chunks/1821-67b12e065693f6d8.js\",\"2838:static/chunks/2838-159008598aa54656.js\",\"8475:static/chunks/84