			height: 10px;
			margin-bottom: 6px;
			margin-top:6px;
		}

		.nl-copertina-img{
			width:100%;
			height: 193px;
			background: #A7A4A8 url(/documents/20182/4902473/newsletter-copertina.jpg/8e87f93f-fddf-0537-e841-f46ccbd2a42e) no-repeat;
			/* background-position: cover; */
			background-size: 100%;
		}

		.nl-copertina-claim-btn{
			margin-top:30px;

		}

		.nl-copertina-claim{
			font-size:24px;
			line-height: 1.2em;
			font-weight:600;
			color:#ffffff;
			text-shadow:
				0px 1px 2px rgba(1, 55, 74,1),
				0px 4px 6px rgba(55,112,132,1),
				0px 4px 8px rgba(55,112,132,1);
		}

		.nl-copertina-btn{
			position:relative;
			display: block;
			border-radius: 32px;
			background: #ffffff;
			border-bottom: 4px solid #28a8db;
			padding: 5px;
			text-align: center;
			font-size: 16px;
			font-weight: 600;
			margin-top: 10px;
			color:#1d7a9e;
			width: 70%;

			-webkit-box-shadow:0 4px 8px 0 rgba(34,42,51,0.16), 0 4px 12px 0 rgba(34,42,51,0.25);
			-moz-box-shadow: 0 4px 8px 0 rgba(34,42,51,0.16), 0 4px 12px 0 rgba(34,42,51,0.25);
			box-shadow: 0 4px 8px 0 rgba(34,42,51,0.16),0px 4px 12px 0 rgba(34,42,51,0.25);

			-webkit-transition: all .1s ease-in-out;
			-moz-transition: all .1s ease-in-out;
			-o-transition: all .1s ease-in-out;
			transition: all .1s ease-in-out;
		}

		.nl-copertina-btn:hover{
			color:#165C76;
			text-decoration:none;
			-webkit-box-shadow:0 8px 16px 0 rgba(34,42,51,0.16), 0 4px 12px 0 rgba(34,42,51,0.25);
			-moz-box-shadow: 0 8px 16px 0 rgba(34,42,51,0.16), 0 4px 12px 0 rgba(34,42,51,0.25);
			box-shadow: 0 15px 20px 0 rgba(34,42,51,0.16),0px 8px 18px 0 rgba(34,42,51,0.25);

		}

		.nl-copertina-btn:before{
			position: absolute;
			content: '';
			background: url(./nl-btn-iscriviti-icon.svg) no-repeat;
			top: 11px;
			width: 11px;
			height: 20px;
			right: 13px;
		}

		.nl-main-item{
			display:block;
			padding: 13px 18px 13px 18px;
			margin: 5px 0px 5px 0px;

			-webkit-transition: all .1s ease-in-out;
			-moz-transition: all .1s ease-in-out;
			-o-transition: all .1s ease-in-out;
			transition: all .1s ease-in-out;
		}

		.nl-secondary-item{
			display:block;
			background:#f1f1f1;
			padding: 25px 20px;

			-webkit-transition: all .1s ease-in-out;
			-moz-transition: all .1s ease-in-out;
			-o-transition: all .1s ease-in-out;
			transition: all .1s ease-in-out;
		}

		.nl-item-icon {
			float:left;
			width:20%;
		}

		.nl-item-icon img{
			max-width:55px;
			margin: 0 auto;
			padding-top: 5px;
		}

		.nl-item-content{
			float:left;
			width:80%;
		}

		.nl-item-date,
		.nl-item-title,
		.nl-item-summary {
			display:block;
		}

		.nl-item-date{
			color:#303030;
			font-size:14px;
		}

		.nl-item-title{
			color:#0066cc;
			font-size:28px;
			font-weight:700;
			line-height: 1em;
		}
		a.nl-main-item:hover{
			background:#E5EFF9;
		}

		a.nl-main-item:hover .nl-item-title{
			text-decoration:underline;
		}

		.nl-item-summary{
			color:#404040;
			font-size:16px;
			font-weight:600;
		}

		.nl-secondary-item .nl-item-date{
			font-size:12px;
		}

		.nl-secondary-item .nl-item-title{
			font-size:22px;
		}

		a.nl-secondary-item:hover{
			background:#E5EFF9;
		}

		a.nl-secondary-item:hover .nl-item-title{
			text-decoration:underline;

		}

		.nl-secondary-item .nl-item-icon img{
			max-width:32px;
		}

		@media only screen and (max-width: 1199px) {
			.nl-copertina-claim-btn{
				margin-top:20px;
				margin-left:10px;
			}

			.nl-copertina-img {
			height: 159px;
			}

			.nl-secondary-item {
				display: block;
				padding: 15px 20px;
				margin-bottom: 5px;
			}
		}
		@media only screen and (max-width: 979px) {
			.nl-copertina-img{
				background-position: 0px -35px;
			}
		}

		@media only screen and (max-width: 590px) {
			.nl-copertina-img{
				background-position: 0px 0px;
			}
		}
		@media only screen and (max-width: 450px) {
			.nl-copertina-claim {
				font-size: 19px;
			}
			.nl-copertina-btn {
				width: 95%;
			}
			.nl-main-item {
				padding: 13px 5px 13px 5px;
			}
			.nl-item-title {
				font-size: 24px;
			}
			.nl-item-summary {
				font-size: 13px;
				line-height: 1em;
				padding-top: 3px;
			}
			.nl-item-icon img {
				max-width: 46px;
			}
			.nl-secondary-item {
				padding: 10px 20px;
				margin-bottom: 5px;
			}
			.nl-copertina-btn {
				font-size: 15px;
			}
			.nl-copertina-btn:before{
				background:none;
			}
			.nl-copertina-img {
				height: 149px;
			}
		}

		/* SEZIONE NEWSLETTER fine  */
	</style>
</div>
