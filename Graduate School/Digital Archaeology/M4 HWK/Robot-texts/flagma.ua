			font-size: 22px;
		}
		.bl2 {font-size: 12px;}
	}
</style>

<div style="text-align: center; padding: 0 20px;">
<div class="bl1">Для корректной работы сайта<br />нам необходимо убедиться, что вы не бот.</div>
<div class="bl2">Для продолжения работы подтвердите, что вы не робот.<br />Мы запомним ваш выбор и в дальнейшем вы сможете пользоваться сайтом без ограничений.</div>
<form id="rcform" action="/robots.txt" method="get"><div id="recaptcha" class="g-recaptcha"></div>
</form></div>

<script>
	var captchaWidgetId;
	var recaptchaPublicKey = "6Ld_lUEUAAAAAHV79_R68i4BtSbm-9G7cWhI4e0b";
	var onloadCallback = function() {
		captchaWidgetId = grecaptcha.render('recaptcha', {
			'sitekey' : recaptchaPublicKey,
			'callback' : function(){
				document.getElementById('rcform').submit();
			}
		});
	};

</script>



