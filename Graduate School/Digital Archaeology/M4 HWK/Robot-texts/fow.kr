<SCRIPT>
$(window).click(function(e) {
    if($(e.target).closest("#history-all").length === 0) $("#history-all").hide();
    if($(e.target).closest("#region_select").length === 0 && $(e.target).closest("#current_region_btn").length === 0) {
        $("#region_select").addClass("hidden");
    }       
});
$("#field").on("click", function(e) {
    $("#history-all").show();
    e.stopPropagation();
});
$('.btn_fav').live( "click", function()
{
    let ikey = $(this).attr('data-ikey');
    let fullname = $(this).attr('data-fullname');
    let region = $(this).attr('data-region');

    if(isFavExists(ikey)) {
        removeFromFav(ikey)
        $(this).show()
    }
    else
    {
        addToFav(ikey, fullname, region)
        $(this).hide();
    }
    $("#history-all").show();
    let _tg = $("#ul_top_fav li a[data-key='" + ikey + "']").closest('li');
    _tg.addClass("fav_highlight");
    setTimeout( function() {
        _tg.removeClass("fav_highlight");
    }, 5000);
    
    if(e.preventDefault)
            e.preventDefault();
    else
            e.returnValue = false;

    return false;       
});
$("#top_champ_title .btn_x").live("click", function(e)
{
    if( confirm("챔피언 기록을 전부 삭제하시겠습니까??") != true ) return false;
    removeAllFavChamps()
});
$("#top_his_title .btn_x").live("click", function(e)
{
    if( confirm("소환사 검색기록을 전부 삭제하시겠습니까??") != true ) return false;
    removeAllHistory()
});
$("#ul_top_his .btn_x,#div_ab_his .btn_x").live( "click", function(e)
{
        let key = $(this).parent().find("A:first-child").attr('data-key');
        removeFromHistory(key);

        if(e.preventDefault)
                e.preventDefault();
        else
                e.returnValue = false;

        return false;
});
$("#ul_top_fav .btn_x,#div_ab_fav .btn_x").live( "click", function(e)
{
        if( confirm("정말 삭제하시겠습니까??") != true ) return false;

        let key = $(this).parent().find("A:first-child").attr('data-key');
        removeFromFav(key);

        let v = $('.username').attr('iname');
        if( key === v )
        {
                $('.btn_fav').show();
        }

        if(e.preventDefault)
                e.preventDefault();
        else
                e.returnValue = false;

        return false;
});
function init_region_select_btn()
{
    $("#current_region_btn").on("click", function (e) {
        if( $("#region_select").hasClass('hidden') )
        {
            $("#region_select").removeClass('hidden');
        }
        else
        {
            $("#region_select").addClass('hidden');
        }
    });
    $(".region_select_btn").on("click", function(e) {
        let region = $(this).text();
        $("#region").val(region);
        $(".current_region_name").text(region);
        $("#region_select").addClass('hidden');
        $.cookie('rg', region, { expires: 3650, path: '/' });
        location.reload();
    });
}
$( function()
{
        init_region_select_btn();
        // update_top_fav();
        // update_top_his();
        // init_top_champs()
        // update_top_champs();
    $( window ).on("scroll", function(e)
        {
                if( $( window ).scrollTop() > 70 )
                {
                    $("#fixed_top").addClass("top_sticky");
                }
                else
                {
                        $("#fixed_top").removeClass("top_sticky");
                }
        });
    $('#find_form').submit(function(e) {
        let field = $('#field').val();
        if(field === '') {
            return false;
        }
        return true;
    });
});
