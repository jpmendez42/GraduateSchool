    .word {
        position: absolute;
        font-size: 60px;
        font-family: "Lato", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
        display: flex;
        justify-content: center;
        margin-bottom: 0px;
        font-weight: 900;
        transform-style: preserve-3d;
        transform-origin: center bottom;
    }
    .word.out {
        transform: rotateX(90deg);
        opacity: 0;
        transition: transform 0.5s ease-in-out, opacity 0.5s ease-in-out;
    }
    .word.behind {
        transform: rotateX(-90deg);
        opacity: 0;
    }
    .word.in {
        transform: rotateX(0deg);
        opacity: 1;
        transition: transform 0.5s ease-in-out, opacity 0.5s ease-in-out;
    }
    .t80 {
        color: #63748A;
    }

    .amber {
        color: #FFCC33;
    }

    .lavender {
        color: #A4A2FF;
    }

    .mint {
        color: #04edba;
    }

    .teal {
        color: #20827C;
    }

    @media (max-width:600px) {
        .word {
            font-size: 40px;
        }
    }
</style>
<p>
    <span style="color: #63748A" class="word t80">efficient</span>
    <span style="color: #FFCC33" class="word amber">visible</span>
    <span style="color: #A4A2FF" class="word lavender">bookings</span>
    <span style="color: #04edba" class="word mint">integrated</span>
    <span style="color: #20827C"class="word teal">money</span>
</p>
<script type="rocketlazyloadscript">
    var words = document.getElementsByClassName('word');
    var currentWord = 0;

    // Initialize first word
    words[currentWord].className = 'word in';

    function changeWord() {
        var cw = words[currentWord];
        var nw = currentWord == words.length-1 ? words[0] : words[currentWord+1];
        
        cw.className = 'word out';
        nw.className = 'word behind';
        setTimeout(function() {
            nw.className = 'word in';
        }, 250); // Slight delay for smoother transition
        
        currentWord = (currentWord == words.length-1) ? 0 : currentWord+1;
    }

    changeWord();
    setInterval(changeWord, 2600);
</script></div></div></div><div  class="column mcb-column mcb-item-jt6jurtcd one laptop-one tablet-one mobile-one column_column" style="" ><div class="mcb-column-inner mfn-module-wrapper mcb-column-inner-jt6jurtcd mcb-item-column-inner"><div class="column_attr mfn-inline-editor clearfix" style=""><p>Manage your entire hotel with one powerful hotel management software.</p></div></div></div></div></div><div  class="wrap mcb-wrap mcb-wrap-b60708352 one tablet-one laptop-one mobile-one clearfix" data-desktop-col="one" data-laptop-col="laptop-one" data-tablet-col="tablet-one" data-mobile-col="mobile-one" style=""   ><div class="mcb-wrap-inner mcb-wrap-inner-b60708352 mfn-module-wrapper mfn-wrapper-for-wraps"  ><div class="mcb-wrap-background-overlay"></div><div  class="wrap mcb-wrap mcb-wrap-2c15b32de one-fifth tablet-one-fifth laptop-one-fifth mobile-one mfn-nested-wrap clearfix" data-desktop-col="one-fifth" data-laptop-col="laptop-one-fifth" data-tablet-col="tablet-one-fifth" data-mobile-col="mobile-one" style=""   ><div class="mcb-wrap-inner mcb-wrap-inner-2c15b32de mfn-module-wrapper mfn-wrapper-for-wraps"  ><div class="mcb-wrap-background-overlay"></div><div  class="column mcb-column mcb-item-7a22067a8 one laptop-one tablet-one mobile-one column_button" style="" ><div class="mcb-column-inner mfn-module-wrapper mcb-column-inner-7a22067a8 mcb-item-button-inner"><a class="button  button_size_2" href="/demo/"         title=""><span class="button_label">Book a demo</span></a>
