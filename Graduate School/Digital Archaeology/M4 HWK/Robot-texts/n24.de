bac0ed/ci23x11-w2000/paderborn-fomsrjp-1748328287 2000w" sizes="(min-width: 910px) calc(970px / 3), (min-width: 600px) 50vw, 100vw"/><img src="https://images.welt.de/68ece0f78803ba0529238cb7/91ec1a4863d71c27d9c765e025bac0ed/ci23x11-w200/paderborn-fomsrjp-1748328287" class="c-picture__image" alt="Die künstlerische Performance „Westfalen Side Story“ des Ensembles Bodytalk im Hohen Dom zu Paderborn am 15. Mai" loading="lazy" decoding="async"/></picture></div></header></div><div class="c-teaser__container is-full-height-flex"><div class="c-teaser__overline"><div class="c-teaser__ellipsis-container"><span class="c-teaser__badge has-frame " data-external="Teaser.TypeBadge"><span class="u-visually-hidden">Artikeltyp<!-- -->:</span>Meinung</span><span class="c-teaser__topic" data-external="Teaser.Topic">Kirchenschändung</span></div></div><div class="c-teaser__body" data-external="Teaser.Body"><h4 class="c-teaser__headline" data-external="Teaser.Title"><a class="is-link c-teaser__headline-link is-teaser-link is-emphasis" href="/kultur/article68ece0f78803ba0529238cb7/kirchenschaendung-der-pinkler-vom-petersdom-und-seine-vielen-gleichgesinnten.html" title="Der Pinkler vom Petersdom und seine vielen Gleichgesinnten" data-external="Teaser.Link" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;news_a_free&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/kultur/article68ece0f78803ba0529238cb7/kirchenschaendung-der-pinkler-vom-petersdom-und-seine-vielen-gleichgesinnten.html&quot;,&quot;trackingName&quot;:&quot;Der Pinkler vom Petersdom und seine vielen Gleichgesinnten&quot;,&quot;trackingLabel&quot;:&quot;Der Pinkler vom Petersdom und seine vielen Gleichgesinnten&quot;}}" aria-label="Meinung - Kirchenschändung: Der Pinkler vom Petersdom und seine vielen Gleichgesinnten">Der Pinkler vom Petersdom und seine vielen Gleichgesinnten</a></h4><p class="c-teaser__intro" data-external="Teaser.Intro">Das Christentum ist geschwächt, aber immer noch so schön, dass sich Menschen an einer Kirchenschändung aufgeilen können. Darin sind sich Hooligans in Rom, britische Künstler und deutsche Theaterleute einig. Was das mit dem Trend zur öffentlichen Selbstverstümmelung zu tun hat.</p></div><script type="application/hydration-data" data-internal-ref="TeaserFooter-4fd26ec0-d2f7-4ae2-7f6f-37c42f101d74">{"teaserId":"68ece0f78803ba0529238cb7","showCommentCount":true,"author":{"name":"Matthias Heine"}}</script><div data-component="TeaserFooter" data-internal-id="TeaserFooter-4fd26ec0-d2f7-4ae2-7f6f-37c42f101d74" class="is-teaser-footer-hydrated"><footer class="c-teaser__footer" data-external="Teaser.Footer"><ul class="c-teaser__footer-list"><li class="c-teaser__footer-list-item"><span class="c-teaser__author" data-external="Teaser.Author">Matthias Heine</span></li></ul></footer></div></div></article></div><div data-external="Stage.Item" class="u-grid-item is-grid-col-mobile-s-12 is-grid-col-mobile-l-6 is-grid-col-tablet-l-4"><article class="c-teaser c-teaser--default" data-external="Teaser" data-external-id="68ecbfdc096e7c49e6b1b964"><div class="c-teaser__container"><header class="c-teaser__header" data-external="Teaser.Header"><div class="c-picture has-placeholder-image is-aspect-ratio-mobile-s-23x11  c-picture--default" data-external="Teaser.PictureElement.Placeholder"><picture class="c-picture__image-container is-aspect-ratio-mobile-s-23x11 "><source media="(min-width:0px)" srcSet="https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w200/verleihung-deutscher-buchpreis-2025 200w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w400/verleihung-deutscher-buchpreis-2025 400w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w600/verleihung-deutscher-buchpreis-2025 600w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w800/verleihung-deutscher-buchpreis-2025 800w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w1000/verleihung-deutscher-buchpreis-2025 1000w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w1200/verleihung-deutscher-buchpreis-2025 1200w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w1400/verleihung-deutscher-buchpreis-2025 1400w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w1600/verleihung-deutscher-buchpreis-2025 1600w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w1800/verleihung-deutscher-buchpreis-2025 1800w, https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w2000/verleihung-deutscher-buchpreis-2025 2000w" sizes="(min-width: 910px) calc(970px / 3), (min-width: 600px) 50vw, 100vw"/><img src="https://images.welt.de/68ecbfdc096e7c49e6b1b964/beb40bdb14b042ed7e0809cce3a4e380/ci23x11-w200/verleihung-deutscher-buchpreis-2025" class="c-picture__image" alt="13.10.2025, Hessen, Frankfurt/Main: Die Schweizer Autorin Dorothee Elmiger wird für ihren Roman «Die Holländerinnen» mit dem Deutschen Buchpreis 2025 ausgezeichnet. Die Auszeichnung für den besten deutschsprachigen Roman wird seit 2005 von der Stiftung Buchkultur und Leseförderung des Börsenvereins des Deutschen Buchhandels verliehen. Foto: Arne Dedert/dpa +++ dpa-Bildfunk +++" loading="lazy" decoding="async"/></picture></div></header></div><div class="c-teaser__container is-full-height-flex"><div class="c-teaser__overline"><div class="c-teaser__ellipsis-container"><span class="c-teaser__badge " data-external="Teaser.Badge"><a class="is-link c-teaser__badge-link is-teaser-link" href="/kultur/" title="Kultur" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;link&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/kultur/&quot;,&quot;trackingName&quot;:&quot;Kultur&quot;,&quot;trackingLabel&quot;:&quot;Kultur&quot;}}" tabindex="-1"><span class="u-visually-hidden">Ressort<!-- -->:</span>Kultur</a></span><span class="c-teaser__topic" data-external="Teaser.Topic">Deutscher Buchpreis</span></div></div><div class="c-teaser__body" data-external="Teaser.Body"><h4 class="c-teaser__headline" data-external="Teaser.Title"><a class="is-link c-teaser__headline-link is-teaser-link" href="/kultur/article68ecbfdc096e7c49e6b1b964/deutscher-buchpreis-fuer-dorothee-elmiger-literatur-als-kuscheldecke-nicht-mit-diesem-buch.html" title="Literatur als Kuscheldecke? Nicht mit diesem Buch!" data-external="Teaser.Link" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;news_a_free&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/kultur/article68ecbfdc096e7c49e6b1b964/deutscher-buchpreis-fuer-dorothee-elmiger-literatur-als-kuscheldecke-nicht-mit-diesem-buch.html&quot;,&quot;trackingName&quot;:&quot;Literatur als Kuscheldecke? Nicht mit diesem Buch!&quot;,&quot;trackingLabel&quot;:&quot;Literatur als Kuscheldecke? Nicht mit diesem Buch!&quot;}}" aria-label="Kultur - Deutscher Buchpreis: Literatur als Kuscheldecke? Nicht mit diesem Buch!">Literatur als Kuscheldecke? Nicht mit diesem Buch!</a></h4><p class="c-teaser__intro" data-external="Teaser.Intro">So mancher sieht Romane als Mittel zum Zweck: Sie sollen Zeit und Entschleunigung schenken, Momente zum Innehalten. Dorothee Elmiger verweigert sich diesem Verständnis von Literatur – und gewinnt den Deutschen Buchpreis verdientermaßen.</p></div><script type="application/hydration-data" data-internal-ref="TeaserFooter-2614a27b-57d5-468a-7237-82693527154b">{"teaserId":"68ecbfdc096e7c49e6b1b964","showCommentCount":true,"author":{"name":"Mara Delius"}}</script><div data-component="TeaserFooter" data-internal-id="TeaserFooter-2614a27b-57d5-468a-7237-82693527154b" class="is-teaser-footer-hydrated"><footer class="c-teaser__footer" data-external="Teaser.Footer"><ul class="c-teaser__footer-list"><li class="c-teaser__footer-list-item"><span class="c-teaser__author" data-external="Teaser.Author">Mara Delius</span></li></ul></footer></div></div></article></div><div data-external="Stage.Item" class="u-grid-item is-grid-col-mobile-s-12 is-grid-col-mobile-l-6 is-grid-col-tablet-l-4"><article class="c-teaser c-teaser--default" data-external="Teaser" data-external-id="68ed08848aebc6b8453b900d"><div class="c-teaser__container"><header class="c-teaser__header" data-external="Teaser.Header"><div class="c-picture has-placeholder-image is-aspect-ratio-mobile-s-23x11  c-picture--default" data-external="Teaser.PictureElement.Placeholder"><picture class="c-picture__image-container is-aspect-ratio-mobile-s-23x11 "><source media="(min-width:0px)" srcSet="https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w200/fussball-woche-wird-eingestellt 200w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w400/fussball-woche-wird-eingestellt 400w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w600/fussball-woche-wird-eingestellt 600w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w800/fussball-woche-wird-eingestellt 800w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w1000/fussball-woche-wird-eingestellt 1000w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w1200/fussball-woche-wird-eingestellt 1200w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w1400/fussball-woche-wird-eingestellt 1400w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w1600/fussball-woche-wird-eingestellt 1600w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w1800/fussball-woche-wird-eingestellt 1800w, https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w2000/fussball-woche-wird-eingestellt 2000w" sizes="(min-width: 910px) calc(970px / 3), (min-width: 600px) 50vw, 100vw"/><img src="https://images.welt.de/68ed08848aebc6b8453b900d/62abbe84983c2a9a4f84b2f2160022f7-master/ci23x11-w200/fussball-woche-wird-eingestellt" class="c-picture__image" alt="13.10.2025, Berlin: Die &quot;Fußball-Woche&quot; liegt in einem Kiosk am Alexanderplatz. Die FuWo wird eingestellt. Nach 102 Jahren ist die Berliner Zeitschrift «Fußball-Woche» an diesem Montag zum letzten Mal erschienen. Foto: Annette Riedl/dpa - ACHTUNG: Nur zur redaktionellen Verwendung im Zusammenhang mit der aktuellen Berichterstattung. +++ dpa-Bildfunk +++" loading="lazy" decoding="async"/></picture></div></header></div><div class="c-teaser__container is-full-height-flex"><div class="c-teaser__overline"><div class="c-teaser__ellipsis-container"><span class="c-teaser__badge has-frame " data-external="Teaser.TypeBadge"><span class="u-visually-hidden">Artikeltyp<!-- -->:</span>Meinung</span><span class="c-teaser__topic" data-external="Teaser.Topic">Fußball-Woche (†102)</span></div></div><div class="c-teaser__body" data-external="Teaser.Body"><h4 class="c-teaser__headline" data-external="Teaser.Title"><a class="is-link c-teaser__headline-link is-teaser-link is-emphasis" href="/sport/fussball/article68ed08848aebc6b8453b900d/fussball-woche-102-fuer-einen-namen-in-der-ueberschrift-gab-es-einen-kasten-bier-in-der-kabine.html" title="Für einen Namen in der Überschrift gab es einen Kasten Bier in der Kabine" data-external="Teaser.Link" data-internal-tracking-enabled="true" data-internal-tracking="{&quot;action&quot;:&quot;click&quot;,&quot;label&quot;:&quot;news_a_free&quot;,&quot;name&quot;:&quot;Inline Element&quot;,&quot;data&quot;:{&quot;source&quot;:&quot;&quot;,&quot;target&quot;:&quot;/sport/fussball/article68ed08848aebc6b8453b900d/fussball-woche-102-fuer-einen-namen-in-der-ueberschrift-gab-es-einen-kasten-bier-in-der-kabine.html&quot;,&quot;trackingName&quot;:&quot;Für einen Namen in der Überschrift gab es einen Kasten Bier in der Kabine&quot;,&quot;trackingLabel&quot;:&quot;Für einen Namen in der Überschrift gab es einen Kasten Bier in der Kabine&quot;}}" aria-label="Meinung - Fußball-Woche (†102): Für einen Namen in der Überschrift gab es einen Kasten Bier in der Kabine">Für einen Namen in der Überschrift gab es einen Kasten Bier in der Kabine</a></h4><p class="c-teaser__intro" data-external="Teaser.Intro">Nach 102 Jahren wird die Fußball-Woche eingestellt. Wegen der FuWo konnten sich Amateurfußballer am Montagmorgen wie Stars fühlen. Das Berliner Blatt setzte auch in den Kabinen der Hauptstadt Maßstäbe. Eine wehmütige Liebeserklärung.</p></div><script type="application/hydration-data" data-internal-ref="TeaserFooter-91ec4aa5-4bea-47fa-7fd1-e18fb1574b34">{"teaserId":"68ed08848aebc6b8453b900d","showCommentCount":true,"author":{"name":"Stephan Flohr"}}</script><div data-component="TeaserFooter" data-internal-id="TeaserFooter-91ec4aa5-4bea-47fa-7fd1-e18fb1574b34" class="is-teaser-footer-hydrated"><footer class="c-teaser__footer" data-external="Teaser.Footer"><ul class="c-teaser__footer-list"><li class="c-teaser__footer-list-item"><span class="c-teaser__author" data-external="Teaser.Author">Stephan Flohr</span></li></ul></footer></div></div></article></div><div data-external="Stage.Item" class="u-grid-item is-grid-col-mobile-s-12 is-grid-col-mobile-l-6 is-grid-col-tablet-l-4"><article class="c-teaser c-teaser--default is-last" data-external="Teaser" data-external-id="68ed577f5d2ebdb13fe7322a"><di