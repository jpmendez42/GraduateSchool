<script type="text/javascript" src="js/jquery.matchHeight.js"></script> 
<script type="text/javascript">
		var minWidth = 450;
		var ctrlMatchHeight = function() {
			if (minWidth <= $(window).width()) {
				// PC
				$('.mH,.mH2,.mH3,.mH4').matchHeight();
			} else {
				// SP
				$('.mH3').matchHeight();
			}
		}
		$(function() {
			ctrlMatchHeight();
			$(window).resize(function(){
				ctrlMatchHeight();
			}).trigger('resize');
		});    
	</script> 
