            <script type="text/javascript">
              //для открытия поиска

                let menu = document.querySelector('.nav-holder');
                let global = document.querySelector('.panel-nav__my-global');
                let search = document.querySelector('.panel-nav__my-search');
                let searchMy = document.querySelectorAll('.search-slide')
                searchMy[1].classList.add('search-slide-input-search')
                const inputSearch = searchMy[1].querySelector('form input')

                let close = searchMy[1].querySelector('.search-slide__close')

                close.addEventListener('click', () => {
                  searchMy[1].classList.toggle('js-slide-hidden')
                  if(searchMy[1].style.display == 'block' ) {
                    searchMy[1].style.display = 'none'
                    inputSearch.value = ''
                    insertContainer.innerHTML = ''
                  } else {
                    searchMy[1].style.display = 'block'
                    inputSearch.value = ''
                    insertContainer.innerHTML = ''
                  }
                })

                search.addEventListener('click', () => {
                  searchMy[1].classList.toggle('js-slide-hidden')
                  if(searchMy[1].style.display == 'block' ) {
                    searchMy[1].style.display = 'none'
                  } else {
                    searchMy[1].style.display = 'block'
                  }
                })

                global.addEventListener('click', () => {
                  let body = document.querySelector('body');
                  body.classList.add('sales-active')
                })

                
                document.addEventListener("DOMContentLoaded", function(){
                  let img = document.querySelector('.kt img')
                  img.style.height = `${window.innerHeight}px`
                  if(window.innerHeight < 800) {
                    img.style.height = `754px`
                  } else {
                    img.style.height = `900px`
                  }
                 
                  let elem = document.querySelector('.kt-viev');
                  if(elem) {
                    let logo = menu.querySelector('.logo');
                    let distance = logo.getBoundingClientRect();
                    let distanceElem = elem.getBoundingClientRect();
                    if(distance.left > 20) {
                        elem.style.left = `${distance.left}px`;
                      } else {
                        elem.style = '';
                      }

                    window.addEventListener('resize', (e) => {
                      let logo = menu.querySelector('.logo');
                      let elem = document.querySelector('.kt-viev');
                      let distance = logo.getBoundingClientRect();
                      let distanceElem = elem.getBoundingClientRect();
                      if(distance.left > 20) {
                        elem.style.left = `${distance.left}px`;
                      } else {
                        elem.style = '';
                      }
                    });
                  }
                });
                
                // для подсказок в поиске

                const arrWord = ['Продукция',
                                'Развитие',
                                'Карьера',
                                'Вакансии',
                                'Пресс-центр', 
                                'Инвесторам', 
                                'Активы', 
                                'Проекты', 
                                'Учредительные документы', 
                                'Комплаенс',
                                'Противодействие коррупции',
                                'Удобрения',
                                'Кормовые продукты',
                                'Экология',
                                'Национальные проекты',
                                'Программа развития регионов',
                                'Корпоративное управление',
                                'Охрана труда',
                                'Vision Zero',
                                'Новости',
                                'Инновации',
                                'Жизнь',
                                'Карьерные программы',
                                'Контакты служб персонала',
                                'Объявления в СМИ',
                                'Социальные сети',
                                'Долговые инвесторы',
                                'Волгакалий',
                                'Еврохим Волгакалий',
                                'Усольский калийный комбинат',
                                'Ковдорский ГОК',
                                'Невинномысский Азот',
                                'НАК АЗОТ',
                                'Фосфорит',
                                'Березники',
                                'Вакансии Березники',
                                'Вакансии Пермь',
                                'Вакансии Волгакалий',
                                'Вакансии Новомосковск',
                                'Вакансии Тула',
                                'Вакансии Ванино',
                                'Вакансии Хабаровск',
                                'Вакансии Ковдор',
                                'Вакансии Санкт-Петербург',
                                'Гремячинский ГОК',
                                'Котельниково',
                                'Белореченск',
                                'Волгоград',
                                'Невинномысск',
                                'Кингисепп',
                                'Москва',
                                'Новомосковск',
                                'Каратау',
                                'УКК',
                                'pte.eurochem.ru',
                                'Контакты',
                                'БМУ Белореченск',
                                'Красноярск',
                                'Кемерово',
                                'ЕвроХим-Северо-Запад',
                                'Производство удобрений',
                                'Вакансии ремонт',
                                'Казахстан']


                searchMy[1].insertAdjacentHTML('beforeend',`<div class="insert-container"></div>`)
                let insertContainer = searchMy[1].querySelector('.insert-container')

                document.addEventListener('click', (e) => {
                  if(e.target != inputSearch) insertContainer.innerHTML = ''
                })

                inputSearch.addEventListener('focus', (e) => {
                  let valueInput = e.target.value.toLowerCase()

                  if(valueInput.length > 0) {
                    for(let i = 0; arrWord.length > i; i++) {
                      if(valueInput == arrWord[i].substr(0, valueInput.length).toLowerCase()) {
                        insertContainer.insertAdjacentHTML('beforeend',`<div class="insert-container__div" data=${i}><span>${arrWord[i].substr(0, valueInput.length)}</span>${arrWord[i].substr(valueInput.length, 999)}</div>`)
                      }
                    }
                  }
                })

                insertContainer.addEventListener('click', (e) => {
                  if(e.target.classList == 'insert-container__div') {
                    inputSearch.value = e.target.innerText
                    insertContainer.innerHTML = ''
                  }
                })

                inputSearch.addEventListener('keydown', (e) => {
                  insertContainer.innerHTML = ''
                })

                inputSearch.addEventListener('keyup', (e) => {
                  if(e.key != 'Shift') {
                    let valueInput = e.target.value.toLowerCase()

                    if(valueInput.length > 0) {
                      for(let i = 0; arrWord.length > i; i++) {
                        if(valueInput == arrWord[i].substr(0, valueInput.length).toLowerCase()) {
                          insertContainer.insertAdjacentHTML('beforeend',`<div class="insert-container__div" data=${i}><span>${arrWord[i].substr(0, valueInput.length)}</span>${arrWord[i].substr(valueInput.length, 999)}</div>`)
                        }
                      }
                    }
                  }
                })
                
            </script>	
