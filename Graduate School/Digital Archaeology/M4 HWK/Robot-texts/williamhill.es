        <style>html{box-sizing:border-box}*,*:before,*:after{box-sizing:inherit}body{background-color:transparent;font-family:Verdana,Helvetica,Helvetica Neue,sans-serif;color:#66728B;margin:0}.no-wrap{white-space:nowrap}.global-modal-wrapper{width:100vw;display:flex}@media screen and (min-width: 576px){.global-modal-wrapper{height:100vh;align-items:center;justify-content:center}}.global-modal{border-radius:3px;overflow:hidden;box-shadow:0 0 10px rgba(11,22,80,0.2);background-color:white;max-width:700px;font-size:12px}.global-modal-header{background-color:#0B1650;display:flex;padding:12px 12px 12px}@media screen and (min-width: 576px){.global-modal-header{padding-top:24px}}.global-modal-header__logo{width:40%;text-align:center;display:flex;justify-content:center;align-items:center;flex-direction:column}@media screen and (min-width: 576px){.global-modal-header__logo{width:30%}}.global-modal-header__logo img{width:100%;padding-right:12px}@media screen and (min-width: 576px){.global-modal-header__logo img{width:70%;padding-right:0px}}.global-modal-header__title{width:70%;color:white;font-weight:normal;display:flex;align-items:center}.global-modal-header__title h1{margin:0;margin-top:3px;font-size:16px;line-height:1.3em;font-weight:normal}@media screen and (min-width: 576px){.global-modal-header__title h1{font-size:20px}}.global-modal-body{background-color:white;padding:12px}.global-modal-body__image{text-align:center}.global-modal-body__image svg{max-height:150px}@media screen and (min-width: 576px){.global-modal-body{display:flex}.global-modal-body__image{width:30%;display:flex;align-items:center;justify-content:center}.global-modal-body__image svg{width:80%}}.global-modal-body__content a:visited,.global-modal-body__content a{color:#00AFFF}@media screen and (min-width: 576px){.global-modal-body__content{width:70%;padding-right:36px}}.global-modal-footer{display:flex;justify-content:space-evenly;flex-direction:row;padding:12px;text-align:center;flex-wrap:wrap;justify-content:space-between}@media screen and (min-width: 576px){.global-modal-footer{flex-wrap:unset}}.global-modal-footer__button{background-color:#F8CE3F;color:#0B1650;display:flex;justify-content:center;flex-direction:column;padding:6px;text-decoration:none;border-radius:3px;font-size:10px;width:calc(33.3% - 6px)}@media screen and (min-width: 576px){.global-modal-footer__button{margin:12px;margin-top:0;width:100%}}.global-modal-footer__button--light{margin-top:12px;background-color:transparent;border:2px solid #F8CE3F;text-align:center;padding:12px;order:4;flex-grow:1;flex-basis:100%}@media screen and (min-width: 576px){.global-modal-footer__button--light{order:0;margin-top:0}}
</style>
        
