	$(document).ready(function() {
        var error = false;
    
        function validateForm(form) {
            var fields = form[0].querySelectorAll('.site-form_item_input');
            error = false;
        
            for (var i = 0; i < fields.length; i++) {
            	if (fields[i].nextElementSibling!==null && fields[i].nextElementSibling.innerHTML!=='ИНН') {
	                $(fields[i]).removeClass('error');
	                if (!fields[i].value) {
	                    $(fields[i]).addClass('error');
	                    error = true;
	                }
                }
            }
        }

		$("form[name=SIMPLE_FORM_5_POPUP]").submit(function( event ) {
			event.preventDefault();
            validateForm($(this))
            
            if (error) return false;
            
            var $dataForm = $(this).serialize() + "&AJAX_CALL=Y&web_form_submit=Y&web_form_apply=Y";
                    
            if ($('#ajax_form_custom').hasClass('e-commerce-form')) {
                $dataForm = $(this).serialize() + "&AJAX_CALL=Y&web_form_submit=Y&web_form_apply=Y&comment=форму заполнили и получили презентацию";
            }
            
			var type_form = "";
			
			$.ajax({
				url: "/ajax/SIMPLE_FORM_5_POPUP.php?utm_term=",
				type: 'POST',
				data: $dataForm,
				cache : false,
				success: function(data, textStatus) {
                    if ($('#ajax_form_custom').hasClass('e-commerce-form')) {
                        const a = document.createElement('a');
                        a.target="_blank";
                        a.href=`${window.location.origin}/upload/2021/b2b-e-commerce-long-rus_final.pdf`;
                        a.click();
                    }        
		
		  
					$('#ajax_form_custom').html(data);
					if ($("form[name=SIMPLE_FORM_5_POPUP]").find('input[name=page_url]').length)
					{
						$("form[name=SIMPLE_FORM_5_POPUP]").find('input[name=page_url]').val(window.location.href);
					}
				    $("form[name=SIMPLE_FORM_5_POPUP]").find("input[type='tel']").mask("+7 (999) 999-9999");
					BX.closeWait();
				},
				error: function (jqxhr, status, errorMs)
				{
					console.log(status);
				}
			});
			return false;
		});
	});
</script>
