<script>
	(function (w) {
		OneSignal = w.OneSignal || [];
		OneSignal.push(['init', {
			appId: 'a2924c17-052d-489d-899d-bbd26021e045',
			autoRegister: false,
			notifyButton: {
				enable: false
			},
			promptOptions: {
				actionMessage: "Odebírejte mimořádné zprávy Aktuálně.cz. Zapněte si upozornění!",
				acceptButtonText: "Ano, zapnout",
				cancelButtonText: "Ne, děkuji"
			},
			welcomeNotification: {
				title: "Aktuálně.cz",
				message: "Děkujeme za přihlášení k odběru!",
			}
		}]);

		function promptAndSubscribeUser() {
			if (!SiteAdvert.source || SiteAdvert.source.substr(0, 3) !== 'sez') {
				OneSignal.push(function() {
					OneSignal.showHttpPrompt();
				});
			}
		}

		if(BBX.checkStorageSupport(w.localStorage)) {
			// rounded per seconds
			var ttl = 60 * 60 * 24 * 60; // seconds * minutes * hours * days
			var name = 'bbxOneSignalConfirmExpire';
			var now = parseInt(Date.now() / 1000, 10);
			var nextTriggerTime = parseInt(w.localStorage.getItem(name), 10);
			if (isNaN(nextTriggerTime) || now >= nextTriggerTime) {
				w.localStorage.setItem(name, now + ttl);
				promptAndSubscribeUser();
				console.log('BBX Onesignal: next trigger planned to timestamp ' + (now + ttl));
			}
		} else {
			promptAndSubscribeUser();
		}

	}(window));
</script>

