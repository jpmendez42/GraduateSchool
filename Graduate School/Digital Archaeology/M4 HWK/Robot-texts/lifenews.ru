hdGlvbnMvMjAyNC84LzYvNzgyOTMzMjM5ODEwLjk2MTQud2VicA==","name":"s3://life-static/publications/2024/8/6/782933239810.9614.webp"}},"index":5768233,"storage":"FILE_STORAGE_RT_S3","storageBucket":"life-static","posts":[],"name":"782933239810.9614.webp","url":"https://static.life.ru/publications/2024/8/6/782933239810.9614.webp","mimeType":"image/webp","size":170532,"fileName":"publications/2024/8/6/782933239810.9614.webp","width":1200,"height":800,"hash":"a73d9d91dec8325a1291d9e4d278d83f76b36514","createdAt":"2024-08-06T10:16:17.163Z","updatedAt":"2024-08-06T10:16:17.163Z"},"coverTitle":"","order":12,"visible":true,"description":"Проект \"SHOT ПРОВЕРКА\" внедрил своих агентов в магазины сети SPAR и выяснил, что лоск сети, за который его многие любят, лишь декорация. Просрочка, антисанитария, нехватка персонала и работа сотрудников на износ — неприглядные реалии супермаркетов.","publicationDate":null,"section":"SPECIAL_PROJECT_SHOT_CHECK","title":"\"На просрочку клейте новую этикетку\": Почему покупатели массово жалуются на магазины SPAR","type":"SPECIAL_PROJECT_EDITORING","url":"https://life.ru/p/1677458","createdAt":"2024-08-06T10:16:28.291Z","updatedAt":"2024-08-06T10:16:28.313Z"},{"_id":"6687993f34419f001269d6ec","flags":{"isMain":false},"cover":{"_id":"6687992ac9e6ff001242a17c","media":{"W450":{"url":"https://static.life.ru/ip/unsafe/rs:fill:450:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC83LzUvMTQzMTg5ODAwMDcyMy4zMDgzLndlYnA=","name":"s3://life-static/publications/2024/7/5/1431898000723.3083.webp"},"W1200":{"url":"https://static.life.ru/ip/unsafe/rs:fill:1200:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC83LzUvMTQzMTg5ODAwMDcyMy4zMDgzLndlYnA=","name":"s3://life-static/publications/2024/7/5/1431898000723.3083.webp"},"W600":{"url":"https://static.life.ru/ip/unsafe/rs:fill:600:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNC83LzUvMTQzMTg5ODAwMDcyMy4zMDgzLndlYnA=","name":"s3://life-static/publications/2024/7/5/1431898000723.3083.webp"}},"index":5753444,"storage":"FILE_STORAGE_RT_S3","storageBucket":"life-static","posts":[],"name":"1431898000723.3083.webp","url":"https://static.life.ru/publications/2024/7/5/1431898000723.3083.webp","mimeType":"image/webp","size":125384,"fileName":"publications/2024/7/5/1431898000723.3083.webp","width":1024,"height":576,"hash":"1eb1c1a56190dfab1d7f4d2a218d7ba287a413c1","createdAt":"2024-07-05T06:56:42.439Z","updatedAt":"2024-07-05T06:56:42.439Z"},"coverTitle":"","order":13,"visible":true,"description":"В последние годы полки магазинов заполнились товарами из Китая. Чтобы заработать больше, байеры даже известных сетей при закупках экономят на качестве. Проект \"SHOT ПРОВЕРКА\" выяснил, как в России легализуют брак и даже несуществующие товары.","publicationDate":null,"section":"SPECIAL_PROJECT_SHOT_CHECK","title":"Как в Россию попадают опасные и бракованные товары из Китая","type":"SPECIAL_PROJECT_EDITORING","url":"https://life.ru/p/1669953","createdAt":"2024-07-05T06:57:03.307Z","updatedAt":"2024-07-08T09:46:22.627Z"}],"layouts":[]}]},{"alias":"Specs","heading":{"type":"Link","title":"Спецпроекты","link":"special"},"layouts":[{"alias":"Top","items":[{"_id":"681b64c97b42c1001383b911","flags":{"isMain":false},"cover":{"_id":"681b64bd74e962001a136f40","media":{"W450":{"url":"https://static.life.ru/ip/unsafe/rs:fill:450:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS81LzcvMTU0MzIyOTEyODk0OC44MjEud2VicA==","name":"s3://life-static/publications/2025/5/7/1543229128948.821.webp"},"W1200":{"url":"https://static.life.ru/ip/unsafe/rs:fill:1200:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS81LzcvMTU0MzIyOTEyODk0OC44MjEud2VicA==","name":"s3://life-static/publications/2025/5/7/1543229128948.821.webp"},"W600":{"url":"https://static.life.ru/ip/unsafe/rs:fill:600:/gravity:ce/q:100/czM6Ly9saWZlLXN0YXRpYy9wdWJsaWNhdGlvbnMvMjAyNS81LzcvMTU0MzIyOTEyODk0OC44MjEud2VicA==","name":"s3://life-static/publications/2025/5/7/1543229128948.821.