<script>
    function hideCookieNotification() {
        var element = document.getElementById("cookie-notification");
        element.style.display = "none";
        localStorage.setItem("cookieNotificationShown", "true");
    }

    document.addEventListener("DOMContentLoaded", function() {
        var cookieNotificationShown = localStorage.getItem("cookieNotificationShown");
        if (cookieNotificationShown) {
            var element = document.getElementById("cookie-notification");
            element.style.display = "none";
        }
    });
</script>
