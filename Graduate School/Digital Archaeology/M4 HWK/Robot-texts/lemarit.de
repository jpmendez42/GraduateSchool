#sp-ea-9696 .spcollapsing { height: 0; overflow: hidden; transition-property: height;transition-duration: 300ms;}#sp-ea-9696.sp-easy-accordion>.sp-ea-single {margin-bottom: 10px; border: 1px none #e2e2e2; }#sp-ea-9696.sp-easy-accordion>.sp-ea-single>.ea-header a {color: #4b5152;}#sp-ea-9696.sp-easy-accordion>.sp-ea-single>.sp-collapse>.ea-body {background: transparent; color: #4b5152;}#sp-ea-9696.sp-easy-accordion>.sp-ea-single {background: transparent;}#sp-ea-9696.sp-easy-accordion>.sp-ea-single>.ea-header a .ea-expand-icon { float: left; color: #4b5152;font-size: 16px;}
