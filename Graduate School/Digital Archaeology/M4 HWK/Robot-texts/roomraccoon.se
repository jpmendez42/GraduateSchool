<!-- DISPLAY POPUP ON CERTAIN PAGES AND COOKIE TO DISPLAY ONCE A DAY
 DOAH -   .com : 247107 & 250647 
NL : 247276
DE: 
ES: 
PT: 247473

NL pop-up : 250863
ES pop up : 250865
PT pop up : 250864
 -->
 <script type="rocketlazyloadscript" data-rocket-src="https://cdnjs.cloudflare.com/ajax/libs/js-cookie/3.0.1/js.cookie.min.js" defer></script>
<script type="rocketlazyloadscript">
jQuery(document).ready(function() {
    console.log("Script is running");

    function showPopup(pageIds, popupId, cookieKey) {
        var popupCount = Cookies.get(cookieKey) ? parseInt(Cookies.get(cookieKey)) : 0;
        var currentURL = window.location.href;
        var isPageMatched = pageIds.some(id => jQuery('body').hasClass(id));

        console.log("Checking pop-up:", popupId);
        console.log("Popup count:", popupCount);
        console.log("Is page matched:", isPageMatched);
        console.log("Cookie value:", Cookies.get(cookieKey));

        if (popupCount < 2 && isPageMatched) {
            console.log("Showing popup:", popupId);
            jQuery(popupId).fadeIn().addClass('mfn-popup-active');
            Cookies.set(cookieKey, popupCount + 1, { expires: 1 });
        } else {
            console.log("Hiding popup:", popupId);
            jQuery(popupId).hide();
        }
    }

    // **Hide all pop-ups by default to prevent unwanted display**
    var popupIDs = [
        "#mfn-popup-template-244066",
        "#mfn-popup-template-250863",
        "#mfn-popup-template-250864",
        "#mfn-popup-template-250865"
    ];

    popupIDs.forEach(function(popupId) {
        jQuery(popupId).hide();
    });

    var pagePopups = [
        { pageIds: ['page-id-247107', 'page-id-246990'], popupId: '#mfn-popup-template-244066', cookieKey: 'mfn-popup-count-244066' },
        { pageIds: ['page-id-247276', 'page-id-250684'], popupId: '#mfn-popup-template-250863', cookieKey: 'mfn-popup-count-250863' },
        { pageIds: ['page-id-247473', 'page-id-250675'], popupId: '#mfn-popup-template-250864', cookieKey: 'mfn-popup-count-250864' },
        { pageIds: ['page-id-247778', 'page-id-250676'], popupId: '#mfn-popup-template-250865', cookieKey: 'mfn-popup-count-250865' }
    ];

    pagePopups.forEach(function(popup) {
        showPopup(popup.pageIds, popup.popupId, popup.cookieKey);
    });
});
</script>


