\u043e-\u043c\u0438\u043d\u0435\u0440\u0430\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043c\u0443\u0437\u0435\u0439 \u0438\u043c\u0435\u043d\u0438<b> \u0412\u0430\u043b\u0435\u043d\u0442\u0438\u043d\u0430 \u0418\u0432\u0430\u043d\u043e\u0432\u0438\u0447\u0430 \u0417\u0443\u0431\u043e\u0432\u0430<\/b>&nbsp;\u2014 \u043c\u0435\u0441\u0442\u043e \u0434\u043b\u044f \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0445 \u0432\u0441\u0442\u0440\u0435\u0447! \u0414\u043b\u044f \u0448\u043a\u043e\u043b\u044c\u043d\u0438\u043a\u043e\u0432, \u0441\u0442\u0443\u0434\u0435\u043d\u0442\u043e\u0432 \u0438 \u043f\u0440\u0435\u043f\u043e\u0434\u0430\u0432\u0430\u0442\u0435\u043b\u0435\u0439 \u041f\u0440\u043e\u0441\u0432\u0435\u0442\u0430 \u043f\u0440\u043e\u0448\u043b\u0430 \u0432\u044b\u0441\u0442\u0430\u0432\u043a\u0430 \u00ab\u0416\u0438\u0437\u043d\u044c \u043a\u0430\u043c\u043d\u0435\u0439\u00bb.<br>\r\n <\/span><br>\r\n <span style=\"font-family: Georgia, serif; font-size: 14pt;\">\u0415\u0451 \u043f\u0440\u043e\u0432\u0451\u043b \u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439 \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u0438\u0437\u0430\u0442\u043e\u0440 \u043c\u0438\u043d\u0435\u0440\u0430\u043b\u043e\u0433\u0438\u0438, \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a, \u043e\u0441\u043d\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u043e-\u043f\u043e\u0437\u043d\u0430\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0439 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u044b<b> <\/b><\/span><a href=\"https:\/\/t.me\/aprelevka_geology_VALENTIN\" title=\"https:\/\/t.me\/aprelevka_geology_VALENTIN\" target=\"_blank\"><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\"Aprelevka-geology\" <\/b><\/span><\/a><span style=\"font-family: Georgia, serif; font-size: 14pt;\"><b>\u0412\u0430\u043b\u0435\u043d\u0442\u0438\u043d \u0410\u043b\u0435\u043a\u0441\u0430\u