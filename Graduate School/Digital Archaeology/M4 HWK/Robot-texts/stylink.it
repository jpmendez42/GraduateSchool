<script id="cornerstone-custom-js" type="text/javascript">
/* <![CDATA[ */
jQuery(document).ready(function($) {
	$(".esg-navigationbutton.esg-left, .esg-navigationbutton.esg-right").click(function() {
		$('html, body').animate({
			scrollTop: $("#esg-grid-1-1-wrap").offset().top
		}, 1000);
	});
});

/* All Details Toggle */
const All_Details = document.querySelectorAll('details');
if (typeof(All_Details) != 'undefined' && All_Details != null) {
	All_Details.forEach(deet=>{
		deet.addEventListener('toggle', toggleOpenOneOnly)
	});
}

function toggleOpenOneOnly(e) {
	if (this.open) {
		All_Details.forEach(deet=> {
			if (deet!=this && deet.open) deet.open = false
		});
	}
}

/* Hide iMessage for non-Apple devices */
document.addEventListener('DOMContentLoaded', function () {
	const isAppleDevice = /Mac|iPhone|iPad|iPod/.test(navigator.userAgent);
	if (!isAppleDevice) {
		const appleOnlyElements = document.querySelectorAll('.apple-only');
		if (typeof(appleOnlyElements) != 'undefined' && appleOnlyElements != null) {
			appleOnlyElements.forEach(element => {
				element.style.display = 'none';
			});
		}
	}
});

/* Show more and show less "Deine Benefits", Karriere Seite */
const moreButton = document.getElementById('load-more');
const lessButton = document.getElementById('show-less');

if (typeof(moreButton) != 'undefined' && moreButton != null && typeof(lessButton) != 'undefined' && lessButton != null) {
	document.getElementById('load-more').addEventListener('click', function() {
    	let items = document.querySelectorAll('.grid-item');

		for (let i = 0; i < 13; i++) { // Show first 13 items
			if (items[i]) {
				items[i].style.display = 'block';
			}
		}
	
		// Hide "Load More" button
		this.style.display = 'none';
		// Show "Show Less" button
		document.getElementById('show-less').style.display = 'inline-block';
	});

	document.getElementById('show-less').addEventListener('click', function() {
		let items = document.querySelectorAll('.grid-item');
	
		for (let i = 5; i < 13; i++) { // Hide items again (keep first 4 visible)
			if (items[i]) {
				items[i].style.display = 'none';
			}
		}
	
		// Show "Load More" button again
		document.getElementById('load-more').style.display = 'inline-block';
		// Hide "Show Less" button
		this.style.display = 'none';
	});
}	

/* ]]> */
</script>

</body>
</html>