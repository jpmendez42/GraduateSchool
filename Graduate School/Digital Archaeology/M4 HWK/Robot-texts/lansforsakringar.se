<!DOCTYPE html>
<html lang=" sv">

<head>
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="-1" />
    <meta http-equiv="CacheControl" content="no-cache" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <link rel="shortcut icon" href="data:;base64,iVBORw0KGgo=" />
    <meta name="viewport" content="width=device-width, initial-scale=0.5">

    <style>
        body {
            background-color: #F3F3F3;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            height: 100%;
            top: -570px;
            left: -1680px;
            padding-bottom: 142px;
            gap: 72px;
        }

        header {
            width: 100%;
            height: 62px;
            background-color: white;
            display: flex;
            justify-content: left;
            align-items: left;
            border-bottom: 2px solid #E0E0E0;
        }

        header div {
            padding-top: 12px;
            padding-left: 162px;
        }


        .bottom {
            display: flex;
            flex-direction: column;
            padding-right: 40px;
            padding-left: 40px;
        }

        .link {
            /*styleName: Link/Secondary;
                    */
            font-family: Arial;
            font-size: 16px;
            font-weight: 400;
            line-height: 19px;
            color: #005AA0;
        }

        .captcha-base {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-direction: column;
        }


        .captcha-image {
            align-items: center;
            display: flex;
            gap: 16px;
        }


        .input {
            display: flex;
            flex-direction: row;
            gap: 24px;
            margin-top: 48px;

        }

        .base-container {
            align-items: center;
            background-color: white;
            display: flex;
            width: 90%;
            max-width: 790px;
            flex-direction: column;
            padding: 80px 0px 80px 0px;
            gap: 48px;

        }

        .container {
            align-items: center;
            background-color: white;
            display: flex;
            width: 90%;
            max-width: 790px;
            flex-direction: column;
            gap: 16px;
            padding: 0;
        }


        .container h1 {
            font-family: "LF Rubrik", georgia, "Times New Roman", times, serif;
            size: 50px;
            font-weight: 400;
            line-height: 60px;
            text-align: center;
            color: #005AA0;
        }

        .container p {
            font-family: "Intro Cond", arial, "Helvetica Neue", sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
            size: 18px;
            font-weight: 400;
            line-height: 23px;
            width: 100%;
            max-width: 480px;
            text-align: center;
            color: #222222;
        }

        .textarea {
            margin: 0;
            width: 100%;
            max-width: 480px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* LF Rubrik Font */
        @font-face {
            font-family: "LF Rubrik";
            src: url(data:font/woff;base64, ) format("woff");
        }

        @media (min-width: 768px) {

            .base-container {
                width: 80%;
                padding: 80px 0px;
            }

            .container h1 {
                font-size: 2.5rem;
            }

            .container p {
                font-size: 1.25rem;
            }
        }

        @media (min-width: 992px) {
            .body {
                height: auto;
            }

            header div {
                padding-left: 162px;
            }
        }


        .input button:not([disabled]):not(.disabled):active {
            color: #00325c;
            background: #f2f7fb;
            border-color: #00325c;
            box-shadow: inset 0 0 0 1px #00325c, inset 0 0 0 1px #00325c, inset 0 0 0 1px #00325c, inset 0 0 0 1px #00325c;

        }

        .input button:hover {
            text-decoration: none;
            transition: .2s linear;
            transition-property: all;

        }

        .input button:hover,
        .input button:hover:focus {
            color: #00325c;
            background-color: transparent;
            border-color: #00325c;
            box-shadow: inset 0 0 0 1px #00325c, inset 0 0 0 1px #00325c, inset 0 0 0 1px #00325c, inset 0 0 0 1px #00325c;
        }

        .input button {
            display: flex;
            flex-direction: column;
            padding: calc(.5rem - 2px) calc(1rem - 2px);
            color: #00427a;
            background-color: transparent;
            border-color: #00427a;
            border-radius: .25rem;
            position: relative;
            overflow: hidden;
            font-family: "Intro Cond", arial, "Helvetica Neue", sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
            font-size: 18px;
            text-decoration: none;
            white-space: normal;
            cursor: pointer;
            border-width: 2px;
            border-radius: .25rem;
            transition: .2s linear;
            transition-property: all;
            -webkit-font-smoothing: antialiased;
            display: inline-block;
            font-weight: 700;
            text-align: center;
            vertical-align: middle;
            border: 2px solid;
            -webkit-appearance: button;
            box-sizing: border-box;
            margin-top: 23px;
            margin-bottom: 40px;
        }

        .form-group input:invalid {
            box-shadow: none;
        }

        .form-group input:focus {
            border-color: #005aa0;
            color: #222;
            background-color: #f3f3f3;
            border-color: #005aa0;
            outline: 0;
            box-shadow: none, 0 0 8px #66afe999;
            outline: 0 !important;
        }

        .form-group input:hover:not(:disabled) {
            background: #ececec;
            transition: background .2s;
        }

        .input label {
            display: flex;
            font-family: "Intro Cond", arial, "Helvetica Neue", sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
            font-size: 16px;
            font-weight: 700;
            line-height: 19px;
            margin-bottom: 4px;
        }

        .input-description {
            font-family: arial, "Helvetica Neue", sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
            font-weight: 400;
            font-size: 14px;
            line-height: 18px;
            width: auto;
            height: 36px;
            margin: 0;
            display: flex;
            margin-top: 4px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            text-decoration-thickness: 1px !important;
            text-underline-offset: .1em;
            box-sizing: border-box;
        }


        input {
            text-rendering: auto;
            color: fieldtext;
            letter-spacing: normal;
            word-spacing: normal;
            line-height: normal;
            text-transform: none;
            text-indent: 0px;
            text-shadow: none;
            display: inline-block;
            text-align: start;
            appearance: auto;
            -webkit-rtl-ordering: logical;
            cursor: text;
            background-color: field;
            margin: 0em;
            padding: 1px 0px;
            border-width: 2px;
            border-style: inset;
            border-color: light-dark(rgb(118, 118, 118), rgb(133, 133, 133));
            border-image: initial;
            padding-block: 1px;
            padding-inline: 2px;
        }

        :root {
            --font-family-sans-serif: var(--lf-font-family-sans-serif);
            --font-family-serif: var(--lf-font-family-serif);
            --font-family-base: arial, Helvetica Neue, sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica Neue, Noto Sans, Liberation Sans, Apple Color Emoji, Segoe UI Emoji, Segoe UI Symbol, Noto Color Emoji;
            --font-family-monospace: SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, Courier New, monospace;
            --font-size-xl: 1.25rem;
            --font-size-lg: 1.125rem;
            --font-size-md: 1rem;
            --font-size-sm: .875rem;
            --font-size-xs: .75rem;
            --font-line-height: 1.45;

            --ease-in: cubic-bezier(.4, 0, 1, 1);
            --ease-out: cubic-bezier(0, 0, .2, 1);
            --ease: cubic-bezier(.4, 0, .2, 1);

            --color-body: #222;
            --color-info: #005aa0;
            --color-info-light: #e5eff7;
            --color-success: #1B5E20;
            --color-success-light: #e5fff0;
            --color-warning: #fdd835;
            --color-warning-light: #ffffd6;
            --color-danger: #ad1015;
            --color-danger-light: #FCD2D3;
            --color-risk-0: #515151;
            --color-risk-1: #2a7fd4;
            --color-risk-2: #389fb9;
            --color-risk-3: #8dba84;
            --color-risk-4: #b8be34;
            --color-risk-5: #fdb514;
            --color-risk-6: #ed7721;
            --color-risk-7: #ce161d;
            --login-logout-blue: #007db0;

            --wine: #ad1015;
            --red: #e30613;
            --pink: #FCD2D3;
            --green: #1B5E20;
            --mint: #e5fff0;
            --orange: #fdd835;
            --yellow: #ffffd6;
            --navy: #00427a;
            --blue: #005aa0;
            --sky: #76bbe7;
            --baby: #badaf3;
            --cloud: #eff4f9;
            --mist: #f9fbfd;
            --black: #222;
            --gray: #6b7070;
            --aluminium: #8C8F90;
            --silver: #b1b3b6;
            --smoke: #d9d9d9;
            --shadow: #e5e5e5;
            --tint: #f3f3f3;
            --white: #fff;

            --duet-color-primary: $blue;
            --duet-color-text: inherit;
            --duet-color-text-active: $black;
            --duet-color-placeholder: #666;
            --duet-color-button: $black;
            --duet-color-surface: $white;
            --duet-color-overlay: rgba(0, 0, 0, .7);
            --duet-color-border: #eee;
            --duet-font: inherit;
            --duet-font-normal: normal;
            --duet-font-bold: bold;
            --duet-radius: 0;
            --duet-z-index: 4;

            --background-box-hover: var(--white);
        }

        .form-group input {
            box-shadow: none;

            min-width: 0;

            min-height: 40px;
            padding: .663rem .75rem .463rem;
            font-weight: 400;
            line-height: 1.25;
            background-clip: inherit;
            transition: border-color 60ms linear;

            display: block;
            width: 100%;
            height: 40px;
            padding: .563rem .75rem;
            font-size: 1rem;
            font-weight: 400;
            line-height: 1.25;
            color: #222;
            background-color: #f3f3f3;
            background-clip: padding-box;
            border: 2px solid #d9d9d9;
            border-width: 0 0 2px 0;
            border-radius: 0;


            font-family: arial, Helvetica Neue, sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica Neue, Noto Sans, Liberation Sans, "Apple Color Emoji", "Segoe UI Emoji", Segoe UI Symbol, "Noto Color Emoji";
            font-size: 1rem;
            font-weight: 400;
            line-height: 1.45;
            color: #222;
            text-align: left;
            background-color: #f3f3f3;

            overflow: visible;

            text-decoration-thickness: 1px !important;
            text-underline-offset: .1em;

            box-sizing: border-box;

            padding-block: 1px;
            padding-inline: 2px;

        }
    </style>


</head>

