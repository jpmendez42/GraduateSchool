<span id="BrowserInfoModal" data-jn-modal
    data-trigger="event"
    data-open-auto="false"
    data-confirm-txt="LUK"
    data-hide-dismiss="true"
    data-scope="{'url': 'https://support.jobnet.dk/krav-til-dit-system/browsere-og-smartphones'}"
    data-title="Du bør ikke bruge Internet Explorer på Jobnet efter d. 12. juni 2021"
    data-view="/CV/Areas/Frontpage/Scripts/Angular/Modal/partial.browserNotSupported.html">
</span>

<article id="Welcome" class="dynamic-background clearfix" aria-label="Welcome to Jobnet">
    
    <h1 class="sr-only">Velkommen til Jobnet</h1>
    <div id="WelcomeContent" class="bootstrap-container">
        <div class="row">
            <article id="FindJobs" class="col-xs-12 col-sm-6 col-md-5 col-lg-4" aria-label="Find job">
                <div>
                    <h2>
                        <label for="SearchField">Find job</label>
                    </h2>
                    <section aria-label="Søg på jobnet">
                        <form id="frmFrontPageSearch">
                            <input id="SearchField" type="Search" placeholder="fx stilling, by, virksomhed" />
                            <button id="btnSearch"
                                    class="button-search icon icon-spyglass icon-2x"
                                    type="submit"
                                    aria-label="Søg på Jobnet">
                            </button>
                        </form>
                    </section>
                    <!--
                        <a class="text-small" id="AdvancedSearch" href="/CV/FindWork"> &gt; Vis flere søgekriterier</a>
                    -->
                    <a aria-label="Vis flere søgekriterier" class="primary" href="/CV/FindWork" id="AdvancedSearch">Vis flere s&#248;gekriterier</a>
                </div>
            </article>

            
                <section id="Credentials" class="col-xs-12 col-sm-6 col-md-5 col-lg-4" aria-label="Login">
                    <div id="LoginExistingUser">
                        <span id="SkipNavigation" tabindex="-1"></span>
                        
                        <h2 id="MainContent" tabindex="-1">
                            Allerede bruger?
                        </h2>
                        <a id="CredentialsKnownUserMitIdLogin" class="button primary nemlogin-focus" href="/CV/login.ashx?profile=Person" aria-label="Log ind med MitID">
                            Log ind med <img src="/CV/Images/Frontpage/MitID_LOGO_CLEAN_CROPPED_1d3847.png?jv=2025.3.0.18" alt="MitID" width="73" height="16" />
                        </a>
                        <hr />
                        <div class="login-operations">
                            <a aria-label="Har du ikke MitID? Gå til log ind med brugerkoder" class=" primary" href="/CV/UsernameAndPassword">Har du ikke MitID? G&#229; til log ind med brugerkoder</a>
                        </div>
                    </div>
                    
                    <div id="CreateNewUser">
                        <h2>
                            Ny bruger?
                        </h2>
                        <a id="CredentialsCreateNewUser" href="/CV/NemLogin/CreateCitizenProfile" class="button"
                           aria-label="Opret mig med MitID">Opret mig med <img src="/CV/Images/Frontpage/MitID_LOGO_CLEAN_CROPPED_1d3847.png?jv=2025.3.0.18" alt="MitID" width="73" height="16" /></a>
                    </div>
                </section>
            <ul class="contact-support col-xs-12 col-sm-6 col-md-7 col-lg-8">
                <li class="col-xs-12 col-md-6">
                    <a href="https://info.jobnet.dk/mit-jobcenter" target="_blank">
                        <img src="/CV/Images/FrontPage/JobcenterImage.png?jv=2025.3.0.18" alt="Kontakt dit jobcenter billede" />
                        <figure>Kontakt dit jobcenter</figure>
                    </a>
                </li>
                <li class="col-xs-12 col-md-6">
                    <a href="https://support.jobnet.dk" target="_blank">
                        <img src="/CV/Images/FrontPage/KontaktSupportenImg.jpg?jv=2025.3.0.18" alt="Kontakt supporten billede" />
                        <figure>Support</figure>
                    </a>
                </li>
            </ul>
        </div>
    </div>
</article>


