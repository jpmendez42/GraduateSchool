<html lang="en"><head>
      <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
      <!-- Meta, title, CSS, favicons, etc. -->
      <meta charset="utf-8">
      <meta http-equiv="X-UA-Compatible" content="IE=edge">
      <meta name="viewport" content="width=device-width, initial-scale=1">
      <title>4Bet</title>
      <link rel="icon" type="image/png" sizes="16x16" href="/images/fav_icon.png">
       <link rel="preconnect" href="https://fonts.gstatic.com?v=0.15">
<link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@300&display=swap?v=0.15" rel="stylesheet">
      <!-- Bootstrap -->
       <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css?v=0.15">
      <!-- Font Awesome -->
      <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.css?v=0.15" rel="stylesheet">
      <!-- Custom Theme Style -->
      <link href="/user/css/custom.css?v=0.15" rel="stylesheet">
      <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.6.9/angular.min.js"></script>  
      <script src="https://cdn.jsdelivr.net/npm/@fingerprintjs/fingerprintjs@3/dist/fp.min.js"></script>
</head>
   <body class="bg_login">
  
      <div id="wrapper">
         <div class="logo"><img src="/user/images/4bet.png" alt="..."></div>
         <div ng-app="loginApp" ng-controller="loginController" class="form">
            <section class="login_content">
           <form name="loginForm" 
        ng-submit="validateAndSubmit(loginForm)" 
        novalidate 
        autocomplete="off"
        method="post"
        action="/home">
		   <span style="color:red;font-weight:bold" id="error">  </span>
               <div>
                  <label> Username</label>
                  <div class="linput">  <input  type="text" name="userid" placeholder="Username" 
		             ng-model="userid" 
		             required 
		             style="padding-left:10px;font-weight:bold" value=""
		             class="form-control">
                  </div>
               </div>
               <div>
                  <label> Password</label>
                  <div class="linput">  <input  style="padding-left:10px;font-weight:bold"
                  type="password" 
             name="password" 
             placeholder="Password" 
             ng-model="password" 
             required 
             class="form-control">
             
              <input type="hidden" ng-model="type" name="type" />
</div>
               </div>
               <div class="checkbox">
                  <label><input type="checkbox" name="remember" id="remember"> Remember me</label>
				 <a style="color: #232323;" href="" class="download-apk-btn"> <i class="fa fa-android"></i></a>
               </div>
               <div>
                  
                  <button type="submit" class="btn btn-default submit">Log in</button>
                  
                   <h6 style="color:#000;font-weight:bold" id="loginMessage">-</h6>
               </div>
               <div class="clearfix"></div>
               </form>            </section>
         </div>
      </div>
 
   

</body></html>

    

<script>
		$(document).ready(function(){
			
			getLoginMessage();
			window.name = "dublicateTabs";
				selfLogoutUser()
			
		});
		
		function selfLogoutUser(){
	        $.ajax({
	       			url:'/api/logout;jsessionid=48F66D6B81C815874B04644163F8647D?id='+"",
	      			success: function(jsondata, textStatus, xhr) {
	      				if(xhr.status == 200){
	      				}
	        		}
	        	});
	        }
		
		
		function getLoginMessage()
		 {
		 	$.ajax({
		 				type:'POST',
		 	   			url:'/api/getLoginMessage;jsessionid=48F66D6B81C815874B04644163F8647D?userType=1',
		 	  			success: function(jsondata, textStatus, xhr) {
		 	  				if(xhr.status == 200){
							 $("#loginMessage").html(jsondata.message);
		 	  				}
		 	    		}
		 	    	});  
		         	
		 }
	
</script>


