strar imagen según radio seleccionado */\n    #h-calzado:checked ~ .card-container .img-calzado,\n    #h-ropa:checked ~ .card-container .img-ropa,\n    #h-accesorios:checked ~ .card-container .img-accesorios {\n        display: block;\n    }\n    .texto-descriptivo {\n      margin: 10px 0;\n      font-weight: 800;\n\n    }\n\n    .botones {\n      display: flex;\n      justify-content: center;\n      gap: 10px;\n      margin-bottom: 20px;\n    }\n\n   .botones a {\n        background-color: white;\n        color: #666;\n        padding: 8px 16px;\n        border-radius: 20px;\n        border: 1px solid #ccc;\n        text-decoration: none;\n        font-size: 0.9rem;\n        transition: all 0.3s ease;\n    }\n\n    .botones a:hover {\n    background-color: #333;\n    color: white;\n    border-color: #333;\n    }\n\n      .botones label {\n    background-color: white;\n    color: #666;\n    padding: 8px 16px;\n    border-radius: 20px;\n    border: 1px solid #ccc;\n    text-decoration: none;\n    font-size: 0.9rem;\n    transition: all 0.3s ease;\n    cursor: pointer;\n  }\n\n  .botones label:hover {\n    background-color: #333;\n    color: white;\n    border-color: #333;\n  }\n\n  .botones {\n    display: flex;\n    justify-content: center;\n    gap: 10px;\n    margin-top: 10px;\n  }\n\n    @media (max-width: 768px) {\n        .texto-botones{\n            margin-top: 0%;\n            display:block;\n        }\n    }\n  \u003c/style\u003e\n\n\u003cdp-container\u003e\n    \u003cdp-h2\u003eMESES SIN INTERESES Y ENVÍO GRATIS\u003c/dp-h2\u003e\n    \u003cdiv class=\"contenedor-cards\"\u003e\n  \u003c!--TARJETA PARA HOMBRE--\u003e\n      \u003cdiv class=\"card\"\u003e\n          \u003cdiv class=\"card-container\"\u003e\n              \u003ca href=\"/hombre-segundo-articulo\"\u003e\n              \u003cimg src=\"https://dpjye2wk9gi5z.cloudfront.net/wcsstore/DportenisStorefrontAssetStore/Img/Banners/2025/septiembre/Secundarios%20home/secundarios-home-dportenis-02.webp\" alt