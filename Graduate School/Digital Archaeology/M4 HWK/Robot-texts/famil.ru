nks/6548-07f5499c27997b7d.js\",\"2139:static/chunks/2139-54e0cc021310d3f4.js\",\"2749:static/chunks/2749-6e3aaca3a7ee2a7b.js\",\"1821:static/chunks/1821-67b12e065693f6d8.js\",\"2838:static/chunks/2838-159008598aa54656.js\",\"8475:static/chunks/8475-9144134b303e6b03.js\",\"9274:static/chunks/9274-0789ba12ccf9bf65.js\",\"6938:static/chunks/6938-17b5ad9866a655b8.js\",\"724:static/chunks/724-f36de06f7198ae75.js\",\"6754:static/chunks/6754-63e8ff37e5152ac6.js\",\"8:static/chunks/8-e5cc71b684e530c8.js\",\"1376:static/chunks/1376-363a5420d1d0d55f.js\",\"3311:static/chunks/3311-b4b1d180944cbdf9.js\",\"6186:static/chunks/6186-cd8f667a991c30ba.js\",\"3645:static/chunks/3645-075b7cf44d6ff90f.js\",\"5896:static/chunks/5896-c8af9181e1ef3411.js\",\"3463:static/chunks/3463-f74410595dbb225e.js\",\"1356:static/chunks/1356-dfeda3edebfb6633.js\",\"9203:static/chunks/9203-9dd30fc91865952f.js\",\"4577:static/chunks/4577-8b083eedacb02d4b.js\",\"8805:static/chunks/app/(root)/[locale]/page-7c013cb352997da2.js\"],\"name\":\"\",\"async\":false}\n"])</script><script>self.__next_f.push([1,"34:I{\"id\":99359,\"chunks\":[\"9313:static/chunks/fdfeff44-33183653e9c29060.js\",\"7728:static/chunks/7728-037425c0981966b0.js\",\"4535:static/chunks/4535-7ddc930e7d2deef9.js\",\"6548:static/chunks/6548-07f5499c27997b7d.js\",\"2139:static/chunks/2139-54e0cc021310d3f4.js\",\"2749:static/chunks/2749-6e3aaca3a7ee2a7b.js\",\"1821:static/chunks/1821-67b12e065693f6d8.js\",\"2838:static/chunks/2838-159008598aa54656.js\",\"8475:static/chunks/8475-9144134b303e6b03.js\",\"9274:static/chunks/9274-0789ba12ccf9bf65.js\",\"6938:static/chunks/6938-17b5ad9866a655b8.js\",\"724:static/chunks/724-f36de06f7198ae75.js\",\"6754:static/chunks/6754-63e8ff37e5152ac6.js\",\"8:static/chunks/8-e5cc71b684e530c8.js\",\"1376:static/chunks/1376-363a5420d1d0d55f.js\",\"3311:static/chunks/3311-b4b1d180944cbdf9.js\",\"6186:static/chunks/6186-cd8f667a991c30ba.js\",\"3645:static/chunks/3645-075b7cf44d6ff90f.js\",\"5896:static/chunks/5896-c8af9181e1ef3411.js\",\"3463:static/chunks/3463-f74410595dbb225e.js\",\"1356:static/chunks/1356-dfeda3edebfb6633.js\",\"9203:static/chunks/9203-9dd30fc91865952f.js\",\"4577:static/chunks/4577-8b083eedacb02d4b.js\",\"8805:static/chunks/app/(root)/[locale]/page-7c013cb352997da2.js\"],\"name\":\"\",\"async\":false}\n"])</script><script>self.__next_f.push([1,"26:[[\"$\",\"div\",null,{\"className\":\"main_block_title\",\"children\":[\"$\",\"div\",null,{\"className\":\"container\",\"children\":[\"$\",\"h1\",null,{\"children\":\"Familia — сеть офф-прайс магазинов \"}]}]}],[[\"$\",\"div\",null,{\"className\":\"main_block banners\",\"children\":[\"$\",\"div\",null,{\"className\":\"main-page-block_wrapper__uS5CF container\",\"children\":[[\"$\",\"$L2a\",null,{\"animateBanner\":{\"previewImageDesktop\":{\"id\":\"6862949a86a08552af5068ff\",\"filename\":\"w8z01m0a53h2dbl5jed60n.mp4\",\"mimeType\":\"video/mp4\",\"filesize\":2393626,\"sizes\":{\"thumbnail\":{},\"portrait\":{},\"hero\":{},\"w32\":{},\"w64\":{},\"w128\":{},\"w384\":{},\"w640\":{},\"w1080\":{},\"w1920\":{},\"w3840\":{}},\"createdAt\":\"2025-06-30T13:43:54.169Z\",\"updatedAt\":\"2025-08-29T07:16:51.859Z\",\"url\":\"/cms/media/w8z01m0a53h2dbl5jed60n.mp4\"},\"previewImageMobile\":{\"id\":\"686294a2ebbcf8db8e989829\",\"filename\":\"9xjlc0p8xz4admgzbigl.mp4\",\"mimeType\":\"video/mp4\",\"filesize\":1347399,\"sizes\":{\"thumbnail\":{},\"portrait\":{},\"hero\":{},\"w32\":{},\"w64\":{},\"w128\":{},\"w384\":{},\"w640\":{},\"w1080\":{},\"w1920\":{},\"w3840\":{}},\"createdAt\":\"2025-06-30T13:44:02.036Z\",\"updatedAt\":\"2025-08-29T07:16:52.040Z\",\"url\":\"/cms/media/9xjlc0p8xz4admgzbigl.mp4\"},\"title\":\"Офф-прайс — уникальный формат шопинга\",\"description\":[{\"children\":[{\"text\":\"Familia – рай для любителей азартного шопинга\"}],\"type\":\"h2\"},{\"children\":[{\"text\":\"\"}]},{\"children\":[{\"text\":\"Мы работаем в уникальном формате офф-прайс: в магазинах представлены товары со скидками до -85% из коллекций прошлых сезонов мировых и российских брендов, шоурумов, коллекции, которые не вышли в массовое производство, а иногда даже экземпляры с подиумов.\\n\"}]},{\"children\":[{\"text\":\"\\nВ Familia только оригинальные бренды – мы закупаем товары напрямую у поставщиков со всего мира. Вы найдете одежду разного ценового уровня: от масс-маркета до премиальных марок, а смешение стилей, цветов и фасонов поможет подчеркнуть индивидуальность. \\n\"}]},{\"children\":[{\"text\":\"\\nОдежда, обувь, аксессуары, товары для дома – огромный ассортимент и только выгодные покупки.\"}]},{\"children\":[{\"text\":\"\"}]}],\"shortInfo\":[{\"title\":\"6500+ брендов\",\"description\":[{\"children\":[{\"text\":\"от масс-маркета до премиальных, от известных до нишевых и локальных\\n\\n\"}]}],\"id\":\"659d32c161ce695b6b48bbdb\"},{\"title\":\"Скидки до -85%\",\"description\":[{\"children\":[{\"text\":\"совершайте выгодные покупки\\n\\n\"}]}],\"id\":\"659d362261ce695b6b48bbdc\"},{\"title\":\"Только оригиналы\",\"description\":[{\"children\":[{\"text\":\"мы контролируем оригинальность закупаемых брендов\\n\\n\"}]}],\"id\":\"659d364161ce695b6b48bbdd\"}],\"banner\":{\"title\":\"Ассортимент каждого магазина уникале\",\"description\":[{\"children\":[{\"text\":\"Только в магазинах Familia можно получить незабываемый яркий опыт «поиска сокровищ» - среди тысяч наименований товара найти уникальную вещь, зачастую представленную в единственном экземпляре, и значительно сэкономить. Ассортимент каждого из магазинов разный, а поставки осуществляются ежедневно.\"}]},{\"children\":[{\"text\":\"Шоппинг в формате Off-price предоставляет постоянное чувство азарта, поскольку бренды и ценовые категории регулярно обновляются, что создает неожиданность при каждом визите и возможность найти что-то уникальное на полках магазина.\"}]},{\"children\":[{\"text\":\"\\n\\n\"}]}],\"imageDesktop\":\"6584544caca6854b7a61aaac\",\"imageMobile\":\"6584544caca6854b7a61aaac\",\"buttonText\":\"Узнай как найти свои сокровища\",\"buttonIsOn\":true,\"bannerShortInfo\":{\"title\":\"25 000 +\",\"description\":[{\"children\":[{\"text\":\"SKU в каждом магазине\"}]}]}},\"clothesSearch\":{\"title\":\"Как найти свои сокровища в магазине Familia\",\"mediaFile\":null,\"points\":[{\"title\":\"Выделите время \",\"description\":\"Выделите на шопинг побольше времени и получайте удовольствие от процесса: в зале магазина 25000+ наименований товара, и большинство вещей представлено в единственном экземпляре. Такой шопинг требует терпения, которое наверняка будет вознаграждено супер-находкой!\",\"number\":1,\"id\":\"658d6bcc0be3961868548773\"},{\"title\":\"Смотрите глубже\",\"description\":\"Не ходите только по периметру магазина, заглядывайте вглубь рейлов, там может прятаться самое интересное. Бренды отдельно не выделены, но ориентироваться в магазине просто — все вещи распределены по категориям и размерам.\",\"number\":2,\"id\":\"658d6bdb0be3961868548774\"},{\"title\":\"Пробуйте разное\",\"description\":\"Даже если вы покупаете одежду в одном и том же бренде, часто разные вещи в одинаковом размере сидят по-разному. Не зацикливайтесь на своем размере — обязательно смотрите соседние (один-два как в плюс, так и в минус) и примеряйте.\",\"number\":3,\"id\":\"658d6beb0be3961868548775\"},{\"title\":\"Экспериментируйте\",\"description\":\"У нас представлено большое число ярких, акцентных вещей, которые могут стать основой для новых образов. Сочетайте их с базовыми вещами — их в магазинах Familia тоже достаточно.\",\"number\":4,\"id\":\"658d6bfc0be3961868548776\"},{\"title\":\"Открывайте новое\",\"description\":\"Не стоит зацикливаться на конкретной покупке, часто в глубине рейлов прячется «та самая вещь», про которую так и не вспомнить, но, увидев ее, вы будете искренне рады. Позвольте себе больше:в зоне Gold Brands представлены премиальные бренды, могут попадаться марки класса люкс или вещи из шоурумов и с подиумов.\",\"number\":5,\"id\":\"658d6c120be3961868548777\"},{\"title\":\"Примеряйте\",\"description\":\"Мы не ограничиваем число вещей для примерочной, экспериментируйте, создавайте образы прямо в магазине.\",\"number\":6,\"id\":\"658d6c220be3961868548778\"}]},\"aboutBrands\":{\"title\":\"Не упустите появление новых сокровищ\",\"isOn\":true},\"createdAt\":\"2023-12-21T16:14:16.020Z\",\"globalType\":\"infoPageOffPrice\",\"updatedAt\":\"2025-08-12T14:58:06.010Z\",\"urlName\":\"aboutus-more\",\"bannerBlock\":{\"title\":\"Ассортимент каждого магазина уникален\",\"description\":[{\"children\":[{\"text\":\"\\nТолько в магазинах Familia можно получить незабываемый и яркий опыт «поиска сокровищ» – среди тысяч наименований товаров найти уникальную вещь, зачастую представленную в единственном экземпляре, и значительно сэкономить. Ассортимент каждого магазина уникален, а поставки осуществляются ежедневно.\\n\"}]},{\"children\":[{\"text\":\"Шопинг в формате офф-прайс — это азарт, поскольку бренды и ценовые категории регулярно обновляются, и каждый найдет для себя что-то новое и интересное.\\n\\n\\n\\n\\n\\n\\n\\n\"}]}],\"buttonText\":\"Узнайте, как найти свои сокровища\",\"buttonIsOn\":false,\"banner\":[{\"title\":\"25 000+ \",\"description\":[{\"children\":[{\"text\":\"товаров в каждом магазине\\n\\n\"}]}],\"imageDesktop\":{\"id\":\"6842fbd1d1c4e4d30626aa7f\",\"filename\":\"d3214rv443bqehsorjeg29.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":595819,\"width\":1662,\"height\":1110,\"sizes\":{\"thumbnail\":{\"url\":\"/cms/media/d3214rv443bqehsorjeg29-480x320.jpg\",\"width\":480,\"height\":320,\"mimeType\":\"image/jpeg\",\"filesize\":38366,\"filename\":\"d3214rv443bqehsorjeg29-480x320.jpg\"},\"portrait\":{\"url\":\"/cms/media/d3214rv443bqehsorjeg29-768x1024.jpg\",\"width\":768,\"height\":1024,\"mimeType\":\"image/jpeg\",\"filesize\":157460,\"filename\":\"d3214rv443bqehsorjeg29-768x1024.jpg\"},\"hero\":{\"url\":\"/cms/media/d3214rv443bqehsorjeg29-1920x1080.jpg\",\"width\":1920,\"height\":1080,\"mimeType\":\"image/jpeg\",\"filesize\":302791,\"filename\":\"d3214rv443bqehsorjeg29-1920x1080.jpg\"},\"w32\":