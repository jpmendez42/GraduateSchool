    $(document).ready(function () {
        let interval;
        const switchInterval = 5000; // 倒计时 5 秒
        let currentIndex = 0; // 当前激活的标签索引

        function activateTab ($tab) {
            $(".tab-item").removeClass("tab-item-active");
            $(".content-item").removeClass("active");
            $(".tab-item .tab-item-active-line").css("width", "0");
            $(".tab-item .tab-item-active-line .tab-item-active-line-bar").css("animation", "none");


            $tab.addClass("tab-item-active");
            let $line = $tab.find(".tab-item-active-line");
            let $lineBar = $tab.find(".tab-item-active-line .tab-item-active-line-bar");
            $line.css({ width: $tab.outerWidth() + "px" });
            $lineBar.css({ animation: "progress 5s infinite linear" });
            let index = $tab.index();
            $(".content-item").eq(index).addClass("active");
        }

        function autoSwitchTab () {
            currentIndex = (currentIndex + 1) % $(".tab-item").length;
            const $nextTab = $(".tab-item").eq(currentIndex);
            activateTab($nextTab);
        }

        // 点击事件
        $(".tab-item").click(function () {
            clearInterval(interval); // 点击时重置倒计时
            currentIndex = $(this).index(); // 获取当前点击的索引
            activateTab($(this));
            startAutoSwitch(); // 重新开始自动切换
        });

        // 自动切换
        function startAutoSwitch () {
            interval = setInterval(autoSwitchTab, switchInterval);
        }

        // 启动时激活第一个标签
        $(".tab-item").first().click();
    });

