            (function() {
              try {
                const deferred = () => {
                  let fns = [];
                  const ret = { isDone: false};
                
                  ret.resolve = () => {
                    if (ret.isDone) return;
                    ret.isDone = true;
                    setTimeout(() => {
                      fns.forEach((fn) => fn());
                      fns = [];
                    });
                  };
                
                  ret.then = (fn) => {
                    if (ret.isDone) {
                      setTimeout(fn);
                    } else {
                      fns.push(fn);
                    }
                  };
                
                  return ret;
                };
                if(!window.zdfsite){
                  window.zdfsite = {};
                }
                if(!window.zdfsite.userReady){
                  window.zdfsite.userReady = deferred();
                }
              } catch (e) { }
