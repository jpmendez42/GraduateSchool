}

.wpcf7-form input[type="radio"]:checked::before {
  transform: scale(1);
}

.wpcf7-form input[type="radio"]:focus {
  outline: max(2px, 0.15em) solid currentColor;
  outline-offset: max(2px, 0.15em);
}

.wpcf7 form.invalid .wpcf7-response-output {
